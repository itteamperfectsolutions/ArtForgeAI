@page "/gallery"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IGenerationHistoryService HistoryService
@inject ILogger<Gallery> Logger
@inject ISubscriptionService SubscriptionService
@inject ICoinService CoinService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IAuthService AuthService

<PageTitle>ArtForge AI - Gallery</PageTitle>

<div class="page-header">
    <h2>Gallery</h2>
    <p>@(_isSuperAdmin ? "All generation history" : "Your generation history")</p>
</div>

@if (_loading)
{
    <div class="empty-state">
        <div class="loading-spinner"></div>
        <p>Loading gallery...</p>
    </div>
}
else if (_generations.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">&#127912;</div>
        <h3>No images yet</h3>
        <p>Start creating beautiful images on the Create page!</p>
    </div>
}
else
{
    <div class="image-grid">
        @foreach (var gen in _generations)
        {
            <ImageCard Generation="gen" OnClick="OpenPreview" />
        }
    </div>

    @if (_hasMore)
    {
        <div style="text-align: center; margin-top: 2rem;">
            <button class="btn-secondary" @onclick="LoadMore">Load More</button>
        </div>
    }
}

<ImagePreviewModal Generation="_selectedGeneration"
                   OnClose="ClosePreview"
                   OnDelete="DeleteGeneration" />

<Toast @ref="_toast" />

@code {
    [CascadingParameter] private Task<AuthenticationState>? _authStateCascade { get; set; }
    private string _userId = "default";
    private bool _isSuperAdmin;
    private List<ImageGeneration> _generations = new();
    private ImageGeneration? _selectedGeneration;
    private bool _loading = true;
    private bool _hasMore;
    private int _page = 1;
    private const int PageSize = 20;
    private Toast? _toast;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);

        if (int.TryParse(userIdStr, out var uid))
        {
            var dbUser = await AuthService.GetUserByIdAsync(uid);
            _isSuperAdmin = dbUser?.Role == ArtForgeAI.Models.AppRole.SuperAdmin;

            if (!_isSuperAdmin)
            {
                if (!await SubscriptionService.HasFeatureAccessAsync(uid, ArtForgeAI.Models.FeatureAccess.Gallery))
                {
                    Nav.NavigateTo("/pricing", forceLoad: true);
                    return;
                }
            }
        }

        _userId = userIdStr ?? "default";
        try
        {
            await LoadGenerations();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize gallery");
        }
    }

    private async Task LoadGenerations()
    {
        _loading = true;
        _page = 1;
        try
        {
            if (_isSuperAdmin)
            {
                _generations = await HistoryService.GetAllHistoryAsync(page: _page, pageSize: PageSize);
                var total = await HistoryService.GetAllTotalCountAsync();
                _hasMore = total > _generations.Count;
            }
            else
            {
                _generations = await HistoryService.GetHistoryAsync(userId: _userId, page: _page, pageSize: PageSize);
                var total = await HistoryService.GetTotalCountAsync(userId: _userId);
                _hasMore = total > _generations.Count;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load generations");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadMore()
    {
        try
        {
            List<ImageGeneration> more;
            int total;
            if (_isSuperAdmin)
            {
                more = await HistoryService.GetAllHistoryAsync(page: _page + 1, pageSize: PageSize);
                total = await HistoryService.GetAllTotalCountAsync();
            }
            else
            {
                more = await HistoryService.GetHistoryAsync(userId: _userId, page: _page + 1, pageSize: PageSize);
                total = await HistoryService.GetTotalCountAsync(userId: _userId);
            }
            _generations.AddRange(more);
            _page++;
            _hasMore = total > _generations.Count;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load more generations");
        }
    }

    private void OpenPreview(ImageGeneration gen)
    {
        _selectedGeneration = gen;
    }

    private void ClosePreview()
    {
        _selectedGeneration = null;
    }

    private async Task DeleteGeneration(int id)
    {
        try
        {
            var success = await HistoryService.DeleteGenerationAsync(id);
            if (success)
            {
                _generations.RemoveAll(g => g.Id == id);
                _selectedGeneration = null;
                if (_toast is not null)
                    _ = _toast.ShowAsync("Image deleted");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete generation {GenerationId}", id);
        }
    }
}
