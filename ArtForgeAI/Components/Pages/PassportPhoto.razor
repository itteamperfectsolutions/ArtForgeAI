    /// <summary>
    /// Swap crop image to the correct version based on current toggle states.
    /// Combines: original → (bg-removed?) → (sharpened?) → display.
    /// </summary>
    private async Task SwapToCurrentImage()
    {
        // Pick base: bg-removed or original
        var baseUrl = _removeBg && !string.IsNullOrEmpty(_bgRemovedDataUrl)
            ? _bgRemovedDataUrl
            : _originalDataUrl;

        if (string.IsNullOrEmpty(baseUrl)) return;

        string finalUrl;
        if (_enhancePhoto)
        {
            // Apply sharpen (re-compute if cache is empty)
            if (string.IsNullOrEmpty(_enhancedDataUrl))
                _enhancedDataUrl = await Task.Run(() => SharpenImage(baseUrl, (float)_sharpenLevel));
            finalUrl = _enhancedDataUrl;
        }
        else
        {
            _enhancedDataUrl = null;
            finalUrl = baseUrl;
        }

        await JS.InvokeVoidAsync("passportPhoto.swapCropImage", finalUrl);
        await ClientSideRender();
    }

    /// <summary>Apply Gaussian sharpen + slight contrast boost. Input/output are data URLs.</summary>
    private static string SharpenImage(string dataUrl, float sigma)
    {
        // Parse data URL → bytes
        var base64 = dataUrl[(dataUrl.IndexOf(",", StringComparison.Ordinal) + 1)..];
        var bytes = Convert.FromBase64String(base64);

        using var image = Image.Load<Rgba32>(bytes);
        image.Mutate(ctx =>
        {
            ctx.GaussianSharpen(sigma);
            ctx.Contrast(1.05f); // subtle contrast boost
            ctx.Saturate(1.03f); // tiny saturation lift
        });

        using var ms = new MemoryStream();
        image.SaveAsJpeg(ms, new SixLabors.ImageSharp.Formats.Jpeg.JpegEncoder { Quality = 95 });
        return "data:image/jpeg;base64," + Convert.ToBase64String(ms.ToArray());
    }

    // ── Background removal ──

    private async Task OnRemoveBgChanged()
    {
        if (string.IsNullOrEmpty(_uploadedPath)) return;
        _enhancedDataUrl = null; // base image changed, invalidate sharpen cache

        if (_removeBg)
        {
            // If we already have a cached bg-removed image, just swap it
            if (!string.IsNullOrEmpty(_bgRemovedDataUrl))
            {
                await SwapToCurrentImage();
                await ScrollBgColourIntoView();
                return;
            }

            // Local U-2-Net ONNX background removal
            _isProcessing = true;
            _processingStatus = "Preparing background removal...";
            _bgRemovalStatus = "Processing...";
            _errorMessage = null;
            StateHasChanged();

            try
            {
                var fullPath = ResolveFullPath(_uploadedPath);
                var imageBytes = await File.ReadAllBytesAsync(fullPath);

                // Resize large images for faster processing + smaller data URL
                imageBytes = await Task.Run(() => ResizeForBgRemoval(imageBytes, 1600));

                _processingStatus = "Removing background (U-2-Net)...";
                StateHasChanged();

                var transparentBytes = await BgRemoval.RemoveBackgroundAsync(imageBytes);

                _processingStatus = "Compositing on white...";
                StateHasChanged();

                // Composite transparent subject on white background (JPEG for smaller data URL)
                _transparentPngCache = transparentBytes;
                var whiteDataUrl = await Task.Run(() => CompositeOnColour(transparentBytes, _selectedBgColor));

                _bgRemovedDataUrl = whiteDataUrl;
                _bgRemovalStatus = "Background removed (U-2-Net local)";

                await SwapToCurrentImage();
                await ScrollBgColourIntoView();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Background removal failed");
                _errorMessage = "Background removal failed: " + ex.Message;
                _removeBg = false;
                _bgRemovalStatus = null;
            }
            finally
            {
                _isProcessing = false;
                _processingStatus = "";
                StateHasChanged();
            }
        }
        else
        {
            // Restore original (or enhanced original)
            _bgRemovalStatus = null;
            await SwapToCurrentImage();
        }
    }

    /// <summary>Resize image to max dimension if needed (for faster Gemini processing + smaller data URL).</summary>
    private static byte[] ResizeForBgRemoval(byte[] imageBytes, int maxDimension)
    {
        using var img = Image.Load<Rgba32>(imageBytes);
        if (img.Width <= maxDimension && img.Height <= maxDimension)
            return imageBytes;

        var scale = (double)maxDimension / Math.Max(img.Width, img.Height);
        int newW = (int)(img.Width * scale);
        int newH = (int)(img.Height * scale);
        img.Mutate(ctx => ctx.Resize(newW, newH));

        using var ms = new MemoryStream();
        img.SaveAsPng(ms);
        return ms.ToArray();
    }

    /// <summary>Composite a transparent PNG onto a coloured background. Returns a JPEG data URL.</summary>
    private static string CompositeOnColour(byte[] transparentPngBytes, string hexColor = "#FFFFFF")
    {
        var bg = Rgba32.ParseHex(hexColor);
        bg.A = 255;

        using var subject = Image.Load<Rgba32>(transparentPngBytes);
        using var canvas = new Image<Rgba32>(subject.Width, subject.Height, bg);

        canvas.Mutate(ctx => ctx.DrawImage(subject, 1f));

        using var ms = new MemoryStream();
        canvas.SaveAsJpeg(ms, new SixLabors.ImageSharp.Formats.Jpeg.JpegEncoder { Quality = 92 });
        return "data:image/jpeg;base64," + Convert.ToBase64String(ms.ToArray());
    }

