@page "/embroidery-art"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IGeminiImageService GeminiService
@inject IImageStorageService ImageStorage
@inject IImageEnhancerService ImageEnhancer
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject ILogger<EmbroideryArt> Logger
@inject ISubscriptionService SubscriptionService
@inject ICoinService CoinService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IBackgroundRemovalService BgRemovalService

<PageTitle>ArtForge AI - Embroidery Art</PageTitle>

<div class="page-header page-header-lg">
    <h2>Embroidery Art</h2>
    <p>Transform any image or logo into stunning embroidery-style artwork</p>
</div>

<div class="create-layout">
    @* ── Left column ── *@
    <div class="create-left">
        <div class="card">
            <div class="card-body">

                @* Upload area *@
                <div class="mb-3">
                    <label class="form-label">Upload Image or Logo</label>
                    @if (!string.IsNullOrEmpty(_uploadedPath))
                    {
                        <div style="position: relative;">
                            <button class="ref-thumb-remove" @onclick="RemovePhoto" disabled="@_isProcessing"
                                    style="position:absolute;top:4px;right:4px;z-index:20;">&#10005;</button>
                            <img src="@_uploadedDataUrl" alt="Uploaded"
                                 style="width:100%;border-radius:8px;object-fit:contain;max-height:280px;background:var(--bg-secondary);" />
                        </div>
                        @if (_sourceWidth > 0)
                        {
                            <p style="font-size: 0.72rem; color: var(--text-muted); margin: 0.35rem 0 0 0;">
                                Source: @(_sourceWidth)x@(_sourceHeight) px
                            </p>
                        }
                    }
                    else
                    {
                        <label class="upload-area upload-area-compact @(_isUploading ? "disabled" : "")">
                            <span class="upload-icon">&#129525;</span>
                            <span>Upload a photo, logo, or artwork</span>
                            <span style="font-size: 0.7rem; color: var(--text-muted); margin-left: 0.5rem;">JPG, PNG, WebP up to 10MB</span>
                            <InputFile OnChange="HandleFileUpload" accept="image/*" style="display:none" disabled="@(_isProcessing || _isUploading)" />
                        </label>
                    }
                    @if (_isUploading)
                    {
                        <div class="upload-progress-bar" style="margin-top: 0.35rem;">
                            <div class="upload-progress-fill" style="width: 50%"></div>
                            <span class="upload-progress-text">Uploading...</span>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_uploadedPath))
                {
                    <hr style="margin: 0.5rem 0; border-color: var(--border-color);" />

                    @* Embroidery Style Selection *@
                    <div class="mb-3">
                        <label class="form-label">Embroidery Style</label>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.4rem;">
                            @foreach (var style in _embroideryStyles)
                            {
                                <button class="@(style.Key == _selectedStyle ? "btn-primary-gradient" : "btn-secondary")"
                                        style="font-size:0.78rem;padding:0.4rem 0.5rem;text-align:left;"
                                        @onclick="() => _selectedStyle = style.Key"
                                        disabled="@_isProcessing">
                                    @style.Value.icon @style.Value.name
                                </button>
                            }
                        </div>
                    </div>

                    @* Thread Color *@
                    <div class="mb-3">
                        <label class="form-label">Thread Color</label>
                        <div style="display:flex;gap:0.5rem;align-items:center;">
                            <select class="form-control" style="flex:1;" @bind="_colorMode" disabled="@_isProcessing">
                                <option value="original">Same as Original (preserve colors)</option>
                                <option value="custom">Single Color (entire design)</option>
                            </select>
                        </div>
                        @if (_colorMode == "custom")
                        {
                            <div style="display:flex;gap:0.5rem;align-items:center;margin-top:0.4rem;">
                                <input type="color" @bind="_customColor" disabled="@_isProcessing"
                                       style="width:40px;height:34px;border:none;padding:0;cursor:pointer;border-radius:4px;" />
                                <span style="font-size:0.78rem;color:var(--text-muted);">@_customColor</span>
                                <div style="display:flex;gap:0.25rem;margin-left:auto;">
                                    @foreach (var preset in _colorPresets)
                                    {
                                        <button style="width:24px;height:24px;border-radius:50%;border:2px solid @(preset.hex == _customColor ? "var(--accent)" : "var(--border-color)");background:@preset.hex;cursor:pointer;padding:0;"
                                                title="@preset.name"
                                                @onclick="() => _customColor = preset.hex"
                                                disabled="@_isProcessing"></button>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    @* Thread Style *@
                    <div class="mb-3">
                        <label class="form-label">Thread Type</label>
                        <select class="form-control" @bind="_selectedThread" disabled="@_isProcessing">
                            <option value="cotton">Cotton Thread</option>
                            <option value="silk">Silk Thread</option>
                            <option value="metallic">Metallic/Gold Thread</option>
                            <option value="wool">Wool Yarn</option>
                        </select>
                    </div>

                    <button class="btn-primary-gradient" style="width:100%;margin-top:0.5rem;"
                            @onclick="GenerateEmbroidery" disabled="@_isProcessing">
                        &#129525; Create Embroidery
                    </button>
                    <p style="font-size:0.7rem;color:var(--text-muted);margin-top:0.25rem;">
                        AI transforms your image into embroidery-style artwork ready for DTF printing or embroidery machine use.
                    </p>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="card" style="margin-top: 0.75rem; border-left: 3px solid var(--danger);">
                <div class="card-body" style="padding: 0.75rem 1rem; color: var(--danger); font-size: 0.85rem;">
                    <strong>Error:</strong> @_errorMessage
                </div>
            </div>
        }
    </div>

    @* ── Right column: result ── *@
    <div class="create-right" style="overflow-y:auto;">
        @if (_resultReady)
        {
            <div class="right-panel-card" style="overflow:visible;">
                <div class="right-panel-label">Embroidery Result</div>

                <img src="@_resultDataUrl" alt="Embroidery Result"
                     style="width:100%;border-radius:8px;object-fit:contain;max-height:500px;background:var(--bg-secondary);" />

                <p style="font-size:0.7rem;color:var(--text-muted);margin-top:0.4rem;text-align:center;">
                    @_embroideryStyles[_selectedStyle].name style &mdash; @(_resultWidth)x@(_resultHeight) px
                </p>

                @* DPI selector *@
                <div style="display:flex;align-items:center;gap:0.4rem;margin-top:0.75rem;justify-content:center;">
                    <label style="font-size:0.78rem;color:var(--text-muted);">Print DPI:</label>
                    <select class="form-select" style="width:auto;font-size:0.8rem;padding:0.25rem 0.5rem;" @bind="_selectedDpi">
                        <option value="300">300 DPI</option>
                        <option value="600">600 DPI</option>
                        <option value="1200">1200 DPI</option>
                    </select>
                </div>

                @* Download buttons *@
                <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.5rem;justify-content:center;">
                    <button class="btn-primary-gradient" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;"
                            @onclick='() => DownloadResult("png")' disabled="@_isDownloading">
                        &#128424; PNG
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;"
                            @onclick='() => DownloadResult("jpg")' disabled="@_isDownloading">
                        JPG
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;"
                            @onclick='() => DownloadUpscaled(2)' disabled="@_isDownloading">
                        &#128200; 2x
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;"
                            @onclick='() => DownloadUpscaled(4)' disabled="@_isDownloading">
                        &#128200; 4x
                    </button>
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.5rem;justify-content:center;">
                    <button class="btn-primary-gradient" style="font-size: 0.82rem; padding: 0.4rem 0.85rem; background: linear-gradient(135deg, #e84393, #fd79a8);"
                            @onclick="DownloadTransparentDTF" disabled="@_isDownloading">
                        &#127912; DTF Print (Transparent)
                    </button>
                    <button class="btn-primary-gradient" style="font-size: 0.82rem; padding: 0.4rem 0.85rem; background: linear-gradient(135deg, #00b894, #55efc4);"
                            @onclick="DownloadTransparentMachine" disabled="@_isDownloading">
                        &#129525; Embroidery Machine (Transparent)
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;"
                            @onclick="StartNew">
                        &#129525; Create Another
                    </button>
                </div>

                @if (_isDownloading)
                {
                    <div class="upload-progress-bar" style="margin-top: 0.5rem;">
                        <div class="upload-progress-fill" style="width: @(_downloadProgress)%"></div>
                        <span class="upload-progress-text">@_downloadStatus @(_downloadProgress)%</span>
                    </div>
                }

                <div class="ai-disclaimer">
                    AI-generated embroidery artwork &mdash; results simulate realistic needlework.
                </div>
            </div>
        }
    </div>
</div>

@* ── Processing overlay ── *@
@if (_isProcessing)
{
    <div class="pp-processing-overlay">
        <div class="pp-processing-modal">
            <div class="processing-spinner" style="width:36px;height:36px;margin:0 auto 1rem;"></div>
            <p style="margin:0;font-size:0.95rem;color:var(--text-primary);">@_processingStatus</p>
        </div>
    </div>
}

@code {
    // ── Embroidery style definitions ──
    private readonly Dictionary<string, (string name, string icon, string prompt)> _embroideryStyles = new()
    {
        ["cross-stitch"] = (
            "Cross Stitch",
            "\U0001FA9F",
            "Transform this image into a cross-stitch embroidery artwork. " +
            "STYLE RULE: Use ONLY the cross-stitch technique throughout the ENTIRE design — no other stitch types allowed. " +
            "Every single part of the image must be rendered as individual X-shaped cross stitches on an even-weave grid. " +
            "Show the characteristic pixelated grid pattern with visible individual X-shaped stitches. " +
            "The grid alignment must be perfectly consistent across the entire design. " +
            "Do NOT mix in satin stitch, chain stitch, French knots, or any other technique — cross stitch ONLY."
        ),
        ["satin-stitch"] = (
            "Satin Stitch",
            "\U0001F9F5",
            "Transform this image into a satin stitch embroidery artwork. " +
            "STYLE RULE: Use ONLY the satin stitch technique throughout the ENTIRE design — no other stitch types allowed. " +
            "Render every part using smooth, closely-placed parallel satin stitches with a luxurious sheen. " +
            "Each color region must show long, smooth, parallel thread lines that catch light with a silky luster. " +
            "Stitches should follow the contours of shapes. Show directional light reflection where threads gleam differently based on stitch direction. " +
            "Do NOT mix in cross stitch, chain stitch, French knots, couching, or any other technique — satin stitch ONLY."
        ),
        ["thread-painting"] = (
            "Thread Painting",
            "\U0001F3A8",
            "Transform this image into a thread painting (needle painting) embroidery artwork. " +
            "STYLE RULE: Use ONLY the long-and-short stitch technique throughout the ENTIRE design — no other stitch types allowed. " +
            "Create photorealistic gradients and smooth color transitions using varying stitch lengths. " +
            "Stitches should blend seamlessly like brush strokes, with fine thread work showing individual strands up close. " +
            "Achieve smooth tonal gradations throughout. " +
            "Do NOT mix in cross stitch, satin stitch, chain stitch, couching, or any other technique — long-and-short needle painting ONLY."
        ),
        ["crewel"] = (
            "Crewel Work",
            "\U0001F33A",
            "Transform this image into a crewel embroidery artwork. " +
            "STYLE RULE: Use ONLY crewel embroidery techniques throughout — chain stitch outlines, laid work fills, French knots for dots, stem stitch for lines. " +
            "The thread must look like wool yarn with a matte, slightly fuzzy texture. " +
            "Create a raised, three-dimensional quality with heavily textured stitch areas and bold outlines. " +
            "The entire design must have a consistent crewel/Jacobean look. " +
            "Do NOT mix in satin stitch, cross stitch, couching, or metallic thread techniques — crewel wool work ONLY."
        ),
        ["machine-embroidery"] = (
            "Machine Embroidery",
            "\U0001FAA1",
            "Transform this image into a machine embroidery design as stitched on a commercial embroidery machine. " +
            "STYLE RULE: Use ONLY machine embroidery techniques throughout — tatami fill, contour fill for large areas, satin column for outlines. " +
            "Show perfectly uniform, precise stitching with consistent density and tension throughout the ENTIRE design. " +
            "Every area must have the clean, digitized look of machine stitching with sharp edges and uniform stitch density. " +
            "This should look like a real embroidered patch or applique from a single machine run. " +
            "Do NOT mix in hand-embroidery styles, couching, French knots, or freeform techniques — clean machine embroidery ONLY."
        ),
        ["goldwork"] = (
            "Goldwork",
            "\U0001F451",
            "Transform this image into a goldwork embroidery artwork using ONLY metallic gold thread. " +
            "STYLE RULE: Use ONLY goldwork techniques throughout the ENTIRE design — couching (metal threads laid on surface secured with tiny stitches), or nue shading, and pearl purl outlines. " +
            "The ENTIRE design must use ONLY gold/metallic toned threads — no colored silk, no cotton, no other thread colors. " +
            "Create depth using light gold, dark gold, antique gold, and bright gold variations ONLY. " +
            "The metallic threads must have a brilliant, reflective shine with realistic light catching on metal surfaces. " +
            "Do NOT add any colored thread accents, jewel tones, or non-gold elements — pure goldwork ONLY."
        )
    };

    // ── Color presets ──
    private readonly (string name, string hex)[] _colorPresets =
    [
        ("Black", "#000000"),
        ("White", "#FFFFFF"),
        ("Navy", "#1e3a5f"),
        ("Red", "#dc2626"),
        ("Gold", "#d4a017"),
        ("Forest Green", "#166534"),
        ("Royal Blue", "#2563eb"),
        ("Burgundy", "#7f1d1d"),
        ("Silver", "#9ca3af"),
        ("Pink", "#ec4899")
    ];

    // ── State ──
    private string _selectedStyle = "thread-painting";
    private string _selectedThread = "cotton";
    private string _colorMode = "original";
    private string _customColor = "#1e3a5f";

    private string? _uploadedPath;
    private string? _uploadedDataUrl;
    private bool _isUploading;
    private bool _isProcessing;
    private string _processingStatus = "";
    private string? _errorMessage;
    private int _sourceWidth;
    private int _sourceHeight;

    // Result
    private bool _resultReady;
    private string? _resultImagePath;
    private string? _resultDataUrl;
    private int _resultWidth;
    private int _resultHeight;

    // Download
    private bool _isDownloading;
    private int _downloadProgress;
    private string _downloadStatus = "";
    private int _selectedDpi = 300;

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("SuperAdmin"))
        {
            var userIdStr = authState.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (int.TryParse(userIdStr, out var uid))
            {
                if (!await SubscriptionService.HasFeatureAccessAsync(uid, ArtForgeAI.Models.FeatureAccess.EmbroideryArt))
                {
                    Nav.NavigateTo("/pricing", forceLoad: true);
                    return;
                }
            }
        }
    }

    // ── Upload ──

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        if (file.Size > ImageUploadHelper.DefaultMaxUploadSize)
        {
            if (file.Size > ImageUploadHelper.MaxReadSize)
            {
                _errorMessage = $"File is too large ({ImageUploadHelper.FormatFileSize(file.Size)}). Maximum allowed is {ImageUploadHelper.FormatFileSize(ImageUploadHelper.MaxReadSize)}.";
                StateHasChanged();
                return;
            }
            try
            {
                using var readMs = new MemoryStream();
                await file.OpenReadStream(ImageUploadHelper.MaxReadSize).CopyToAsync(readMs);
                var compressed = ImageUploadHelper.CompressToFit(readMs.ToArray(), file.Name);
                await ProcessUpload(e, compressed);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Image compression failed");
                _errorMessage = "Failed to compress the image. Please try a smaller file.";
                StateHasChanged();
            }
            return;
        }

        await ProcessUpload(e);
    }

    private async Task ProcessUpload(InputFileChangeEventArgs e, MemoryStream? compressedStream = null)
    {
        _isUploading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var file = e.File;
            if (compressedStream is not null)
            {
                _uploadedPath = await ImageStorage.SaveUploadedFileAsync(compressedStream, file.Name);
            }
            else
            {
                using var stream = file.OpenReadStream(ImageUploadHelper.MaxReadSize);
                _uploadedPath = await ImageStorage.SaveUploadedFileAsync(stream, file.Name);
            }
            _resultReady = false;
            _resultImagePath = null;
            _resultDataUrl = null;

            var fullPath = ResolveFullPath(_uploadedPath);
            var imageBytes = await File.ReadAllBytesAsync(fullPath);
            using var img = SixLabors.ImageSharp.Image.Load(imageBytes);
            _sourceWidth = img.Width;
            _sourceHeight = img.Height;

            var ext = _uploadedPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ? "png" : "jpeg";
            _uploadedDataUrl = $"data:image/{ext};base64," + Convert.ToBase64String(imageBytes);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Upload failed");
            _errorMessage = "Upload failed. Please try again.";
            return;
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
        }
    }

    // ── Generate Embroidery ──

    private async Task GenerateEmbroidery()
    {
        if (string.IsNullOrEmpty(_uploadedPath)) return;

        // Debit coins
        var authStateC = await AuthState.GetAuthenticationStateAsync();
        var uidStrC = authStateC.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (int.TryParse(uidStrC, out var userIdC) && !authStateC.User.IsInRole("SuperAdmin"))
        {
            var cost = ArtForgeAI.Models.FeatureAccess.GetCost("EmbroideryArt");
            if (!await CoinService.DebitCoinsAsync(userIdC, cost, ArtForgeAI.Models.CoinTransactionType.GenerationSpend, "Embroidery Art"))
            {
                _errorMessage = "Insufficient coins. Please top up to continue.";
                StateHasChanged();
                return;
            }
        }

        _isProcessing = true;
        _processingStatus = "Analyzing your image...";
        _errorMessage = null;
        _resultReady = false;
        StateHasChanged();

        try
        {
            var fullPath = ResolveFullPath(_uploadedPath);
            var imageBytes = await File.ReadAllBytesAsync(fullPath);
            var mimeType = _uploadedPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
                ? "image/png" : "image/jpeg";

            var style = _embroideryStyles[_selectedStyle];

            // Build the comprehensive embroidery prompt
            var threadDesc = _selectedThread switch
            {
                "cotton" => "high-quality cotton embroidery floss (like DMC stranded cotton)",
                "silk" => "lustrous silk embroidery thread with a natural sheen",
                "metallic" => "metallic and gold embroidery thread with reflective shimmer",
                "wool" => "soft wool crewel yarn with a matte, slightly fuzzy texture",
                _ => "cotton embroidery floss"
            };

            // Color instruction based on mode
            var colorInstruction = _colorMode == "custom"
                ? $"COLOR: The ENTIRE embroidery design must use ONLY a single thread color: {_customColor}. " +
                  $"Every stitch, every element, every part of the design — all in {_customColor} thread. " +
                  "Use light/dark shading variations of this single color to create depth and dimension, but the base hue must remain the same throughout. " +
                  "This is a monochrome single-color embroidery — like a single-color logo stitch."
                : "COLOR PRESERVATION (CRITICAL — HIGHEST PRIORITY): " +
                  "You MUST use ONLY the exact colors that exist in the original source image. " +
                  "Do NOT add any color that is not present in the original. " +
                  "Do NOT add white thread, white stitching, white outlines, or white borders to the design edges — if white is not a color in the original image, there must be ZERO white thread in the output. " +
                  "Do NOT add any outline, edge stitching, or border stitching in a color that does not exist in the original. " +
                  "The embroidery edges must end cleanly where the design ends — no extra stitching around the perimeter. " +
                  "Every color region in the original must appear using the exact same hue, saturation, and brightness. " +
                  "Do NOT desaturate, grey out, mute, or alter any colors. Do NOT convert to monochrome or metallic. " +
                  "If the original has blue, use blue thread. If it has red, use red thread. No extra colors.";

            var prompt = $"{style.prompt} " +
                $"THREAD: Use {threadDesc} for all stitching. " +
                $"{colorInstruction} " +
                "BACKGROUND: The background MUST be pure solid white (#FFFFFF). " +
                "Do NOT add any fabric texture, cloth, canvas, linen, burlap, or any material behind the embroidery. " +
                "Do NOT add any embroidery hoop, frame, or border. " +
                "Do NOT add any outline or edge stitching around the design boundary. " +
                "The embroidery design must float on a completely clean, flat, pure white background with no shadows, no texture, and no gradients. " +
                "The design edges must transition directly to the white background — no border stitching, no white thread outlines, no extra framing stitches. " +
                "This output is for DTF printing and embroidery machine use — the design must be isolated and print-ready. " +
                "CRITICAL QUALITY REQUIREMENTS: " +
                "1) Individual thread strands and stitch patterns MUST be clearly visible — this is the most important aspect. Zoom into any area and you should see actual thread fibers. " +
                "2) The thread must have realistic texture — slight sheen, dimensional raised quality, and natural thread fiber detail. " +
                "3) Maintain the EXACT composition, proportions, shapes, text, and all details of the original image — transform only the MEDIUM (to embroidery), never alter the content or layout. " +
                "4) The result must look like a real close-up photograph of actual embroidery stitching, not a digital filter or illustration. " +
                "5) If the source is a logo or text, ensure ALL text remains perfectly readable and ALL logo elements are faithfully reproduced in thread with exact positioning. " +
                "6) Show realistic stitch detail: thread overlap at color boundaries, slight dimensional quality where stitches build up, and natural thread fiber texture. " +
                "7) Do NOT invent or add any colors, outlines, borders, or elements that are not in the original source image.";

            _processingStatus = $"Creating {style.name} embroidery...";
            StateHasChanged();

            var images = new List<(byte[] data, string mimeType)> { (imageBytes, mimeType) };
            var (_, resultBytes) = await GeminiService.EditImageAsync(
                prompt, images, _sourceWidth, _sourceHeight);

            _processingStatus = "Saving result...";
            StateHasChanged();

            var outputFileName = $"emb_{Guid.NewGuid():N}.png";
            _resultImagePath = await ImageStorage.SaveImageFromBytesAsync(
                BinaryData.FromBytes(resultBytes), outputFileName);

            using var resultImg = SixLabors.ImageSharp.Image.Load(resultBytes);
            _resultWidth = resultImg.Width;
            _resultHeight = resultImg.Height;
            _resultDataUrl = "data:image/png;base64," + Convert.ToBase64String(resultBytes);
            _resultReady = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Embroidery generation failed");
            _errorMessage = "Embroidery generation failed: " + ex.Message;
        }
        finally
        {
            _isProcessing = false;
            _processingStatus = "";
            StateHasChanged();
        }
    }

    // ── Downloads ──

    private async Task DownloadResult(string format)
    {
        if (string.IsNullOrEmpty(_resultImagePath)) return;
        try
        {
            var webPath = await ImageStorage.PrepareHighResDownloadAsync(
                _resultImagePath, format, _resultWidth, _resultHeight, _selectedDpi);
            await JS.InvokeVoidAsync("downloadFile", $"/{webPath}", $"embroidery_art_{_selectedDpi}dpi.{format}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Download failed");
            _errorMessage = "Download failed: " + ex.Message;
            StateHasChanged();
        }
    }

    private async Task DownloadUpscaled(int multiplier)
    {
        if (string.IsNullOrEmpty(_resultImagePath)) return;

        _isDownloading = true;
        _downloadProgress = 10;
        _downloadStatus = $"Preparing {multiplier}x upscale...";
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var targetW = _resultWidth * multiplier;
            var targetH = _resultHeight * multiplier;

            if (targetW > 16384 || targetH > 16384)
            {
                var scale = 16384.0 / Math.Max(targetW, targetH);
                targetW = (int)(targetW * scale);
                targetH = (int)(targetH * scale);
            }

            _downloadProgress = 30;
            _downloadStatus = $"Upscaling to {targetW}x{targetH}...";
            StateHasChanged();

            var webPath = await ImageStorage.PrepareHighResDownloadAsync(
                _resultImagePath, "png", targetW, targetH, _selectedDpi);

            _downloadProgress = 85;
            _downloadStatus = "Starting download...";
            StateHasChanged();

            await JS.InvokeVoidAsync("downloadFile", $"/{webPath}", $"embroidery_art_{multiplier}x_{_selectedDpi}dpi.png");

            _downloadProgress = 100;
            _downloadStatus = "Done!";
            StateHasChanged();

            await Task.Delay(500);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "{Multiplier}x download failed", multiplier);
            _errorMessage = $"{multiplier}x download failed: " + ex.Message;
        }
        finally
        {
            _isDownloading = false;
            _downloadProgress = 0;
            _downloadStatus = "";
            StateHasChanged();
        }
    }

    // ── Transparent Downloads (DTF / Embroidery Machine) ──

    private async Task DownloadTransparentDTF() => await DownloadTransparent("dtf_print");
    private async Task DownloadTransparentMachine() => await DownloadTransparent("embroidery_machine");

    private async Task DownloadTransparent(string prefix)
    {
        if (string.IsNullOrEmpty(_resultImagePath)) return;

        _isDownloading = true;
        _downloadProgress = 10;
        _downloadStatus = "Loading ONNX model...";
        _errorMessage = null;
        StateHasChanged();

        try
        {
            _downloadProgress = 20;
            _downloadStatus = "Removing background...";
            StateHasChanged();

            // Use IBackgroundRemovalService for reliable background removal
            var bgResult = await BgRemovalService.RemoveBackgroundAsync(_resultImagePath);

            _downloadProgress = 75;
            _downloadStatus = "Saving transparent PNG...";
            StateHasChanged();

            var outputFileName = $"{prefix}_{Guid.NewGuid():N}.png";
            var savedPath = await ImageStorage.SaveImageFromBytesAsync(
                BinaryData.FromBytes(bgResult.TransparentPngBytes), outputFileName);

            _downloadProgress = 90;
            _downloadStatus = "Starting download...";
            StateHasChanged();

            await JS.InvokeVoidAsync("downloadFile", $"/{savedPath}", $"{prefix}_transparent.png");

            _downloadProgress = 100;
            _downloadStatus = "Done!";
            StateHasChanged();

            await Task.Delay(500);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Transparent download failed");
            _errorMessage = "Transparent download failed: " + ex.Message;
        }
        finally
        {
            _isDownloading = false;
            _downloadProgress = 0;
            _downloadStatus = "";
            StateHasChanged();
        }
    }

    // ── Start New ──

    private async Task StartNew()
    {
        await RemovePhoto();
        StateHasChanged();
    }

    // ── Remove photo ──

    private async Task RemovePhoto()
    {
        if (!string.IsNullOrEmpty(_uploadedPath))
            await ImageStorage.DeleteImageAsync(_uploadedPath);

        _uploadedPath = null;
        _uploadedDataUrl = null;
        _resultReady = false;
        _errorMessage = null;
        _resultImagePath = null;
        _resultDataUrl = null;
        _sourceWidth = 0;
        _sourceHeight = 0;
        _resultWidth = 0;
        _resultHeight = 0;
    }

    // ── Helpers ──

    private string ResolveFullPath(string webRelativePath) =>
        System.IO.Path.Combine(Env.WebRootPath, webRelativePath.Replace("/", System.IO.Path.DirectorySeparatorChar.ToString()));
}
