@page "/3d-mockups"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject ILogger<Mockup3D> Logger
@inject IImageStorageService ImageStorage
@inject IGenerationHistoryService HistoryService
@inject ICoinService CoinService
@inject ISubscriptionService SubscriptionService
@inject AuthenticationStateProvider AuthState
@using ArtForgeAI.Services
@using ArtForgeAI.Models
@implements IDisposable

<PageTitle>ArtForge AI - 3D Mockups</PageTitle>

<link href="css/mockup3d.css" rel="stylesheet" />

<div class="page-header page-header-lg">
    <h2>3D Mockups</h2>
    <p>Interactive 3D product mockups — rotate, zoom, and place your logo</p>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="m3d-error">@_errorMessage</div>
}

<div class="m3d-layout">
    <div class="m3d-viewport">
        <div id="m3d-canvas-container" style="width:100%;height:100%;"></div>

        @if (_isModelLoading)
        {
            <div class="m3d-loading">
                <div class="loading-spinner"></div>
                <span>@_loadingStatus</span>
            </div>
        }

        @if (!_isModelLoading && !_webglSupported)
        {
            <div class="m3d-no-webgl">
                <span style="font-size:2rem;">&#9888;</span>
                <span>WebGL is not supported in your browser.</span>
                <span>Please use a modern browser like Chrome, Firefox, or Edge.</span>
            </div>
        }

        @if (_webglSupported && string.IsNullOrEmpty(_frontDesignUrl) && string.IsNullOrEmpty(_backDesignUrl) && string.IsNullOrEmpty(_wrapDesignUrl) && !_isModelLoading)
        {
            <div class="m3d-upload-prompt">
                <button class="m3d-upload-btn" @onclick='() => OpenDesignModal("wrap")'>
                    &#128083; Add Full Wrap Design
                </button>
            </div>
        }

        @if (_isProcessing)
        {
            <div class="m3d-loading">
                <div class="loading-spinner"></div>
                <span>@_processingStatus</span>
            </div>
        }
    </div>

    <div class="m3d-toolbar">
        <div class="m3d-product-tabs">
            @foreach (var product in _products)
            {
                var p = product;
                var locked = !_availableProducts.Contains(p.Slug);
                <button class="m3d-product-tab @(_activeProduct.Slug == p.Slug ? "active" : "") @(locked ? "locked" : "")"
                        @onclick="() => SwitchProduct(p)"
                        disabled="@locked"
                        title="@(locked ? "Upgrade plan to unlock" : p.Name)">
                    @p.Name
                </button>
            }
        </div>

        <div class="m3d-sep"></div>

        @if (_activeProduct.Slug == "mug")
        {
            <div class="m3d-slot-group">
                <span class="m3d-slot-label">Shape</span>
                <button class="m3d-product-tab @(_mugStyle == "straight" ? "active" : "")"
                        @onclick='() => SetMugStyle("straight")'>Straight</button>
                <button class="m3d-product-tab @(_mugStyle == "tapered" ? "active" : "")"
                        @onclick='() => SetMugStyle("tapered")'>Tapered</button>
            </div>
            <div class="m3d-sep"></div>
        }
        @if (_activeProduct.Slug == "tshirt")
        {
            <div class="m3d-slot-group">
                <span class="m3d-slot-label">Neck</span>
                <button class="m3d-product-tab @(_tshirtStyle == "crew" ? "active" : "")"
                        @onclick='() => SetTshirtStyle("crew")'>With Neck</button>
                <button class="m3d-product-tab @(_tshirtStyle == "scoop" ? "active" : "")"
                        @onclick='() => SetTshirtStyle("scoop")'>Without Neck</button>
            </div>
            <div class="m3d-sep"></div>
        }

        <div class="m3d-colors">
            @foreach (var color in _activeProduct.Colors)
            {
                var c = color;
                <div class="m3d-color-swatch @(_selectedColor == c ? "active" : "")"
                     style="background-color:@c;"
                     @onclick="() => SetColor(c)"
                     title="@c"></div>
            }
        </div>

        <div class="m3d-sep"></div>

        <div class="m3d-slot-group">
            <span class="m3d-slot-label">Wrap</span>
            @if (!string.IsNullOrEmpty(_wrapDesignUrl))
            {
                <input type="range" class="m3d-slider" title="Vertical" min="-1.0" max="1.0" step="0.05"
                       @bind="_wrapV" @bind:event="oninput" @bind:after='() => OnDesignTransformChanged("wrap")' />
                <button class="btn-secondary" style="font-size:0.7rem;padding:0.2rem 0.4rem;"
                        @onclick='() => OpenDesignModal("wrap")'>&#128260;</button>
                <button class="btn-secondary" style="font-size:0.7rem;padding:0.2rem 0.4rem;"
                        @onclick='() => ClearDesign("wrap")'>&#10005;</button>
            }
            else
            {
                <button class="btn-secondary" style="font-size:0.75rem;padding:0.25rem 0.6rem;"
                        @onclick='() => OpenDesignModal("wrap")'>&#43; Full Wrap</button>
            }
        </div>

        <div class="m3d-sep"></div>

        <div class="m3d-slot-group">
            <span class="m3d-slot-label">Front</span>
            @if (!string.IsNullOrEmpty(_frontDesignUrl))
            {
                <input type="range" class="m3d-slider" title="Size" min="0.2" max="1.5" step="0.05"
                       @bind="_frontSize" @bind:event="oninput" @bind:after='() => OnDesignTransformChanged("front")' />
                <input type="range" class="m3d-slider" title="Vertical" min="-1.0" max="1.0" step="0.05"
                       @bind="_frontV" @bind:event="oninput" @bind:after='() => OnDesignTransformChanged("front")' />
                <button class="btn-secondary" style="font-size:0.7rem;padding:0.2rem 0.4rem;"
                        @onclick='() => OpenDesignModal("front")'>&#128260;</button>
                <button class="btn-secondary" style="font-size:0.7rem;padding:0.2rem 0.4rem;"
                        @onclick='() => ClearDesign("front")'>&#10005;</button>
            }
            else
            {
                <button class="btn-secondary" style="font-size:0.75rem;padding:0.25rem 0.6rem;"
                        @onclick='() => OpenDesignModal("front")'>&#43; Front</button>
            }
        </div>

        <div class="m3d-sep"></div>

        <div class="m3d-slot-group">
            <span class="m3d-slot-label">Back</span>
            @if (!string.IsNullOrEmpty(_backDesignUrl))
            {
                <input type="range" class="m3d-slider" title="Size" min="0.2" max="1.5" step="0.05"
                       @bind="_backSize" @bind:event="oninput" @bind:after='() => OnDesignTransformChanged("back")' />
                <input type="range" class="m3d-slider" title="Vertical" min="-1.0" max="1.0" step="0.05"
                       @bind="_backV" @bind:event="oninput" @bind:after='() => OnDesignTransformChanged("back")' />
                <button class="btn-secondary" style="font-size:0.7rem;padding:0.2rem 0.4rem;"
                        @onclick='() => OpenDesignModal("back")'>&#128260;</button>
                <button class="btn-secondary" style="font-size:0.7rem;padding:0.2rem 0.4rem;"
                        @onclick='() => ClearDesign("back")'>&#10005;</button>
            }
            else
            {
                <button class="btn-secondary" style="font-size:0.75rem;padding:0.25rem 0.6rem;"
                        @onclick='() => OpenDesignModal("back")'>&#43; Back</button>
            }
        </div>

        <div class="m3d-sep"></div>

        <div class="m3d-actions">
            <button class="btn-primary-gradient" style="font-size:0.8rem;padding:0.35rem 0.8rem;"
                    @onclick="Download3DRender" disabled="@(_isProcessing || !_webglSupported)">
                &#128424; PNG &middot; 2
            </button>
            <button class="btn-primary-gradient" style="font-size:0.8rem;padding:0.35rem 0.8rem;"
                    @onclick="ShareOnWhatsApp" disabled="@(_isProcessing || !_webglSupported)">
                &#127909; Video &middot; 4
            </button>
        </div>
    </div>
</div>

@if (_showShareReady)
{
    <div class="m3d-modal-overlay" @onclick="CancelShare">
        <div class="m3d-modal" @onclick:stopPropagation="true" style="max-width:380px;">
            <div class="m3d-modal-header">
                <h3>Video Ready</h3>
                <button class="m3d-modal-close" @onclick="CancelShare">&#10005;</button>
            </div>
            <div class="m3d-modal-body" style="text-align:center;padding:1.25rem;">
                <div style="font-size:2.5rem;">&#127909;</div>
                <p style="margin:0.75rem 0 1rem;">Your 3D rotation video is ready. Tap below to share on WhatsApp (opens your system share sheet).</p>
                <button class="btn-primary-gradient" style="width:100%;padding:0.65rem;background:linear-gradient(135deg,#25d366,#128c7e);font-size:0.95rem;margin-bottom:0.5rem;"
                        @onclick="SendCachedToWhatsApp">
                    &#128241; Share to WhatsApp
                </button>
                <button class="btn-secondary" style="width:100%;padding:0.55rem;font-size:0.85rem;"
                        @onclick="DownloadCachedVideo">
                    &#128190; Download instead
                </button>
            </div>
        </div>
    </div>
}

@if (_showLogoModal)
{
    <div class="m3d-modal-overlay" @onclick="() => _showLogoModal = false">
        <div class="m3d-modal" @onclick:stopPropagation="true">
            <div class="m3d-modal-header">
                <h3>Select @(_editingSlot == "back" ? "Back" : "Front") Design</h3>
                <button class="m3d-modal-close" @onclick="() => _showLogoModal = false">&#10005;</button>
            </div>

            <div class="m3d-modal-tabs">
                <button class="m3d-modal-tab @(_modalTab == "upload" ? "active" : "")"
                        @onclick='() => _modalTab = "upload"'>Upload</button>
                <button class="m3d-modal-tab @(_modalTab == "gallery" ? "active" : "")"
                        @onclick="OpenGalleryTab">Gallery</button>
            </div>

            <div class="m3d-modal-body">
                @if (_modalTab == "upload")
                {
                    <button class="upload-area upload-area-compact" style="min-height:120px;width:100%;cursor:pointer;background:transparent;border:2px dashed var(--border-color);"
                            @onclick="TriggerClientUpload">
                        <span class="upload-icon">&#128083;</span>
                        <span>Upload a logo or image</span>
                        <span style="font-size:0.7rem;color:var(--text-muted);">PNG, JPG, WebP — files over 10 MB will be compressed automatically</span>
                    </button>
                }
                else
                {
                    @if (_galleryImages == null)
                    {
                        <div style="text-align:center;padding:2rem;">
                            <div class="loading-spinner"></div>
                        </div>
                    }
                    else if (_galleryImages.Count == 0)
                    {
                        <p style="text-align:center;color:var(--text-muted);padding:2rem;">No images in gallery yet.</p>
                    }
                    else
                    {
                        <div class="m3d-gallery-grid">
                            @foreach (var img in _galleryImages)
                            {
                                var imgPath = img;
                                <div class="m3d-gallery-item" @onclick="() => SelectGalleryImage(imgPath)">
                                    <img src="@imgPath" alt="Gallery image" loading="lazy" />
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    private record Product3D(string Name, string Slug, string ModelFile, string[] Colors);
    private class VideoResult
    {
        public string Data { get; set; } = "";
        public string Ext { get; set; } = "";
        public string Mime { get; set; } = "";
    }

    private static readonly Product3D[] _products =
    [
        new("Mug", "mug", "3d-models/mug.glb", ["#FFFFFF", "#222222", "#C0C0C0"]),
        new("T-Shirt", "tshirt", "3d-models/tshirt.glb", ["#FFFFFF", "#222222", "#C0C0C0", "#1B3A5C", "#C0392B"]),
        new("Hoodie", "hoodie", "3d-models/hoodie.glb", ["#FFFFFF", "#222222", "#808080", "#1B3A5C", "#4B2E2E"]),
    ];

    private Product3D _activeProduct = _products[0];
    private string _selectedColor = "#FFFFFF";

    private string? _frontDesignUrl;
    private float _frontSize = 0.7f;
    private float _frontV = 0f;

    private string? _backDesignUrl;
    private float _backSize = 0.7f;
    private float _backV = 0f;

    private string? _wrapDesignUrl;
    private float _wrapV = 0f;

    private string _editingSlot = "front";
    private string _mugStyle = "straight";
    private string _tshirtStyle = "crew";

    private bool _isModelLoading = true;
    private string _loadingStatus = "Loading 3D model...";
    private bool _isProcessing;
    private string _processingStatus = "";
    private string? _errorMessage;
    private bool _webglSupported = true;

    private bool _showLogoModal;
    private string _modalTab = "upload";
    private List<string>? _galleryImages;

    private bool _showShareReady;
    private string? _pendingVideoFileName;
    private string? _pendingVideoMime;

    private int _userId;
    private bool _isSuperAdmin;
    private string _userPlan = "Free";
    private HashSet<string> _availableProducts = new() { "mug", "tshirt", "hoodie" };

    private DotNetObjectReference<Mockup3D>? _dotnetRef;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        if (int.TryParse(user.FindFirst("UserId")?.Value, out var uid))
            _userId = uid;
        _isSuperAdmin = user.IsInRole("SuperAdmin");
        _userPlan = await SubscriptionService.GetCurrentPlanNameAsync(_userId);
        if (_userPlan != "Free" || _isSuperAdmin)
            _availableProducts = new HashSet<string> { "mug", "tshirt", "hoodie" };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _dotnetRef = DotNetObjectReference.Create(this);
        var supported = await JS.InvokeAsync<bool>("mockup3d.initScene", "m3d-canvas-container", _dotnetRef);
        if (!supported)
        {
            _webglSupported = false;
            _isModelLoading = false;
            StateHasChanged();
            return;
        }
        await JS.InvokeVoidAsync("mockup3d.loadModel", _activeProduct.ModelFile);
    }

    [JSInvokable]
    public void OnModelLoaded()
    {
        _isModelLoading = false;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnModelError(string message)
    {
        _isModelLoading = false;
        _errorMessage = "Failed to load 3D model: " + message;
        StateHasChanged();
    }

    private async Task SwitchProduct(Product3D product)
    {
        if (!_availableProducts.Contains(product.Slug)) return;
        if (_activeProduct.Slug == product.Slug) return;
        _activeProduct = product;
        _selectedColor = product.Colors[0];
        _frontSize = 0.7f;
        _frontV = 0f;
        _backSize = 0.7f;
        _backV = 0f;
        _isModelLoading = true;
        _loadingStatus = $"Loading {product.Name}...";
        StateHasChanged();
        await JS.InvokeVoidAsync("mockup3d.loadModel", product.ModelFile);
    }

    private async Task SetColor(string color)
    {
        _selectedColor = color;
        await JS.InvokeVoidAsync("mockup3d.setColor", color);
    }

    private void OpenDesignModal(string slot)
    {
        _editingSlot = slot;
        _showLogoModal = true;
    }

    private async Task SetMugStyle(string style)
    {
        if (_mugStyle == style) return;
        _mugStyle = style;
        _isModelLoading = true;
        _loadingStatus = "Rebuilding mug...";
        StateHasChanged();
        await JS.InvokeVoidAsync("mockup3d.setMugStyle", style);
    }

    private async Task SetTshirtStyle(string style)
    {
        if (_tshirtStyle == style) return;
        _tshirtStyle = style;
        _isModelLoading = true;
        _loadingStatus = "Rebuilding t-shirt...";
        StateHasChanged();
        await JS.InvokeVoidAsync("mockup3d.setTshirtStyle", style);
    }

    private async Task ClearDesign(string slot)
    {
        if (slot == "front") _frontDesignUrl = null;
        else if (slot == "back") _backDesignUrl = null;
        else if (slot == "wrap") _wrapDesignUrl = null;
        StateHasChanged();
        await JS.InvokeVoidAsync("mockup3d.clearDesign", slot);
    }

    private void SetSlotUrl(string url)
    {
        if (_editingSlot == "back") _backDesignUrl = url;
        else if (_editingSlot == "wrap") _wrapDesignUrl = url;
        else _frontDesignUrl = url;
    }

    private async Task TriggerClientUpload()
    {
        _errorMessage = null;
        if (_dotnetRef is null) _dotnetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("mockup3d.pickAndCompressImage", _editingSlot, _dotnetRef, 10 * 1024 * 1024);
    }

    [JSInvokable]
    public async Task OnClientImagePicked(string slot, string dataUrl, bool compressed, long origSize, long outSize)
    {
        if (string.IsNullOrEmpty(dataUrl)) return;
        _editingSlot = slot;
        SetSlotUrl(dataUrl);
        _showLogoModal = false;
        if (compressed)
        {
            _errorMessage = $"Image was {origSize / (1024 * 1024)} MB — compressed to {outSize / 1024} KB for upload.";
        }
        StateHasChanged();
        await JS.InvokeVoidAsync("mockup3d.setDesign", slot, dataUrl);
    }

    [JSInvokable]
    public void OnClientImageError(string message)
    {
        _errorMessage = message;
        StateHasChanged();
    }

    private async Task SelectGalleryImage(string imagePath)
    {
        SetSlotUrl(imagePath);
        var slot = _editingSlot;
        _showLogoModal = false;
        StateHasChanged();
        var fullPath = Path.Combine(Env.WebRootPath, imagePath.Replace("/", Path.DirectorySeparatorChar.ToString()).TrimStart(Path.DirectorySeparatorChar));
        if (File.Exists(fullPath))
        {
            var bytes = await File.ReadAllBytesAsync(fullPath);
            var dataUrl = "data:image/png;base64," + Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("mockup3d.setDesign", slot, dataUrl);
        }
    }

    private async Task OpenGalleryTab()
    {
        _modalTab = "gallery";
        if (_galleryImages == null)
        {
            try
            {
                var history = await HistoryService.GetHistoryAsync(_userId.ToString(), 1, 40);
                _galleryImages = history
                    .Where(h => !string.IsNullOrEmpty(h.LocalImagePath))
                    .Select(h => h.LocalImagePath!)
                    .ToList();
            }
            catch { _galleryImages = new List<string>(); }
        }
    }

    private async Task OnDesignTransformChanged(string slot)
    {
        float size, v;
        if (slot == "wrap") { size = 1.0f; v = _wrapV; }
        else if (slot == "back") { size = _backSize; v = _backV; }
        else { size = _frontSize; v = _frontV; }
        await JS.InvokeVoidAsync("mockup3d.updateDesignTransform", slot, size, v);
    }

    private async Task Download3DRender()
    {
        if (_isProcessing) return;
        _isProcessing = true;
        _processingStatus = "Capturing 3D render...";
        _errorMessage = null;
        StateHasChanged();
        try
        {
            if (!await TryDebitCoins(2, "3D Mockups download"))
            {
                _isProcessing = false;
                StateHasChanged();
                return;
            }
            var base64 = await JS.InvokeAsync<string>("mockup3d.captureSnapshot", 1920, 1080);
            if (string.IsNullOrEmpty(base64))
            {
                _errorMessage = "Failed to capture render.";
                return;
            }
            var fileName = $"3d_{_activeProduct.Slug}_{DateTime.Now:yyyyMMdd_HHmmss}.png";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "image/png", base64);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "3D download failed");
            _errorMessage = "Download failed: " + ex.Message;
        }
        finally
        {
            _isProcessing = false;
            _processingStatus = "";
            StateHasChanged();
        }
    }

    private async Task DownloadRotationVideo()
    {
        if (_isProcessing) return;
        _isProcessing = true;
        _processingStatus = "Recording rotation (~8s)...";
        _errorMessage = null;
        StateHasChanged();
        try
        {
            if (!await TryDebitCoins(4, "3D Mockups rotation video"))
            {
                _isProcessing = false;
                StateHasChanged();
                return;
            }
            var result = await JS.InvokeAsync<VideoResult>("mockup3d.captureRotationVideo", 8, 30);
            if (result is null || string.IsNullOrEmpty(result.Data))
            {
                _errorMessage = "Video recording failed. Your browser may not support MediaRecorder.";
                return;
            }
            if (result.Ext != "mp4")
            {
                _processingStatus = "Converting to MP4 for WhatsApp...";
                StateHasChanged();
                var mp4Data = await JS.InvokeAsync<string?>("mockup3d.transcodeToMp4", result.Data);
                if (!string.IsNullOrEmpty(mp4Data))
                {
                    result = new VideoResult { Data = mp4Data, Ext = "mp4", Mime = "video/mp4" };
                }
                else
                {
                    _errorMessage = "Server transcoding failed. Saved as .webm instead — may not preview in WhatsApp.";
                }
            }
            var fileName = $"3d_{_activeProduct.Slug}_rotation_{DateTime.Now:yyyyMMdd_HHmmss}.{result.Ext}";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, result.Mime, result.Data);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "3D rotation video failed");
            _errorMessage = "Video download failed: " + ex.Message;
        }
        finally
        {
            _isProcessing = false;
            _processingStatus = "";
            StateHasChanged();
        }
    }

    private async Task ShareOnWhatsApp()
    {
        if (_isProcessing) return;
        _isProcessing = true;
        _processingStatus = "Recording rotation (~8s)...";
        _errorMessage = null;
        _showShareReady = false;
        StateHasChanged();
        try
        {
            if (!await TryDebitCoins(4, "3D Mockups WhatsApp share"))
            {
                _isProcessing = false;
                StateHasChanged();
                return;
            }
            var result = await JS.InvokeAsync<VideoResult>("mockup3d.captureRotationVideo", 8, 30);
            if (result is null || string.IsNullOrEmpty(result.Data))
            {
                _errorMessage = "Video recording failed.";
                return;
            }
            if (result.Ext != "mp4")
            {
                _processingStatus = "Converting to MP4...";
                StateHasChanged();
                var mp4Data = await JS.InvokeAsync<string?>("mockup3d.transcodeToMp4", result.Data);
                if (!string.IsNullOrEmpty(mp4Data))
                    result = new VideoResult { Data = mp4Data, Ext = "mp4", Mime = "video/mp4" };
            }
            var fileName = $"3d_{_activeProduct.Slug}_{DateTime.Now:yyyyMMdd_HHmmss}.{result.Ext}";
            var cached = await JS.InvokeAsync<bool>("mockup3d.cacheShareFile", result.Data, result.Mime, fileName, "3D Mockup");
            if (!cached)
            {
                _errorMessage = "Failed to prepare video for sharing.";
                return;
            }
            _pendingVideoFileName = fileName;
            _pendingVideoMime = result.Mime;
            _showShareReady = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "3D share failed");
            _errorMessage = "Share failed: " + ex.Message;
        }
        finally
        {
            _isProcessing = false;
            _processingStatus = "";
            StateHasChanged();
        }
    }

    private async Task SendCachedToWhatsApp()
    {
        try
        {
            var status = await JS.InvokeAsync<string>("mockup3d.shareCachedFile");
            if (status == "shared" || status == "cancelled")
            {
                _showShareReady = false;
                await JS.InvokeVoidAsync("mockup3d.clearCachedShare");
            }
            else
            {
                await JS.InvokeVoidAsync("mockup3d.downloadCachedFile");
                await JS.InvokeVoidAsync("mockup3d.openWhatsAppWeb");
                _errorMessage = "Direct share isn't available — the video downloaded to your Downloads folder. WhatsApp Web has opened: drag the file into the chat.";
                _showShareReady = false;
                await JS.InvokeVoidAsync("mockup3d.clearCachedShare");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Share failed: " + ex.Message;
        }
        StateHasChanged();
    }

    private async Task DownloadCachedVideo()
    {
        await JS.InvokeVoidAsync("mockup3d.downloadCachedFile");
        _showShareReady = false;
        await JS.InvokeVoidAsync("mockup3d.clearCachedShare");
        StateHasChanged();
    }

    private async Task CancelShare()
    {
        _showShareReady = false;
        await JS.InvokeVoidAsync("mockup3d.clearCachedShare");
        StateHasChanged();
    }

    private async Task<bool> TryDebitCoins(int cost, string description)
    {
        if (_isSuperAdmin) return true;
        if (!await CoinService.DebitCoinsAsync(_userId, cost, CoinTransactionType.GenerationSpend, description))
        {
            _errorMessage = "Insufficient coins. Please top up to continue.";
            StateHasChanged();
            return false;
        }
        return true;
    }

    public void Dispose()
    {
        _ = JS.InvokeVoidAsync("mockup3d.dispose");
        _dotnetRef?.Dispose();
    }
}
