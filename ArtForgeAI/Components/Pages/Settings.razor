    {
        _testingStyleId = null;
        _testSourcePath = null;
        _testResultPath = null;
        _testError = null;
        StateHasChanged();
    }

    private async Task OverlayMemorialText(string localImagePath)
    {
        try
        {
            var fullPath = Path.Combine(Env.WebRootPath,
                localImagePath.Replace("/", Path.DirectorySeparatorChar.ToString()));
            if (!File.Exists(fullPath)) return;

            var imageBytes = await File.ReadAllBytesAsync(fullPath);
            using var img = Image.Load<Rgba32>(imageBytes);

            FontFamily family;
            if (!SystemFonts.TryGet("Georgia", out family) &&
                !SystemFonts.TryGet("Times New Roman", out family) &&
                !SystemFonts.TryGet("Segoe UI", out family) &&
                !SystemFonts.TryGet("Arial", out family))
                family = SystemFonts.Families.First();

            var imgW = img.Width;
            var imgH = img.Height;
            var textAreaTop = (int)(imgH * 0.82);
            var textAreaHeight = imgH - textAreaTop;
            var centerX = imgW / 2f;

            var nameFont = family.CreateFont(imgW * 0.045f, FontStyle.Bold);
            var dateFont = family.CreateFont(imgW * 0.028f, FontStyle.Bold);
            var shadow = new Color(new Rgba32(0, 0, 0, 128));
            var gold = Color.ParseHex("#FFD700");

            var dateParts = new List<string>();
            if (_testMemorialDob.HasValue)
                dateParts.Add($"DOB: {_testMemorialDob.Value:dd-MM-yyyy}");
            if (_testMemorialDod.HasValue)
                dateParts.Add($"DOD: {_testMemorialDod.Value:dd-MM-yyyy}");
            var dateLine = string.Join("     ", dateParts);

            img.Mutate(ctx =>
            {
                if (!string.IsNullOrWhiteSpace(_testMemorialName))
                {
                    var nameY = textAreaTop + textAreaHeight * 0.25f;
                    ctx.DrawText(new RichTextOptions(nameFont)
                    {
                        Origin = new System.Numerics.Vector2(centerX + 2, nameY + 2),
                        HorizontalAlignment = HorizontalAlignment.Center,
                        VerticalAlignment = VerticalAlignment.Center
                    }, _testMemorialName.Trim().ToUpper(), shadow);
                    ctx.DrawText(new RichTextOptions(nameFont)
                    {
                        Origin = new System.Numerics.Vector2(centerX, nameY),
                        HorizontalAlignment = HorizontalAlignment.Center,
                        VerticalAlignment = VerticalAlignment.Center
                    }, _testMemorialName.Trim().ToUpper(), Color.White);
                }

                if (!string.IsNullOrWhiteSpace(dateLine))
                {
                    var dateY = textAreaTop + textAreaHeight * 0.68f;
                    ctx.DrawText(new RichTextOptions(dateFont)
                    {
                        Origin = new System.Numerics.Vector2(centerX + 1, dateY + 1),
                        HorizontalAlignment = HorizontalAlignment.Center,
                        VerticalAlignment = VerticalAlignment.Center
                    }, dateLine, shadow);
                    ctx.DrawText(new RichTextOptions(dateFont)
                    {
                        Origin = new System.Numerics.Vector2(centerX, dateY),
                        HorizontalAlignment = HorizontalAlignment.Center,
                        VerticalAlignment = VerticalAlignment.Center
                    }, dateLine, gold);
                }
            });

            await using var ms = new MemoryStream();
            await img.SaveAsPngAsync(ms);
            await File.WriteAllBytesAsync(fullPath, ms.ToArray());
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Memorial text overlay failed (non-fatal)");
        }
    }

    private async Task GenerateThumbnail(StylePreset preset)
    {
        if (_generatingThumbnailId is not null) return;

        _generatingThumbnailId = preset.Id;
        _thumbnailMessage = $"Generating thumbnail for {preset.Name}...";
        StateHasChanged();

        try
        {
            var isCollage = preset.Name.Contains("Collage", StringComparison.OrdinalIgnoreCase);
            var request = new GenerationRequest
            {
                Prompt = $"A beautiful landscape, golden hour lighting. {preset.PromptTemplate}",
                Width = isCollage ? 768 : 512,
                Height = isCollage ? 1152 : 512,
                SizeName = isCollage ? "20x30" : "Square",
                EnhancePrompt = false,
                Provider = ImageProvider.Gemini
            };

            var result = await ImageGenService.GenerateImageAsync(request);

            if (result.Success && !string.IsNullOrEmpty(result.LocalImagePath))
            {
                // Move thumbnail from generated/ to presets/ folder
                var presetPath = await MoveToPresetsFolder(result.LocalImagePath);

                var entity = await StyleService.GetByIdAsync(preset.Id);
                if (entity is not null)
                {
                    entity.ThumbnailPath = presetPath;
                    await StyleService.UpdateAsync(entity);
                }
                _thumbnailMessage = $"Thumbnail generated for {preset.Name}!";
            }
            else
            {
                _thumbnailMessage = "Thumbnail generation failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Thumbnail generation failed for {StyleName}", preset.Name);
            _thumbnailMessage = "An error occurred. Please try again.";
        }
        finally
        {
            _generatingThumbnailId = null;
            await LoadStyles();
            StateHasChanged();
        }
    }

    private async Task GenerateAllThumbnails()
    {
        if (_batchGenerating) return;

        // Get styles missing thumbnails
        var pending = _allStyles
            .Where(s => string.IsNullOrEmpty(s.ThumbnailPath))
            .ToList();

        if (pending.Count == 0)
        {
            _thumbnailMessage = "All styles already have thumbnails!";
            StateHasChanged();
            return;
        }

        _batchGenerating = true;
        _batchTotal = pending.Count;
        _batchCompleted = 0;
        _batchActiveIds = [];
        _thumbnailMessage = null;
        StateHasChanged();

        var semaphore = new SemaphoreSlim(8);
        var tasks = pending.Select(async preset =>
        {
            await semaphore.WaitAsync();
            try
            {
                // Mark as active on UI
                lock (_batchActiveIds) { _batchActiveIds.Add(preset.Id); }
                await InvokeAsync(StateHasChanged);

                var batchIsCollage = preset.Name.Contains("Collage", StringComparison.OrdinalIgnoreCase);
                var request = new GenerationRequest
                {
                    Prompt = $"A beautiful landscape, golden hour lighting. {preset.PromptTemplate}",
                    Width = batchIsCollage ? 768 : 512,
                    Height = batchIsCollage ? 1152 : 512,
                    SizeName = batchIsCollage ? "20x30" : "Square",
                    EnhancePrompt = false,
                    Provider = ImageProvider.Gemini
                };

                var result = await ImageGenService.GenerateImageAsync(request);

                if (result.Success && !string.IsNullOrEmpty(result.LocalImagePath))
                {
                    var presetPath = await MoveToPresetsFolder(result.LocalImagePath);
                    var entity = await StyleService.GetByIdAsync(preset.Id);
                    if (entity is not null)
                    {
                        entity.ThumbnailPath = presetPath;
                        await StyleService.UpdateAsync(entity);
                    }
                }
            }
            catch
            {
                // Skip failures silently during batch
            }
            finally
            {
                lock (_batchActiveIds) { _batchActiveIds.Remove(preset.Id); }
                Interlocked.Increment(ref _batchCompleted);
                await InvokeAsync(async () =>
                {
                    await LoadStyles();
                    StateHasChanged();
                });
                semaphore.Release();
            }
        });

        await Task.WhenAll(tasks);

        _batchGenerating = false;
        _batchActiveIds = [];
        _thumbnailMessage = $"Done! Generated {_batchCompleted} thumbnails.";
        await LoadStyles();
        StateHasChanged();
    }

    // ── Bulk Assign ──

    private List<StylePreset> GetBulkFilteredStyles()
    {
        IEnumerable<StylePreset> result = _allStyles;

        if (!string.IsNullOrWhiteSpace(_bulkSearchQuery))
        {
            var q = _bulkSearchQuery.Trim();
            result = result.Where(s => s.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
                                    || s.Category.Contains(q, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrEmpty(_bulkFilterCategory))
            result = result.Where(s => s.Category == _bulkFilterCategory);

        if (_bulkFilterGroupId == "-1")
            result = result.Where(s => s.StyleGroupId is null);
        else if (int.TryParse(_bulkFilterGroupId, out var gid))
            result = result.Where(s => s.StyleGroupId == gid);

        return result.OrderBy(s => s.Category).ThenBy(s => s.Name).ToList();
    }

    private void ToggleBulkSelect(int id)
    {
        if (!_bulkSelectedIds.Remove(id))
            _bulkSelectedIds.Add(id);
    }

    private void BulkSelectAll()
    {
        foreach (var s in GetBulkFilteredStyles())
            _bulkSelectedIds.Add(s.Id);
    }

    private void BulkDeselectAll()
    {
        var filtered = GetBulkFilteredStyles().Select(s => s.Id).ToHashSet();
        _bulkSelectedIds.RemoveWhere(id => filtered.Contains(id));
    }

    private async Task ApplyBulkAssign()
    {
        if (_bulkSelectedIds.Count == 0) return;

        int? targetGroupId = int.TryParse(_bulkTargetGroupId, out var gid) ? gid : null;
        var ids = _bulkSelectedIds.ToList();

        foreach (var id in ids)
        {
            var preset = await StyleService.GetByIdAsync(id);
            if (preset is not null)
            {
                preset.StyleGroupId = targetGroupId;
                await StyleService.UpdateAsync(preset);
            }
        }

        var groupName = targetGroupId.HasValue
            ? _allGroups.FirstOrDefault(g => g.StyleGroupId == targetGroupId)?.Name ?? "group"
            : "none";
        _bulkAssignMessage = $"Assigned {ids.Count} presets to {groupName}";
        _bulkSelectedIds.Clear();
        await LoadStyles();
        StateHasChanged();
    }

