    private string BuildCalendarDescription(DateTime date)
    {
        var monthName = date.ToString("MMMM").ToUpper();
        var year = date.Year;
        // Reference Image 2 is the pre-rendered pixel-perfect calendar
        return $"A calendar grid for {monthName} {year} with the date {date.Day} marked with a red circle. " +
               $"IMPORTANT: Use Reference Image 2 as the EXACT calendar layout — copy the day positions, numbers, and grid EXACTLY as shown. " +
               $"Do NOT rearrange or guess the day positions — the reference image has the correct calendar.";
    }
}
