    private async Task AcceptCompression()
    {
        if (_pendingFileEvent is null || _pendingFileStyle is null) return;

        _pendingCompression = false;
        _selectedStyle = _pendingFileStyle;
        _error = null;
        _result = null;
        _placeholderError = null;

        try
        {
            var file = _pendingFileEvent.File;
            using var stream = file.OpenReadStream(ImageUploadHelper.MaxReadSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var rawBytes = ms.ToArray();

            // Resize dimensions to bring file size under the limit (no quality reduction)
            using var outMs = ImageUploadHelper.CompressToFit(rawBytes, file.Name);
            _sourcePath = await ImageStorage.SaveUploadedFileAsync(outMs, file.Name);
            Logger.LogInformation("Compressed oversized image: {OrigSize} → {NewSize}",
                ImageUploadHelper.FormatFileSize(_pendingFileSize), ImageUploadHelper.FormatFileSize(outMs.Length));

            _pendingFileEvent = null;
            _pendingFileStyle = null;

            // Continue with the normal flow
            var style = _selectedStyle;

            if (style.Name == "Silhouette Contour")
            {
                _silhouetteOrientation = "side";
                _silhouetteBodyType = "bust";
                _pendingSilhouetteOptions = true;
                StateHasChanged();
                return;
            }

            if (style.Category == "Memorial")
            {
                _memorialName = string.Empty;
                _memorialDob = null;
                _memorialDod = null;
                _pendingPlaceholders = true;
                StateHasChanged();
                return;
            }

            if (HasPlaceholders(style))
            {
                _occasionText = string.Empty;
                _messageText = string.Empty;
                _calendarDate = null;
                _numberValue = null;
                _dateText = string.Empty;
                _datePickerValue = null;
                _memorialName = string.Empty;
                _memorialDob = null;
                _memorialDod = null;
                _pendingPlaceholders = true;
                StateHasChanged();
                return;
            }

            await RunGeneration(style.PromptTemplate);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Image compression failed");
            _error = "Failed to compress the image. Please try a smaller file.";
            StateHasChanged();
        }
    }

