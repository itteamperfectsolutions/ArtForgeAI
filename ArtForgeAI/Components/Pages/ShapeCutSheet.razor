@page "/shape-cut"
@rendermode InteractiveServer
@attribute [Authorize]
@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.PixelFormats
@using SixLabors.ImageSharp.Processing
@using ArtForgeAI.Models
@inject IImageStorageService ImageStorage
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject ILogger<ShapeCutSheet> Logger
@inject RemoveBgApiService RemoveBgApi
@inject ISubscriptionService SubscriptionService
@inject ICoinService CoinService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>ArtForge AI - Half Cut Stickers</PageTitle>

<div class="page-header page-header-lg">
    <h2>Half Cut Stickers</h2>
    <p>Upload logos, crop to shape, and generate cut lines for Cricut, Graphtec, Silhouette &amp; other cutting machines</p>
</div>

<div class="create-layout">
    @* ── Left column: upload + logo grid ── *@
    <div class="create-left">
        <div class="card">
            <div class="card-body">

                @* Upload area *@
                <div class="mb-3">
                    <label class="form-label">Upload Logos</label>
                    <label class="upload-area upload-area-compact @(_isUploading ? "disabled" : "")">
                        <span class="upload-icon">&#128444;</span>
                        <span>@(_logos.Count == 0 ? "Upload logo images" : "Add more logos")</span>
                        <span style="font-size: 0.7rem; color: var(--text-muted); margin-left: 0.5rem;">PNG, JPG up to 10MB each</span>
                        <InputFile OnChange="HandleFileUpload" accept=".jpg,.jpeg,.png,.webp" multiple style="display:none" disabled="@(_isProcessing || _isUploading)" />
                    </label>
                    @if (_isUploading)
                    {
                        <div class="upload-progress-bar" style="margin-top: 0.35rem;">
                            <div class="upload-progress-fill" style="width: 50%"></div>
                            <span class="upload-progress-text">Uploading...</span>
                        </div>
                    }
                </div>

                @* Logo grid *@
                @if (_logos.Count > 0)
                {
                    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:0.5rem;">
                        @foreach (var logo in _logos)
                        {
                            <div @key="logo.Id"
                                 style="position:relative;aspect-ratio:1;background:var(--bg-secondary);border:2px solid @(logo.IsConfirmed ? "var(--accent-primary)" : "var(--border-color)");border-radius:8px;cursor:pointer;overflow:hidden;display:flex;align-items:center;justify-content:center;transition:border-color 0.2s;"
                                 @onclick="() => OpenLogoModal(logo)">
                                @if (!string.IsNullOrEmpty(logo.ProcessedDataUrl))
                                {
                                    <img src="@logo.ProcessedDataUrl" alt="@logo.FileName"
                                         style="max-width:100%;max-height:100%;object-fit:contain;" />
                                }
                                else if (!string.IsNullOrEmpty(logo.OriginalDataUrl))
                                {
                                    <img src="@logo.OriginalDataUrl" alt="@logo.FileName"
                                         style="max-width:100%;max-height:100%;object-fit:contain;" />
                                }
                                @if (logo.IsProcessing)
                                {
                                    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;">
                                        <div class="processing-spinner" style="width:24px;height:24px;"></div>
                                    </div>
                                }
                                @if (logo.IsConfirmed)
                                {
                                    <div style="position:absolute;top:2px;left:2px;background:var(--accent-primary);color:#fff;border-radius:50%;width:18px;height:18px;font-size:0.6rem;display:flex;align-items:center;justify-content:center;">&#10003;</div>
                                }
                                <button style="position:absolute;top:2px;right:2px;background:rgba(0,0,0,0.6);color:#fff;border:none;border-radius:50%;width:20px;height:20px;font-size:0.65rem;cursor:pointer;display:flex;align-items:center;justify-content:center;"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => RemoveLogo(logo)" title="Remove">✕</button>
                                <span style="position:absolute;bottom:2px;left:0;right:0;text-align:center;font-size:0.55rem;color:var(--text-muted);background:rgba(0,0,0,0.5);padding:1px 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    @logo.FileName
                                </span>
                            </div>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div style="margin-top:0.75rem;border-left:3px solid var(--danger);background:var(--bg-secondary);padding:0.5rem 0.75rem;border-radius:4px;color:var(--danger);font-size:0.85rem;">
                        <strong>Error:</strong> @_errorMessage
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── Right column: confirmed stickers list ── *@
    <div class="create-right">
        @if (_confirmedLogos.Count > 0)
        {
            <div class="right-panel-card">
                <div class="right-panel-label">Confirmed Stickers (@_confirmedLogos.Count)</div>

                <div style="display:flex;flex-direction:column;gap:0.6rem;max-height:500px;overflow-y:auto;">
                    @foreach (var logo in _confirmedLogos)
                    {
                        <div @key="logo.Id" style="display:flex;gap:0.6rem;align-items:center;background:var(--bg-secondary);border-radius:8px;padding:0.5rem;">
                            @* Thumbnail *@
                            <div style="width:60px;height:60px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:var(--bg-tertiary);border-radius:6px;overflow:hidden;">
                                <img src="@(logo.CroppedDataUrl ?? logo.ProcessedDataUrl)" alt="@logo.FileName"
                                     style="max-width:100%;max-height:100%;object-fit:contain;" />
                            </div>
                            @* Details *@
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:0.8rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="@logo.FileName">@logo.FileName</div>
                                <div style="font-size:0.75rem;color:var(--text-secondary);">
                                    @($"{logo.CroppedWidthIn:F2}\" × {logo.CroppedHeightIn:F2}\"")
                                    &nbsp;(@($"{logo.CroppedWidthPx} × {logo.CroppedHeightPx} px"))
                                </div>
                                <div style="display:flex;align-items:center;gap:0.3rem;margin-top:0.2rem;">
                                    <span style="font-size:0.7rem;color:var(--text-muted);">Qty:</span>
                                    <strong style="font-size:0.8rem;">@logo.Quantity</strong>
                                </div>
                            </div>
                            @* Actions *@
                            <div style="display:flex;flex-direction:column;gap:0.25rem;">
                                <button class="btn-secondary" style="font-size:0.65rem;padding:0.2rem 0.4rem;" @onclick="() => OpenLogoModal(logo)" title="Edit">&#9998;</button>
                                <button class="btn-secondary" style="font-size:0.65rem;padding:0.2rem 0.4rem;color:var(--danger);" @onclick="() => UnconfirmLogo(logo)" title="Remove">✕</button>
                            </div>
                        </div>
                    }
                </div>

                <div class="sc-download-bar" style="margin-top:0.75rem;">
                    <button class="btn-primary-gradient" style="font-size:0.85rem;padding:0.4rem 0.85rem;" @onclick="DownloadAllPng">
                        &#128424; Download All (PNG)
                    </button>
                    <button class="btn-secondary" style="font-size:0.85rem;padding:0.4rem 0.85rem;" @onclick="DownloadAllSvg">
                        &#9986; Download All (SVG)
                    </button>
                </div>
                <p style="font-size:0.65rem;color:var(--text-muted);text-align:center;margin-top:0.4rem;">
                    Half-cut: blade cuts the sticker vinyl but not the backing.
                    Import SVG into Cricut Design Space, Graphtec Studio, or Silhouette Studio.
                </p>
            </div>
        }
        else
        {
            <div class="right-panel-card" style="display:flex;align-items:center;justify-content:center;min-height:300px;color:var(--text-muted);">
                <div style="text-align:center;">
                    <div style="font-size:2.5rem;margin-bottom:0.5rem;">&#9986;</div>
                    <p>Click a logo, crop it, and confirm to add stickers here</p>
                </div>
            </div>
        }
    </div>
</div>

@* ══════════════════════════════════════════════════ *@
@* ── MODAL: Step 1 = Crop, Step 2 = Confirm ──     *@
@* ══════════════════════════════════════════════════ *@
@if (_modalLogo != null)
{
    <div class="pp-processing-overlay" style="z-index:1000;" @onclick="CloseModal">
        <div class="gs-crop-modal" style="max-width:800px;max-height:90vh;overflow-y:auto;" @onclick:stopPropagation="true">
            <div class="gs-crop-modal-header">
                <span>@_modalLogo.FileName — @(_modalStep == 1 ? "Crop" : "Confirm")</span>
                <button class="gs-design-remove" @onclick="CloseModal" style="width:24px;height:24px;">✕</button>
            </div>

            @* ───── Step 1: Crop ───── *@
            @if (_modalStep == 1)
            {
                <div style="display:flex;gap:1rem;flex-wrap:wrap;">
                    @* Left: Crop area *@
                    <div style="flex:1;min-width:280px;">
                        <div id="scCropArea" class="gs-crop-inline" style="max-height:400px;"></div>
                        <p style="font-size:0.68rem;color:var(--text-muted);margin:0.25rem 0 0;">
                            Drag to move. Resize freely from corners/edges.
                        </p>
                    </div>

                    @* Right: Settings *@
                    <div style="flex:0 0 220px;display:flex;flex-direction:column;gap:0.6rem;">

                        <div style="background:var(--bg-secondary);border-radius:6px;padding:0.5rem;">
                            <div style="font-size:0.7rem;color:var(--text-muted);margin-bottom:0.2rem;">Original Size</div>
                            <div style="font-size:0.85rem;font-weight:600;">@(_modalLogo.OriginalWidthPx) × @(_modalLogo.OriginalHeightPx) px</div>
                        </div>

                        @* BG removal *@
                        <div class="pp-toggle-row">
                            <label class="pp-toggle">
                                <input type="checkbox" checked="@_modalLogo.RemoveBg"
                                       @onchange="e => OnModalToggleBg((bool)e.Value!)"
                                       disabled="@(_modalLogo.IsProcessing || !RemoveBgApi.IsAvailable)" />
                                <span class="pp-toggle-slider"></span>
                            </label>
                            <span class="pp-toggle-label" style="font-size:0.8rem;">Remove Background</span>
                        </div>
                        @if (!RemoveBgApi.IsAvailable)
                        {
                            <p style="font-size:0.6rem;color:var(--text-muted);margin:-0.4rem 0 0;">Requires remove.bg API key</p>
                        }

                        @* White removal *@
                        <div class="pp-toggle-row">
                            <label class="pp-toggle">
                                <input type="checkbox" checked="@_modalLogo.RemoveWhites"
                                       @onchange="e => OnModalToggleWhite((bool)e.Value!)"
                                       disabled="@_modalLogo.IsProcessing" />
                                <span class="pp-toggle-slider"></span>
                            </label>
                            <span class="pp-toggle-label" style="font-size:0.8rem;">Remove Whites</span>
                        </div>

                        @* Cut line settings *@
                        <div style="background:var(--bg-secondary);border-radius:6px;padding:0.5rem;">
                            <div style="font-size:0.7rem;color:var(--text-muted);margin-bottom:0.35rem;">Cut Line Settings</div>
                            <div style="display:flex;flex-direction:column;gap:0.3rem;">
                                <div class="gs-item-field">
                                    <label style="min-width:50px;">Offset</label>
                                    <input type="number" min="0" max="80" step="1" value="@_modalLogo.CutGapPx"
                                           @onchange="e => OnStep1OutlineChanged(int.Parse(e.Value!.ToString()!), _modalLogo.CornerSmoothPx, _modalLogo.OutlineWidthPx)" style="flex:1;" />
                                    <span style="font-size:0.65rem;color:var(--text-muted);">px</span>
                                </div>
                                <div class="gs-item-field">
                                    <label style="min-width:50px;">Smooth</label>
                                    <input type="number" min="0" max="40" step="1" value="@_modalLogo.CornerSmoothPx"
                                           @onchange="e => OnStep1OutlineChanged(_modalLogo.CutGapPx, int.Parse(e.Value!.ToString()!), _modalLogo.OutlineWidthPx)" style="flex:1;" />
                                    <span style="font-size:0.65rem;color:var(--text-muted);">px</span>
                                </div>
                                <div class="gs-item-field">
                                    <label style="min-width:50px;">Line</label>
                                    <input type="number" min="1" max="15" step="1" value="@_modalLogo.OutlineWidthPx"
                                           @onchange="e => OnStep1OutlineChanged(_modalLogo.CutGapPx, _modalLogo.CornerSmoothPx, int.Parse(e.Value!.ToString()!))" style="flex:1;" />
                                    <span style="font-size:0.65rem;color:var(--text-muted);">px</span>
                                </div>
                            </div>
                        </div>

                        @* Live cut line preview *@
                        <div id="scStep1OutlinePreview" style="background:var(--bg-secondary);border-radius:6px;min-height:100px;display:flex;align-items:center;justify-content:center;overflow:hidden;">
                            <span style="font-size:0.7rem;color:var(--text-muted);">Cut line preview</span>
                        </div>
                    </div>
                </div>

                <div style="display:flex;gap:0.5rem;margin-top:0.75rem;">
                    <button class="btn-primary-gradient" style="flex:1;font-size:0.85rem;padding:0.5rem;"
                            @onclick="CropAndProceed" disabled="@_modalLogo.IsProcessing">
                        &#9986; Crop &amp; Next
                    </button>
                    <button class="btn-secondary" style="font-size:0.85rem;padding:0.5rem 0.75rem;" @onclick="CloseModal">
                        Cancel
                    </button>
                </div>
            }

            @* ───── Step 2: Confirm size & quantity ───── *@
            @if (_modalStep == 2)
            {
                <div style="display:flex;gap:1.5rem;flex-wrap:wrap;align-items:flex-start;">
                    @* Preview *@
                    <div style="flex:1;min-width:250px;display:flex;align-items:center;justify-content:center;background:var(--bg-secondary);border-radius:8px;padding:0.75rem;min-height:250px;">
                        <img src="@(_modalLogo.OutlineDataUrl ?? _modalLogo.CroppedDataUrl)" alt="Preview"
                             style="max-width:100%;max-height:350px;object-fit:contain;" />
                    </div>

                    @* Size & quantity *@
                    <div style="flex:0 0 240px;display:flex;flex-direction:column;gap:0.75rem;">

                        @* Dimensions *@
                        <div style="background:var(--bg-secondary);border-radius:6px;padding:0.75rem;">
                            <div style="font-size:0.7rem;color:var(--text-muted);margin-bottom:0.3rem;">Cropped Size</div>
                            <div style="font-size:1.1rem;font-weight:700;">
                                @($"{_modalLogo.CroppedWidthPx} × {_modalLogo.CroppedHeightPx}") px
                            </div>
                            <div style="font-size:0.9rem;color:var(--text-secondary);margin-top:0.15rem;">
                                @($"{_modalLogo.CroppedWidthIn:F2}\" × {_modalLogo.CroppedHeightIn:F2}\"")
                            </div>
                        </div>

                        @* DPI *@
                        <div>
                            <label class="form-label" style="font-size:0.75rem;">Print DPI</label>
                            <select class="form-select" style="font-size:0.8rem;padding:0.3rem 0.5rem;"
                                    value="@_dpi" @onchange="OnDpiChanged">
                                <option value="72">72 DPI (Screen)</option>
                                <option value="150">150 DPI</option>
                                <option value="300">300 DPI (Print)</option>
                                <option value="600">600 DPI (High Res)</option>
                            </select>
                        </div>

                        @* Quantity *@
                        <div>
                            <label class="form-label" style="font-size:0.75rem;">Quantity</label>
                            <div style="display:flex;align-items:center;gap:0.4rem;">
                                <button class="gs-qty-btn" style="width:32px;height:32px;font-size:1.1rem;"
                                        @onclick="() => { _modalLogo.Quantity = Math.Max(1, _modalLogo.Quantity - 1); }"
                                        disabled="@(_modalLogo.Quantity <= 1)">−</button>
                                <input type="number" class="form-input" min="1" max="100"
                                       style="width:60px;text-align:center;font-size:1rem;padding:0.3rem;"
                                       value="@_modalLogo.Quantity"
                                       @onchange="e => _modalLogo.Quantity = Math.Max(1, int.TryParse(e.Value?.ToString(), out var v) ? v : 1)" />
                                <button class="gs-qty-btn" style="width:32px;height:32px;font-size:1.1rem;"
                                        @onclick="() => { _modalLogo.Quantity++; }">+</button>
                            </div>
                        </div>

                        @* Cut line settings *@
                        <div style="background:var(--bg-secondary);border-radius:6px;padding:0.5rem;">
                            <div style="font-size:0.7rem;color:var(--text-muted);margin-bottom:0.35rem;">Cut Line Settings</div>
                            <div style="display:flex;flex-direction:column;gap:0.3rem;">
                                <div class="gs-item-field">
                                    <label style="min-width:50px;">Offset</label>
                                    <input type="number" min="0" max="80" step="1" value="@_modalLogo.CutGapPx"
                                           @onchange="e => OnConfirmOutlineChanged(int.Parse(e.Value!.ToString()!), _modalLogo.CornerSmoothPx, _modalLogo.OutlineWidthPx)" style="flex:1;" />
                                    <span style="font-size:0.65rem;color:var(--text-muted);">px</span>
                                </div>
                                <div class="gs-item-field">
                                    <label style="min-width:50px;">Smooth</label>
                                    <input type="number" min="0" max="40" step="1" value="@_modalLogo.CornerSmoothPx"
                                           @onchange="e => OnConfirmOutlineChanged(_modalLogo.CutGapPx, int.Parse(e.Value!.ToString()!), _modalLogo.OutlineWidthPx)" style="flex:1;" />
                                    <span style="font-size:0.65rem;color:var(--text-muted);">px</span>
                                </div>
                                <div class="gs-item-field">
                                    <label style="min-width:50px;">Line</label>
                                    <input type="number" min="1" max="15" step="1" value="@_modalLogo.OutlineWidthPx"
                                           @onchange="e => OnConfirmOutlineChanged(_modalLogo.CutGapPx, _modalLogo.CornerSmoothPx, int.Parse(e.Value!.ToString()!))" style="flex:1;" />
                                    <span style="font-size:0.65rem;color:var(--text-muted);">px</span>
                                </div>
                            </div>
                        </div>

                        @* Sticker name *@
                        <div>
                            <label class="form-label" style="font-size:0.75rem;">Sticker Name</label>
                            <input type="text" class="form-input" style="font-size:0.85rem;padding:0.35rem 0.5rem;"
                                   @bind="_modalLogo.FileName" />
                        </div>
                    </div>
                </div>

                <div style="display:flex;gap:0.5rem;margin-top:0.75rem;">
                    <button class="btn-secondary" style="font-size:0.85rem;padding:0.5rem 0.75rem;" @onclick="BackToCrop">
                        &#8592; Back
                    </button>
                    <button class="btn-primary-gradient" style="flex:1;font-size:0.9rem;padding:0.5rem;"
                            @onclick="ConfirmSticker">
                        &#10003; Confirm Sticker
                    </button>
                </div>
            }
        </div>
    </div>
}

@* ── Processing overlay ── *@
@if (_isProcessing)
{
    <div class="pp-processing-overlay">
        <div class="pp-processing-modal">
            <div class="processing-spinner" style="width:36px;height:36px;margin:0 auto 1rem;"></div>
            <p style="margin:0;font-size:0.95rem;color:var(--text-primary);">@_processingStatus</p>
        </div>
    </div>
}

@code {
    // ── Models ──

    private sealed class LogoItem
    {
        public string Id { get; set; } = Guid.NewGuid().ToString("N")[..8];
        public string FileName { get; set; } = "";
        public string? UploadedPath { get; set; }

        // Data URLs
        public string? OriginalDataUrl { get; set; }
        public string? ProcessedDataUrl { get; set; }
        public string? CroppedDataUrl { get; set; }
        public string? OutlineDataUrl { get; set; }

        // Raw bytes
        public byte[]? OriginalBytes { get; set; }
        public byte[]? TransparentPngBytes { get; set; }

        // Original image dimensions
        public int OriginalWidthPx { get; set; }
        public int OriginalHeightPx { get; set; }

        // Cropped dimensions
        public int CroppedWidthPx { get; set; }
        public int CroppedHeightPx { get; set; }
        public double CroppedWidthIn { get; set; }
        public double CroppedHeightIn { get; set; }

        // Cut line settings
        public int CutGapPx { get; set; } = 3;
        public int CornerSmoothPx { get; set; } = 8;
        public int OutlineWidthPx { get; set; } = 2;

        // Quantity & state
        public int Quantity { get; set; } = 1;
        public bool RemoveBg { get; set; }
        public bool RemoveWhites { get; set; }
        public int WhiteTolerance { get; set; } = 30;
        public bool IsProcessing { get; set; }
        public bool IsConfirmed { get; set; }
    }

    // ── State ──

    private List<LogoItem> _logos = new();
    private List<LogoItem> _confirmedLogos => _logos.Where(l => l.IsConfirmed).ToList();
    private LogoItem? _modalLogo;
    private int _modalStep = 1; // 1 = crop, 2 = confirm
    private bool _isUploading;
    private bool _isProcessing;
    private string _processingStatus = "";
    private string? _errorMessage;
    private int _dpi = 300;

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("SuperAdmin"))
        {
            var userIdStr = authState.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (int.TryParse(userIdStr, out var uid))
            {
                if (!await SubscriptionService.HasFeatureAccessAsync(uid, FeatureAccess.ShapeCutSheet))
                {
                    Nav.NavigateTo("/pricing", forceLoad: true);
                    return;
                }
            }
        }
    }

    public void Dispose()
    {
        try { JS.InvokeVoidAsync("shapeCut.disposeCropTool"); } catch { }
    }

    // ── Upload ──

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        _isUploading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var files = e.GetMultipleFiles(20);
            foreach (var file in files)
            {
                if (file.Size > ImageUploadHelper.MaxReadSize)
                {
                    _errorMessage = $"File '{file.Name}' exceeds {ImageUploadHelper.FormatFileSize(ImageUploadHelper.MaxReadSize)} limit, skipped.";
                    continue;
                }

                try
                {
                    string uploadedPath;
                    if (file.Size > ImageUploadHelper.DefaultMaxUploadSize)
                    {
                        using var readMs = new MemoryStream();
                        await file.OpenReadStream(ImageUploadHelper.MaxReadSize).CopyToAsync(readMs);
                        using var compressed = ImageUploadHelper.CompressToFit(readMs.ToArray(), file.Name);
                        uploadedPath = await ImageStorage.SaveUploadedFileAsync(compressed, file.Name);
                    }
                    else
                    {
                        using var stream = file.OpenReadStream(ImageUploadHelper.MaxReadSize);
                        uploadedPath = await ImageStorage.SaveUploadedFileAsync(stream, file.Name);
                    }

                    var fullPath = ResolveFullPath(uploadedPath);
                    var imageBytes = await File.ReadAllBytesAsync(fullPath);

                    int origW, origH;
                    using (var img = Image.Load<Rgba32>(imageBytes))
                    {
                        origW = img.Width;
                        origH = img.Height;
                    }

                    var ext = uploadedPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ? "png" : "jpeg";

                    _logos.Add(new LogoItem
                    {
                        FileName = file.Name,
                        UploadedPath = uploadedPath,
                        OriginalBytes = imageBytes,
                        OriginalDataUrl = $"data:image/{ext};base64," + Convert.ToBase64String(imageBytes),
                        OriginalWidthPx = origW,
                        OriginalHeightPx = origH,
                    });
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Failed to upload {FileName}", file.Name);
                    _errorMessage = $"Failed to upload '{file.Name}'.";
                }
            }

            // Debit coins
            if (_logos.Count > 0)
            {
                var authStateC = await AuthState.GetAuthenticationStateAsync();
                var uidStrC = authStateC.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
                if (int.TryParse(uidStrC, out var userIdC) && !authStateC.User.IsInRole("SuperAdmin"))
                {
                    var cost = FeatureAccess.GetCost("ShapeCutSheet");
                    if (!await CoinService.DebitCoinsAsync(userIdC, cost, CoinTransactionType.GenerationSpend, "Shape Cut Sheet generation"))
                    {
                        _errorMessage = "Insufficient coins. Please purchase more.";
                    }
                }
            }
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
        }
    }

    // ── Open logo modal (always starts at step 1) ──

    private async Task OpenLogoModal(LogoItem logo)
    {
        if (logo.IsProcessing) return;

        _modalLogo = logo;
        _modalStep = 1;
        _errorMessage = null;
        StateHasChanged();
        await Task.Delay(100);

        var dataUrl = logo.ProcessedDataUrl ?? logo.OriginalDataUrl;
        if (string.IsNullOrEmpty(dataUrl)) return;

        await JS.InvokeVoidAsync("shapeCut.setAspectRatio", 0);
        await JS.InvokeVoidAsync("shapeCut.initCropTool", "scCropArea", dataUrl);

        // Show live cut line preview
        await UpdateStep1OutlinePreview();
    }

    // ── Step 1: outline settings changed → update preview ──

    private async Task OnStep1OutlineChanged(int gap, int smooth, int width)
    {
        if (_modalLogo == null) return;
        _modalLogo.CutGapPx = Math.Max(0, Math.Min(80, gap));
        _modalLogo.CornerSmoothPx = Math.Max(0, Math.Min(40, smooth));
        _modalLogo.OutlineWidthPx = Math.Max(1, Math.Min(15, width));
        await UpdateStep1OutlinePreview();
    }

    private async Task UpdateStep1OutlinePreview()
    {
        if (_modalLogo == null) return;
        try
        {
            await JS.InvokeVoidAsync("shapeCut.updateOutlinePreview",
                _modalLogo.CutGapPx, _modalLogo.CornerSmoothPx, _modalLogo.OutlineWidthPx);
        }
        catch { }
    }

    // ── Step 1 → Step 2: Crop and move to confirm ──

    private async Task CropAndProceed()
    {
        if (_modalLogo == null) return;

        _modalLogo.IsProcessing = true;
        _isProcessing = true;
        _processingStatus = "Cropping and generating cut line...";
        StateHasChanged();

        try
        {
            var croppedUrl = await JS.InvokeAsync<string>("shapeCut.extractCrop", 0, 0);
            if (string.IsNullOrEmpty(croppedUrl))
            {
                _errorMessage = "Crop failed — no selection.";
                return;
            }

            _modalLogo.CroppedDataUrl = croppedUrl;

            // Get cropped dimensions
            var dims = await JS.InvokeAsync<int[]>("shapeCut.getImageDimensions", croppedUrl);
            _modalLogo.CroppedWidthPx = dims[0];
            _modalLogo.CroppedHeightPx = dims[1];
            RecalcInches(_modalLogo);

            // Generate cut line
            int outlinePad = _modalLogo.CutGapPx + _modalLogo.CornerSmoothPx + _modalLogo.OutlineWidthPx + 5;
            var croppedBytes = Convert.FromBase64String(croppedUrl.Split(",")[1]);
            var paddedBytes = await Task.Run(() => AddOutlinePadding(croppedBytes, outlinePad));
            var paddedUrl = "data:image/png;base64," + Convert.ToBase64String(paddedBytes);

            var outlineUrl = await JS.InvokeAsync<string>("shapeCut.generateOutline",
                paddedUrl, _modalLogo.CutGapPx, _modalLogo.CornerSmoothPx, _modalLogo.OutlineWidthPx);

            _modalLogo.OutlineDataUrl = await JS.InvokeAsync<string>("shapeCut.compositeDesignAndOutline",
                paddedUrl, outlineUrl);

            _modalLogo.ProcessedDataUrl = croppedUrl;

            try { await JS.InvokeVoidAsync("shapeCut.disposeCropTool"); } catch { }

            _modalStep = 2;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Crop/outline failed for {FileName}", _modalLogo.FileName);
            _errorMessage = $"Processing failed for '{_modalLogo.FileName}'.";
        }
        finally
        {
            _modalLogo.IsProcessing = false;
            _isProcessing = false;
            _processingStatus = "";
            StateHasChanged();
        }
    }

    // ── Step 2 → Back to Step 1 ──

    private async Task BackToCrop()
    {
        if (_modalLogo == null) return;
        _modalStep = 1;
        StateHasChanged();
        await Task.Delay(100);

        var dataUrl = _modalLogo.ProcessedDataUrl ?? _modalLogo.OriginalDataUrl;
        if (!string.IsNullOrEmpty(dataUrl))
        {
            await JS.InvokeVoidAsync("shapeCut.setAspectRatio", 0);
            await JS.InvokeVoidAsync("shapeCut.initCropTool", "scCropArea", dataUrl);
        }
    }

    // ── Confirm sticker ──

    private void ConfirmSticker()
    {
        if (_modalLogo == null) return;
        _modalLogo.IsConfirmed = true;
        _modalLogo = null;
        _modalStep = 1;
        StateHasChanged();
    }

    // ── Cut line settings changed in Step 2 → regenerate outline ──

    private async Task OnConfirmOutlineChanged(int gap, int smooth, int width)
    {
        if (_modalLogo == null || string.IsNullOrEmpty(_modalLogo.CroppedDataUrl)) return;

        _modalLogo.CutGapPx = Math.Max(0, Math.Min(80, gap));
        _modalLogo.CornerSmoothPx = Math.Max(0, Math.Min(40, smooth));
        _modalLogo.OutlineWidthPx = Math.Max(1, Math.Min(15, width));

        try
        {
            int outlinePad = _modalLogo.CutGapPx + _modalLogo.CornerSmoothPx + _modalLogo.OutlineWidthPx + 5;
            var croppedBytes = Convert.FromBase64String(_modalLogo.CroppedDataUrl.Split(",")[1]);
            var paddedBytes = await Task.Run(() => AddOutlinePadding(croppedBytes, outlinePad));
            var paddedUrl = "data:image/png;base64," + Convert.ToBase64String(paddedBytes);

            var outlineUrl = await JS.InvokeAsync<string>("shapeCut.generateOutline",
                paddedUrl, _modalLogo.CutGapPx, _modalLogo.CornerSmoothPx, _modalLogo.OutlineWidthPx);

            _modalLogo.OutlineDataUrl = await JS.InvokeAsync<string>("shapeCut.compositeDesignAndOutline",
                paddedUrl, outlineUrl);

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Outline regeneration failed");
        }
    }

    // ── Unconfirm (remove from confirmed list) ──

    private void UnconfirmLogo(LogoItem logo)
    {
        logo.IsConfirmed = false;
        logo.CroppedDataUrl = null;
        logo.OutlineDataUrl = null;
        StateHasChanged();
    }

    // ── DPI changed → recalc inches ──

    private void OnDpiChanged(ChangeEventArgs e)
    {
        _dpi = int.TryParse(e.Value?.ToString(), out var v) ? v : 300;
        if (_modalLogo != null)
            RecalcInches(_modalLogo);
    }

    private void RecalcInches(LogoItem logo)
    {
        logo.CroppedWidthIn = logo.CroppedWidthPx / (double)_dpi;
        logo.CroppedHeightIn = logo.CroppedHeightPx / (double)_dpi;
    }

    // ── Close modal ──

    private async Task CloseModal()
    {
        try { await JS.InvokeVoidAsync("shapeCut.disposeCropTool"); } catch { }
        _modalLogo = null;
        _modalStep = 1;
        StateHasChanged();
    }

    // ── Modal toggles ──

    private async Task OnModalToggleBg(bool enabled)
    {
        if (_modalLogo == null) return;

        _modalLogo.RemoveBg = enabled;

        if (enabled && _modalLogo.TransparentPngBytes == null)
        {
            if (!RemoveBgApi.IsAvailable)
            {
                _errorMessage = "remove.bg API key not configured.";
                _modalLogo.RemoveBg = false;
                StateHasChanged();
                return;
            }

            _modalLogo.IsProcessing = true;
            _isProcessing = true;
            _processingStatus = $"Removing background ({_modalLogo.FileName})...";
            StateHasChanged();

            try
            {
                var imageBytes = _modalLogo.OriginalBytes!;
                imageBytes = await Task.Run(() => ResizeForProcessing(imageBytes, 2400));
                _modalLogo.TransparentPngBytes = await RemoveBgApi.RemoveBackgroundAsync(imageBytes);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "BG removal failed for {FileName}", _modalLogo.FileName);
                _errorMessage = $"BG removal failed for '{_modalLogo.FileName}'.";
                _modalLogo.RemoveBg = false;
                _modalLogo.IsProcessing = false;
                _isProcessing = false;
                _processingStatus = "";
                StateHasChanged();
                return;
            }
            finally
            {
                _modalLogo.IsProcessing = false;
                _isProcessing = false;
                _processingStatus = "";
            }
        }

        await RebuildProcessedImage(_modalLogo);
        StateHasChanged();
        await Task.Delay(50);
        var dataUrl = _modalLogo.ProcessedDataUrl ?? _modalLogo.OriginalDataUrl;
        if (!string.IsNullOrEmpty(dataUrl))
            await JS.InvokeVoidAsync("shapeCut.swapCropImage", dataUrl);
    }

    private async Task OnModalToggleWhite(bool enabled)
    {
        if (_modalLogo == null) return;
        _modalLogo.RemoveWhites = enabled;
        await RebuildProcessedImage(_modalLogo);
        StateHasChanged();
        await Task.Delay(50);
        var dataUrl = _modalLogo.ProcessedDataUrl ?? _modalLogo.OriginalDataUrl;
        if (!string.IsNullOrEmpty(dataUrl))
            await JS.InvokeVoidAsync("shapeCut.swapCropImage", dataUrl);
    }

    private async Task RebuildProcessedImage(LogoItem logo)
    {
        byte[] imageBytes;

        if (logo.RemoveBg && logo.TransparentPngBytes != null)
        {
            imageBytes = logo.TransparentPngBytes;
            imageBytes = await Task.Run(() => TrimTransparentPadding(imageBytes));
        }
        else
        {
            imageBytes = logo.OriginalBytes!;
            imageBytes = await Task.Run(() => EnsurePng(imageBytes));
        }

        if (logo.RemoveWhites)
            imageBytes = await Task.Run(() => StripWhitePixels(imageBytes, logo.WhiteTolerance));

        logo.ProcessedDataUrl = "data:image/png;base64," + Convert.ToBase64String(imageBytes);
    }

    // ── Remove logo ──

    private async Task RemoveLogo(LogoItem logo)
    {
        if (!string.IsNullOrEmpty(logo.UploadedPath))
            try { await ImageStorage.DeleteImageAsync(logo.UploadedPath); } catch { }
        _logos.Remove(logo);
        StateHasChanged();
    }

    // ── Downloads ──

    private async Task DownloadAllPng()
    {
        foreach (var logo in _confirmedLogos)
        {
            var dataUrl = logo.CroppedDataUrl;
            if (string.IsNullOrEmpty(dataUrl)) continue;
            try
            {
                await JS.InvokeVoidAsync("shapeCut.downloadDesignPng",
                    dataUrl, $"halfcut_{SanitizeFilename(logo.FileName)}.png");
                await Task.Delay(400);
            }
            catch (Exception ex) { Logger.LogError(ex, "Download failed for {Name}", logo.FileName); }
        }
    }

    private async Task DownloadAllSvg()
    {
        foreach (var logo in _confirmedLogos)
        {
            if (string.IsNullOrEmpty(logo.CroppedDataUrl)) continue;
            try
            {
                int outlinePad = logo.CutGapPx + logo.CornerSmoothPx + logo.OutlineWidthPx + 5;
                var croppedBytes = Convert.FromBase64String(logo.CroppedDataUrl.Split(",")[1]);
                var paddedBytes = await Task.Run(() => AddOutlinePadding(croppedBytes, outlinePad));
                var paddedUrl = "data:image/png;base64," + Convert.ToBase64String(paddedBytes);

                var svgContent = await JS.InvokeAsync<string>("shapeCut.generateCutContourSVG",
                    paddedUrl, logo.CutGapPx, logo.CornerSmoothPx);

                await JS.InvokeVoidAsync("shapeCut.downloadSvgString",
                    svgContent, $"halfcut_{SanitizeFilename(logo.FileName)}.svg");
                await Task.Delay(400);
            }
            catch (Exception ex) { Logger.LogError(ex, "SVG download failed for {Name}", logo.FileName); }
        }
    }

    // ── Helpers ──

    private string ResolveFullPath(string webRelativePath) =>
        System.IO.Path.Combine(Env.WebRootPath, webRelativePath.Replace("/", System.IO.Path.DirectorySeparatorChar.ToString()));

    private static string SanitizeFilename(string name)
    {
        var withoutExt = System.IO.Path.GetFileNameWithoutExtension(name);
        return System.Text.RegularExpressions.Regex.Replace(withoutExt, @"[^a-zA-Z0-9_-]", "_");
    }

    private static byte[] ResizeForProcessing(byte[] imageBytes, int maxDimension)
    {
        using var img = Image.Load<Rgba32>(imageBytes);
        if (img.Width <= maxDimension && img.Height <= maxDimension)
            return imageBytes;
        var scale = (double)maxDimension / Math.Max(img.Width, img.Height);
        img.Mutate(ctx => ctx.Resize((int)(img.Width * scale), (int)(img.Height * scale)));
        using var ms = new MemoryStream();
        img.SaveAsPng(ms);
        return ms.ToArray();
    }

    private static byte[] EnsurePng(byte[] imageBytes)
    {
        using var img = Image.Load<Rgba32>(imageBytes);
        using var ms = new MemoryStream();
        img.SaveAsPng(ms);
        return ms.ToArray();
    }

    private static byte[] AddOutlinePadding(byte[] pngBytes, int padPx)
    {
        if (padPx <= 0) return pngBytes;
        using var src = Image.Load<Rgba32>(pngBytes);
        using var result = new Image<Rgba32>(src.Width + 2 * padPx, src.Height + 2 * padPx);
        result.Mutate(ctx => ctx.DrawImage(src, new SixLabors.ImageSharp.Point(padPx, padPx), 1f));
        using var ms = new MemoryStream();
        result.SaveAsPng(ms);
        return ms.ToArray();
    }

    private static byte[] StripWhitePixels(byte[] pngBytes, int tolerance)
    {
        using var img = Image.Load<Rgba32>(pngBytes);
        byte threshold = (byte)(255 - Math.Clamp(tolerance, 0, 254));
        img.ProcessPixelRows(accessor =>
        {
            for (int y = 0; y < accessor.Height; y++)
            {
                var row = accessor.GetRowSpan(y);
                for (int x = 0; x < row.Length; x++)
                {
                    ref var pixel = ref row[x];
                    if (pixel.A == 0) continue;
                    if (pixel.R >= threshold && pixel.G >= threshold && pixel.B >= threshold)
                        pixel.A = 0;
                }
            }
        });
        using var ms = new MemoryStream();
        img.SaveAsPng(ms);
        return ms.ToArray();
    }

    private static byte[] TrimTransparentPadding(byte[] pngBytes)
    {
        using var img = Image.Load<Rgba32>(pngBytes);
        int w = img.Width, h = img.Height;
        int top = h, bottom = 0, left = w, right = 0;
        img.ProcessPixelRows(accessor =>
        {
            for (int y = 0; y < accessor.Height; y++)
            {
                var row = accessor.GetRowSpan(y);
                for (int x = 0; x < row.Length; x++)
                {
                    if (row[x].A > 10)
                    {
                        if (y < top) top = y;
                        if (y > bottom) bottom = y;
                        if (x < left) left = x;
                        if (x > right) right = x;
                    }
                }
            }
        });
        if (top > bottom || left > right) return pngBytes;
        img.Mutate(ctx => ctx.Crop(new SixLabors.ImageSharp.Rectangle(left, top, right - left + 1, bottom - top + 1)));
        using var ms = new MemoryStream();
        img.SaveAsPng(ms);
        return ms.ToArray();
    }
}
