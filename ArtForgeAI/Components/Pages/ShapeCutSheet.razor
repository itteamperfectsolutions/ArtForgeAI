@page "/shape-cut"
@rendermode InteractiveServer
@attribute [Authorize]
@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.PixelFormats
@using SixLabors.ImageSharp.Processing
@using ArtForgeAI.Models
@inject IImageStorageService ImageStorage
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject ILogger<ShapeCutSheet> Logger
@inject OnnxBgRemovalService BgRemoval
@inject ISubscriptionService SubscriptionService
@inject ICoinService CoinService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>ArtForge AI - Shape Cut Sheet</PageTitle>

<div class="page-header page-header-lg">
    <h2>Shape Cut Gang Sheet</h2>
    <p>Upload multiple designs, generate contour outlines, and create print + cut files</p>
</div>

<div class="create-layout">
    @* ── Left column ── *@
    <div class="create-left">
        <div class="card">
            <div class="card-body">

                @* Upload area *@
                <div class="mb-3">
                    <label class="form-label">Design Images</label>
                    <label class="upload-area upload-area-compact @(_isUploading ? "disabled" : "")">
                        <span class="upload-icon">&#128424;</span>
                        <span>@(_designs.Count == 0 ? "Upload design images" : "Add more designs")</span>
                        <span style="font-size: 0.7rem; color: var(--text-muted); margin-left: 0.5rem;">PNG, JPG up to 10MB each</span>
                        <InputFile OnChange="HandleFileUpload" accept=".jpg,.jpeg,.png,.webp" multiple style="display:none" disabled="@(_isProcessing || _isUploading)" />
                    </label>
                    @if (_isUploading)
                    {
                        <div class="upload-progress-bar" style="margin-top: 0.35rem;">
                            <div class="upload-progress-fill" style="width: 50%"></div>
                            <span class="upload-progress-text">Uploading...</span>
                        </div>
                    }
                </div>

                @* Design list *@
                @if (_designs.Count > 0)
                {
                    <div class="gs-design-list">
                        @foreach (var design in _designs)
                        {
                            <div class="gs-design-item-block" @key="design.Id">
                                @* Row 1: thumb + info + qty + remove *@
                                <div class="gs-design-row1">
                                    <div class="gs-design-thumb">
                                        @if (!string.IsNullOrEmpty(design.ProcessedDataUrl))
                                        {
                                            <img src="@design.ProcessedDataUrl" alt="@design.FileName" />
                                        }
                                        else if (!string.IsNullOrEmpty(design.OriginalDataUrl))
                                        {
                                            <img src="@design.OriginalDataUrl" alt="@design.FileName" />
                                        }
                                        @if (design.IsProcessing)
                                        {
                                            <div class="gs-thumb-spinner"></div>
                                        }
                                        <button class="gs-thumb-crop" @onclick="() => OpenCropModal(design)"
                                                disabled="@(design.IsProcessing || _isProcessing)" title="Crop">&#9986;</button>
                                    </div>

                                    <div class="gs-design-info">
                                        <span class="gs-design-filename" title="@design.FileName">@design.FileName</span>
                                        <div class="gs-design-toggles">
                                            @if (BgRemoval.IsAvailable)
                                            {
                                                <label class="gs-mini-toggle">
                                                    <input type="checkbox" checked="@design.RemoveBg"
                                                           @onchange="e => ToggleBgRemoval(design, (bool)e.Value!)"
                                                           disabled="@(design.IsProcessing || _isProcessing)" />
                                                    BG
                                                </label>
                                            }
                                            <label class="gs-mini-toggle">
                                                <input type="checkbox" checked="@design.RemoveWhites"
                                                       @onchange="e => ToggleWhiteRemoval(design, (bool)e.Value!)"
                                                       disabled="@(design.IsProcessing || _isProcessing)" />
                                                W
                                            </label>
                                        </div>
                                    </div>

                                    <div class="gs-design-qty">
                                        <button class="gs-qty-btn" @onclick="() => AdjustQuantity(design, -1)"
                                                disabled="@(design.Quantity <= 1 || _isProcessing)">−</button>
                                        <input type="number" class="gs-qty-input" min="1" value="@design.Quantity"
                                               @onchange="e => SetQuantity(design, int.TryParse(e.Value?.ToString(), out var v) ? v : design.Quantity)"
                                               disabled="@_isProcessing" />
                                        <button class="gs-qty-btn" @onclick="() => AdjustQuantity(design, 1)"
                                                disabled="@(_isProcessing)">+</button>
                                    </div>

                                    <button class="gs-design-remove" @onclick="() => RemoveDesign(design)"
                                            disabled="@_isProcessing" title="Remove">✕</button>
                                </div>

                                @* Row 2: per-item size and spacing *@
                                <div class="gs-design-row2">
                                    <div class="gs-item-field">
                                        <label>W</label>
                                        <input type="number" min="0.5" max="24" step="0.25"
                                               value="@design.WidthIn"
                                               @onchange="e => OnItemSizeChanged(design, double.Parse(e.Value!.ToString()!), design.HeightIn)"
                                               disabled="@(design.IsProcessing || _isProcessing)" />
                                    </div>
                                    <span class="gs-item-sep">×</span>
                                    <div class="gs-item-field">
                                        <label>H</label>
                                        <input type="number" min="0.5" max="36" step="0.25"
                                               value="@design.HeightIn"
                                               @onchange="e => OnItemSizeChanged(design, design.WidthIn, double.Parse(e.Value!.ToString()!))"
                                               disabled="@(design.IsProcessing || _isProcessing)" />
                                    </div>
                                    <div class="gs-item-field">
                                        <label>SX</label>
                                        <input type="number" min="0" max="2" step="0.0625"
                                               value="@design.SpaceXIn"
                                               @onchange="e => OnItemSpacingChanged(design, double.Parse(e.Value!.ToString()!), design.SpaceYIn)"
                                               disabled="@_isProcessing" />
                                    </div>
                                    <div class="gs-item-field">
                                        <label>SY</label>
                                        <input type="number" min="0" max="2" step="0.0625"
                                               value="@design.SpaceYIn"
                                               @onchange="e => OnItemSpacingChanged(design, design.SpaceXIn, double.Parse(e.Value!.ToString()!))"
                                               disabled="@_isProcessing" />
                                    </div>
                                </div>

                                @* Row 3: per-item outline settings *@
                                <div class="gs-design-row2">
                                    <div class="gs-item-field">
                                        <label>Gap</label>
                                        <input type="number" min="0" max="80" step="1"
                                               value="@design.CutGapPx"
                                               @onchange="e => OnDesignOutlineChanged(design, int.Parse(e.Value!.ToString()!), design.CornerSmoothPx, design.OutlineWidthPx)"
                                               disabled="@(design.IsProcessing || _isProcessing)" />
                                    </div>
                                    <div class="gs-item-field">
                                        <label>Smooth</label>
                                        <input type="number" min="0" max="40" step="1"
                                               value="@design.CornerSmoothPx"
                                               @onchange="e => OnDesignOutlineChanged(design, design.CutGapPx, int.Parse(e.Value!.ToString()!), design.OutlineWidthPx)"
                                               disabled="@(design.IsProcessing || _isProcessing)" />
                                    </div>
                                    <div class="gs-item-field">
                                        <label>Width</label>
                                        <input type="number" min="1" max="15" step="1"
                                               value="@design.OutlineWidthPx"
                                               @onchange="e => OnDesignOutlineChanged(design, design.CutGapPx, design.CornerSmoothPx, int.Parse(e.Value!.ToString()!))"
                                               disabled="@(design.IsProcessing || _isProcessing)" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <hr style="margin: 0.6rem 0; border-color: var(--border-color);" />

                    @* Gang sheet size *@
                    <div class="mb-3">
                        <label class="form-label">Gang Sheet Size</label>
                        <select class="form-select" @bind="_selectedSheet" @bind:after="OnSheetChanged" disabled="@_isProcessing">
                            @foreach (var s in GangSheetConfig.Presets)
                            {
                                <option value="@s.Id">@s.Label</option>
                            }
                            <option value="Custom">Custom Size</option>
                        </select>
                    </div>

                    @if (_selectedSheet == "Custom")
                    {
                        <div style="display:flex;gap:0.5rem;margin-bottom:0.75rem;">
                            <div style="flex:1;">
                                <label class="form-label" style="font-size:0.75rem;">Width (in)</label>
                                <input type="number" class="form-input" min="4" max="60" step="1"
                                       @bind="_customSheetWidthIn" @bind:event="oninput" @onchange="OnSheetChanged"
                                       style="width:100%;padding:0.35rem 0.5rem;font-size:0.85rem;" />
                            </div>
                            <div style="flex:1;">
                                <label class="form-label" style="font-size:0.75rem;">Height (in)</label>
                                <input type="number" class="form-input" min="4" max="120" step="1"
                                       @bind="_customSheetHeightIn" @bind:event="oninput" @onchange="OnSheetChanged"
                                       style="width:100%;padding:0.35rem 0.5rem;font-size:0.85rem;" />
                            </div>
                        </div>
                    }

                    @* Auto-fill toggle *@
                    <div class="gs-quantity-row">
                        <div class="pp-toggle-row" style="margin-bottom:0.25rem;">
                            <label class="pp-toggle">
                                <input type="checkbox" @bind="_autoFill" @bind:after="OnAutoFillChanged" disabled="@_isProcessing" />
                                <span class="pp-toggle-slider"></span>
                            </label>
                            <span class="pp-toggle-label">Auto-fill sheet</span>
                        </div>
                    </div>

                    @* Layout info *@
                    <div class="gs-layout-info">
                        @_layoutInfoText
                    </div>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="card" style="margin-top: 0.75rem; border-left: 3px solid var(--danger);">
                <div class="card-body" style="padding: 0.75rem 1rem; color: var(--danger); font-size: 0.85rem;">
                    <strong>Error:</strong> @_errorMessage
                </div>
            </div>
        }
    </div>

    @* ── Right column: sheet preview ── *@
    <div class="create-right">
        @if (_sheetReady)
        {
            <div class="right-panel-card">
                <div class="right-panel-label">Shape Cut Preview (@GetSheetLabel())</div>


                <div class="sc-sheet-container">
                    <canvas id="scSheetCanvas"></canvas>
                </div>
                <div class="sc-download-bar">
                    <button class="btn-primary-gradient" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;" @onclick="DownloadBoth">
                        &#128424; Download Both (Print + Cut)
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;" @onclick="DownloadPrintOnly">
                        Print Only (PNG)
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;" @onclick="DownloadCutOnly">
                        Cut Only (PNG)
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;" @onclick="DownloadCutSVG">
                        Cut Only (SVG)
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;" @onclick="StartNew">
                        &#10024; Start New
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@* ── Processing modal overlay ── *@
@if (_isProcessing)
{
    <div class="pp-processing-overlay">
        <div class="pp-processing-modal">
            <div class="processing-spinner" style="width:36px;height:36px;margin:0 auto 1rem;"></div>
            <p style="margin:0;font-size:0.95rem;color:var(--text-primary);">@_processingStatus</p>
        </div>
    </div>
}

@* ── Design settings modal overlay ── *@
@if (_cropDesign != null)
{
    <div class="pp-processing-overlay" style="z-index:1000;">
        <div class="gs-crop-modal" style="max-width:700px;">
            <div class="gs-crop-modal-header">
                <span>Edit: @_cropDesign.FileName</span>
                <button class="gs-design-remove" @onclick="CancelCrop" style="width:24px;height:24px;">✕</button>
            </div>

            <div style="display:flex;gap:1rem;flex-wrap:wrap;">
                @* Left: Crop area *@
                <div style="flex:1;min-width:250px;">
                    <div id="scCropArea" class="gs-crop-inline" style="max-height:320px;"></div>
                    <p style="font-size:0.68rem;color:var(--text-muted);margin:0.25rem 0 0;">
                        Drag to move, resize from corners. Ratio locked (@(_cropDesign.WidthIn)" × @(_cropDesign.HeightIn)").
                    </p>
                </div>

                @* Right: Settings + outline preview *@
                <div style="flex:0 0 220px;display:flex;flex-direction:column;gap:0.5rem;">
                    @* Outline preview *@
                    <div id="scModalOutlinePreview" style="background:var(--bg-secondary);border-radius:6px;min-height:120px;display:flex;align-items:center;justify-content:center;overflow:hidden;">
                        <span style="font-size:0.7rem;color:var(--text-muted);">Outline preview</span>
                    </div>

                    @* BG / White toggles *@
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        @if (BgRemoval.IsAvailable)
                        {
                            <label class="gs-mini-toggle">
                                <input type="checkbox" checked="@_cropDesign.RemoveBg"
                                       @onchange="e => OnModalToggleBg((bool)e.Value!)" />
                                BG
                            </label>
                        }
                        <label class="gs-mini-toggle">
                            <input type="checkbox" checked="@_cropDesign.RemoveWhites"
                                   @onchange="e => OnModalToggleWhite((bool)e.Value!)" />
                            W
                        </label>
                    </div>

                    @* Size *@
                    <div style="display:flex;gap:0.35rem;align-items:center;">
                        <div class="gs-item-field"><label>W</label>
                            <input type="number" min="0.5" max="24" step="0.25" value="@_cropDesign.WidthIn"
                                   @onchange="e => OnModalSizeChanged(double.Parse(e.Value!.ToString()!), _cropDesign.HeightIn)" />
                        </div>
                        <span class="gs-item-sep">×</span>
                        <div class="gs-item-field"><label>H</label>
                            <input type="number" min="0.5" max="36" step="0.25" value="@_cropDesign.HeightIn"
                                   @onchange="e => OnModalSizeChanged(_cropDesign.WidthIn, double.Parse(e.Value!.ToString()!))" />
                        </div>
                    </div>

                    @* Outline settings *@
                    <div style="display:flex;gap:0.35rem;align-items:center;flex-wrap:wrap;">
                        <div class="gs-item-field"><label>Gap</label>
                            <input type="number" min="0" max="80" step="1" value="@_cropDesign.CutGapPx"
                                   @onchange="e => OnModalOutlineChanged(int.Parse(e.Value!.ToString()!), _cropDesign.CornerSmoothPx, _cropDesign.OutlineWidthPx)" />
                        </div>
                        <div class="gs-item-field"><label>Smooth</label>
                            <input type="number" min="0" max="40" step="1" value="@_cropDesign.CornerSmoothPx"
                                   @onchange="e => OnModalOutlineChanged(_cropDesign.CutGapPx, int.Parse(e.Value!.ToString()!), _cropDesign.OutlineWidthPx)" />
                        </div>
                        <div class="gs-item-field"><label>Width</label>
                            <input type="number" min="1" max="15" step="1" value="@_cropDesign.OutlineWidthPx"
                                   @onchange="e => OnModalOutlineChanged(_cropDesign.CutGapPx, _cropDesign.CornerSmoothPx, int.Parse(e.Value!.ToString()!))" />
                        </div>
                    </div>

                    @* Spacing *@
                    <div style="display:flex;gap:0.35rem;align-items:center;">
                        <div class="gs-item-field"><label>SX</label>
                            <input type="number" min="0" max="2" step="0.0625" value="@_cropDesign.SpaceXIn"
                                   @onchange="e => { _cropDesign.SpaceXIn = double.Parse(e.Value!.ToString()!); }" />
                        </div>
                        <div class="gs-item-field"><label>SY</label>
                            <input type="number" min="0" max="2" step="0.0625" value="@_cropDesign.SpaceYIn"
                                   @onchange="e => { _cropDesign.SpaceYIn = double.Parse(e.Value!.ToString()!); }" />
                        </div>
                    </div>
                </div>
            </div>

            <div style="display:flex;gap:0.5rem;margin-top:0.75rem;">
                <button class="btn-primary-gradient" style="flex:1;font-size:0.85rem;padding:0.4rem;" @onclick="ApplyCrop">
                    Apply &amp; Close
                </button>
                <button class="btn-secondary" style="font-size:0.85rem;padding:0.4rem 0.75rem;" @onclick="CancelCrop">
                    Cancel
                </button>
            </div>
        </div>
    </div>
}

@code {
    // ── State ──
    private List<DesignItem> _designs = new();
    private bool _isUploading;
    private bool _isProcessing;
    private string _processingStatus = "";
    private string? _errorMessage;
    private DesignItem? _cropDesign;
    // Default outline settings for new uploads
    private int _outlineDistancePx = 15;
    private int _cornerRadiusPx = 20;
    private int _outlineWidthPx = 3;

    // Sheet settings
    private string _selectedSheet = "11x12";
    private double _customSheetWidthIn = 22;
    private double _customSheetHeightIn = 24;
    private bool _autoFill = true;
    private string _layoutInfoText = "";

    // Sheet state
    private bool _sheetReady;

    // Computed
    private int TotalQuantity => _designs.Sum(d => d.Quantity);

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("SuperAdmin"))
        {
            var userIdStr = authState.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (int.TryParse(userIdStr, out var uid))
            {
                if (!await SubscriptionService.HasFeatureAccessAsync(uid, ArtForgeAI.Models.FeatureAccess.ShapeCutSheet))
                {
                    Nav.NavigateTo("/pricing", forceLoad: true);
                    return;
                }
            }
        }
    }

    public void Dispose()
    {
        try { JS.InvokeVoidAsync("shapeCut.dispose"); } catch { }
    }

    // ── Upload ──

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        _isUploading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var files = e.GetMultipleFiles(20);
            foreach (var file in files)
            {
                if (file.Size > ImageUploadHelper.MaxReadSize)
                {
                    _errorMessage = $"File '{file.Name}' exceeds {ImageUploadHelper.FormatFileSize(ImageUploadHelper.MaxReadSize)} limit, skipped.";
                    continue;
                }

                try
                {
                    string uploadedPath;
                    if (file.Size > ImageUploadHelper.DefaultMaxUploadSize)
                    {
                        using var readMs = new MemoryStream();
                        await file.OpenReadStream(ImageUploadHelper.MaxReadSize).CopyToAsync(readMs);
                        using var compressed = ImageUploadHelper.CompressToFit(readMs.ToArray(), file.Name);
                        uploadedPath = await ImageStorage.SaveUploadedFileAsync(compressed, file.Name);
                    }
                    else
                    {
                        using var stream = file.OpenReadStream(ImageUploadHelper.MaxReadSize);
                        uploadedPath = await ImageStorage.SaveUploadedFileAsync(stream, file.Name);
                    }

                    var design = new DesignItem
                    {
                        FileName = file.Name,
                        UploadedPath = uploadedPath,
                        Quantity = 1,
                        CutGapPx = _outlineDistancePx,
                        CornerSmoothPx = _cornerRadiusPx,
                        OutlineWidthPx = _outlineWidthPx,
                    };

                    var fullPath = ResolveFullPath(uploadedPath);
                    var imageBytes = await File.ReadAllBytesAsync(fullPath);
                    var ext = uploadedPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ? "png" : "jpeg";
                    design.OriginalDataUrl = $"data:image/{ext};base64," + Convert.ToBase64String(imageBytes);

                    _designs.Add(design);
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Failed to upload {FileName}", file.Name);
                    _errorMessage = $"Failed to upload '{file.Name}'.";
                }
            }
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
        }

        if (_designs.Count > 0)
        {
            var authStateC = await AuthState.GetAuthenticationStateAsync();
            var uidStrC = authStateC.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (int.TryParse(uidStrC, out var userIdC) && !authStateC.User.IsInRole("SuperAdmin"))
            {
                var cost = ArtForgeAI.Models.FeatureAccess.GetCost("ShapeCutSheet");
                if (!await CoinService.DebitCoinsAsync(userIdC, cost, ArtForgeAI.Models.CoinTransactionType.GenerationSpend, "Shape Cut Sheet generation"))
                {
                    _errorMessage = "Insufficient coins. Please purchase more.";
                    StateHasChanged();
                    return;
                }
            }

            _isProcessing = true;
            _processingStatus = "Processing designs...";
            StateHasChanged();

            try
            {
                await ProcessAllDesigns();
                UpdateLayoutInfo();
                await RenderSheet();
            }
            finally
            {
                _isProcessing = false;
                _processingStatus = "";
                StateHasChanged();
            }
        }
    }

    // ── Per-item size changed ──

    private async Task OnItemSizeChanged(DesignItem design, double newW, double newH)
    {
        design.WidthIn = Math.Max(0.5, Math.Min(24, newW));
        design.HeightIn = Math.Max(0.5, Math.Min(36, newH));

        await RebuildDesignImage(design);
        await GenerateOutlineForDesign(design);
        UpdateLayoutInfo();
        await RenderSheet();
    }

    // ── Per-item spacing changed ──

    private async Task OnItemSpacingChanged(DesignItem design, double newSX, double newSY)
    {
        design.SpaceXIn = Math.Max(0, Math.Min(2, newSX));
        design.SpaceYIn = Math.Max(0, Math.Min(2, newSY));

        UpdateLayoutInfo();
        await RenderSheet();
    }

    // ── Toggle BG Removal (per-item) ──

    private async Task ToggleBgRemoval(DesignItem design, bool enabled)
    {
        design.RemoveBg = enabled;

        if (enabled && design.TransparentPngBytes == null)
        {
            design.IsProcessing = true;
            _processingStatus = $"Removing background ({design.FileName})...";
            StateHasChanged();

            try
            {
                var fullPath = ResolveFullPath(design.UploadedPath!);
                var imageBytes = await File.ReadAllBytesAsync(fullPath);
                imageBytes = await Task.Run(() => ResizeForProcessing(imageBytes, 1600));
                var bgRemoved = await BgRemoval.RemoveBackgroundAsync(imageBytes);
                // Strip white/near-white pixels to handle logos/graphics
                design.TransparentPngBytes = await Task.Run(() => StripWhitePixels(bgRemoved, 30));
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "BG removal failed for {FileName}", design.FileName);
                _errorMessage = $"BG removal failed for '{design.FileName}'.";
                design.RemoveBg = false;
                design.IsProcessing = false;
                _processingStatus = "";
                StateHasChanged();
                return;
            }
        }

        await RebuildDesignImage(design);
        await GenerateOutlineForDesign(design);
        await RenderSheet();
    }

    // ── Toggle White Removal (per-item) ──

    private async Task ToggleWhiteRemoval(DesignItem design, bool enabled)
    {
        design.RemoveWhites = enabled;
        await RebuildDesignImage(design);
        await GenerateOutlineForDesign(design);
        await RenderSheet();
    }

    // ── Rebuild single design image chain ──

    private async Task RebuildDesignImage(DesignItem design)
    {
        design.IsProcessing = true;
        StateHasChanged();

        try
        {
            byte[] imageBytes;

            if (design.RemoveBg && design.TransparentPngBytes != null)
            {
                imageBytes = design.TransparentPngBytes;
                // Tight-crop to non-transparent bounding box to remove all empty space
                imageBytes = await Task.Run(() => TrimTransparentPadding(imageBytes));
            }
            else
            {
                var fullPath = ResolveFullPath(design.UploadedPath!);
                imageBytes = await File.ReadAllBytesAsync(fullPath);
                imageBytes = await Task.Run(() => ResizeForProcessing(imageBytes, 1600));
                imageBytes = await Task.Run(() => EnsurePng(imageBytes));
            }

            if (design.RemoveWhites)
            {
                var tol = design.WhiteTolerance;
                imageBytes = await Task.Run(() => StripWhitePixels(imageBytes, tol));
            }

            design.ProcessedDataUrl = "data:image/png;base64," + Convert.ToBase64String(imageBytes);

            int targetW = (int)Math.Round(design.WidthIn * GangSheetConfig.Dpi);
            int targetH = (int)Math.Round(design.HeightIn * GangSheetConfig.Dpi);
            var scaledBytes = await Task.Run(() => ScaleToDesignSize(imageBytes, targetW, targetH));

            // Add transparent padding so the cut outline has room to expand fully
            int outlinePad = design.CutGapPx + design.CornerSmoothPx + design.OutlineWidthPx + 5;
            var paddedBytes = await Task.Run(() => AddOutlinePadding(scaledBytes, outlinePad));
            design.FinalDesignUrl = "data:image/png;base64," + Convert.ToBase64String(paddedBytes);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Image processing failed for {FileName}", design.FileName);
            _errorMessage = $"Processing failed for '{design.FileName}'.";
        }
        finally
        {
            design.IsProcessing = false;
            StateHasChanged();
        }
    }

    // ── Per-item cut gap changed ──

    private async Task OnDesignOutlineChanged(DesignItem design, int gap, int smooth, int width)
    {
        design.CutGapPx = Math.Max(0, Math.Min(80, gap));
        design.CornerSmoothPx = Math.Max(0, Math.Min(40, smooth));
        design.OutlineWidthPx = Math.Max(1, Math.Min(15, width));
        await RebuildDesignImage(design);
        await GenerateOutlineForDesign(design);
        await RenderSheet();
    }

    // ── Generate outline for a single design ──

    private async Task GenerateOutlineForDesign(DesignItem design)
    {
        if (string.IsNullOrEmpty(design.FinalDesignUrl)) return;

        try
        {
            design.OutlineDataUrl = await JS.InvokeAsync<string>(
                "shapeCut.generateOutline",
                design.FinalDesignUrl,
                design.CutGapPx, design.CornerSmoothPx, design.OutlineWidthPx);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Outline generation failed for {FileName}", design.FileName);
        }
    }

