                    @* Completed (with thumbnails) section — same format as active tab *@
                    @if (inactiveCompleted.Count > 0)
                    {
                        <div class="admin-style-section-header completed">
                            <span>&#10003; With Thumbnails</span>
                            <span class="admin-style-section-count">@inactiveCompleted.Count</span>
                        </div>

                        @foreach (var group in groupedInactive)
                        {
                            <div class="admin-completed-category-header">@group.Key</div>
                            <div class="admin-completed-grid">
                                @foreach (var preset in group)
                                {
                                    <div class="admin-completed-card @(_editingStyleId == preset.Id ? "editing" : "")">
                                        @if (_editingStyleId == preset.Id)
                                        {
                                            <div class="admin-style-card-edit">
