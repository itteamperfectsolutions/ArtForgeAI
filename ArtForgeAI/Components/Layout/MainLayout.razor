@inherits LayoutComponentBase

<div class="app-layout">
    <NavMenu />
    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>
    <main class="main-content">
        <button class="mobile-menu-btn" onclick="toggleSidebar()">&#9776;</button>
