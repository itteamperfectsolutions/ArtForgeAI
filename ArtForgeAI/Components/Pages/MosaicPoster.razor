@page "/mosaic-poster"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IImageStorageService ImageStorage
@inject IJSRuntime JS
@inject ILogger<MosaicPoster> Logger
@inject ISubscriptionService SubscriptionService
@inject ICoinService CoinService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IImageEnhancerService ImageEnhancer
@inject IColorEnhancementService ColorEnhancer
@inject IWebHostEnvironment Env
@implements IDisposable

<PageTitle>ArtForge AI - Mosaic Poster</PageTitle>

<div class="page-header">
    <h2>Mosaic Poster</h2>
    <p>Create a stunning mosaic poster with your images</p>
</div>

<div class="create-layout">
    @* ── Left column: controls ── *@
    <div class="create-left">
        <div class="card">
            <div class="card-body">

                @* Hidden plain HTML file inputs — no Blazor InputFile *@
                <input type="file" id="mosaicMainInput" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none;" />
                <input type="file" id="mosaicBgInput" accept=".jpg,.jpeg,.png,.webp,.gif" multiple style="display:none;" />

                @* Main Image Upload *@
                <div class="mb-3">
                    <label class="form-label">Main Image (Foreground)</label>
                    @if (_mainImagePath is not null)
                    {
                        <div class="mosaic-main-thumb">
                            <img src="/@_mainImagePath" alt="Main" />
                            <button class="mosaic-thumb-remove" @onclick="RemoveMainImage" title="Remove">&#10005;</button>
                        </div>
                    }
                    else
                    {
                        <div class="upload-area" style="cursor:pointer;" @onclick="ClickMainInput">
                            <div class="upload-icon">&#128444;</div>
                            <div style="font-size:0.82rem;">Click to upload main image</div>
                        </div>
                    }
                </div>

                @* Background Images Upload *@
                <div class="mb-3">
                    <label class="form-label">
                        Background Images
                        <span style="color:var(--text-muted); font-weight:400; font-size:0.75rem;">
                            (@_bgImagePaths.Count / 60 — min 6)
                        </span>
                    </label>

                    @if (_bgImagePaths.Count > 0)
                    {
                        <div class="mosaic-bg-grid">
                            @for (int i = 0; i < Math.Min(_bgImagePaths.Count, 12); i++)
                            {
                                var idx = i;
                                var path = _bgImagePaths[idx];
                                <div class="mosaic-bg-thumb">
                                    <img src="/@path" alt="BG @(idx + 1)" />
                                    <button class="mosaic-thumb-remove" @onclick="() => RemoveBgImage(idx)" title="Remove">&#10005;</button>
                                </div>
                            }
                            @if (_bgImagePaths.Count > 12)
                            {
                                <div class="mosaic-bg-count">+@(_bgImagePaths.Count - 12) more</div>
                            }
                        </div>
                    }

                    @if (_bgImagePaths.Count < 60)
                    {
                        <div class="upload-area upload-area-compact" style="cursor:pointer; margin-top:0.4rem;" @onclick="ClickBgInput">
                            <span class="upload-icon">&#43;</span>
                            <span style="font-size:0.82rem;">Add background images</span>
                        </div>
                    }
                </div>

                @* Canvas Size *@
                <div class="mb-3">
                    <label class="form-label">Canvas Size</label>
                    <select class="form-input" @onchange="OnCanvasSizeChanged" disabled="@_isProcessing">
                        @foreach (var size in _canvasSizes)
                        {
                            <option value="@size.Key" selected="@(size.Key == _selectedCanvasSize)">@size.Value.name</option>
                        }
                    </select>
                </div>

                @* Layout Mode *@
                <div class="mb-3">
                    <label class="form-label">Layout Mode</label>
                    <div class="mosaic-layout-grid">
                        @foreach (var layout in _layoutModes)
                        {
                            var l = layout;
                            <button class="mosaic-layout-tile @(_selectedLayout == l.Key ? "selected" : "")"
                                    @onclick="() => OnLayoutChanged(l.Key)"
                                    disabled="@(!_isCanvasReady)">
                                <span class="mosaic-layout-icon">@l.Value.icon</span>
                                <span class="mosaic-layout-name">@l.Value.name</span>
                            </button>
                        }
                    </div>
                </div>

                @* BG Settings *@
                <div class="mb-3">
                    <label class="form-label">Background Settings</label>

                    <div class="mosaic-slider-row">
                        <span>Gutter</span>
                        <input type="range" min="0" max="20" step="1"
                               value="@_settings.TileGutter"
                               @onchange="OnGutterChanged"
                               disabled="@(!_isCanvasReady)" />
                        <span class="mosaic-slider-val">@_settings.TileGutter</span>
                    </div>

                    <div class="mosaic-slider-row">
                        <span>Opacity</span>
                        <input type="range" min="0.1" max="1" step="0.05"
                               value="@_settings.BgOpacity.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               @onchange="OnOpacityChanged"
                               disabled="@(!_isCanvasReady)" />
                        <span class="mosaic-slider-val">@_settings.BgOpacity.ToString("F2")</span>
                    </div>

                    <div class="mosaic-slider-row">
                        <span>Blur</span>
                        <input type="range" min="0" max="50" step="1"
                               value="@_settings.BgBlurPx"
                               @onchange="OnBlurChanged"
                               disabled="@(!_isCanvasReady)" />
                        <span class="mosaic-slider-val">@_settings.BgBlurPx</span>
                    </div>

                    <div class="mosaic-slider-row">
                        <span>Saturation</span>
                        <input type="range" min="-1" max="1" step="0.1"
                               value="@_settings.BgSaturation.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               @onchange="OnSaturationChanged"
                               disabled="@(!_isCanvasReady)" />
                        <span class="mosaic-slider-val">@_settings.BgSaturation.ToString("F1")</span>
                    </div>

                    <div class="mosaic-slider-row">
                        <span>Brightness</span>
                        <input type="range" min="-0.5" max="0.5" step="0.05"
                               value="@_settings.BgBrightness.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               @onchange="OnBrightnessChanged"
                               disabled="@(!_isCanvasReady)" />
                        <span class="mosaic-slider-val">@_settings.BgBrightness.ToString("F2")</span>
                    </div>
                </div>

                @* Foreground Settings *@
                <div class="mb-3">
                    <label class="form-label">Foreground Settings</label>

                    <div class="mosaic-slider-row">
                        <span>Scale</span>
                        <input type="range" min="0" max="0.8" step="0.05"
                               value="@_settings.ForegroundScale.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               @onchange="OnScaleChanged"
                               disabled="@(!_isCanvasReady)" />
                        <span class="mosaic-slider-val">@((_settings.ForegroundScale * 100).ToString("F0"))%</span>
                    </div>

                    <div class="mosaic-slider-row">
                        <span>Border</span>
                        <input type="range" min="0" max="40" step="2"
                               value="@_settings.BorderWidth"
                               @onchange="OnBorderChanged"
                               disabled="@(!_isCanvasReady)" />
                        <span class="mosaic-slider-val">@_settings.BorderWidth</span>
                    </div>

                    <div class="mosaic-slider-row">
                        <span>Corners</span>
                        <input type="range" min="0" max="40" step="2"
                               value="@_settings.CornerRadius"
                               @onchange="OnCornerRadiusChanged"
                               disabled="@(!_isCanvasReady)" />
                        <span class="mosaic-slider-val">@_settings.CornerRadius</span>
                    </div>
                </div>

                @* Quick Presets — Mosaic *@
                <div class="mb-3">
                    <label class="form-label">Mosaic Presets</label>
                    <div class="mosaic-presets">
                        <button class="btn-secondary" @onclick='() => ApplyPreset("classicGrid")' disabled="@(!_isCanvasReady)">
                            &#9632; Classic Grid
                        </button>
                        <button class="btn-secondary" @onclick='() => ApplyPreset("premiumMasonry")' disabled="@(!_isCanvasReady)">
                            &#9638; Premium Masonry
                        </button>
                        <button class="btn-secondary" @onclick='() => ApplyPreset("festivePolaroid")' disabled="@(!_isCanvasReady)">
                            &#127881; Festive Polaroid
                        </button>
                    </div>
                </div>

                @* Quick Presets — Collage *@
                <div class="mb-3">
                    <label class="form-label">Collage Presets</label>
                    <div class="mosaic-presets">
                        <button class="btn-secondary" @onclick='() => ApplyPreset("natureCircle")' disabled="@(!_isCanvasReady)">
                            &#9673; Nature Circle
                        </button>
                        <button class="btn-secondary" @onclick='() => ApplyPreset("editorialSpread")' disabled="@(!_isCanvasReady)">
                            &#9641; Editorial Spread
                        </button>
                        <button class="btn-secondary" @onclick='() => ApplyPreset("cleanFeature")' disabled="@(!_isCanvasReady)">
                            &#9703; Clean Feature
                        </button>
                        <button class="btn-secondary" @onclick='() => ApplyPreset("warmStoryboard")' disabled="@(!_isCanvasReady)">
                            &#9635; Warm Storyboard
                        </button>
                        <button class="btn-secondary" @onclick='() => ApplyPreset("elegantTriptych")' disabled="@(!_isCanvasReady)">
                            &#9776; Elegant Triptych
                        </button>
                        <button class="btn-secondary" @onclick='() => ApplyPreset("boldPanoramic")' disabled="@(!_isCanvasReady)">
                            &#9644; Bold Panoramic
                        </button>
                        <button class="btn-secondary" @onclick='() => ApplyPreset("spotlightTop")' disabled="@(!_isCanvasReady)">
                            &#9700; Spotlight Top
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="card" style="margin-top: 0.75rem; border-left: 3px solid var(--danger);">
                <div class="card-body" style="padding: 0.75rem 1rem; color: var(--danger); font-size: 0.85rem;">
                    <strong>Error:</strong> @_errorMessage
                </div>
            </div>
        }
    </div>

    @* ── Right column: canvas preview + export ── *@
    <div class="create-right">
        @if (_isCanvasReady)
        {
            <div class="right-panel-card">
                <div class="right-panel-label">Mosaic Preview</div>
                <div class="mosaic-canvas-wrap">
                    <canvas id="mosaicCanvas"></canvas>
                </div>
                <div style="display:flex;align-items:center;gap:0.4rem;margin-top:0.5rem;justify-content:center;">
                    <label style="font-size:0.78rem;color:var(--text-muted);">Print DPI:</label>
                    <select class="form-select" style="width:auto;font-size:0.8rem;padding:0.25rem 0.5rem;" @bind="_selectedDpi">
                        <option value="300">300 DPI</option>
                        <option value="600">600 DPI</option>
                        <option value="1200">1200 DPI</option>
                    </select>
                </div>
                <div class="right-panel-actions">
                    <button class="btn-primary-gradient" @onclick="ExportPng" disabled="@_isProcessing">
                        &#11015; Download PNG
                    </button>
                    <button class="btn-secondary" @onclick="StartNew" disabled="@_isProcessing">
                        &#10024; Start New
                    </button>
                    @if (ImageEnhancer.IsAvailable)
                    {
                        <button class="btn-enhance" @onclick="EnhanceAndDownload" disabled="@(_isEnhancing || _isProcessing)">
                            @if (_isEnhancing)
                            {
                                <span>Enhancing...</span>
                            }
                            else
                            {
                                <span>&#9889; Enhance 4x</span>
                            }
                        </button>
                    }
                    @*@if (ColorEnhancer.IsAvailable)
                    {
                        <button class="btn-color-enhance" @onclick="ColorEnhanceAndDownload" disabled="@(_isColorEnhancing || _isProcessing)">
                            @if (_isColorEnhancing)
                            {
                                <span>Enhancing...</span>
                            }
                            else
                            {
                                <span>&#127912; Enhance Colors</span>
                            }
                        </button>
                    }*@
                    <button class="btn-secondary" @onclick="ExportZip" disabled="@_isProcessing">
                        &#128230; Download BG ZIP
                    </button>
                    <button class="btn-secondary" @onclick="ExportMetadata" disabled="@_isProcessing">
                        &#128196; Metadata JSON
                    </button>
                </div>
                @if (_isEnhancing)
                {
                    <div class="enhance-progress-bar">
                        <div class="enhance-progress-fill" style="width: @(_enhanceProgress)%"></div>
                        <span class="enhance-progress-text">@(_enhanceProgress)%</span>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="right-panel-empty">
                <div class="empty-icon">&#129513;</div>
                <p>
                    @if (_mainImagePath is null)
                    {
                        <span>Upload a main image and at least 6 background images to get started</span>
                    }
                    else if (_bgImagePaths.Count < 6)
                    {
                        <span>Add @(6 - _bgImagePaths.Count) more background image@(6 - _bgImagePaths.Count == 1 ? "" : "s") to create your mosaic</span>
                    }
                </p>
            </div>
        }
    </div>
</div>

<Toast @ref="_toast" />

@code {
    private string? _mainImagePath;
    private List<string> _bgImagePaths = new();
    private string _selectedCanvasSize = "poster";
    private string _selectedLayout = "grid";
    private bool _isCanvasReady;
    private bool _isProcessing;
    private bool _isEnhancing;
    private int _selectedDpi = 300;
    private int _enhanceProgress;
    private bool _isColorEnhancing;
    private string? _errorMessage;
    private Toast? _toast;
    private bool _pendingInit;

    private MosaicSettings _settings = new();
    private DotNetObjectReference<MosaicPoster>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("SuperAdmin"))
        {
            var userIdStr = authState.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (int.TryParse(userIdStr, out var uid))
            {
                if (!await SubscriptionService.HasFeatureAccessAsync(uid, ArtForgeAI.Models.FeatureAccess.MosaicPoster))
                {
                    Nav.NavigateTo("/pricing", forceLoad: true);
                    return;
                }
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("mosaicFileHelper.register", "mosaicMainInput", _dotNetRef, "OnMainFilesReceived");
            await JS.InvokeVoidAsync("mosaicFileHelper.register", "mosaicBgInput", _dotNetRef, "OnBgFilesReceived");
        }
        if (_pendingInit)
        {
            _pendingInit = false;
            await InitCanvas();
        }
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    // Canvas sizes
    private static readonly Dictionary<string, (string name, int w, int h)> _canvasSizes = new()
    {
        ["a4portrait"] = ("A4 Portrait (2480×3508)", 2480, 3508),
        ["a4landscape"] = ("A4 Landscape (3508×2480)", 3508, 2480),
        ["square"] = ("Square (3000×3000)", 3000, 3000),
        ["poster"] = ("Poster (3000×2000)", 3000, 2000)
    };

    // Layout modes
    private static readonly Dictionary<string, (string name, string icon)> _layoutModes = new()
    {
        ["grid"] = ("Grid", "&#9632;"),
        ["masonry"] = ("Masonry", "&#9638;"),
        ["polaroid"] = ("Polaroid", "&#128247;"),
        ["hex"] = ("Hex", "&#11042;"),
        ["centerCircle"] = ("Center \u25CB", "&#9673;"),
        ["editorialMix"] = ("Editorial", "&#9641;"),
        ["featureLeft"] = ("Feature L", "&#9703;"),
        ["featureTop"] = ("Feature T", "&#9700;"),
        ["triptych"] = ("Triptych", "&#9776;"),
        ["storyboard"] = ("Story", "&#9635;"),
        ["panoramicStrip"] = ("Panoramic", "&#9644;")
    };

    private async Task ClickMainInput()
    {
        await JS.InvokeVoidAsync("mosaicFileHelper.click", "mosaicMainInput");
    }

    private async Task ClickBgInput()
    {
        await JS.InvokeVoidAsync("mosaicFileHelper.click", "mosaicBgInput");
    }

    [JSInvokable]
    public async Task OnMainFilesReceived(List<FileData> files)
    {
        if (files is null || files.Count == 0) return;
        _errorMessage = null;
        try
        {
            var f = files[0];
            var ext = Path.GetExtension(f.Name);
            if (string.IsNullOrEmpty(ext)) ext = ".png";
            var fileName = $"mosaic_main_{Guid.NewGuid():N}{ext}";
            var bytes = Convert.FromBase64String(f.Base64);
            using var ms = new MemoryStream(bytes);
            _mainImagePath = await ImageStorage.SaveUploadedFileAsync(ms, fileName);
            TryScheduleInit();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Main image upload failed");
            _errorMessage = "Upload failed. Please try again.";
        }
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnBgFilesReceived(List<FileData> files)
    {
        if (files is null || files.Count == 0) return;
        _errorMessage = null;
        try
        {
            foreach (var f in files)
            {
                if (_bgImagePaths.Count >= 60) break;
                var ext = Path.GetExtension(f.Name);
                if (string.IsNullOrEmpty(ext)) ext = ".png";
                var fileName = $"mosaic_bg_{Guid.NewGuid():N}{ext}";
                var bytes = Convert.FromBase64String(f.Base64);
                using var ms = new MemoryStream(bytes);
                var path = await ImageStorage.SaveUploadedFileAsync(ms, fileName);
                _bgImagePaths.Add(path);
            }
            TryScheduleInit();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Background images upload failed");
            _errorMessage = "Upload failed. Please try again.";
        }
        StateHasChanged();
    }

    public class FileData
    {
        public string Name { get; set; } = "";
        public string Base64 { get; set; } = "";
    }

    private void RemoveMainImage()
    {
        _mainImagePath = null;
        _isCanvasReady = false;
    }

    private void StartNew()
    {
        _mainImagePath = null;
        _bgImagePaths.Clear();
        _isCanvasReady = false;
        _errorMessage = null;
        _settings = new MosaicSettings();
        _selectedLayout = "grid";
        _selectedCanvasSize = "poster";
    }

    private async Task RemoveBgImage(int index)
    {
        if (index >= 0 && index < _bgImagePaths.Count)
        {
            _bgImagePaths.RemoveAt(index);
            if (_bgImagePaths.Count < 6)
            {
                _isCanvasReady = false;
            }
            else if (_isCanvasReady)
            {
                await UpdateCanvas();
            }
        }
    }

    // ── Slider Handlers ──

    private async Task OnGutterChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val)) _settings.TileGutter = val;
        await UpdateCanvasLayout();
    }

    private async Task OnOpacityChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.CultureInfo.InvariantCulture, out var val)) _settings.BgOpacity = val;
        await UpdateCanvasLayout();
    }

    private async Task OnBlurChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val)) _settings.BgBlurPx = val;
        await UpdateCanvasLayout();
    }

    private async Task OnSaturationChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.CultureInfo.InvariantCulture, out var val)) _settings.BgSaturation = val;
        await UpdateCanvasLayout();
    }

    private async Task OnBrightnessChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.CultureInfo.InvariantCulture, out var val)) _settings.BgBrightness = val;
        await UpdateCanvasLayout();
    }

    private async Task OnScaleChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.CultureInfo.InvariantCulture, out var val)) _settings.ForegroundScale = val;
        await UpdateCanvasLayout();
    }

    private async Task OnBorderChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val)) _settings.BorderWidth = val;
        await UpdateCanvasLayout();
    }

    private async Task OnCornerRadiusChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val)) _settings.CornerRadius = val;
        await UpdateCanvasLayout();
    }

    private async Task OnCanvasSizeChanged(ChangeEventArgs e)
    {
        _selectedCanvasSize = e.Value?.ToString() ?? "poster";
        if (_isCanvasReady)
        {
            await InitCanvas();
        }
    }

    private void OnLayoutChanged(string layout)
    {
        _selectedLayout = layout;
        if (_isCanvasReady)
        {
            _ = UpdateCanvasLayout();
        }
    }

    private void TryScheduleInit()
    {
        if (_mainImagePath is not null && _bgImagePaths.Count >= 6 && !_isCanvasReady)
        {
            _pendingInit = true;
        }
    }

    private async Task InitCanvas()
    {
        _isProcessing = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var size = _canvasSizes[_selectedCanvasSize];
            _isCanvasReady = true;
            StateHasChanged();

            // Wait for DOM to render the canvas element
            await Task.Delay(100);

            await JS.InvokeVoidAsync("mosaicPoster.init", "mosaicCanvas", size.w, size.h);

            // Load main image
            var mainUrl = "/" + _mainImagePath;
            await JS.InvokeVoidAsync("mosaicPoster.setMainImage", mainUrl);

            // Load BG images
            var bgUrls = _bgImagePaths.Select(p => "/" + p).ToArray();
            await JS.InvokeAsync<object>("mosaicPoster.setBgImages", (object)bgUrls);

            // Apply layout with settings
            await JS.InvokeVoidAsync("mosaicPoster.setLayout", _selectedLayout, _buildJsSettings());

            if (_toast is not null)
                _ = _toast.ShowAsync("Mosaic canvas ready!");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Canvas initialization failed");
            _errorMessage = "Canvas initialization failed. Please try again.";
            _isCanvasReady = false;
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task UpdateCanvas()
    {
        if (!_isCanvasReady) return;

        try
        {
            // Reload BG images in case they changed
            var bgUrls = _bgImagePaths.Select(p => "/" + p).ToArray();
            await JS.InvokeAsync<object>("mosaicPoster.setBgImages", (object)bgUrls);
            await JS.InvokeVoidAsync("mosaicPoster.updateSettings", _buildJsSettings());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Canvas update failed");
            _errorMessage = "Update failed. Please try again.";
        }
    }

    private async Task UpdateCanvasLayout()
    {
        if (!_isCanvasReady) return;
        try
        {
            await JS.InvokeVoidAsync("mosaicPoster.setLayout", _selectedLayout, _buildJsSettings());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Layout update failed");
            _errorMessage = "Layout update failed. Please try again.";
        }
    }

    private async Task ApplyPreset(string presetName)
    {
        if (!_isCanvasReady) return;

        try
        {
            await JS.InvokeVoidAsync("mosaicPoster.applyPreset", presetName);

            // Sync local settings with preset values
            switch (presetName)
            {
                case "classicGrid":
                    _selectedLayout = "grid";
                    _settings = new MosaicSettings
                    {
                        TileGutter = 4, BgOpacity = 0.9, BgBlurPx = 0, BgSaturation = 0, BgBrightness = 0,
                        ForegroundScale = 0.45, BorderWidth = 12, CornerRadius = 12
                    };
                    break;
                case "premiumMasonry":
                    _selectedLayout = "masonry";
                    _settings = new MosaicSettings
                    {
                        TileGutter = 6, BgOpacity = 0.6, BgBlurPx = 15, BgSaturation = -0.3, BgBrightness = -0.1,
                        ForegroundScale = 0.5, BorderWidth = 16, CornerRadius = 20
                    };
                    break;
                case "festivePolaroid":
                    _selectedLayout = "polaroid";
                    _settings = new MosaicSettings
                    {
                        TileGutter = 0, BgOpacity = 1, BgBlurPx = 0, BgSaturation = 0.2, BgBrightness = 0.05,
                        ForegroundScale = 0.4, BorderWidth = 20, CornerRadius = 8
                    };
                    break;
                case "natureCircle":
                    _selectedLayout = "centerCircle";
                    _settings = new MosaicSettings
                    {
                        TileGutter = 8, BgOpacity = 1, BgBlurPx = 0, BgSaturation = 0.1, BgBrightness = 0,
                        ForegroundScale = 0, BorderWidth = 0, CornerRadius = 0
                    };
                    break;
                case "editorialSpread":
                    _selectedLayout = "editorialMix";
                    _settings = new MosaicSettings
                    {
                        TileGutter = 6, BgOpacity = 1, BgBlurPx = 0, BgSaturation = 0, BgBrightness = 0,
                        ForegroundScale = 0, BorderWidth = 0, CornerRadius = 0
                    };
                    break;
                case "cleanFeature":
                    _selectedLayout = "featureLeft";
                    _settings = new MosaicSettings
                    {
                        TileGutter = 4, BgOpacity = 1, BgBlurPx = 0, BgSaturation = 0, BgBrightness = 0,
                        ForegroundScale = 0, BorderWidth = 0, CornerRadius = 0
                    };
                    break;
                case "warmStoryboard":
                    _selectedLayout = "storyboard";
                    _settings = new MosaicSettings
                    {
                        TileGutter = 5, BgOpacity = 1, BgBlurPx = 0, BgSaturation = 0.15, BgBrightness = 0.03,
                        BgTintColor = "#f5e6d3", BgTintOpacity = 0.08,
                        ForegroundScale = 0, BorderWidth = 0, CornerRadius = 0
                    };
                    break;
                case "elegantTriptych":
                    _selectedLayout = "triptych";
                    _settings = new MosaicSettings
                    {
                        TileGutter = 10, BgOpacity = 1, BgBlurPx = 0, BgSaturation = -0.2, BgBrightness = 0,
                        ForegroundScale = 0, BorderWidth = 0, CornerRadius = 0
                    };
                    break;
                case "boldPanoramic":
                    _selectedLayout = "panoramicStrip";
                    _settings = new MosaicSettings
                    {
                        TileGutter = 3, BgOpacity = 1, BgBlurPx = 0, BgSaturation = 0.1, BgBrightness = 0.02,
                        ForegroundScale = 0, BorderWidth = 0, CornerRadius = 0
                    };
                    break;
                case "spotlightTop":
                    _selectedLayout = "featureTop";
                    _settings = new MosaicSettings
                    {
                        TileGutter = 5, BgOpacity = 1, BgBlurPx = 0, BgSaturation = 0, BgBrightness = 0,
                        ForegroundScale = 0, BorderWidth = 0, CornerRadius = 0
                    };
                    break;
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Preset application failed for {PresetName}", presetName);
            _errorMessage = "Preset failed. Please try again.";
        }
    }

    private async Task ExportPng()
    {
        if (!_isCanvasReady || _isProcessing) return;

        // Debit coins for export
        var authState2 = await AuthState.GetAuthenticationStateAsync();
        var uidStr = authState2.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (int.TryParse(uidStr, out var userId2) && !authState2.User.IsInRole("SuperAdmin"))
        {
            var cost = ArtForgeAI.Models.FeatureAccess.GetCost("MosaicPoster");
            if (!await CoinService.DebitCoinsAsync(userId2, cost, ArtForgeAI.Models.CoinTransactionType.GenerationSpend, "Mosaic Poster export"))
            {
                _errorMessage = "Insufficient coins. Please purchase more coins.";
                return;
            }
        }

        _isProcessing = true;
        StateHasChanged();

        try
        {
            var dataUrl = await JS.InvokeAsync<string>("mosaicPoster.exportComposite");
            if (!string.IsNullOrEmpty(dataUrl))
            {
                // dataUrl is "data:image/png;base64,..."
                var rawBase64 = dataUrl.Substring(dataUrl.IndexOf(",") + 1);
                var rawBytes = Convert.FromBase64String(rawBase64);
                var dpiBytes = await ImageStorage.EmbedDpiAsync(rawBytes, _selectedDpi);
                var base64 = Convert.ToBase64String(dpiBytes);
                var fileName = $"mosaic_poster_{_selectedDpi}dpi_{DateTime.Now:yyyyMMdd_HHmmss}.png";
                await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "image/png", base64);

                if (_toast is not null)
                    _ = _toast.ShowAsync("PNG downloaded!");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "PNG export failed");
            _errorMessage = "Export failed. Please try again.";
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

