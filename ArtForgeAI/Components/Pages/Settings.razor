                                            <button class="btn-primary-gradient btn-sm" style="font-size:0.68rem;padding:0.2rem 0.4rem;" @onclick="() => SaveStyleEdit(preset.Id)">Save</button>
                                            <button class="btn-secondary btn-sm" style="font-size:0.68rem;padding:0.2rem 0.4rem;" @onclick="CancelStyleEdit">Cancel</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="admin-completed-thumb">
                                        <img src="/@preset.ThumbnailPath" alt="@preset.Name" />
