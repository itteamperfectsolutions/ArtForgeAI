    // ── Layout info ──

    private void UpdateLayoutInfo()
    {
        var sheet = GetCurrentSheetSize();
        int totalQty = TotalQuantity;
        int imageCount = _designs.Count;
        _layoutInfoText = $"{totalQty} designs on {sheet.Label} [{imageCount} image{(imageCount != 1 ? "s" : "")}]";
    }

    // ── Render sheet ──

    private async Task RenderSheet()
    {
        if (!_designs.Any(d => d.FinalDesignUrl != null)) return;

        if (!_sheetReady)
        {
            _sheetReady = true;
            StateHasChanged();
            await Task.Delay(50);
        }

        var sheet = GetCurrentSheetSize();

        var entries = _designs
            .Where(d => d.FinalDesignUrl != null && d.OutlineDataUrl != null)
            .Select(d =>
            {
                int pad = d.CutGapPx + d.CornerSmoothPx + d.OutlineWidthPx + 5;
                return new
                {
                    designUrl = d.FinalDesignUrl!,
                    outlineUrl = d.OutlineDataUrl!,
                    quantity = d.Quantity,
                    widthPx = (int)Math.Round(d.WidthIn * GangSheetConfig.Dpi) + 2 * pad,
                    heightPx = (int)Math.Round(d.HeightIn * GangSheetConfig.Dpi) + 2 * pad,
                    spaceXPx = Math.Max(0, (int)Math.Round(d.SpaceXIn * GangSheetConfig.Dpi) - 2 * pad),
                    spaceYPx = Math.Max(0, (int)Math.Round(d.SpaceYIn * GangSheetConfig.Dpi) - 2 * pad),
                    cutGapPx = d.CutGapPx,
                    cornerRadiusPx = d.CornerSmoothPx,
                };
            })
            .ToArray();

        await JS.InvokeVoidAsync("shapeCut.renderSheetMulti",
            "scSheetCanvas",
            entries,
            sheet.WidthPx,
            sheet.HeightPx);

        StateHasChanged();
    }

