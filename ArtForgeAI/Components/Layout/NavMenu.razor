@inject IJSRuntime JS
@inject IGenerationHistoryService HistoryService
@inject ISubscriptionService SubscriptionService
@inject ICoinService CoinService
@inject AuthenticationStateProvider AuthState
@inject IAuthService AuthService

<nav class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-icon">&#9733;</div>
        <h1>ArtForge AI</h1>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="sidebar-user">
                @if (!string.IsNullOrEmpty(context.User.FindFirst("avatar")?.Value))
                {
                    <img class="user-avatar" src="@context.User.FindFirst("avatar")?.Value" alt="avatar" referrerpolicy="no-referrer" />
                }
                else
                {
                    <div class="user-avatar-placeholder">@(context.User.Identity?.Name?.FirstOrDefault())</div>
                }
                <div class="user-info">
                    <span class="user-name">@context.User.Identity?.Name</span>
                    <span class="user-email">@context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</span>
                </div>
            </div>

            @if (!_isSuperAdmin)
            {
                <div class="sidebar-coins">
                    <span class="coin-icon">&#127902;</span>
                    <span>@_coinBalance coins</span>
                </div>
            }
        </Authorized>
    </AuthorizeView>

    <div class="sidebar-nav" onclick="if(window.innerWidth<=768)toggleSidebar()">
        @* ── Always visible ── *@
        <NavLink class="nav-item" href="quick-style">
            <span class="nav-icon">&#9889;</span>
            Quick Style
        </NavLink>

        @if (_isSuperAdmin)
        {
            @* ── SuperAdmin: usage-sorted feature links ── *@
            @foreach (var item in _orderedNavItems)
            {
                @if (item.Href == "")
                {
                    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                        <span class="nav-icon">@((MarkupString)item.Icon)</span>
                        @item.Label
                    </NavLink>
                }
                else
                {
                    <NavLink class="nav-item" href="@item.Href">
                        <span class="nav-icon">@((MarkupString)item.Icon)</span>
                        @item.Label
                    </NavLink>
                }
            }

            @* ── Gallery always after features ── *@
            <NavLink class="nav-item" href="gallery">
                <span class="nav-icon">&#128444;</span>
                Gallery
            </NavLink>
            <NavLink class="nav-item" href="settings">
                <span class="nav-icon">&#9881;</span>
                Settings
            </NavLink>
            <NavLink class="nav-item nav-item-admin" href="admin">
                <span class="nav-icon">&#128737;</span>
                Admin Panel
            </NavLink>
            <NavLink class="nav-item nav-item-admin" href="photo-collage-settings">
                <span class="nav-icon">&#128444;</span>
                Collage Templates
            </NavLink>
        }
        else
        {
            @* ── Regular users: usage-sorted, plan-gated features ── *@
            @foreach (var item in _orderedNavItems)
            {
                @if (_accessibleFeatures.Contains(item.FeatureKey))
                {
                    @if (item.Href == "")
                    {
                        <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                            <span class="nav-icon">@((MarkupString)item.Icon)</span>
                            @item.Label
                        </NavLink>
                    }
                    else
                    {
                        <NavLink class="nav-item" href="@item.Href">
                            <span class="nav-icon">@((MarkupString)item.Icon)</span>
                            @item.Label
                        </NavLink>
                    }
                }
            }

            @* ── Always-visible utility links for regular users ── *@
            @if (_accessibleFeatures.Contains("Gallery"))
            {
                <NavLink class="nav-item" href="gallery">
                    <span class="nav-icon">&#128444;</span>
                    Gallery
                </NavLink>
            }
            @if (_accessibleFeatures.Contains("ImageViewer"))
            {
                <NavLink class="nav-item" href="image-viewer">
                    <span class="nav-icon">&#128065;</span>
                    Image Viewer
                </NavLink>
            }

            <NavLink class="nav-item" href="wallet">
                <span class="nav-icon">&#128176;</span>
                Wallet
            </NavLink>

            <NavLink class="nav-item" href="pricing">
                <span class="nav-icon">&#128179;</span>
                Pricing
            </NavLink>

            <NavLink class="nav-item" href="referrals">
                <span class="nav-icon">&#127873;</span>
                Referrals
            </NavLink>

            <NavLink class="nav-item" href="my-subscription">
                <span class="nav-icon">&#11088;</span>
                My Plan
            </NavLink>

            @if (_accessibleFeatures.Contains("Settings"))
            {
                <NavLink class="nav-item" href="settings">
                    <span class="nav-icon">&#9881;</span>
                    Settings
                </NavLink>
            }
        }
    </div>

    @* ── Upgrade CTA (only for regular non-Enterprise users) ── *@
    @if (!_isSuperAdmin && _planName != "Enterprise")
    {
        <div class="sidebar-upgrade">
            <a href="/pricing">&#9889; Upgrade to unlock more features</a>
        </div>
    }

    <div class="sidebar-footer">
        <ThemeToggle />
        <a href="/api/auth/logout" class="nav-item sign-out-link">
            <span class="nav-icon">&#128682;</span>
            Sign Out
        </a>
    </div>
</nav>

@code {
    private int _coinBalance;
    private string _planName = "Free";
    private bool _isSuperAdmin;
    private int _userId;
    private List<string> _accessibleFeatures = new();
    private List<NavItem> _orderedNavItems = new();

    // ── Nav item definition ──
    private record NavItem(string FeatureKey, string Href, string Icon, string Label);

    // ── All sortable feature nav items (excludes QuickStyle, Gallery, Settings, ImageViewer — those are pinned) ──
    private static readonly NavItem[] AllFeatureNavItems =
    [
        new("Home",         "",                  "&#127912;",  "Create"),
        new("AutoEnhance",  "auto-enhance",      "&#9889;",    "Auto Enhance"),
        new("StyleTransfer", "style-transfer",   "&#10024;",   "Style Transfer"),
        new("StyleRemix",   "style-remix",       "&#127912;",  "Style Remix"),
        new("MosaicPoster", "mosaic-poster",     "&#129513;",  "Mosaic Poster"),
        new("MosaicPoster", "template-collage",  "&#127912;",  "Template Collage"),
        new("PhotoCollages","photo-collages",    "&#128444;",  "Photo Collages"),
        new("PassportPhoto","passport-photo",    "&#128247;",  "Passport Photo"),
        new("PhotoExpand",  "photo-size-expand", "&#128200;",  "Photo Expand"),
        new("GangSheet",    "gang-sheet",        "&#128424;",  "Gang Sheet"),
        new("ShapeCutSheet","shape-cut",         "&#9986;",    "Shape Cut Sheet"),
        new("Merger",       "merger",            "&#129520;",  "Photo Merger"),
        new("EmbroideryArt","embroidery-art",    "&#129525;",  "Embroidery Art"),
        new("NegativeScan", "negative-scan",     "&#127902;",  "Negative Scan"),
        new("BackgroundRemoval", "background-removal", "&#9986;", "BG Removal"),
    ];

    // ── Maps coin transaction descriptions to feature keys ──
    private static readonly Dictionary<string, string> DescriptionToFeatureKey = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Home image generation"]        = "Home",
        ["Quick Style generation"]       = "QuickStyle",
        ["Auto Enhance"]                 = "AutoEnhance",
        ["Style Transfer generation"]    = "StyleTransfer",
        ["Style Remix generation"]       = "StyleRemix",
        ["Mosaic Poster export"]         = "MosaicPoster",
        ["Template Collage generation"]  = "MosaicPoster",
        ["Photo Collage composition"]    = "PhotoCollages",
        ["Passport Photo generation"]    = "PassportPhoto",
        ["AI Passport Adjust"]           = "PassportPhoto",
        ["Photo Expand generation"]      = "PhotoExpand",
        ["Gang Sheet generation"]        = "GangSheet",
        ["Shape Cut Sheet generation"]   = "ShapeCutSheet",
        ["Photo Merger"]                 = "Merger",
        ["Embroidery Art"]               = "EmbroideryArt",
        ["Negative Scan conversion"]     = "NegativeScan",
        ["Negative Scan AI enhancement"] = "NegativeScan",
        ["Background Removal"]           = "BackgroundRemoval",
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var user = authState.User;

            var userIdStr = user.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (int.TryParse(userIdStr, out var userId) && userId > 0)
            {
                _userId = userId;

                // Check SuperAdmin via DB lookup (cookie claims may be stale)
                var dbUser = await AuthService.GetUserByIdAsync(userId);
                _isSuperAdmin = dbUser?.Role == ArtForgeAI.Models.AppRole.SuperAdmin;

                if (_isSuperAdmin)
                {
                    _accessibleFeatures = ArtForgeAI.Models.FeatureAccess.AllFeatures.ToList();
                }
                else
                {
                    _coinBalance = await CoinService.GetBalanceAsync(userId);
                    _planName = await SubscriptionService.GetCurrentPlanNameAsync(userId);
                    _accessibleFeatures = await SubscriptionService.GetAccessibleFeaturesAsync(userId);
                }

                // Get usage-based ordering
                _orderedNavItems = await BuildOrderedNavItems(userId);
            }
            else
            {
                _orderedNavItems = AllFeatureNavItems.ToList();
            }
        }
        catch
        {
            _accessibleFeatures = ArtForgeAI.Models.FeatureAccess.PlanFeatures["Free"].ToList();
            _orderedNavItems = AllFeatureNavItems.ToList();
        }
    }

    private async Task<List<NavItem>> BuildOrderedNavItems(int userId)
    {
        var usageOrder = await CoinService.GetFeatureUsageOrderAsync(userId);

        // Map usage descriptions to feature keys with ordering rank
        var featureRank = new Dictionary<string, int>();
        for (int i = 0; i < usageOrder.Count; i++)
        {
            if (DescriptionToFeatureKey.TryGetValue(usageOrder[i], out var featureKey))
            {
                featureRank.TryAdd(featureKey, i); // first occurrence wins
            }
        }

        // Sort: features with usage data first (by rank), then remaining features in default order
        var sorted = AllFeatureNavItems
            .Select((item, defaultIndex) => (item, defaultIndex))
            .OrderBy(x => featureRank.TryGetValue(x.item.FeatureKey, out var rank) ? rank : 1000 + x.defaultIndex)
            .Select(x => x.item)
            .ToList();

        return sorted;
    }
}
