@* ── Style Test Preview Modal ── *@
@* ── Placeholder text-input modal for test style ── *@
@if (_testPendingPlaceholders && _testPlaceholderPreset is not null)
{
    <div class="style-test-overlay">
        <div class="qs-modal qs-placeholder-modal">
            <div class="qs-modal-header">
                <span>@_testPlaceholderPreset.IconEmoji Personalise Your @_testPlaceholderPreset.Name</span>
                <button class="qs-modal-close" @onclick="CancelTestPlaceholders">&times;</button>
            </div>
            <div class="qs-placeholder-body">
                @if (_testPlaceholderPreset.PromptTemplate.Contains("{{OCCASION}}"))
                {
                    <div class="qs-field">
                        <label>Occasion / Heading <span class="qs-required">*</span></label>
                        <input type="text" @bind="_testOccasionText" placeholder="e.g. Happy Birthday, Happy Anniversary, Congratulations..." maxlength="60" />
                    </div>
                }
                @if (_testPlaceholderPreset.PromptTemplate.Contains("{{MESSAGE}}"))
                {
                    <div class="qs-field">
                        <label>Personal Message <span class="qs-optional">(optional — auto-generated if blank)</span></label>
                        <textarea @bind="_testMessageText" rows="3" placeholder="e.g. Happy Birthday, Olivia! Celebrate and enjoy!" maxlength="200"></textarea>
                    </div>
                }
                @if (_testPlaceholderPreset.PromptTemplate.Contains("{{CALENDAR}}"))
                {
                    <div class="qs-field">
                        <label>Special Date <span class="qs-required">*</span></label>
                        <input type="date" @bind="_testCalendarDate" />
                    </div>
                }
                @if (_testPlaceholderPreset.PromptTemplate.Contains("{{NUMBER}}"))
                {
                    <div class="qs-field">
                        <label>Number / Age <span class="qs-required">*</span></label>
                        <input type="number" @bind="_testNumberValue" min="0" max="999" placeholder="e.g. 2, 5, 25..." />
                    </div>
                }
                @if (_testPlaceholderPreset.PromptTemplate.Contains("{{DATE}}"))
                {
                    <div class="qs-field">
                        <label>Date <span class="qs-required">*</span></label>
                        <input type="text" @bind="_testDateText" placeholder="e.g. 26-07-2023" maxlength="30" />
                    </div>
                }
                @if (_testPlaceholderPreset.Category == "Memorial")
                {
                    <div class="qs-field">
                        <label>Name <span class="qs-required">*</span></label>
                        <input type="text" @bind="_testMemorialName" placeholder="Enter full name..." maxlength="80" />
                    </div>
                    <div class="qs-field">
                        <label>Date of Birth <span class="qs-optional">(optional)</span></label>
                        <input type="date" @bind="_testMemorialDob" />
                    </div>
                    <div class="qs-field">
                        <label>Date of Death <span class="qs-optional">(optional)</span></label>
                        <input type="date" @bind="_testMemorialDod" />
                    </div>
                }
                @if (!string.IsNullOrEmpty(_testPlaceholderError))
                {
                    <div class="qs-field-error">@_testPlaceholderError</div>
                }
            </div>
            <div class="qs-modal-footer">
                <button class="btn-primary-gradient" @onclick="SubmitTestPlaceholders">Generate</button>
                <button class="btn-secondary" @onclick="CancelTestPlaceholders">&times; Cancel</button>
            </div>
        </div>
    </div>
}

@if (_testingStyleId is not null)
{
    <div class="style-test-overlay">
        <div class="style-test-modal">
            <div class="style-test-header">
                <span>Test Style: @_testStyleName</span>
                <button class="style-test-close" @onclick="DiscardTestResult" disabled="@_testProcessing">&times;</button>
            </div>

            <div class="style-test-body">
                @* Left: source image *@
                <div class="style-test-panel">
                    <div class="style-test-panel-label">SOURCE</div>
                    <div class="style-test-image-wrap">
                        @if (!string.IsNullOrEmpty(_testSourcePath))
                        {
                            <img src="@($"{ImageStorage.GetWebPath(_testSourcePath)}?v={_testVersion}")" alt="Source" />
                        }
                    </div>
                </div>

                @* Right: result *@
                <div class="style-test-panel">
                    <div class="style-test-panel-label">RESULT</div>
                    <div class="style-test-image-wrap">
                        @if (_testProcessing)
                        {
                            <div style="display:flex;flex-direction:column;align-items:center;gap:0.75rem;padding:2rem;">
                                <div class="loading-spinner" style="width:36px;height:36px;margin:0;"></div>
                                <span style="font-size:0.85rem;color:var(--text-muted);">Applying @_testStyleName style...</span>
                                <span style="font-size:0.72rem;color:var(--text-muted);opacity:0.6;">This may take 1-2 minutes</span>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(_testError))
                        {
                            <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;padding:1.5rem;text-align:center;">
                                <span style="font-size:1.5rem;">&#9888;</span>
                                <span style="color:var(--danger);font-size:0.82rem;">@_testError</span>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(_testResultPath))
                        {
                            <img src="@($"{ImageStorage.GetWebPath(_testResultPath)}?v={_testVersion}")" alt="Result" />
                        }
                        else
                        {
                            <span style="color:var(--text-muted);font-size:0.85rem;">Waiting...</span>
                        }
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_testError))
            {
                <div style="padding:0.5rem 1rem;color:var(--danger);font-size:0.82rem;">@_testError</div>
            }

            @if (!_testProcessing && !string.IsNullOrEmpty(_testResultPath))
            {
                <div class="style-test-footer">
                    <button class="btn-primary-gradient" @onclick="UseTestResultAsThumbnail">
                        &#10003; Use as Thumbnail
                    </button>
                    <button class="btn-secondary" @onclick="DiscardTestResult">
                        &#10005; Discard
                    </button>
                </div>
            }
        </div>
    </div>
}

@* ── Style Groups Modal ── *@
@if (_showGroupsModal)
{
    <div class="qs-modal-overlay" @onclick="() => _showGroupsModal = false">
        <div class="qs-modal" style="max-width:600px;" @onclick:stopPropagation="true">
            <div class="qs-modal-header">
                <span>&#128193; Style Groups</span>
                <button class="qs-modal-close" @onclick="() => _showGroupsModal = false">&times;</button>
            </div>
            <div class="qs-modal-body" style="padding:1rem;">
                @if (!string.IsNullOrEmpty(_groupMessage))
                {
                    <div style="font-size:0.78rem;color:var(--success);margin-bottom:0.5rem;">@_groupMessage</div>
                }
                <div style="display:flex;gap:0.4rem;align-items:center;margin-bottom:0.75rem;">
                    <input class="form-input" style="width:200px;" @bind="_newGroupName" placeholder="New group name..." />
                    <button class="btn-primary-gradient btn-sm" @onclick="AddGroup"
                            disabled="@(string.IsNullOrWhiteSpace(_newGroupName))">+ Add</button>
                </div>
                @if (_allGroups.Count > 0)
                {
                    <div style="display:flex;flex-direction:column;gap:0.35rem;">
                        @foreach (var group in _allGroups)
                        {
                            @if (_editingGroupId == group.StyleGroupId)
                            {
                                <div class="style-group-chip editing" style="padding:0.5rem;">
                                    <input class="form-input" style="width:140px;padding:0.25rem 0.4rem;font-size:0.78rem;" @bind="_editGroupName" />
                                    <input type="number" class="form-input" style="width:50px;padding:0.25rem 0.3rem;font-size:0.78rem;" @bind="_editGroupSortOrder" title="Sort order" />
                                    <label style="font-size:0.75rem;display:flex;align-items:center;gap:0.2rem;cursor:pointer;">
                                        <input type="checkbox" @bind="_editGroupIsActive" /> Active
                                    </label>
                                    <button class="btn-primary-gradient btn-sm" style="font-size:0.72rem;" @onclick="SaveGroupEdit">Save</button>
                                    <button class="btn-secondary btn-sm" style="font-size:0.72rem;" @onclick="() => _editingGroupId = null">Cancel</button>
                                </div>
                            }
                            else
                            {
                                <div class="style-group-chip @(!group.IsActive ? "inactive" : "")" style="justify-content:space-between;width:100%;" @onclick="() => StartGroupEdit(group)" title="Click to edit — Sort: @group.SortOrder">
                                    <span>@group.Name</span>
                                    <span style="display:flex;align-items:center;gap:0.4rem;">
                                        <span class="style-group-count">@_allStyles.Count(s => s.StyleGroupId == group.StyleGroupId)</span>
                                        <span style="font-size:0.7rem;color:var(--text-muted);">Sort: @group.SortOrder</span>
                                        <button class="style-group-delete" @onclick="() => DeleteGroup(group.StyleGroupId)" @onclick:stopPropagation="true" title="Delete group">&times;</button>
                                    </span>
                                </div>
                            }
                        }
                    </div>
                }
                else
                {
                    <p style="color:var(--text-muted);font-size:0.82rem;">No groups yet. Create one above.</p>
                }
            </div>
        </div>
    </div>
}

@* ── Bulk Assign Modal ── *@
@if (_showBulkAssignModal)
{
    <div class="qs-modal-overlay" @onclick="() => _showBulkAssignModal = false">
        <div class="qs-modal" style="max-width:900px;max-height:85vh;" @onclick:stopPropagation="true">
            <div class="qs-modal-header">
                <span>&#128196; Bulk Assign Group</span>
                <button class="qs-modal-close" @onclick="() => _showBulkAssignModal = false">&times;</button>
            </div>
            <div class="qs-modal-body" style="padding:1rem;overflow-y:auto;">
                @if (!string.IsNullOrEmpty(_bulkAssignMessage))
                {
                    <div style="font-size:0.78rem;color:var(--success);margin-bottom:0.5rem;">@_bulkAssignMessage</div>
                }
                <div style="display:flex;gap:0.4rem;align-items:center;flex-wrap:wrap;margin-bottom:0.5rem;">
                    <input class="form-input" style="width:180px;" @bind="_bulkSearchQuery" @bind:event="oninput" placeholder="Search presets..." />
                    <select class="form-input" style="width:130px;padding:0.35rem 0.4rem;font-size:0.78rem;" @bind="_bulkFilterCategory">
                        <option value="">All Categories</option>
                        @foreach (var cat in _allStyles.Select(s => s.Category).Distinct().OrderBy(c => c))
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                    <select class="form-input" style="width:130px;padding:0.35rem 0.4rem;font-size:0.78rem;" @bind="_bulkFilterGroupId">
                        <option value="">All Groups</option>
                        <option value="-1">No Group</option>
                        @foreach (var g in _allGroups)
                        {
                            <option value="@g.StyleGroupId">@g.Name</option>
                        }
                    </select>
                    <span style="font-size:0.75rem;color:var(--text-muted);">@GetBulkFilteredStyles().Count matching</span>
                </div>
                <div style="display:flex;gap:0.4rem;align-items:center;flex-wrap:wrap;margin-bottom:0.5rem;">
                    <button class="btn-sm" style="font-size:0.72rem;" @onclick="BulkSelectAll">Select All</button>
                    <button class="btn-sm" style="font-size:0.72rem;" @onclick="BulkDeselectAll">Deselect All</button>
                    <span style="font-size:0.75rem;color:var(--text-secondary);">@_bulkSelectedIds.Count selected</span>
                    <span style="margin-left:auto;display:flex;gap:0.4rem;align-items:center;">
                        <select class="form-input" style="width:130px;padding:0.35rem 0.4rem;font-size:0.78rem;" @bind="_bulkTargetGroupId">
                            <option value="">Remove Group</option>
                            @foreach (var g in _allGroups.Where(g => g.IsActive))
                            {
                                <option value="@g.StyleGroupId">@g.Name</option>
                            }
                        </select>
                        <button class="btn-primary-gradient btn-sm" @onclick="ApplyBulkAssign"
                                disabled="@(_bulkSelectedIds.Count == 0)">
                            Assign (@_bulkSelectedIds.Count)
                        </button>
                    </span>
                </div>
                <div class="bulk-assign-grid">
                    @foreach (var style in GetBulkFilteredStyles())
                    {
                        var isSelected = _bulkSelectedIds.Contains(style.Id);
                        var groupName = _allGroups.FirstOrDefault(g => g.StyleGroupId == style.StyleGroupId)?.Name;
                        <label class="bulk-assign-item @(isSelected ? "selected" : "")">
                            <input type="checkbox" checked="@isSelected" @onchange="() => ToggleBulkSelect(style.Id)" />
                            @if (!string.IsNullOrEmpty(style.ThumbnailPath))
                            {
                                <img src="/@style.ThumbnailPath" alt="" />
                            }
                            else
                            {
                                <span class="bulk-assign-emoji">@style.IconEmoji</span>
                            }
                            <div class="bulk-assign-info">
                                <span class="bulk-assign-name">@style.Name</span>
                                <span class="bulk-assign-meta">@style.Category @(groupName != null ? $"· {groupName}" : "")</span>
                            </div>
                        </label>
                    }
                </div>
            </div>
        </div>
    </div>
}

