@page "/passport-photo"
@rendermode InteractiveServer
@attribute [Authorize]
@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.PixelFormats
@using SixLabors.ImageSharp.Processing
@using SixLabors.ImageSharp.Formats.Png
@inject IPassportPhotoService PassportService
@inject IImageStorageService ImageStorage
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject ILogger<PassportPhoto> Logger
@inject OnnxBgRemovalService BgRemoval
@inject ISubscriptionService SubscriptionService
@inject ICoinService CoinService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IImageEnhancerService ImageEnhancer
@inject IColorEnhancementService ColorEnhancer
@inject IImageGenerationService ImageGenService
@implements IDisposable

<PageTitle>ArtForge AI - Passport Photo</PageTitle>

<div class="page-header page-header-lg">
    <h2>Passport Photo</h2>
    <p>Upload a photo to instantly generate a print-ready passport sheet</p>
</div>

<div class="create-layout">
    @* ── Left column ── *@
    <div class="create-left">
        <div class="card">
            <div class="card-body">

                @* Upload / Crop area *@
                <div class="mb-3">
                    <label class="form-label">Upload Your Photo</label>
                    @if (!string.IsNullOrEmpty(_uploadedPath))
                    {
                        <div style="position: relative;">
                            <button class="ref-thumb-remove" @onclick="RemovePhoto" disabled="@_isProcessing"
                                    style="position:absolute;top:4px;right:4px;z-index:20;">&#10005;</button>
                            <div id="ppCropArea" class="pp-crop-inline"></div>
                        </div>
                        <p style="font-size: 0.72rem; color: var(--text-muted); margin: 0.35rem 0 0 0;">
                            Drag to move, resize from corners. Aspect ratio locked 35×45mm.
                        </p>
                    }
                    else
                    {
                        <label class="upload-area upload-area-compact @(_isUploading ? "disabled" : "")">
                            <span class="upload-icon">&#128247;</span>
                            <span>Upload a portrait photo</span>
                            <span style="font-size: 0.7rem; color: var(--text-muted); margin-left: 0.5rem;">JPG, PNG up to 10MB</span>
                            <InputFile OnChange="HandleFileUpload" accept=".jpg,.jpeg,.png,.webp" style="display:none" disabled="@(_isProcessing || _isUploading)" />
                        </label>
                    }
                    @if (_isUploading)
                    {
                        <div class="upload-progress-bar" style="margin-top: 0.35rem;">
                            <div class="upload-progress-fill" style="width: 50%"></div>
                            <span class="upload-progress-text">Uploading...</span>
                        </div>
                    }
                </div>

                @* Settings — always visible once photo uploaded *@
                @if (!string.IsNullOrEmpty(_uploadedPath))
                {
                    <hr style="margin: 0.5rem 0; border-color: var(--border-color);" />

                    @* Paper size dropdown *@
                    <div class="mb-3">
                        <label class="form-label">Paper Size</label>
                        <select class="form-select" @bind="_selectedPaper" @bind:after="OnPaperChanged" disabled="@_isProcessing">
                            @foreach (var p in ArtForgeAI.Models.PassportPhotoConfig.PaperSizes)
                            {
                                <option value="@p.Name">@p.Name (@(p.WidthMm)×@(p.HeightMm)mm)</option>
                            }
                            <option value="Custom">Custom Size</option>
                        </select>
                    </div>

                    @if (_selectedPaper == "Custom")
                    {
                        <div style="display:flex;gap:0.5rem;margin-bottom:0.75rem;">
                            <div style="flex:1;">
                                <label class="form-label" style="font-size:0.75rem;">Width (mm)</label>
                                <input type="number" class="form-input" min="50" max="1000" step="1"
                                       @bind="_customWidthMm" @bind:event="oninput" @onchange="OnPaperChanged"
                                       style="width:100%;padding:0.35rem 0.5rem;font-size:0.85rem;" />
                            </div>
                            <div style="flex:1;">
                                <label class="form-label" style="font-size:0.75rem;">Height (mm)</label>
                                <input type="number" class="form-input" min="50" max="1000" step="1"
                                       @bind="_customHeightMm" @bind:event="oninput" @onchange="OnPaperChanged"
                                       style="width:100%;padding:0.35rem 0.5rem;font-size:0.85rem;" />
                            </div>
                        </div>
                    }

                    <div class="pp-orientation-row">
                        <button class="pp-orient-btn @(!_landscape ? "selected" : "")"
                                @onclick="() => SetOrientation(false)" disabled="@_isProcessing">
                            <span style="font-size: 1.1rem;">&#9645;</span> Portrait
                        </button>
                        <button class="pp-orient-btn @(_landscape ? "selected" : "")"
                                @onclick="() => SetOrientation(true)" disabled="@_isProcessing">
                            <span style="font-size: 1.1rem;">&#9644;</span> Landscape
                        </button>
                    </div>

                    <div class="pp-grid-info">
                        @_gridTotal photos (@(_gridCols)×@(_gridRows))
                    </div>

                    <div class="pp-slider-row">
                        <label>Spacing</label>
                        <input type="range" min="0" max="10" step="0.5" @bind="_spacingMm" @bind:event="oninput"
                               @onchange="OnSettingsChanged" disabled="@_isProcessing" />
                        <span>@(_spacingMm)mm</span>
                    </div>

                    <div class="pp-slider-row">
                        <label>Margin</label>
                        <input type="range" min="0" max="15" step="0.5" @bind="_marginMm" @bind:event="oninput"
                               @onchange="OnSettingsChanged" disabled="@_isProcessing" />
                        <span>@(_marginMm)mm</span>
                    </div>

                    <div class="pp-toggle-row">
                        <label class="pp-toggle">
                            <input type="checkbox" @bind="_cutMarks" @bind:after="OnSettingsChanged" disabled="@_isProcessing" />
                            <span class="pp-toggle-slider"></span>
                        </label>
                        <span class="pp-toggle-label">Outline</span>
                    </div>

                    <div class="pp-toggle-row">
                        <label class="pp-toggle">
                            <input type="checkbox" @bind="_cropMarks" @bind:after="OnSettingsChanged" disabled="@_isProcessing" />
                            <span class="pp-toggle-slider"></span>
                        </label>
                        <span class="pp-toggle-label">Crop marks</span>
                    </div>

                    <hr style="margin: 0.5rem 0; border-color: var(--border-color);" />

                    <div class="pp-toggle-row">
                        <label class="pp-toggle">
                            <input type="checkbox" @bind="_enhancePhoto" @bind:after="OnEnhanceChanged" disabled="@_isProcessing" />
                            <span class="pp-toggle-slider"></span>
                        </label>
                        <span class="pp-toggle-label">Enhance Photo</span>
                    </div>

                    @if (_enhancePhoto)
                    {
                        <div class="pp-slider-row">
                            <label>Sharpen</label>
                            <input type="range" min="0.5" max="5" step="0.5" @bind="_sharpenLevel" @bind:event="oninput"
                                   @onchange="OnEnhanceChanged" disabled="@_isProcessing" />
                            <span>@(_sharpenLevel)x</span>
                        </div>
                    }

                    @if (BgRemoval.IsAvailable)
                    {
                        <div class="pp-toggle-row">
                            <label class="pp-toggle">
                                <input type="checkbox" @bind="_removeBg" @bind:after="OnRemoveBgChanged" disabled="@_isProcessing" />
                                <span class="pp-toggle-slider"></span>
                            </label>
                            <span class="pp-toggle-label">Remove Background</span>
                        </div>

                        @if (_removeBg && !string.IsNullOrEmpty(_bgRemovalStatus))
                        {
                            <p style="font-size: 0.72rem; color: var(--text-muted); margin: 0.15rem 0 0 0;">
                                @_bgRemovalStatus
                            </p>
                        }

                        @if (_removeBg)
                        {
                            <div id="ppBgColourSection" style="margin-top: 0.4rem; margin-bottom: 0.25rem;">
                                <label style="font-size: 0.78rem; font-weight: 500; color: var(--text-secondary); display:block; margin-bottom: 0.3rem;">Background Colour</label>
                                <div style="display:flex; gap:0.4rem; flex-wrap:wrap;">
                                    @for (int i = 0; i < _bgColors.Length; i++)
                                    {
                                        var color = _bgColors[i];
                                        var isTransparent = color.Hex == "transparent";
                                        var isSelected = _selectedBgColor == color.Hex;
                                        <span @onclick="() => OnBgColorChanged(color.Hex)"
                                              title="@color.Name"
                                              style="display:inline-block; width:28px; height:28px; border-radius:50%;
                                                     @(isTransparent
                                                         ? "background: conic-gradient(#ccc 25%, #fff 25% 50%, #ccc 50% 75%, #fff 75%);"
                                                           + "background-size: 10px 10px;"
                                                         : $"background-color:{color.Hex};")
                                                     cursor:pointer; flex-shrink:0;
                                                     border: @(isSelected ? "3px solid #6366f1" : "2px solid #888");
                                                     box-shadow: @(isSelected ? "0 0 0 2px rgba(99,102,241,0.35)" : "0 1px 2px rgba(0,0,0,0.2)");"></span>
                                    }
                                </div>
                            </div>
                        }
                    }

                    <hr style="margin: 0.5rem 0; border-color: var(--border-color);" />

                    <button class="btn-primary-gradient" style="width:100%;padding:0.5rem;font-size:0.88rem;"
                            @onclick="AiPassportAdjust" disabled="@_isProcessing">
                        &#10024; AI Passport Adjust
                    </button>
                    <p style="font-size:0.68rem;color:var(--text-muted);margin:0.2rem 0 0 0;">
                        AI reframes your photo into a proper passport photo with white background, centered face, and correct proportions
                    </p>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="card" style="margin-top: 0.75rem; border-left: 3px solid var(--danger);">
                <div class="card-body" style="padding: 0.75rem 1rem; color: var(--danger); font-size: 0.85rem;">
                    <strong>Error:</strong> @_errorMessage
                </div>
            </div>
        }
    </div>

    @* ── Right column: print sheet only ── *@
    <div class="create-right">
        @if (_sheetReady)
        {
            <div class="right-panel-card">
                <div class="right-panel-label">Print Sheet (@GetPaperLabel() — @_gridTotal photos)</div>
                <div class="pp-sheet-container">
                    <canvas id="ppSheetCanvas"></canvas>
                </div>
                <div style="display:flex;align-items:center;gap:0.4rem;justify-content:center;">
                    <label style="font-size:0.78rem;color:var(--text-muted);">Print DPI:</label>
                    <select class="form-select" style="width:auto;font-size:0.8rem;padding:0.25rem 0.5rem;" @bind="_selectedDpi">
                        <option value="300">300 DPI</option>
                        <option value="600">600 DPI</option>
                        <option value="1200">1200 DPI</option>
                    </select>
                </div>
                <div class="pp-download-bar">
                    <button class="btn-primary-gradient" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;" @onclick="DownloadPrintSheet">
                        &#128424; Download Print Sheet (PNG)
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;" @onclick="DownloadPassportPng">
                        Download Photo PNG
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;" @onclick="DownloadPassportJpg">
                        Download Photo JPG
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;" @onclick="StartNew">
                        &#10024; Process Another
                    </button>
                    @if (_removeBg && _transparentPngCache != null)
                    {
                        <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;" @onclick="DownloadTransparentPng">
                            Download PNG (No BG)
                        </button>
                    }
                    @if (ImageEnhancer.IsAvailable)
                    {
                        <button class="btn-enhance" @onclick="EnhanceAndDownload" disabled="@(_isEnhancing || _isProcessing)">
                            @if (_isEnhancing)
                            {
                                <span>Enhancing...</span>
                            }
                            else
                            {
                                <span>&#9889; Enhance 4x</span>
                            }
                        </button>
                    }
                    @*@if (ColorEnhancer.IsAvailable)
                    {
                        <button class="btn-color-enhance" @onclick="ColorEnhanceAndDownload" disabled="@(_isColorEnhancing || _isProcessing)">
                            @if (_isColorEnhancing)
                            {
                                <span>Enhancing...</span>
                            }
                            else
                            {
                                <span>&#127912; Enhance Colors</span>
                            }
                        </button>
                    }*@
                </div>
                @if (_isEnhancing)
                {
                    <div class="enhance-progress-bar">
                        <div class="enhance-progress-fill" style="width: @(_enhanceProgress)%"></div>
                        <span class="enhance-progress-text">@(_enhanceProgress)%</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

@* ── Processing modal overlay ── *@
@if (_isProcessing)
{
    <div class="pp-processing-overlay">
        <div class="pp-processing-modal">
            <div class="processing-spinner" style="width:36px;height:36px;margin:0 auto 1rem;"></div>
            <p style="margin:0;font-size:0.95rem;color:var(--text-primary);">@_processingStatus</p>
        </div>
    </div>
}

@* ── AI Compare overlay ── *@
@if (_showAiCompare)
{
    <div class="pp-processing-overlay" style="z-index:1000;">
        <div style="background:var(--bg-primary);border-radius:var(--radius-lg);padding:1.25rem;max-width:700px;width:95%;max-height:90vh;overflow-y:auto;box-shadow:0 8px 32px rgba(0,0,0,0.4);">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">
                <span style="font-weight:600;font-size:1rem;color:var(--text-primary);">AI Passport Adjust — Compare</span>
                <button class="gs-design-remove" @onclick="RejectAiResult" style="width:24px;height:24px;">✕</button>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                <div style="text-align:center;">
                    <span style="display:block;font-size:0.78rem;font-weight:500;color:var(--text-muted);margin-bottom:0.35rem;">Original</span>
                    <div style="border-radius:var(--radius-sm);overflow:hidden;background:var(--bg-tertiary);">
                        <img src="@_aiCompareOriginalUrl" alt="Original"
                             style="max-width:100%;max-height:350px;display:block;margin:0 auto;object-fit:contain;" />
                    </div>
                </div>
                <div style="text-align:center;">
                    <span style="display:block;font-size:0.78rem;font-weight:500;color:var(--text-muted);margin-bottom:0.35rem;">AI Adjusted</span>
                    <div style="border-radius:var(--radius-sm);overflow:hidden;background:var(--bg-tertiary);">
                        <img src="@_aiCompareResultUrl" alt="AI Adjusted"
                             style="max-width:100%;max-height:350px;display:block;margin:0 auto;object-fit:contain;" />
                    </div>
                </div>
            </div>
            <p style="font-size:0.72rem;color:var(--text-muted);margin:0.5rem 0 0.75rem 0;text-align:center;">
                Compare facial features. Accept to use the AI result, or reject to keep the original.
            </p>
            <div style="display:flex;gap:0.5rem;justify-content:center;">
                <button class="btn-primary-gradient" style="padding:0.5rem 1.5rem;font-size:0.9rem;" @onclick="AcceptAiResult">
                    &#10004; Accept &amp; Use
                </button>
                <button class="btn-secondary" style="padding:0.5rem 1.5rem;font-size:0.9rem;" @onclick="RejectAiResult">
                    &#10006; Reject
                </button>
            </div>
        </div>
    </div>
}

@code {
    // ── State ──
    private string? _uploadedPath;
    private bool _isUploading;
    private bool _isProcessing;
    private bool _isEnhancing;
    private int _enhanceProgress;
    private bool _isColorEnhancing;
    private int _selectedDpi = 300;
    private string _processingStatus = "";
    private string? _errorMessage;

    // AI Compare state
    private bool _showAiCompare;
    private string? _aiCompareOriginalUrl;
    private string? _aiCompareResultUrl;
    private byte[]? _aiResultBytes;
    private string? _aiResultLocalPath;

    // Print sheet settings
    private string _selectedPaper = "4\u00d76\"";
    private int _customWidthMm = 200;
    private int _customHeightMm = 300;
    private double _spacingMm = 2.0;
    private double _marginMm = 3.0;
    private bool _cutMarks = true;
    private bool _cropMarks;
    private bool _landscape = true;
    private int _gridCols;
    private int _gridRows;
    private int _gridTotal;

    // True once a sheet has been rendered (enables download buttons)
    private bool _sheetReady;

    // Enhance photo
    private bool _enhancePhoto;
    private double _sharpenLevel = 2.0;
    private string? _enhancedDataUrl;

    // Background removal
    private bool _removeBg;
    private string? _bgRemovalStatus;
    private string? _originalDataUrl;   // original image data URL (before bg removal)
    private string? _bgRemovedDataUrl;  // bg-removed image data URL (composited on selected colour)
    private byte[]? _transparentPngCache; // cached transparent PNG for re-compositing on colour change
    private string _selectedBgColor = "#FFFFFF";

    // Background colour palette
    private record BgColor(string Name, string Hex);
    private static readonly BgColor[] _bgColors = new[]
    {
        new BgColor("Transparent", "transparent"),
        new BgColor("White",      "#FFFFFF"),
        new BgColor("Light Grey", "#D3D3D3"),
        new BgColor("Light Blue", "#ADD8E6"),
        new BgColor("Blue",       "#4A90D9"),
        new BgColor("Red",        "#DC3545"),
        new BgColor("Green",      "#28A745"),
        new BgColor("Yellow",     "#FFC107"),
        new BgColor("Black",      "#000000"),
    };

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        RecalcGrid();

        var authState = await AuthState.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("SuperAdmin"))
        {
            var userIdStr = authState.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (int.TryParse(userIdStr, out var uid))
            {
                if (!await SubscriptionService.HasFeatureAccessAsync(uid, ArtForgeAI.Models.FeatureAccess.PassportPhoto))
                {
                    Nav.NavigateTo("/pricing", forceLoad: true);
                    return;
                }
            }
        }
    }

    public void Dispose()
    {
        try { JS.InvokeVoidAsync("passportPhoto.dispose"); } catch { }
    }

    // ── Upload → show crop tool + auto generate sheet ──

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        // Auto-compress oversized images
        if (file.Size > ImageUploadHelper.DefaultMaxUploadSize)
        {
            if (file.Size > ImageUploadHelper.MaxReadSize)
            {
                _errorMessage = $"File is too large ({ImageUploadHelper.FormatFileSize(file.Size)}). Maximum allowed is {ImageUploadHelper.FormatFileSize(ImageUploadHelper.MaxReadSize)}.";
                StateHasChanged();
                return;
            }
            try
            {
                using var readMs = new MemoryStream();
                await file.OpenReadStream(ImageUploadHelper.MaxReadSize).CopyToAsync(readMs);
                var compressed = ImageUploadHelper.CompressToFit(readMs.ToArray(), file.Name);
                await ProcessUpload(e, compressed);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Image compression failed");
                _errorMessage = "Failed to compress the image. Please try a smaller file.";
                StateHasChanged();
            }
            return;
        }

        await ProcessUpload(e);
    }

    private async Task ProcessUpload(InputFileChangeEventArgs e, MemoryStream? compressedStream = null)
    {
        _isUploading = true;
        _errorMessage = null;
        StateHasChanged();

        var authStateC = await AuthState.GetAuthenticationStateAsync();
        var uidStrC = authStateC.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (int.TryParse(uidStrC, out var userIdC) && !authStateC.User.IsInRole("SuperAdmin"))
        {
            var cost = ArtForgeAI.Models.FeatureAccess.GetCost("PassportPhoto");
            if (!await CoinService.DebitCoinsAsync(userIdC, cost, ArtForgeAI.Models.CoinTransactionType.GenerationSpend, "Passport Photo generation"))
            {
                _errorMessage = "Insufficient coins. Please top up to continue.";
                _isUploading = false;
                StateHasChanged();
                return;
            }
        }

        try
        {
            var file = e.File;
            if (compressedStream is not null)
            {
                _uploadedPath = await ImageStorage.SaveUploadedFileAsync(compressedStream, file.Name);
            }
            else
            {
                using var stream = file.OpenReadStream(ImageUploadHelper.MaxReadSize);
                _uploadedPath = await ImageStorage.SaveUploadedFileAsync(stream, file.Name);
            }
            _sheetReady = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Upload failed");
            _errorMessage = "Upload failed. Please try again.";
            return;
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
        }

        // Init crop tool on the uploaded image
        if (!string.IsNullOrEmpty(_uploadedPath))
        {
            await Task.Delay(150);
            try
            {
                var fullPath = ResolveFullPath(_uploadedPath);
                var imageBytes = await File.ReadAllBytesAsync(fullPath);
                var ext = _uploadedPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ? "png" : "jpeg";
                var dataUrl = $"data:image/{ext};base64," + Convert.ToBase64String(imageBytes);
                _originalDataUrl = dataUrl;
                _bgRemovedDataUrl = null;
                _transparentPngCache = null;
                _selectedBgColor = "#FFFFFF";
                _removeBg = false;
                await JS.InvokeVoidAsync("passportPhoto.initCropTool", "ppCropArea", dataUrl);
                // Enable auto-regenerate on crop changes
                await JS.InvokeVoidAsync("passportPhoto.setCropChangedCallback", true);
            }
            catch (Exception jsEx)
            {
                Logger.LogWarning(jsEx, "Crop tool init failed");
            }

            // U-2-Net: detect person + pre-cache bg removal in one pass
            try
            {
                var fullPath2 = ResolveFullPath(_uploadedPath);
                var rawBytes = await File.ReadAllBytesAsync(fullPath2);
                var resizedBytes = await Task.Run(() => ResizeForBgRemoval(rawBytes, 1600));

                var bgResult = await BgRemoval.RemoveBackgroundWithBoundsAsync(resizedBytes);

                // Pre-cache the bg-removed composite for instant toggle
                _transparentPngCache = bgResult.TransparentPngBytes;
                _bgRemovedDataUrl = await Task.Run(() => CompositeOnColour(bgResult.TransparentPngBytes, _selectedBgColor));

                // Estimate face region from subject bounds for crop positioning
                double subH = bgResult.SubjectBottom - bgResult.SubjectTop;
                double subW = bgResult.SubjectRight - bgResult.SubjectLeft;
                double subCX = (bgResult.SubjectLeft + bgResult.SubjectRight) / 2.0;

                // Face (crown-to-chin) ratio relative to visible subject height.
                // Human head = ~1/7.5 of full body height.
                // Use subject width/height aspect to determine body coverage:
                //   Wide+short = headshot, narrow+tall = full body
                double subAspect = subW / Math.Max(0.01, subH);
                double faceRatio = subAspect > 0.9 ? 0.75   // very close-up (mostly head)
                                 : subAspect > 0.7 ? 0.45   // head + neck
                                 : subAspect > 0.5 ? 0.28   // head + shoulders
                                 : subAspect > 0.3 ? 0.18   // half body
                                 : 0.12;                     // full body

                double faceTop = bgResult.SubjectTop;
                double faceBottom = bgResult.SubjectTop + subH * faceRatio;
                double faceH = faceBottom - faceTop;
                double eyeLineY = faceTop + faceH * 0.45;

                // Pass face left/right for horizontal centering (narrower than subject)
                double faceHalfW = subW * 0.30;
                double faceLeft = subCX - faceHalfW;
                double faceRight = subCX + faceHalfW;

                await JS.InvokeVoidAsync("passportPhoto.setCropBoxFromFaceDetection",
                    faceTop, faceBottom, faceLeft, faceRight, eyeLineY);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "U-2-Net detection failed, using default center crop");
            }

            // Initial render: crop + sheet entirely client-side
            await ClientSideRender();
        }
    }

    /// <summary>Render crop + sheet entirely in the browser (no server call).</summary>
    private async Task ClientSideRender()
    {
        try
        {
            // Ensure canvas element exists in DOM before rendering
            if (!_sheetReady)
            {
                _sheetReady = true;
                RecalcGrid();
                StateHasChanged();
                await Task.Delay(50);
            }

            await SyncJsSettings();
            await JS.InvokeVoidAsync("passportPhoto.cropAndRenderSheet", "ppSheetCanvas");
            RecalcGrid();
            StateHasChanged();
        }
