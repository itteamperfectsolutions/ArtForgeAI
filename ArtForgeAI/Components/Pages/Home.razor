@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IImageGenerationService ImageGenService
@inject IImageStorageService ImageStorage
@inject IBackgroundRemovalService BgRemoval
@inject IImageEnhancerService ImageEnhancer
@inject IColorEnhancementService ColorEnhancer
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject ILogger<Home> Logger
@inject ISubscriptionService SubscriptionService
@inject ICoinService CoinService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>ArtForge AI - Create</PageTitle>

<div class="page-header">
    <h2>Create Image</h2>
    <p>Describe your vision and let AI bring it to life</p>
</div>

<div class="create-layout">
    @* ── Left column: controls ── *@
    <div class="create-left">
        <div class="card">
            <div class="card-body">
                <PromptInput @bind-Prompt="_prompt"
                             @bind-EnhancePrompt="_enhancePrompt"
                             @bind-ReferenceImagePaths="_referenceImagePaths"
                             IsDisabled="_isGenerating"
                             OnRemoveBackground="RemoveRefBackground" />

                <ProviderSelector @bind-SelectedProvider="_selectedProvider"
                                 IsDisabled="_isGenerating" />

                @*<SizeSelector SelectedSizeId="_selectedSize?.Id ?? 0"
                              SelectedSizeChanged="OnSizeChanged"
                              IsDisabled="_isGenerating" />*@

                @if (BgRemoval.IsAvailable)
                {
                    <div class="mb-3">
                        <label class="form-check-enhanced">
                            <input type="checkbox" checked="@_autoRemoveBg" @onchange="OnAutoRemoveBgChange" disabled="@_isGenerating" />
                            <span>Auto Remove Background</span>
                        </label>
                    </div>
                }


                <button class="btn-primary-gradient"
                        style="width: 100%; justify-content: center; padding: 0.55rem;"
                        @onclick="GenerateImage"
                        disabled="@(_isGenerating || string.IsNullOrWhiteSpace(_prompt))">
                    @if (_isGenerating)
                    {
                        <span>Generating...</span>
                    }
                    else
                    {
                        <span>&#10024; Generate Image</span>
                    }
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="card" style="margin-top: 0.75rem; border-left: 3px solid var(--danger);">
                <div class="card-body" style="padding: 0.75rem 1rem; color: var(--danger); font-size: 0.85rem;">
                    <strong>Error:</strong> @_errorMessage
                </div>
            </div>
        }

    </div>

    @* ── Right column: image preview ── *@
    <div class="create-right">
        @if (_referenceImagePaths.Count > 0)
        {
            <div class="ref-images-grid ref-count-@(_referenceImagePaths.Count)">
                @foreach (var path in _referenceImagePaths)
                {
                    var p = path;
                    var state = GetRefState(p);
                    <div class="right-panel-card">
                        <div class="right-panel-label">
                            Reference @(_referenceImagePaths.Count > 1 ? $"{_referenceImagePaths.IndexOf(p) + 1}" : "Image")
                            @if (state.IsProcessing)
                            {
                                <span class="bg-reprocessing-indicator">Processing...</span>
                            }
                        </div>
                        <div class="ref-image-wrap">
                            <img src="@(state.ProcessedPath is not null
                                ? $"/{state.ProcessedPath}?v={state.Version}"
                                : $"/{p}")" alt="Reference" />
                            @if (state.IsProcessing)
                            {
                                <div class="ref-processing-overlay">
                                    <div class="loading-spinner" style="width:28px;height:28px;margin:0;"></div>
                                </div>
                            }
                        </div>
                        <div class="right-panel-actions">
                            <button class="btn-secondary btn-sm" @onclick="() => DownloadRefImage(p)">&#11015; Download</button>
                            @if (state.TransparentBytes is not null)
                            {
                                <button class="btn-transparent-download btn-sm" @onclick="() => DownloadRefTransparent(p)">&#11015; Transparent</button>
                            }
                            @if (ImageEnhancer.IsAvailable && !state.IsProcessing)
                            {
                                <button class="btn-enhance btn-sm" @onclick="() => EnhanceRefImage(p)" disabled="@state.IsProcessing">&#9889; 4x</button>
                            }
                            @*@if (ColorEnhancer.IsAvailable && !state.IsProcessing)
                            {
                                <button class="btn-color-enhance btn-sm" @onclick="() => ColorEnhanceRefImage(p)" disabled="@state.IsProcessing">&#127912; Colors</button>
                            }*@
                        </div>

                        @if (BgRemoval.IsAvailable)
                        {
                            <div class="bg-remove-section">
                                @if (!state.ShowBgOptions)
                                {
                                    <button class="ref-bg-remove-btn btn-sm" @onclick="() => RemoveRefBackground(p)" disabled="@state.IsProcessing">
                                        @if (state.IsProcessing)
                                        {
                                            <span class="loading-spinner" style="width:14px;height:14px;margin:0;border-width:2px;"></span>
                                            <span>Removing...</span>
                                        }
                                        else
                                        {
                                            <span>&#9986; Remove BG</span>
                                        }
                                    </button>
                                }

                                @if (state.ShowBgOptions)
                                {
                                    <div class="bg-options-header">
                                        <span>Background</span>
                                        @if (state.IsProcessing)
                                        {
                                            <span class="bg-reprocessing-indicator">Applying...</span>
                                        }
                                    </div>

                                    <div class="bg-color-swatches">
                                        @foreach (var swatch in _bgSwatches)
                                        {
                                            var sw = swatch;
                                            <button class="bg-color-swatch @(sw.Hex == state.SelectedBgColor ? "active" : "")"
                                                    style="@(sw.Hex == "transparent"
                                                        ? "background: repeating-conic-gradient(#ccc 0% 25%, #fff 0% 50%) 50% / 10px 10px;"
                                                        : $"background-color: {sw.Hex};")"
                                                    title="@sw.Name"
                                                    disabled="@state.IsProcessing"
                                                    @onclick="() => ChangeRefBgColor(p, sw.Hex)">
                                            </button>
                                        }
                                    </div>

                                    <div class="bg-custom-row">
                                        <input type="text" class="form-input bg-hex-input"
                                               placeholder="#FF6600"
                                               @bind="state.CustomHexColor"
                                               @bind:event="oninput"
                                               disabled="@state.IsProcessing" />
                                        <button class="btn-secondary btn-sm" @onclick="() => ApplyRefCustomHex(p)" disabled="@state.IsProcessing">Apply</button>
                                    </div>

                                    <div class="bg-upload-row">
                                        <button class="bg-upload-btn btn-sm" @onclick="() => ClickRefBgFileInput(p)" disabled="@state.IsProcessing">
                                            &#128247; Upload BG
                                        </button>
                                        <InputFile id="@($"refBgFile_{p.GetHashCode():X}")" OnChange="(e) => OnRefBgImageSelected(e, p)" style="display: none;" accept=".jpg,.jpeg,.png,.webp,.gif" />
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @if (_result is not null && _result.Success)
        {
            <div class="right-panel-card">
                <div class="right-panel-label">
                    Generated Image
                    @if (_result.WasLocalProcessing)
                    {
                        <span class="local-badge">LOCAL</span>
                    }
                </div>
                <div class="right-panel-image-wrap" @key="@_imgVersion">
                    <img src="@($"{ImageStorage.GetWebPath(_result.LocalImagePath ?? "")}?v={_imgVersion}")" alt="Generated image" />
                    @if (_isReprocessing)
                    {
                        <div class="ref-processing-overlay">
                            <div class="loading-spinner" style="width:36px;height:36px;margin:0;"></div>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(_recolorError))
                {
                    <div style="padding: 0.5rem 0.75rem; color: var(--danger); font-size: 0.8rem; border-top: 1px solid var(--border-color);">
                        @_recolorError
                    </div>
                }
                <div class="right-panel-actions">
                    <button class="btn-secondary" @onclick="DownloadPng">&#11015; PNG</button>
                    <button class="btn-secondary" @onclick="DownloadJpg">&#11015; JPG</button>
                    @if (_transparentImageBytes is not null)
                    {
                        <button class="btn-transparent-download" @onclick="DownloadTransparent" title="Download with transparent background">
                            &#11015; Transparent
                        </button>
                    }
                    @if (ImageEnhancer.IsAvailable)
                    {
                        <button class="btn-enhance" @onclick="EnhanceImage" disabled="@_isEnhancing">
                            @if (_isEnhancing)
                            {
                                <span>Enhancing...</span>
                            }
                            else
                            {
                                <span>&#9889; Enhance 4x</span>
                            }
                        </button>
                    }
                    @*@if (ColorEnhancer.IsAvailable)
                    {
                        <button class="btn-color-enhance" @onclick="ColorEnhanceImage" disabled="@_isColorEnhancing">
                            @if (_isColorEnhancing)
                            {
                                <span>Enhancing...</span>
                            }
                            else
                            {
                                <span>&#127912; Enhance Colors</span>
                            }
                        </button>
                    }*@
                    @if (_result.WasLocalProcessing)
                    {
                        <button class="btn-retry-ai" @onclick="RetryWithAi">&#9729; Retry with AI</button>
                    }
                    <button class="btn-primary-gradient" @onclick="StartNew">&#10024; New</button>
                </div>
                @if (_isEnhancing)
                {
                    <div class="enhance-progress-bar">
                        <div class="enhance-progress-fill" style="width: @(_enhanceProgress)%"></div>
                        <span class="enhance-progress-text">@(_enhanceProgress)%</span>
                    </div>
                }

                @* Remove Background button and color swatches *@
                @if (BgRemoval.IsAvailable)
                {
                    <div class="bg-remove-section">
                        @if (!_showBgOptions)
                        {
                            <button class="ref-bg-remove-btn" @onclick="RemoveGeneratedBackground" disabled="@_isReprocessing">
                                @if (_isReprocessing)
                                {
                                    <span class="loading-spinner" style="width:16px;height:16px;margin:0;border-width:2px;"></span>
                                    <span>Removing...</span>
                                }
                                else
                                {
                                    <span>&#9986; Remove Background</span>
                                }
                            </button>
                        }

                        @if (_showBgOptions)
                        {
                            <div class="bg-options-header">
                                <span>Background Options</span>
                                @if (_isReprocessing)
                                {
                                    <span class="bg-reprocessing-indicator">Applying...</span>
                                }
                            </div>

                            <div class="bg-color-swatches">
                                @foreach (var swatch in _bgSwatches)
                                {
                                    <button class="bg-color-swatch @(swatch.Hex == _selectedBgColor ? "active" : "")"
                                            style="@(swatch.Hex == "transparent"
                                                ? "background: repeating-conic-gradient(#ccc 0% 25%, #fff 0% 50%) 50% / 10px 10px;"
                                                : $"background-color: {swatch.Hex};")"
                                            title="@swatch.Name"
                                            disabled="@_isReprocessing"
                                            @onclick="() => ChangeBackgroundColor(swatch.Hex)">
                                    </button>
                                }
                            </div>

                            <div class="bg-custom-row">
                                <input type="text" class="form-input bg-hex-input"
                                       placeholder="#FF6600"
                                       @bind="_customHexColor"
                                       @bind:event="oninput"
                                       disabled="@_isReprocessing" />
                                <button class="btn-secondary" @onclick="ApplyCustomHex" disabled="@_isReprocessing">Apply</button>
                            </div>

                            <div class="bg-upload-row">
                                <button class="bg-upload-btn" @onclick="ClickBgFileInput" disabled="@_isReprocessing">
                                    &#128247; Upload Background Image
                                </button>
                                <InputFile id="bgFileInput" @ref="_bgFileInput" OnChange="OnBgImageSelected" style="display: none;" accept=".jpg,.jpeg,.png,.webp,.gif" />
                            </div>
                        }
                    </div>
                }
            </div>

            @if (_result.WasLocalProcessing)
            {
                <div class="local-notice">
                    Processed locally (instant, free). Not satisfied?
                    <button class="local-notice-link" @onclick="RetryWithAi">Retry with AI</button>
                </div>
            }

            @if (!string.IsNullOrEmpty(_result.EnhancedPrompt))
            {
                <div class="result-prompt" style="margin-top: 0.75rem;">
                    <strong>Enhanced prompt:</strong> @_result.EnhancedPrompt
                </div>
            }
            <div class="ai-disclaimer">
                AI-generated image — minor variations in facial features, colours, and details may occur. For best results, try regenerating if needed.
            </div>
        }
        else if (_referenceImagePaths.Count == 0)
        {
            <div class="right-panel-empty">
                <div class="empty-icon">&#128444;</div>
                <p>Your generated image will appear here</p>
            </div>
        }
    </div>
</div>

<LoadingOverlay IsVisible="_isGenerating" CurrentStep="_loadingStep" Provider="_selectedProvider" AutoRemoveBg="_autoRemoveBg" />
<Toast @ref="_toast" />

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private string _userId = "default";
    private string _prompt = string.Empty;
    private bool _enhancePrompt = false;
    private bool _autoRemoveBg;
    private List<string> _referenceImagePaths = [];
    private ImageSizeMaster? _selectedSize;
    private ImageProvider _selectedProvider = ImageProvider.Gemini;
    private bool _isGenerating;
    private int _loadingStep = 1;
    private string? _errorMessage;
    private GenerationResult? _result;
    private Toast? _toast;

    // Enhancement state
    private bool _isEnhancing;
    private int _enhanceProgress;
    private bool _isColorEnhancing;

    // Reference image processing state
    private readonly Dictionary<string, RefImageState> _refImageStates = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("SuperAdmin"))
        {
            var userIdStr = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (int.TryParse(userIdStr, out var uid))
            {
                if (!await SubscriptionService.HasFeatureAccessAsync(uid, FeatureAccess.Home))
                {
                    Nav.NavigateTo("/pricing", forceLoad: true);
                    return;
                }
            }
        }
    }

    private async Task ResolveUserIdAsync()
    {
        if (_userId == "default" && AuthState is not null)
        {
            var state = await AuthState;
            _userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "default";
        }
    }

    // Background options state
    private string? _transparentImagePath;
    private byte[]? _transparentImageBytes;
    private string _selectedBgColor = "#FFFFFF";
    private string _customHexColor = string.Empty;
    private bool _isReprocessing;
    private bool _showBgOptions;
    private InputFile? _bgFileInput;
    private long _imgVersion;
    private string? _recolorError;

    private static readonly (string Name, string Hex)[] _bgSwatches =
    [
        ("White", "#FFFFFF"),
        ("Black", "#000000"),
        ("Transparent", "transparent"),
        ("Red", "#FF0000"),
        ("Blue", "#0000FF"),
        ("Green", "#008000"),
        ("Gray", "#808080"),
        ("Pink", "#FFC0CB"),
        ("Navy", "#000080"),
        ("Teal", "#008080"),
    ];

    private async Task GenerateImage()
    {
        if (string.IsNullOrWhiteSpace(_prompt)) return;

        // Debit coins
        var authState2 = await AuthStateProvider.GetAuthenticationStateAsync();
        var uidStr = authState2.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (int.TryParse(uidStr, out var userId) && !authState2.User.IsInRole("SuperAdmin"))
        {
            var cost = FeatureAccess.GetCost(FeatureAccess.Home);
            if (!await CoinService.DebitCoinsAsync(userId, cost, CoinTransactionType.GenerationSpend, "Home image generation"))
            {
                _errorMessage = "Insufficient coins. Please purchase more coins.";
                return;
            }
        }

        _isGenerating = true;
        _errorMessage = null;
        _result = null;
        _loadingStep = 1;
        StateHasChanged();

        try
        {
            if (_enhancePrompt)
            {
                _loadingStep = 1;
                StateHasChanged();
                await Task.Delay(500);
            }

            _loadingStep = 2;
            StateHasChanged();

            await ResolveUserIdAsync();
            var request = new GenerationRequest
            {
                Prompt = _prompt,
                Width = _selectedSize?.Width ?? 1024,
                Height = _selectedSize?.Height ?? 1024,
                SizeName = _selectedSize?.Name ?? "Square",
                EnhancePrompt = _enhancePrompt,
                ReferenceImagePaths = _referenceImagePaths,
                Provider = _selectedProvider,
                UserId = _userId
            };

            _result = await ImageGenService.GenerateImageAsync(request);

            _loadingStep = 3;
            StateHasChanged();
            await Task.Delay(300);

            if (!_result.Success)
            {
                _errorMessage = _result.ErrorMessage;
            }
            else
            {
                // Capture transparent data for post-processing
                if (_result.TransparentImagePath is not null)
                {
                    _transparentImagePath = _result.TransparentImagePath;
                    _transparentImageBytes = _result.TransparentPngBytes;
                    _showBgOptions = true;
                    _selectedBgColor = "#FFFFFF";
                    _recolorError = null;
                }
                else
                {
                    _showBgOptions = false;
                    _transparentImageBytes = null;
                }

                // Auto-remove background if enabled and not already transparent
                if (_autoRemoveBg && BgRemoval.IsAvailable
                    && _result.LocalImagePath is not null
                    && _transparentImageBytes is null)
                {
                    _loadingStep = 4;
                    StateHasChanged();
                    try
                    {
                        var fullPath = ResolveFullPath(_result.LocalImagePath);
                        var bgResult = await BgRemoval.RemoveBackgroundAsync(fullPath, "#FFFFFF");
                        _transparentImagePath = bgResult.TransparentImagePath;
                        _transparentImageBytes = bgResult.TransparentPngBytes;
                        _result.LocalImagePath = bgResult.ColoredImagePath;
                        _selectedBgColor = "#FFFFFF";
                        _showBgOptions = true;
                        _imgVersion++;
                    }
                    catch (Exception bgEx)
                    {
                        Logger.LogError(bgEx, "Auto background removal failed");
                        _recolorError = "Auto background removal failed. Please try again.";
                    }
                }

                if (_toast is not null)
                {
                    _ = _toast.ShowAsync("Image generated successfully!");
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Image generation failed");
            _errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isGenerating = false;
            StateHasChanged();
        }
    }

    private void OnAutoRemoveBgChange(ChangeEventArgs e)
    {
        _autoRemoveBg = (bool)(e.Value ?? false);
    }

    private void OnSizeChanged(ImageSizeMaster size)
    {
        _selectedSize = size;
    }

    private Task DownloadPng() => DownloadAs("png");
    private Task DownloadJpg() => DownloadAs("jpg");

    private async Task DownloadTransparent()
    {
        if (_transparentImageBytes is null) return;
        try
        {
            var base64 = Convert.ToBase64String(_transparentImageBytes);
            var fileName = $"artforge_{_result?.GenerationId ?? 0}_transparent.png";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "image/png", base64);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Transparent download failed");
            _errorMessage = "Download failed. Please try again.";
        }
    }

    private async Task DownloadRefTransparent(string path)
    {
        var state = GetRefState(path);
        if (state.TransparentBytes is null) return;
        try
        {
            var base64 = Convert.ToBase64String(state.TransparentBytes);
            var fileName = $"artforge_ref_transparent_{Guid.NewGuid():N}.png";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "image/png", base64);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Ref transparent download failed");
            _errorMessage = "Download failed. Please try again.";
        }
    }

    private async Task DownloadAs(string format)
    {
        if (_result?.LocalImagePath is null) return;

        try
        {
            var webPath = await ImageStorage.PrepareHighResDownloadAsync(_result.LocalImagePath, format);
            var fileName = $"artforge_{_result.GenerationId}.{format}";
            await JS.InvokeVoidAsync("downloadFile", $"/{webPath}", fileName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Download failed for format {Format}", format);
            _errorMessage = "Download failed. Please try again.";
        }
    }

    private async Task EnhanceImage()
    {
        if (_result?.LocalImagePath is null || _isEnhancing) return;

        _isEnhancing = true;
        _enhanceProgress = 0;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var progress = new Progress<int>(pct =>
            {
                _enhanceProgress = pct;
                InvokeAsync(StateHasChanged);
            });

            var enhancedPath = await ImageEnhancer.EnhanceImageAsync(_result.LocalImagePath, progress);
            _result.LocalImagePath = enhancedPath;
            _imgVersion++;

            if (_toast is not null)
            {
                _ = _toast.ShowAsync("Image enhanced (4x upscale)!");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Image enhancement failed");
            _errorMessage = "Enhancement failed. Please try again.";
        }
        finally
        {
            _isEnhancing = false;
            StateHasChanged();
        }
    }

    private async Task RetryWithAi()
    {
        if (string.IsNullOrWhiteSpace(_prompt)) return;

        _isGenerating = true;
        _errorMessage = null;
        _result = null;
        _loadingStep = 1;
        _showBgOptions = false;
        _transparentImagePath = null;
        _transparentImageBytes = null;
        _selectedBgColor = "#FFFFFF";
        _customHexColor = string.Empty;
        _recolorError = null;
        StateHasChanged();

        try
        {
            _loadingStep = 2;
            StateHasChanged();

            await ResolveUserIdAsync();
            var request = new GenerationRequest
            {
                Prompt = _prompt,
                Width = _selectedSize?.Width ?? 1024,
                Height = _selectedSize?.Height ?? 1024,
                SizeName = _selectedSize?.Name ?? "Square",
                EnhancePrompt = _enhancePrompt,
                ReferenceImagePaths = _referenceImagePaths,
                Provider = _selectedProvider,
                ForceCloudProvider = true,
                UserId = _userId
            };

            _result = await ImageGenService.GenerateImageAsync(request);

            _loadingStep = 3;
            StateHasChanged();
            await Task.Delay(300);

            if (!_result.Success)
            {
                _errorMessage = _result.ErrorMessage;
            }
            else if (_toast is not null)
            {
                _ = _toast.ShowAsync("Image regenerated with AI!");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Retry with AI failed");
            _errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isGenerating = false;
            StateHasChanged();
        }
    }

    private void StartNew()
    {
        _prompt = string.Empty;
        _result = null;
        _errorMessage = null;
        _referenceImagePaths = [];
        _showBgOptions = false;
        _transparentImagePath = null;
        _transparentImageBytes = null;
        _selectedBgColor = "#FFFFFF";
        _customHexColor = string.Empty;
        _recolorError = null;
        _refImageStates.Clear();
    }

    private async Task ChangeBackgroundColor(string color)
    {
        if (_result is null || _isReprocessing) return;
        if (_transparentImageBytes is null && _transparentImagePath is null) return;

        _isReprocessing = true;
        _selectedBgColor = color;
        _recolorError = null;
        StateHasChanged();

        try
        {
            string newPath;
            if (_transparentImageBytes is not null)
            {
                // Preferred: recolor from in-memory bytes (bypasses file I/O issues)
                newPath = await BgRemoval.RecolorBackgroundFromBytesAsync(_transparentImageBytes, color);
            }
            else
            {
                // Fallback: recolor from file on disk
                newPath = await BgRemoval.RecolorBackgroundAsync(_transparentImagePath!, color);
            }
            _result.LocalImagePath = newPath;
            _imgVersion++;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Background recolor failed");
            _recolorError = "Recolor failed. Please try again.";
        }
        finally
        {
            _isReprocessing = false;
            StateHasChanged();
        }
    }

    private async Task ApplyCustomHex()
    {
        var hex = _customHexColor.Trim();
        if (string.IsNullOrEmpty(hex)) return;

        if (hex.Length == 6 && !hex.StartsWith('#'))
            hex = "#" + hex;

        if (System.Text.RegularExpressions.Regex.IsMatch(hex, @"^#[0-9a-fA-F]{6}$"))
        {
            await ChangeBackgroundColor(hex);
        }
        else
        {
            _errorMessage = "Invalid hex color. Use format #RRGGBB.";
            StateHasChanged();
        }
    }

    private async Task ClickBgFileInput()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('bgFileInput')?.click()");
    }

    private async Task OnBgImageSelected(InputFileChangeEventArgs e)
    {
        if (_result is null || _isReprocessing) return;
        if (_transparentImagePath is null && _transparentImageBytes is null) return;

        var file = e.File;
        if (file is null) return;

        _isReprocessing = true;
        _selectedBgColor = string.Empty;
        _recolorError = null;
        StateHasChanged();

        try
        {
            var fileName = $"bg_{Guid.NewGuid():N}{Path.GetExtension(file.Name)}";
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var uploadedPath = await ImageStorage.SaveUploadedFileAsync(stream, fileName);

            string newPath;
            if (_transparentImageBytes is not null)
            {
                newPath = await BgRemoval.CompositeOverImageFromBytesAsync(_transparentImageBytes, uploadedPath);
            }
            else
            {
                newPath = await BgRemoval.CompositeOverImageAsync(_transparentImagePath!, uploadedPath);
            }
            _result.LocalImagePath = newPath;
            _imgVersion++;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Background image upload failed");
            _recolorError = "Background image failed. Please try again.";
        }
        finally
        {
            _isReprocessing = false;
            StateHasChanged();
        }
    }

    // ── Reference image processing ──

    private RefImageState GetRefState(string path)
    {
        if (!_refImageStates.TryGetValue(path, out var state))
        {
            state = new RefImageState();
            _refImageStates[path] = state;
        }
        return state;
    }

    private string ResolveFullPath(string webRelativePath) =>
        Path.Combine(Env.WebRootPath, webRelativePath.Replace("/", Path.DirectorySeparatorChar.ToString()));

    private async Task RemoveRefBackground(string path)
    {
        var state = GetRefState(path);
        if (state.IsProcessing) return;

        state.IsProcessing = true;
        StateHasChanged();

        try
        {
            var fullPath = ResolveFullPath(path);
            var result = await BgRemoval.RemoveBackgroundAsync(fullPath, "#FFFFFF");
            state.ProcessedPath = result.ColoredImagePath;
            state.TransparentPath = result.TransparentImagePath;
            state.TransparentBytes = result.TransparentPngBytes;
            state.SelectedBgColor = "#FFFFFF";
            state.ShowBgOptions = true;
            state.Version++;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Reference background removal failed");
            _errorMessage = "Background removal failed. Please try again.";
        }
        finally
        {
            state.IsProcessing = false;
            StateHasChanged();
        }
    }

    private async Task RemoveGeneratedBackground()
    {
        if (_result?.LocalImagePath is null || _isReprocessing) return;

        _isReprocessing = true;
        _recolorError = null;
        StateHasChanged();

        try
        {
            var fullPath = ResolveFullPath(_result.LocalImagePath);
            var bgResult = await BgRemoval.RemoveBackgroundAsync(fullPath, "#FFFFFF");
            _transparentImagePath = bgResult.TransparentImagePath;
            _transparentImageBytes = bgResult.TransparentPngBytes;
            _result.LocalImagePath = bgResult.ColoredImagePath;
            _selectedBgColor = "#FFFFFF";
            _showBgOptions = true;
            _imgVersion++;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Generated background removal failed");
            _recolorError = "Background removal failed. Please try again.";
        }
        finally
        {
            _isReprocessing = false;
            StateHasChanged();
        }
    }

    private async Task ChangeRefBgColor(string path, string color)
    {
        var state = GetRefState(path);
        if (state.IsProcessing || state.TransparentBytes is null) return;

        state.IsProcessing = true;
        state.SelectedBgColor = color;
        StateHasChanged();

        try
        {
            var newPath = await BgRemoval.RecolorBackgroundFromBytesAsync(state.TransparentBytes, color);
            state.ProcessedPath = newPath;
            state.Version++;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Reference recolor failed");
            _errorMessage = "Recolor failed. Please try again.";
        }
        finally
        {
            state.IsProcessing = false;
            StateHasChanged();
        }
    }

    private async Task DownloadRefImage(string path)
    {
        var state = GetRefState(path);
        var downloadPath = state.ProcessedPath ?? path;

        try
        {
            var webPath = await ImageStorage.PrepareHighResDownloadAsync(downloadPath, "png");
            var fileName = $"artforge_ref_{Guid.NewGuid():N}.png";
            await JS.InvokeVoidAsync("downloadFile", $"/{webPath}", fileName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Reference image download failed");
            _errorMessage = "Download failed. Please try again.";
        }
    }

    private async Task ApplyRefCustomHex(string path)
    {
        var state = GetRefState(path);
        var hex = state.CustomHexColor.Trim();
        if (string.IsNullOrEmpty(hex)) return;

        if (hex.Length == 6 && !hex.StartsWith('#'))
            hex = "#" + hex;

        if (System.Text.RegularExpressions.Regex.IsMatch(hex, @"^#[0-9a-fA-F]{6}$"))
        {
            await ChangeRefBgColor(path, hex);
        }
        else
        {
            _errorMessage = "Invalid hex color. Use format #RRGGBB.";
            StateHasChanged();
        }
    }

    private async Task ClickRefBgFileInput(string path)
    {
        var id = $"refBgFile_{path.GetHashCode():X}";
        await JS.InvokeVoidAsync("eval", $"document.getElementById('{id}')?.click()");
    }

    private async Task OnRefBgImageSelected(InputFileChangeEventArgs e, string path)
    {
        var state = GetRefState(path);
        if (state.TransparentPath is null || state.IsProcessing) return;

        var file = e.File;
        if (file is null) return;

        state.IsProcessing = true;
        state.SelectedBgColor = string.Empty;
        StateHasChanged();

        try
        {
            var fileName = $"refbg_{Guid.NewGuid():N}{Path.GetExtension(file.Name)}";
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var uploadedPath = await ImageStorage.SaveUploadedFileAsync(stream, fileName);
            var newPath = await BgRemoval.CompositeOverImageAsync(state.TransparentPath, uploadedPath);
            state.ProcessedPath = newPath;
            state.Version++;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Reference background image upload failed");
            _errorMessage = "Background image failed. Please try again.";
        }
        finally
        {
            state.IsProcessing = false;
            StateHasChanged();
        }
    }

    private async Task EnhanceRefImage(string path)
    {
        var state = GetRefState(path);
        if (state.IsProcessing) return;

        state.IsProcessing = true;
        StateHasChanged();

        try
        {
            var sourcePath = state.ProcessedPath ?? path;
            var enhancedPath = await ImageEnhancer.EnhanceImageAsync(sourcePath);
            state.ProcessedPath = enhancedPath;
            state.Version++;

            if (_toast is not null)
                _ = _toast.ShowAsync("Reference image enhanced (4x)!");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Reference image enhancement failed");
            _errorMessage = "Enhancement failed. Please try again.";
        }
        finally
        {
            state.IsProcessing = false;
            StateHasChanged();
        }
    }

    private async Task ColorEnhanceImage()
    {
        if (_result?.LocalImagePath is null || _isColorEnhancing) return;

        _isColorEnhancing = true;
        _errorMessage = null;
