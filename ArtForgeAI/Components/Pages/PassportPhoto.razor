    // ── Enhancement ──

    private async Task EnhanceAndDownload()
    {
        if (!_sheetReady || _isEnhancing) return;

        _isEnhancing = true;
        _enhanceProgress = 0;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var dataUrl = await JS.InvokeAsync<string>("passportPhoto.exportPng");
            if (string.IsNullOrEmpty(dataUrl)) return;

            var base64 = dataUrl.Substring(dataUrl.IndexOf(",") + 1);
            var imageBytes = Convert.FromBase64String(base64);

            var outputDir = Path.Combine(Env.WebRootPath, "generated");
            Directory.CreateDirectory(outputDir);
            var tempPath = Path.Combine(outputDir, $"passport_temp_{Guid.NewGuid():N}.png");
            await File.WriteAllBytesAsync(tempPath, imageBytes);

            var progress = new Progress<int>(pct =>
            {
                _enhanceProgress = pct;
                InvokeAsync(StateHasChanged);
            });

            var enhancedPath = await ImageEnhancer.EnhanceImageAsync(tempPath, progress);
            var enhancedFullPath = Path.IsPathRooted(enhancedPath) ? enhancedPath : Path.Combine(Env.WebRootPath, enhancedPath.Replace('/', Path.DirectorySeparatorChar));
            var enhancedBytes = await File.ReadAllBytesAsync(enhancedFullPath);
            var enhancedBase64 = Convert.ToBase64String(enhancedBytes);
            var fileName = $"passport_sheet_4x_{DateTime.Now:yyyyMMdd_HHmmss}.png";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "image/png", enhancedBase64);

            try { File.Delete(tempPath); } catch { }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Passport photo 4x enhance failed");
            _errorMessage = "Enhancement failed. Please try again.";
        }
        finally
        {
            _isEnhancing = false;
            StateHasChanged();
        }
    }

