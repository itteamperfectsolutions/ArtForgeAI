                                    </select>
                                            </div>
                                            <textarea class="form-input" style="width: 100%; min-height: 50px; font-size: 0.78rem;" @bind="_editStylePrompt" placeholder="Prompt Template"></textarea>
                                            <div style="display: flex; gap: 0.35rem; justify-content: flex-end;">
                                                <button class="btn-primary-gradient btn-sm" @onclick="() => SaveStyleEdit(preset.Id)">Save</button>
                                                <button class="btn-secondary btn-sm" @onclick="CancelStyleEdit">Cancel</button>
                                            </div>
