    private async Task RotateStatusMessages(CancellationToken ct)
    {
        var styleName = _selectedStyle?.Name ?? "style";
        var messages = new[]
        {
            $"Analysing your photo for {styleName}...",
            "Identifying facial features and expressions...",
            "Matching skin tone and lighting...",
            $"Crafting the {styleName} layout...",
            "Composing individual panels and frames...",
            "Preserving identity across all elements...",
            "Blending colours and applying effects...",
            "Rendering high-quality artwork...",
            "Adding finishing touches and details...",
            "Almost there — polishing the final image..."
        };

        try
        {
            for (int i = 1; i < messages.Length && !ct.IsCancellationRequested; i++)
            {
                await Task.Delay(4000, ct);
                _processingStatus = messages[i];
                await InvokeAsync(StateHasChanged);
            }

            // If still running after all messages, cycle gentle reminders
            var extras = new[]
            {
                "Still working — creating something beautiful...",
                "Hang tight — fine-tuning every detail...",
                "Processing complex elements — nearly done..."
            };
            int idx = 0;
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(5000, ct);
                _processingStatus = extras[idx % extras.Length];
                await InvokeAsync(StateHasChanged);
                idx++;
            }
        }
        catch (OperationCanceledException) { /* expected on completion */ }
    }

    /// <summary>
    /// Ensures the generated image is exactly the target 2:3 aspect ratio.
    /// If not, center-crops and resizes to fit.
    /// </summary>
    private async Task EnforceAspectRatio(int targetW, int targetH)
    {
        if (_result?.LocalImagePath is null) return;

        try
        {
            var fullPath = System.IO.Path.Combine(Env.WebRootPath,
                _result.LocalImagePath.Replace("/", System.IO.Path.DirectorySeparatorChar.ToString()));

            if (!File.Exists(fullPath)) return;

            var imageBytes = await File.ReadAllBytesAsync(fullPath);
            using var img = Image.Load<Rgba32>(imageBytes);

            double targetRatio = (double)targetW / targetH; // 0.6667
            double currentRatio = (double)img.Width / img.Height;

            // Allow 2% tolerance
            if (Math.Abs(currentRatio - targetRatio) < 0.02) return;

            // Center-crop to target aspect ratio, then resize
            int cropW, cropH;
            if (currentRatio > targetRatio)
            {
                // Too wide — crop width
                cropH = img.Height;
                cropW = (int)Math.Round(cropH * targetRatio);
            }
            else
            {
                // Too tall — crop height
                cropW = img.Width;
                cropH = (int)Math.Round(cropW / targetRatio);
            }

            int cropX = (img.Width - cropW) / 2;
            int cropY = (img.Height - cropH) / 2;

            img.Mutate(ctx => ctx
                .Crop(new SixLabors.ImageSharp.Rectangle(cropX, cropY, cropW, cropH))
                .Resize(targetW, targetH));

            await using var ms = new MemoryStream();
            await img.SaveAsPngAsync(ms);
            await File.WriteAllBytesAsync(fullPath, ms.ToArray());

            Logger.LogInformation("Enforced 2:3 aspect ratio on Quick Style output ({OrigW}x{OrigH} → {W}x{H})",
                imageBytes.Length, currentRatio.ToString("F3"), targetW, targetH);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Aspect ratio enforcement failed (non-fatal)");
        }
    }

