    // ── AI Passport Adjust ──

    private async Task AiPassportAdjust()
    {
        if (string.IsNullOrEmpty(_uploadedPath)) return;

        // Debit coins
        var authStateC = await AuthState.GetAuthenticationStateAsync();
        var uidStrC = authStateC.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (int.TryParse(uidStrC, out var userIdC) && !authStateC.User.IsInRole("SuperAdmin"))
        {
            var cost = ArtForgeAI.Models.FeatureAccess.GetCost("PassportPhoto");
            if (!await CoinService.DebitCoinsAsync(userIdC, cost, ArtForgeAI.Models.CoinTransactionType.GenerationSpend, "AI Passport Adjust"))
            {
                _errorMessage = "Insufficient coins. Please top up to continue.";
                StateHasChanged();
                return;
            }
        }

        _isProcessing = true;
        _processingStatus = "AI adjusting photo for passport...";
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var fullPath = ResolveFullPath(_uploadedPath);

            var prompt = "Transform this photo into a professional studio-quality passport photograph. " +
                         "Requirements: " +
                         "1. Pure white background (#FFFFFF). " +
                         "2. Face must be perfectly straight, centered, and looking directly at the camera. " +
                         "3. Frame the person from the top of the head down to the elbows — include head, neck, shoulders, and upper arms. " +
                         "This gives extra space above and below the face for the user to crop precisely later. " +
                         "4. The face should be approximately 50-60% of the total frame height (NOT tightly cropped). " +
                         "5. Even, soft studio lighting with no harsh shadows on the face or background. " +
                         "6. Neutral facial expression with mouth closed. " +
                         "7. Eyes open and clearly visible. " +
                         "8. Sharp focus on the face, natural skin texture. " +
                         "CRITICAL: Preserve the EXACT facial features, skin tone, hair style, and identity of the person. " +
                         "Do NOT change the person's appearance, age, ethnicity, or any identifying features. " +
                         "The result must look like the same person photographed in a professional passport studio." +
                         ArtForgeAI.Models.StylePreset.FacialIdentitySuffix;

            var request = new ArtForgeAI.Models.GenerationRequest
            {
                Prompt = prompt,
                ReferenceImagePaths = [fullPath],
                Provider = ArtForgeAI.Models.ImageProvider.Gemini,
                EnhancePrompt = false,
                Width = 826,
                Height = 1062,
                UserId = uidStrC ?? "default"
            };

            _processingStatus = "Generating passport photo with AI (this may take a moment)...";
            StateHasChanged();

            var result = await ImageGenService.GenerateImageAsync(request);

            if (result.Success && !string.IsNullOrEmpty(result.LocalImagePath))
            {
                // Read the AI-generated passport photo
                var aiFullPath = ResolveFullPath(result.LocalImagePath);
                var aiBytes = await File.ReadAllBytesAsync(aiFullPath);
                var aiDataUrl = "data:image/png;base64," + Convert.ToBase64String(aiBytes);

                // Store for comparison — don't apply yet
                _aiCompareOriginalUrl = _originalDataUrl;
                _aiCompareResultUrl = aiDataUrl;
                _aiResultBytes = aiBytes;
                _aiResultLocalPath = result.LocalImagePath;
                _showAiCompare = true;
            }
            else
            {
                _errorMessage = "AI passport adjust failed: " + (result.ErrorMessage ?? "Unknown error");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "AI Passport Adjust failed");
            _errorMessage = "AI passport adjust failed: " + ex.Message;
        }
        finally
        {
            _isProcessing = false;
            _processingStatus = "";
            StateHasChanged();
        }
    }

    private async Task AcceptAiResult()
    {
        if (_aiResultBytes == null || string.IsNullOrEmpty(_aiCompareResultUrl)) return;

        _showAiCompare = false;
        var aiDataUrl = _aiCompareResultUrl;

        // Apply the AI result as the new working image
        _originalDataUrl = aiDataUrl;
        _bgRemovedDataUrl = null;
        _transparentPngCache = null;
        _enhancedDataUrl = null;
        _removeBg = false;
        _bgRemovalStatus = null;
        _enhancePhoto = false;

        // Swap the crop tool image
        await JS.InvokeVoidAsync("passportPhoto.swapCropImage", aiDataUrl);

        // Re-run face detection on the AI result
        try
        {
            var resizedBytes = await Task.Run(() => ResizeForBgRemoval(_aiResultBytes, 1600));
            var bgResult = await BgRemoval.RemoveBackgroundWithBoundsAsync(resizedBytes);
            _transparentPngCache = bgResult.TransparentPngBytes;
            _bgRemovedDataUrl = await Task.Run(() => CompositeOnColour(bgResult.TransparentPngBytes, _selectedBgColor));

            double subH = bgResult.SubjectBottom - bgResult.SubjectTop;
            double subW = bgResult.SubjectRight - bgResult.SubjectLeft;
            double subCX = (bgResult.SubjectLeft + bgResult.SubjectRight) / 2.0;
            double subAspect = subW / Math.Max(0.01, subH);
            double faceRatio = subAspect > 0.9 ? 0.75
                             : subAspect > 0.7 ? 0.45
                             : subAspect > 0.5 ? 0.28
                             : subAspect > 0.3 ? 0.18
                             : 0.12;

            double faceTop = bgResult.SubjectTop;
            double faceBottom = bgResult.SubjectTop + subH * faceRatio;
            double faceH = faceBottom - faceTop;
            double eyeLineY = faceTop + faceH * 0.45;
            double faceHalfW = subW * 0.30;
            double faceLeft = subCX - faceHalfW;
            double faceRight = subCX + faceHalfW;

            await JS.InvokeVoidAsync("passportPhoto.setCropBoxFromFaceDetection",
                faceTop, faceBottom, faceLeft, faceRight, eyeLineY);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Face detection on AI result failed");
        }

        // Clear compare state
        _aiCompareOriginalUrl = null;
        _aiCompareResultUrl = null;
        _aiResultBytes = null;
        _aiResultLocalPath = null;

        // Render the sheet
        await ClientSideRender();
    }

    private void RejectAiResult()
    {
        _showAiCompare = false;
        _aiCompareOriginalUrl = null;
        _aiCompareResultUrl = null;
        _aiResultBytes = null;
        _aiResultLocalPath = null;
    }

