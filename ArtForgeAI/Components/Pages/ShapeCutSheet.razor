    // ── Start New ──

    private async Task StartNew()
    {
        foreach (var d in _designs.ToList())
        {
            if (!string.IsNullOrEmpty(d.UploadedPath))
                try { await ImageStorage.DeleteImageAsync(d.UploadedPath); } catch { }
        }
        _designs.Clear();
        _sheetReady = false;
        _errorMessage = null;
        _layoutInfoText = "";
        try { await JS.InvokeVoidAsync("shapeCut.dispose"); } catch { }
        StateHasChanged();
    }

    // ── Remove design ──

    private async Task RemoveDesign(DesignItem design)
    {
        if (!string.IsNullOrEmpty(design.UploadedPath))
            await ImageStorage.DeleteImageAsync(design.UploadedPath);

        _designs.Remove(design);

        if (_designs.Count == 0)
        {
            _sheetReady = false;
            try { await JS.InvokeVoidAsync("shapeCut.dispose"); } catch { }
        }
        else
        {
            UpdateLayoutInfo();
            await RenderSheet();
        }
    }

