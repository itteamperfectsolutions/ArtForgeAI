    // ── Download helpers ──

    private Task DownloadPng() => DownloadAs("png");
    private Task DownloadJpg() => DownloadAs("jpg");

    private async Task DownloadAs(string format)
    {
        if (_result?.LocalImagePath is null) return;
        try
        {
            var webPath = await ImageStorage.PrepareHighResDownloadAsync(_result.LocalImagePath, format, dpi: _selectedDpi);
            var fileName = $"artforge_remix_{_result.GenerationId}_{_selectedDpi}dpi.{format}";
            await JS.InvokeVoidAsync("downloadFile", $"/{webPath}", fileName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Style Remix download failed");
            _errorMessage = "Download failed. Please try again.";
        }
    }

    private async Task DownloadTransparent()
    {
        if (_transparentImageBytes is null) return;
        try
        {
            var dpiBytes = await ImageStorage.EmbedDpiAsync(_transparentImageBytes, _selectedDpi);
            var base64 = Convert.ToBase64String(dpiBytes);
            var fileName = $"artforge_remix_{_result?.GenerationId ?? 0}_transparent_{_selectedDpi}dpi.png";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "image/png", base64);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Style Remix transparent download failed");
            _errorMessage = "Download failed. Please try again.";
        }
    }

    // ── Enhancement ──

    private async Task EnhanceImage()
    {
        if (_result?.LocalImagePath is null || _isEnhancing) return;

        _isEnhancing = true;
        _enhanceProgress = 0;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var progress = new Progress<int>(pct =>
            {
                _enhanceProgress = pct;
                InvokeAsync(StateHasChanged);
            });

            var enhancedPath = await ImageEnhancer.EnhanceImageAsync(_result.LocalImagePath, progress);
            _result.LocalImagePath = enhancedPath;
            _imgVersion++;

            if (_toast is not null)
                _ = _toast.ShowAsync("Image enhanced (4x upscale)!");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Style Remix enhancement failed");
            _errorMessage = "Enhancement failed. Please try again.";
        }
        finally
        {
            _isEnhancing = false;
            StateHasChanged();
        }
    }

