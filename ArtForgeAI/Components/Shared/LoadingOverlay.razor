@if (IsVisible)
{
    <div class="loading-overlay">
        <div class="loading-content">
            <div class="loading-spinner"></div>
            <h3 style="margin-bottom: 1.5rem; font-size: 1.1rem;">Generating your image...</h3>
            <div class="loading-steps">
                @foreach (var step in GetSteps())
                {
                    var css = step.Order < CurrentStep ? "completed"
                            : step.Order == CurrentStep ? "active"
                            : "";
                    <div class="loading-step @css">
                        <span class="step-icon">
                            @if (step.Order < CurrentStep)
                            {
                                <text>&#10003;</text>
                            }
                            else if (step.Order == CurrentStep)
                            {
                                <text>&#9679;</text>
                            }
                            else
                            {
                                <text>&#9675;</text>
                            }
                        </span>
                        <span>@step.Label</span>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public int CurrentStep { get; set; } = 1;
    [Parameter] public ImageProvider Provider { get; set; } = ImageProvider.OpenAI;
    [Parameter] public bool AutoRemoveBg { get; set; }
    [Parameter] public string[]? StepLabels { get; set; }

    private record StepInfo(int Order, string Label);

    private StepInfo[] GetSteps()
    {
        if (StepLabels is not null && StepLabels.Length > 0)
        {
            return StepLabels.Select((label, i) => new StepInfo(i + 1, label)).ToArray();
        }

        var steps = new List<StepInfo>
        {
            new(1, "Enhancing your prompt with AI..."),
            new(2, "Generating image with AI..."),
            new(3, "Saving & optimizing...")
        };

        if (AutoRemoveBg)
        {
            steps.Add(new(4, "Removing background..."));
        }

        return steps.ToArray();
    }
}
