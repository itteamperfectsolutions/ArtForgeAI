    /// <summary>
    /// Copies a generated/uploaded image to the presets/ folder and returns the new path.
    /// The original file is deleted after a successful copy.
    /// </summary>
    private async Task<string> MoveToPresetsFolder(string sourcePath)
    {
        var fullSource = Path.Combine(Env.WebRootPath, sourcePath.Replace("/", Path.DirectorySeparatorChar.ToString()));
        if (!File.Exists(fullSource)) return sourcePath; // fallback: keep original path

        var imageBytes = await File.ReadAllBytesAsync(fullSource);
        var fileName = Path.GetFileName(fullSource);
        var presetPath = await ImageStorage.SavePresetThumbnailAsync(BinaryData.FromBytes(imageBytes), fileName);

        // Delete original from generated/uploads
        try { File.Delete(fullSource); } catch { /* best effort */ }

        return presetPath;
    }
