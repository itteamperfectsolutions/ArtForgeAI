    private string ResolveFullPath(string webRelativePath) =>
        System.IO.Path.Combine(Env.WebRootPath, webRelativePath.Replace("/", System.IO.Path.DirectorySeparatorChar.ToString()));

    private static byte[] ResizeForProcessing(byte[] imageBytes, int maxDimension)
    {
        using var img = Image.Load<Rgba32>(imageBytes);
        if (img.Width <= maxDimension && img.Height <= maxDimension)
            return imageBytes;

        var scale = (double)maxDimension / Math.Max(img.Width, img.Height);
        int newW = (int)(img.Width * scale);
        int newH = (int)(img.Height * scale);
        img.Mutate(ctx => ctx.Resize(newW, newH));

        using var ms = new MemoryStream();
        img.SaveAsPng(ms);
        return ms.ToArray();
    }

    private static byte[] EnsurePng(byte[] imageBytes)
    {
        using var img = Image.Load<Rgba32>(imageBytes);
        using var ms = new MemoryStream();
        img.SaveAsPng(ms);
        return ms.ToArray();
    }

    /// <summary>
    /// Add transparent padding around an image so the cut outline has room to expand fully.
    /// </summary>
    private static byte[] AddOutlinePadding(byte[] pngBytes, int padPx)
    {
        if (padPx <= 0) return pngBytes;

        using var src = Image.Load<Rgba32>(pngBytes);
        int newW = src.Width + 2 * padPx;
        int newH = src.Height + 2 * padPx;

        using var result = new Image<Rgba32>(newW, newH);
        result.Mutate(ctx => ctx.DrawImage(src, new SixLabors.ImageSharp.Point(padPx, padPx), 1f));

        using var ms = new MemoryStream();
        result.SaveAsPng(ms);
        return ms.ToArray();
    }

    private static byte[] StripWhitePixels(byte[] pngBytes, int tolerance)
    {
        using var img = Image.Load<Rgba32>(pngBytes);
        byte threshold = (byte)(255 - Math.Clamp(tolerance, 0, 254));

        img.ProcessPixelRows(accessor =>
        {
            for (int y = 0; y < accessor.Height; y++)
            {
                var row = accessor.GetRowSpan(y);
                for (int x = 0; x < row.Length; x++)
                {
                    ref var pixel = ref row[x];
                    if (pixel.A == 0) continue;
                    if (pixel.R >= threshold && pixel.G >= threshold && pixel.B >= threshold)
                    {
                        pixel.A = 0;
                    }
                }
            }
        });

        using var ms = new MemoryStream();
        img.SaveAsPng(ms);
        return ms.ToArray();
    }

    private static byte[] DilateAlphaMask(byte[] transparentPng, byte[] originalBytes, int radiusPx)
    {
        using var transImg = Image.Load<Rgba32>(transparentPng);
        using var origImg = Image.Load<Rgba32>(originalBytes);
        int w = transImg.Width, h = transImg.Height;

        if (origImg.Width != w || origImg.Height != h)
            origImg.Mutate(ctx => ctx.Resize(w, h));

        var hasAlpha = new bool[w * h];
        for (int y = 0; y < h; y++)
            for (int x = 0; x < w; x++)
                hasAlpha[y * w + x] = transImg[x, y].A > 0;

        var dilatedH = new bool[w * h];
        for (int y = 0; y < h; y++)
        {
            for (int x = 0; x < w; x++)
            {
                int xStart = Math.Max(0, x - radiusPx);
                int xEnd = Math.Min(w - 1, x + radiusPx);
                for (int nx = xStart; nx <= xEnd; nx++)
                {
                    if (hasAlpha[y * w + nx]) { dilatedH[y * w + x] = true; break; }
                }
            }
        }

        var dilated = new bool[w * h];
        for (int y = 0; y < h; y++)
        {
            for (int x = 0; x < w; x++)
            {
                int yStart = Math.Max(0, y - radiusPx);
                int yEnd = Math.Min(h - 1, y + radiusPx);
                for (int ny = yStart; ny <= yEnd; ny++)
                {
                    if (dilatedH[ny * w + x]) { dilated[y * w + x] = true; break; }
                }
            }
        }

        for (int y = 0; y < h; y++)
        {
            for (int x = 0; x < w; x++)
            {
                if (dilated[y * w + x] && transImg[x, y].A == 0)
                {
                    var orig = origImg[x, y];
                    transImg[x, y] = new Rgba32(orig.R, orig.G, orig.B, 255);
                }
            }
        }

        using var ms = new MemoryStream();
        transImg.SaveAsPng(ms);
        return ms.ToArray();
    }

    /// <summary>
    /// Trim all fully-transparent rows/columns from edges of a PNG,
    /// so the image tightly wraps the visible content with no empty space.
    /// </summary>
    private static byte[] TrimTransparentPadding(byte[] pngBytes)
    {
        using var img = Image.Load<Rgba32>(pngBytes);
        int w = img.Width, h = img.Height;

        int top = h, bottom = 0, left = w, right = 0;

        img.ProcessPixelRows(accessor =>
        {
            for (int y = 0; y < accessor.Height; y++)
            {
                var row = accessor.GetRowSpan(y);
                for (int x = 0; x < row.Length; x++)
                {
                    if (row[x].A > 10) // threshold to ignore near-invisible pixels
                    {
                        if (y < top) top = y;
                        if (y > bottom) bottom = y;
                        if (x < left) left = x;
                        if (x > right) right = x;
                    }
                }
            }
        });

        if (top > bottom || left > right)
            return pngBytes; // no visible content, return as-is

        int cropW = right - left + 1;
        int cropH = bottom - top + 1;

        img.Mutate(ctx => ctx.Crop(new SixLabors.ImageSharp.Rectangle(left, top, cropW, cropH)));

        using var ms = new MemoryStream();
        img.SaveAsPng(ms);
        return ms.ToArray();
    }
