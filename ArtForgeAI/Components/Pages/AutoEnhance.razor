@page "/auto-enhance"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IImageStorageService ImageStorage
@inject IImageEnhancerService ImageEnhancer
@inject TiledGeminiEnhanceService TiledEnhancer
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject ILogger<AutoEnhance> Logger
@inject ISubscriptionService SubscriptionService
@inject ICoinService CoinService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>ArtForge AI - Auto Enhance</PageTitle>

<div class="page-header page-header-lg">
    <h2>Auto Enhance</h2>
    <p>AI-powered enhancement &mdash; sharpen, restore clarity, and upscale your photos</p>
</div>

<div class="create-layout">
    @* ── Left column ── *@
    <div class="create-left">
        <div class="card">
            <div class="card-body">

                @* Upload area *@
                <div class="mb-3">
                    <label class="form-label">Upload Photo</label>
                    @if (!string.IsNullOrEmpty(_uploadedPath))
                    {
                        <div style="position: relative;">
                            <button class="ref-thumb-remove" @onclick="RemovePhoto" disabled="@_isProcessing"
                                    style="position:absolute;top:4px;right:4px;z-index:20;">&#10005;</button>
                            <div id="autoCropContainer" style="min-height:80px;"></div>
                        </div>
                        @if (_sourceWidth > 0)
                        {
                            <p style="font-size: 0.72rem; color: var(--text-muted); margin: 0.35rem 0 0 0;">
                                Source: @(_sourceWidth)x@(_sourceHeight) px
                            </p>
                        }
                        <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
                            <button class="btn-secondary" style="font-size:0.8rem;padding:0.35rem 0.75rem;"
                                    @onclick="ResetCrop" disabled="@_isProcessing">
                                &#8634; Reset Crop
                            </button>
                        </div>
                    }
                    else
                    {
                        <label class="upload-area upload-area-compact @(_isUploading ? "disabled" : "")">
                            <span class="upload-icon">&#128248;</span>
                            <span>Upload a photo to enhance</span>
                            <span style="font-size: 0.7rem; color: var(--text-muted); margin-left: 0.5rem;">JPG, PNG up to 10MB</span>
                            <InputFile OnChange="HandleFileUpload" accept="image/*;capture=camera" style="display:none" disabled="@(_isProcessing || _isUploading)" />
                        </label>
                    }
                    @if (_isUploading)
                    {
                        <div class="upload-progress-bar" style="margin-top: 0.35rem;">
                            <div class="upload-progress-fill" style="width: 50%"></div>
                            <span class="upload-progress-text">Uploading...</span>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_uploadedPath))
                {
                    <hr style="margin: 0.5rem 0; border-color: var(--border-color);" />

                    @* ── Face Cleanup (Local) ── *@
                    <div class="face-cleanup-section" style="margin-top:0.5rem;">
                        <div style="display:flex;align-items:center;justify-content:space-between;">
                            <label class="form-label" style="margin-bottom:0;">Clear Face Marks</label>
                            <span style="font-size:0.65rem;color:var(--text-muted);background:var(--bg-tertiary);padding:0.15rem 0.4rem;border-radius:4px;">LOCAL</span>
                        </div>
                        <p style="font-size:0.68rem;color:var(--text-muted);margin:0.2rem 0 0.4rem;">
                            Remove blemishes, acne &amp; smooth skin locally on your device. No upload needed.
                        </p>

                        @* Quick actions *@
                        <div style="display:flex;flex-direction:column;gap:0.35rem;">
                            <div style="display:flex;gap:0.35rem;">
                                <button class="btn-secondary face-cleanup-btn" style="flex:1;font-size:0.78rem;padding:0.35rem 0.5rem;"
                                        @onclick='() => RunFaceCleanup("smooth", "light")' disabled="@(_isProcessing || _isCleaning)">
                                    &#128172; Light Smooth
                                </button>
                                <button class="btn-secondary face-cleanup-btn" style="flex:1;font-size:0.78rem;padding:0.35rem 0.5rem;"
                                        @onclick='() => RunFaceCleanup("smooth", "medium")' disabled="@(_isProcessing || _isCleaning)">
                                    &#128172; Medium Smooth
                                </button>
                                <button class="btn-secondary face-cleanup-btn" style="flex:1;font-size:0.78rem;padding:0.35rem 0.5rem;"
                                        @onclick='() => RunFaceCleanup("smooth", "heavy")' disabled="@(_isProcessing || _isCleaning)">
                                    &#128172; Heavy Smooth
                                </button>
                            </div>

                            <div style="display:flex;gap:0.35rem;">
                                <button class="btn-secondary face-cleanup-btn" style="flex:1;font-size:0.78rem;padding:0.35rem 0.5rem;"
                                        @onclick='() => RunFaceCleanup("blemish", "gentle")' disabled="@(_isProcessing || _isCleaning)">
                                    &#10022; Gentle Spot Fix
                                </button>
                                <button class="btn-secondary face-cleanup-btn" style="flex:1;font-size:0.78rem;padding:0.35rem 0.5rem;"
                                        @onclick='() => RunFaceCleanup("blemish", "moderate")' disabled="@(_isProcessing || _isCleaning)">
                                    &#10022; Moderate Fix
                                </button>
                                <button class="btn-secondary face-cleanup-btn" style="flex:1;font-size:0.78rem;padding:0.35rem 0.5rem;"
                                        @onclick='() => RunFaceCleanup("blemish", "aggressive")' disabled="@(_isProcessing || _isCleaning)">
                                    &#10022; Deep Fix
                                </button>
                            </div>

                            <button class="btn-primary-gradient face-cleanup-btn" style="width:100%;font-size:0.82rem;padding:0.4rem 0.5rem;"
                                    @onclick='() => RunFaceCleanup("clearAll", _cleanupLevel)' disabled="@(_isProcessing || _isCleaning)">
                                &#10024; Clear All Face Marks (@_cleanupLevel)
                            </button>

                            <div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.15rem;">
                                <label style="font-size:0.72rem;color:var(--text-muted);white-space:nowrap;">Cleanup Level:</label>
                                <select class="form-select" style="font-size:0.75rem;padding:0.2rem 0.4rem;" @bind="_cleanupLevel">
                                    <option value="light">Light</option>
                                    <option value="medium">Medium</option>
                                    <option value="heavy">Heavy</option>
                                </select>
                            </div>

                            @if (_cleanupApplied)
                            {
                                <div style="display:flex;gap:0.35rem;margin-top:0.15rem;">
                                    <button class="btn-secondary" style="flex:1;font-size:0.75rem;padding:0.3rem 0.5rem;"
                                            @onclick="UndoCleanup" disabled="@(_isProcessing || _isCleaning)">
                                        &#8634; Undo Cleanup
                                    </button>
                                    <button class="btn-secondary" style="flex:1;font-size:0.75rem;padding:0.3rem 0.5rem;"
                                            @onclick="ApplyCleanup" disabled="@(_isProcessing || _isCleaning)">
                                        &#10003; Apply &amp; Keep
                                    </button>
                                </div>
                            }
                        </div>

                        @if (_isCleaning)
                        {
                            <div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.35rem;">
                                <div class="processing-spinner" style="width:16px;height:16px;"></div>
                                <span style="font-size:0.75rem;color:var(--text-muted);">Processing locally...</span>
                            </div>
                        }
                    </div>

                    <hr style="margin: 0.5rem 0; border-color: var(--border-color);" />

                    @* ── AI Actions ── *@
                    <div style="display:flex;flex-direction:column;gap:0.4rem;margin-top:0.5rem;">
                        <button class="btn-primary-gradient" style="width:100%;"
                                @onclick="EnhanceImage" disabled="@_isProcessing">
                            &#10024; Auto Enhance
                        </button>
                        <p style="font-size:0.68rem;color:var(--text-muted);margin:0;">
                            AI enhances your entire image at once, preserving layout and faces. Just better quality.
                        </p>

                        <button class="btn-smartclean" style="width:100%;margin-top:0.25rem;"
                                @onclick="SmartCleanImage" disabled="@_isProcessing">
                            &#9889; Enhance &mdash; SmartClean
                        </button>
                        <p style="font-size:0.68rem;color:var(--text-muted);margin:0;">
                            AI removes acne, blemishes, dark spots &amp; smooths skin while preserving natural face features.
                        </p>
                    </div>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="card" style="margin-top: 0.75rem; border-left: 3px solid var(--danger);">
                <div class="card-body" style="padding: 0.75rem 1rem; color: var(--danger); font-size: 0.85rem;">
                    <strong>Error:</strong> @_errorMessage
                </div>
            </div>
        }
    </div>

    @* ── Right column: result ── *@
    <div class="create-right" style="overflow-y:auto;">
        @if (_resultReady)
        {
            <div class="right-panel-card" style="overflow:visible;">
                <div class="right-panel-label">Enhanced Result</div>

                @* Before / After comparison slider *@
                <div id="compareSliderContainer" style="max-height:500px;"></div>

                <p style="font-size:0.7rem;color:var(--text-muted);margin-top:0.4rem;text-align:center;">
                    Drag the slider to compare &mdash; @(_sourceWidth)x@(_sourceHeight) px
                </p>

                @* DPI selector *@
                <div style="display:flex;align-items:center;gap:0.4rem;margin-top:0.75rem;justify-content:center;">
                    <label style="font-size:0.78rem;color:var(--text-muted);">Print DPI:</label>
                    <select class="form-select" style="width:auto;font-size:0.8rem;padding:0.25rem 0.5rem;" @bind="_selectedDpi">
                        <option value="300">300 DPI</option>
                        <option value="600">600 DPI</option>
                        <option value="1200">1200 DPI</option>
                    </select>
                </div>

                @* Download buttons *@
                <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.5rem;justify-content:center;">
                    <button class="btn-primary-gradient" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;"
                            @onclick='() => DownloadEnhanced("png")' disabled="@_isDownloading">
                        &#128424; PNG
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;"
                            @onclick='() => DownloadEnhanced("jpg")' disabled="@_isDownloading">
                        JPG
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;"
                            @onclick='() => DownloadUpscaled(2)' disabled="@_isDownloading">
                        &#128200; 2x
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;"
                            @onclick='() => DownloadUpscaled(4)' disabled="@_isDownloading">
                        &#128200; 4x
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;"
                            @onclick='() => DownloadUpscaled(8)' disabled="@_isDownloading">
                        &#128200; 8x
                    </button>
                    <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.85rem;"
                            @onclick="StartNew">
                        &#10024; Process Another
                    </button>
                </div>

                @if (_isDownloading)
                {
                    <div class="upload-progress-bar" style="margin-top: 0.5rem;">
                        <div class="upload-progress-fill" style="width: @(_downloadProgress)%"></div>
                        <span class="upload-progress-text">@_downloadStatus @(_downloadProgress)%</span>
                    </div>
                }

                <div class="ai-disclaimer">
                    AI-enhanced &mdash; layout and content preserved, quality improved.
                </div>
            </div>
        }
    </div>
</div>

@* ── Processing overlay ── *@
@if (_isProcessing)
{
    <div class="pp-processing-overlay">
        <div class="pp-processing-modal">
            <div class="processing-spinner" style="width:36px;height:36px;margin:0 auto 1rem;"></div>
            <p style="margin:0;font-size:0.95rem;color:var(--text-primary);">@_processingStatus</p>
        </div>
    </div>
}

@code {
    // ── State ──
    private string? _uploadedPath;
    private string? _uploadedDataUrl;
    private bool _isUploading;
    private bool _isProcessing;
    private string _processingStatus = "";
    private string? _errorMessage;
    private int _sourceWidth;
    private int _sourceHeight;

    // Face cleanup
    private bool _isCleaning;
    private bool _cleanupApplied;
    private string _cleanupLevel = "medium";

    // Crop & compare slider
    private bool _pendingCropInit;
    private bool _pendingCompareInit;
    private string? _originalDataUrl;
    private string? _originalPath;
    private int _originalWidth;
    private int _originalHeight;

    // Result
    private bool _resultReady;
    private string? _enhancedImagePath;
    private string? _enhancedDataUrl;
    private int _enhancedWidth;
    private int _enhancedHeight;

    // Download
    private bool _isDownloading;
    private int _downloadProgress;
    private string _downloadStatus = "";
    private int _selectedDpi = 300;

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("SuperAdmin"))
        {
            var userIdStr = authState.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (int.TryParse(userIdStr, out var uid))
            {
                if (!await SubscriptionService.HasFeatureAccessAsync(uid, ArtForgeAI.Models.FeatureAccess.AutoEnhance))
                {
                    Nav.NavigateTo("/pricing", forceLoad: true);
                    return;
                }
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingCropInit)
        {
            _pendingCropInit = false;
            await JS.InvokeVoidAsync("autoCrop.init", "autoCropContainer", _uploadedDataUrl);
        }
        if (_pendingCompareInit)
        {
            _pendingCompareInit = false;
            await JS.InvokeVoidAsync("compareSlider.init", "compareSliderContainer", _originalDataUrl ?? _uploadedDataUrl, _enhancedDataUrl);
        }
    }

    // ── Crop ──

    private async Task ResetCrop()
    {
        if (_originalDataUrl is not null)
        {
            _uploadedDataUrl = _originalDataUrl;
            _uploadedPath = _originalPath;
            _sourceWidth = _originalWidth;
            _sourceHeight = _originalHeight;
            _pendingCropInit = true;
            StateHasChanged();
        }
        else
        {
            await JS.InvokeVoidAsync("autoCrop.resetCrop");
        }
    }

    private record CropResult(string DataUrl, int Width, int Height);

    // ── Upload ──

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        // Auto-compress oversized images
        if (file.Size > ImageUploadHelper.DefaultMaxUploadSize)
        {
            if (file.Size > ImageUploadHelper.MaxReadSize)
            {
                _errorMessage = $"File is too large ({ImageUploadHelper.FormatFileSize(file.Size)}). Maximum allowed is {ImageUploadHelper.FormatFileSize(ImageUploadHelper.MaxReadSize)}.";
                StateHasChanged();
                return;
            }
            try
            {
                using var readMs = new MemoryStream();
                await file.OpenReadStream(ImageUploadHelper.MaxReadSize).CopyToAsync(readMs);
                var compressed = ImageUploadHelper.CompressToFit(readMs.ToArray(), file.Name);
                await ProcessUpload(e, compressed);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Image compression failed");
                _errorMessage = "Failed to compress the image. Please try a smaller file.";
                StateHasChanged();
            }
            return;
        }

        await ProcessUpload(e);
    }

    private async Task ProcessUpload(InputFileChangeEventArgs e, MemoryStream? compressedStream = null)
    {
        _isUploading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var file = e.File;
            if (compressedStream is not null)
            {
                _uploadedPath = await ImageStorage.SaveUploadedFileAsync(compressedStream, file.Name);
            }
            else
            {
                using var stream = file.OpenReadStream(ImageUploadHelper.MaxReadSize);
                _uploadedPath = await ImageStorage.SaveUploadedFileAsync(stream, file.Name);
            }
            _resultReady = false;
            _enhancedImagePath = null;
            _enhancedDataUrl = null;

            // Read dimensions and build data URL
            var fullPath = ResolveFullPath(_uploadedPath);
            var imageBytes = await File.ReadAllBytesAsync(fullPath);
            using var img = SixLabors.ImageSharp.Image.Load(imageBytes);
            _sourceWidth = img.Width;
            _sourceHeight = img.Height;

            var ext = _uploadedPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ? "png" : "jpeg";
            _uploadedDataUrl = $"data:image/{ext};base64," + Convert.ToBase64String(imageBytes);

            // Save originals for crop reset and auto-init the crop tool
            _originalDataUrl = _uploadedDataUrl;
            _originalPath = _uploadedPath;
            _originalWidth = _sourceWidth;
            _originalHeight = _sourceHeight;
            _pendingCropInit = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Upload failed");
            _errorMessage = "Upload failed. Please try again.";
            return;
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
        }
    }

    // ── Face Cleanup (local, client-side) ──

    private async Task RunFaceCleanup(string mode, string level)
    {
        if (string.IsNullOrEmpty(_uploadedDataUrl)) return;

        _isCleaning = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            // Load image into the cleanup module
            await JS.InvokeVoidAsync("faceCleanup.loadImage", _uploadedDataUrl);

            // Run the selected cleanup
            string? resultDataUrl = mode switch
            {
                "smooth"   => await JS.InvokeAsync<string>("faceCleanup.applySkinSmoothing", level),
                "blemish"  => await JS.InvokeAsync<string>("faceCleanup.removeBlemishes", level),
                "clearAll" => await JS.InvokeAsync<string>("faceCleanup.clearAllMarks", level),
                _          => null
            };

            if (!string.IsNullOrEmpty(resultDataUrl))
            {
                _uploadedDataUrl = resultDataUrl;
                _cleanupApplied = true;
                _pendingCropInit = true;
            }
            else
            {
                _errorMessage = "Face cleanup returned no result. Try a different setting.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Face cleanup failed");
            _errorMessage = "Face cleanup failed: " + ex.Message;
        }
        finally
        {
            _isCleaning = false;
            StateHasChanged();
        }
    }

    private async Task UndoCleanup()
    {
        if (_originalDataUrl is not null)
        {
            _uploadedDataUrl = _originalDataUrl;
            _uploadedPath = _originalPath;
            _sourceWidth = _originalWidth;
            _sourceHeight = _originalHeight;
            _cleanupApplied = false;
            _pendingCropInit = true;
            StateHasChanged();
        }
    }

    private async Task ApplyCleanup()
    {
        if (!_cleanupApplied || string.IsNullOrEmpty(_uploadedDataUrl)) return;

        try
        {
            // Save the cleaned-up image as the new source
            var base64 = _uploadedDataUrl[(_uploadedDataUrl.IndexOf(",") + 1)..];
            var bytes = Convert.FromBase64String(base64);
            using var ms = new MemoryStream(bytes);
            _uploadedPath = await ImageStorage.SaveUploadedFileAsync(ms, "cleaned.png");

            // Update originals so crop reset uses cleaned version
            _originalDataUrl = _uploadedDataUrl;
            _originalPath = _uploadedPath;
            _cleanupApplied = false;
            _pendingCropInit = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Apply cleanup failed");
            _errorMessage = "Failed to apply cleanup: " + ex.Message;
        }
        StateHasChanged();
    }

    // ── Gemini AI Enhancement (tiled to preserve layout) ──

    private async Task EnhanceImage()
    {
        if (string.IsNullOrEmpty(_uploadedPath)) return;

        // Auto-apply crop before processing
        try
        {
            var cropResult = await JS.InvokeAsync<CropResult>("autoCrop.applyCrop");
            if (cropResult is not null && !string.IsNullOrEmpty(cropResult.DataUrl))
            {
                _uploadedDataUrl = cropResult.DataUrl;
                _sourceWidth = cropResult.Width;
                _sourceHeight = cropResult.Height;

                var base64 = cropResult.DataUrl[(cropResult.DataUrl.IndexOf(",") + 1)..];
                var bytes = Convert.FromBase64String(base64);
                using var ms = new MemoryStream(bytes);
                _uploadedPath = await ImageStorage.SaveUploadedFileAsync(ms, "cropped.png");
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Auto-crop skipped");
        }

        // Debit coins
        var authStateC = await AuthState.GetAuthenticationStateAsync();
        var uidStrC = authStateC.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (int.TryParse(uidStrC, out var userIdC) && !authStateC.User.IsInRole("SuperAdmin"))
        {
            var cost = ArtForgeAI.Models.FeatureAccess.GetCost("AutoEnhance");
            if (!await CoinService.DebitCoinsAsync(userIdC, cost, ArtForgeAI.Models.CoinTransactionType.GenerationSpend, "Auto Enhance"))
            {
                _errorMessage = "Insufficient coins. Please top up to continue.";
                StateHasChanged();
                return;
            }
        }

        _isProcessing = true;
        _processingStatus = "Preparing enhancement...";
        _errorMessage = null;
        _resultReady = false;
        StateHasChanged();

        try
        {
            var fullPath = ResolveFullPath(_uploadedPath);
            var imageBytes = await File.ReadAllBytesAsync(fullPath);

            var progress = new Progress<(int current, int total, string status)>(p =>
            {
                _processingStatus = p.status;
                InvokeAsync(StateHasChanged);
            });

            // Tiled Gemini enhancement — each tile enhanced individually,
            // so the overall layout stays intact
            var enhancedBytes = await TiledEnhancer.EnhanceAsync(
                imageBytes, _sourceWidth, _sourceHeight, progress);

            var outputFileName = $"ae_{Guid.NewGuid():N}.png";
            _enhancedImagePath = await ImageStorage.SaveImageFromBytesAsync(
                BinaryData.FromBytes(enhancedBytes), outputFileName);

            _enhancedWidth = _sourceWidth;
            _enhancedHeight = _sourceHeight;
            _enhancedDataUrl = "data:image/png;base64," + Convert.ToBase64String(enhancedBytes);
            _resultReady = true;
            _pendingCompareInit = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Enhancement failed");
            _errorMessage = "Enhancement failed: " + ex.Message;
        }
        finally
        {
            _isProcessing = false;
            _processingStatus = "";
            StateHasChanged();
        }
    }

    // ── AI SmartClean (Gemini-powered face mark removal) ──

    private async Task SmartCleanImage()
    {
        if (string.IsNullOrEmpty(_uploadedPath)) return;

        // Auto-apply crop before processing
        try
        {
            var cropResult = await JS.InvokeAsync<CropResult>("autoCrop.applyCrop");
            if (cropResult is not null && !string.IsNullOrEmpty(cropResult.DataUrl))
            {
                _uploadedDataUrl = cropResult.DataUrl;
                _sourceWidth = cropResult.Width;
                _sourceHeight = cropResult.Height;

                var base64c = cropResult.DataUrl[(cropResult.DataUrl.IndexOf(",") + 1)..];
                var bytesC = Convert.FromBase64String(base64c);
                using var msC = new MemoryStream(bytesC);
                _uploadedPath = await ImageStorage.SaveUploadedFileAsync(msC, "cropped.png");
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Auto-crop skipped");
        }

        // Debit coins
        var authStateS = await AuthState.GetAuthenticationStateAsync();
        var uidStrS = authStateS.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (int.TryParse(uidStrS, out var userIdS) && !authStateS.User.IsInRole("SuperAdmin"))
        {
            var cost = ArtForgeAI.Models.FeatureAccess.GetCost("AutoEnhance");
            if (!await CoinService.DebitCoinsAsync(userIdS, cost, ArtForgeAI.Models.CoinTransactionType.GenerationSpend, "SmartClean"))
            {
                _errorMessage = "Insufficient coins. Please top up to continue.";
                StateHasChanged();
                return;
            }
        }

        _isProcessing = true;
        _processingStatus = "AI is analyzing your face...";
        _errorMessage = null;
        _resultReady = false;
        StateHasChanged();

        try
        {
            var fullPath = ResolveFullPath(_uploadedPath);
            var imageBytes = await File.ReadAllBytesAsync(fullPath);

            var progress = new Progress<(int current, int total, string status)>(p =>
            {
                _processingStatus = p.status;
                InvokeAsync(StateHasChanged);
            });

            var enhancedBytes = await TiledEnhancer.SmartCleanAsync(
                imageBytes, _sourceWidth, _sourceHeight, progress);

            var outputFileName = $"sc_{Guid.NewGuid():N}.png";
            _enhancedImagePath = await ImageStorage.SaveImageFromBytesAsync(
                BinaryData.FromBytes(enhancedBytes), outputFileName);

            _enhancedWidth = _sourceWidth;
            _enhancedHeight = _sourceHeight;
            _enhancedDataUrl = "data:image/png;base64," + Convert.ToBase64String(enhancedBytes);
            _resultReady = true;
            _pendingCompareInit = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "SmartClean failed");
            _errorMessage = "SmartClean failed: " + ex.Message;
        }
        finally
        {
            _isProcessing = false;
            _processingStatus = "";
            StateHasChanged();
        }
    }

    // ── Downloads ──

    private async Task DownloadEnhanced(string format)
    {
        if (string.IsNullOrEmpty(_enhancedImagePath)) return;
        try
        {
            var webPath = await ImageStorage.PrepareHighResDownloadAsync(
                _enhancedImagePath, format, _enhancedWidth, _enhancedHeight, _selectedDpi);
            await JS.InvokeVoidAsync("downloadFile", $"/{webPath}", $"auto_enhanced_{_selectedDpi}dpi.{format}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Download failed");
            _errorMessage = "Download failed: " + ex.Message;
            StateHasChanged();
        }
    }

    private async Task DownloadUpscaled(int multiplier)
    {
        if (string.IsNullOrEmpty(_enhancedImagePath)) return;

        _isDownloading = true;
        _downloadProgress = 10;
        _downloadStatus = $"Preparing {multiplier}x upscale...";
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var targetW = _enhancedWidth * multiplier;
            var targetH = _enhancedHeight * multiplier;

            // Cap max dimension at 16384 to avoid memory issues
            if (targetW > 16384 || targetH > 16384)
            {
                var scale = 16384.0 / Math.Max(targetW, targetH);
                targetW = (int)(targetW * scale);
                targetH = (int)(targetH * scale);
            }

            _downloadProgress = 30;
            _downloadStatus = $"Upscaling to {targetW}x{targetH}...";
            StateHasChanged();

            var webPath = await ImageStorage.PrepareHighResDownloadAsync(
                _enhancedImagePath, "png", targetW, targetH, _selectedDpi);

            _downloadProgress = 85;
            _downloadStatus = "Starting download...";
            StateHasChanged();

            await JS.InvokeVoidAsync("downloadFile", $"/{webPath}", $"auto_enhanced_{multiplier}x_{_selectedDpi}dpi.png");

            _downloadProgress = 100;
            _downloadStatus = "Done!";
            StateHasChanged();

            await Task.Delay(500);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "{Multiplier}x download failed", multiplier);
            _errorMessage = $"{multiplier}x download failed: " + ex.Message;
        }
        finally
        {
            _isDownloading = false;
            _downloadProgress = 0;
            _downloadStatus = "";
            StateHasChanged();
        }
    }

    // ── Start New ──

    private async Task StartNew()
    {
        await RemovePhoto();
        StateHasChanged();
    }

    // ── Remove photo ──

    private async Task RemovePhoto()
    {
        await JS.InvokeVoidAsync("compareSlider.dispose");
        await JS.InvokeVoidAsync("autoCrop.dispose");

        if (!string.IsNullOrEmpty(_uploadedPath))
            await ImageStorage.DeleteImageAsync(_uploadedPath);

        _uploadedPath = null;
        _uploadedDataUrl = null;
        _originalDataUrl = null;
        _originalPath = null;
        _originalWidth = 0;
        _originalHeight = 0;
        _resultReady = false;
        _errorMessage = null;
        _enhancedImagePath = null;
        _enhancedDataUrl = null;
        _sourceWidth = 0;
        _sourceHeight = 0;
        _enhancedWidth = 0;
        _enhancedHeight = 0;
    }

    // ── Helpers ──

    private string ResolveFullPath(string webRelativePath) =>
        System.IO.Path.Combine(Env.WebRootPath, webRelativePath.Replace("/", System.IO.Path.DirectorySeparatorChar.ToString()));
}
