<div class="mb-3">
    <label class="form-label">Image Size</label>
    <div class="size-selector">
        @foreach (var size in Enum.GetValues<ImageSize>())
        {
            var aspect = size switch
            {
                ImageSize.Square => "1/1",
                ImageSize.Landscape => "1792/1024",
                ImageSize.Portrait => "1024/1792",
                _ => "1/1"
            };
            <div class="size-option @(SelectedSize == size ? "selected" : "")"
                 @onclick="() => SelectSize(size)">
                <div class="size-preview" style="--aspect: @aspect"></div>
                <div class="size-label">@size</div>
                <div class="size-dims">@size.ToDallESize()</div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public ImageSize SelectedSize { get; set; } = ImageSize.Square;
    [Parameter] public EventCallback<ImageSize> SelectedSizeChanged { get; set; }
    [Parameter] public bool IsDisabled { get; set; }

    private async Task SelectSize(ImageSize size)
    {
        if (IsDisabled) return;
        SelectedSize = size;
        await SelectedSizeChanged.InvokeAsync(size);
    }
}
