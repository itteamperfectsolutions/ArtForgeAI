@page "/wallet"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ICoinService CoinService
@inject ISubscriptionService SubscriptionService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>ArtForge AI - Wallet</PageTitle>

<div class="page-header">
    <h2>My Wallet</h2>
    <p>Your coin balance and transaction history</p>
</div>

@if (_loading)
{
    <div style="text-align:center;padding:3rem;">
        <div class="loading-spinner"></div>
    </div>
}
else
{
    @* ── Balance Card ── *@
    <div class="wallet-balance-card">
        <div class="wallet-balance-label">Coin Balance</div>
        <div class="wallet-balance-amount">@_balance</div>
        <div class="wallet-plan-info">Plan: <strong>@_planName</strong></div>
        <button class="btn-primary-gradient" style="margin-top:0.75rem;" @onclick='() => Nav.NavigateTo("/pricing")'>
            Buy More Coins
        </button>
    </div>

    @* ── Transaction History ── *@
    <div class="card" style="margin-top:1.5rem;">
        <div class="card-body">
            <h3 style="margin-bottom:1rem;">Transaction History</h3>
            @if (_transactions.Count == 0)
            {
                <p style="color:var(--text-muted);text-align:center;padding:2rem;">No transactions yet.</p>
            }
            else
            {
                <div class="wallet-tx-list">
                    @foreach (var tx in _transactions)
                    {
                        <div class="wallet-tx-item">
                            <div class="wallet-tx-left">
                                <span class="wallet-tx-type @(tx.Amount >= 0 ? "tx-credit" : "tx-debit")">
                                    @(tx.Amount >= 0 ? "+" : "")@tx.Amount
                                </span>
                                <div>
                                    <div class="wallet-tx-desc">@tx.Description</div>
                                    <div class="wallet-tx-meta">@tx.Type &mdash; @tx.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                                </div>
                            </div>
                            <div class="wallet-tx-balance">Bal: @tx.BalanceAfter</div>
                        </div>
                    }
                </div>

                @* Pagination *@
                @if (_totalPages > 1)
                {
                    <div class="wallet-pagination">
                        <button class="btn-secondary btn-sm" disabled="@(_page <= 1)" @onclick="PrevPage">&laquo; Prev</button>
                        <span style="color:var(--text-muted);font-size:0.8rem;">Page @_page of @_totalPages</span>
                        <button class="btn-secondary btn-sm" disabled="@(_page >= _totalPages)" @onclick="NextPage">Next &raquo;</button>
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int _balance;
    private string _planName = "Free";
    private List<ArtForgeAI.Models.CoinTransaction> _transactions = new();
    private int _page = 1;
    private int _totalPages = 1;
    private const int PageSize = 20;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var userId = await GetUserIdAsync();
            if (userId > 0)
            {
                _balance = await CoinService.GetBalanceAsync(userId);
                _planName = await SubscriptionService.GetCurrentPlanNameAsync(userId);
                var totalCount = await CoinService.GetTransactionCountAsync(userId);
                _totalPages = Math.Max(1, (int)Math.Ceiling((double)totalCount / PageSize));
                _transactions = await CoinService.GetTransactionHistoryAsync(userId, _page, PageSize);
            }
        }
        catch { }
        finally { _loading = false; StateHasChanged(); }
    }

    private async Task PrevPage()
    {
        if (_page > 1) { _page--; await LoadDataAsync(); }
    }

    private async Task NextPage()
    {
        if (_page < _totalPages) { _page++; await LoadDataAsync(); }
    }

    private async Task<int> GetUserIdAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var idStr = authState.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
        return int.TryParse(idStr, out var id) ? id : 0;
    }
}
