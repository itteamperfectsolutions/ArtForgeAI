                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="admin-style-desc">@preset.Description</div>
                                            <div class="admin-style-actions">
                                                <label class="btn-primary-gradient btn-sm admin-upload-label" title="Upload a test image to preview this style"
                                                       style="@(_testingStyleId is not null ? "opacity:0.5;pointer-events:none;" : "")">
                                                    &#10024; Test Style
                                                    <InputFile OnChange="(e) => TestStyle(e, preset)" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none" />
                                                </label>
                                                <button class="btn-secondary btn-sm" @onclick="() => GenerateThumbnail(preset)"
                                                        disabled="@(_generatingThumbnailId is not null)"
                                                        title="Auto-generate thumbnail">
                                                    &#127912; Generate
