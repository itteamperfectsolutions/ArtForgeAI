        public double BgBrightness { get; set; } = 0;
        public string BgTintColor { get; set; } = "";
        public double BgTintOpacity { get; set; } = 0;
        public double ForegroundScale { get; set; } = 0.45;
        public int BorderWidth { get; set; } = 12;
