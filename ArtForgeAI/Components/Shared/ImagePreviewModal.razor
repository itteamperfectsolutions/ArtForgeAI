@inject IJSRuntime JS
@inject IImageStorageService ImageStorage
@inject IImageEnhancerService ImageEnhancer
@inject IColorEnhancementService ColorEnhancer
@inject ILogger<ImagePreviewModal> Logger

@if (Generation is not null)
{
    <div class="preview-modal" @onclick="Close">
        <div class="preview-content" @onclick:stopPropagation="true">
            <div class="preview-image-wrap">
                <button class="preview-close" @onclick="Close">&#10005;</button>
                <img class="preview-image @(_zoomed ? "zoomed" : "")"
                     src="@($"{ImageStorage.GetWebPath(Generation.LocalImagePath ?? "")}?v={_imgVersion}")"
                     alt="Preview"
                     @onclick="ToggleZoom" />
            </div>
            <div class="preview-details">
                <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.5rem;">
                    <span style="font-size: 0.8rem; color: var(--text-muted);">
                        @Generation.ImageSize &middot; @Generation.CreatedAt.ToString("MMMM d, yyyy h:mm tt")
                    </span>
                    <button class="preview-prompt-toggle" @onclick="() => _showPrompt = !_showPrompt">
                        @(_showPrompt ? "Hide Prompt" : "Show Prompt")
                    </button>
                </div>
                @if (_showPrompt)
                {
                    <div class="preview-prompt-panel">
                        @if (!string.IsNullOrEmpty(Generation.EnhancedPrompt))
                        {
                            <div class="prompt-text" style="margin-bottom:0.5rem;">
                                <strong>Enhanced prompt:</strong> @StripModelPrefix(Generation.EnhancedPrompt)
                            </div>
                        }
                        <div class="prompt-text" style="margin-bottom:0;">
                            <strong>Original:</strong> @Generation.OriginalPrompt
                        </div>
                    </div>
                }
                <div class="preview-actions">
                    <button class="btn-secondary" @onclick="DownloadPng">
                        &#11015; PNG
                    </button>
                    <button class="btn-secondary" @onclick="DownloadJpg">
                        &#11015; JPG
                    </button>
                    @if (ImageEnhancer.IsAvailable)
                    {
                        <button class="btn-enhance" @onclick="EnhanceImage" disabled="@_isEnhancing">
                            @if (_isEnhancing)
                            {
                                <span>Enhancing...</span>
                            }
                            else
                            {
                                <span>&#9889; Enhance 4x</span>
                            }
                        </button>
                    }
                    @*@if (ColorEnhancer.IsAvailable)
                    {
                        <button class="btn-color-enhance" @onclick="ColorEnhanceImage" disabled="@_isColorEnhancing">
                            @if (_isColorEnhancing)
                            {
                                <span>Enhancing...</span>
                            }
                            else
                            {
                                <span>&#127912; Enhance Colors</span>
                            }
                        </button>
                    }*@
                    <button class="btn-danger" @onclick="RequestDelete">
                        &#128465; Delete
                    </button>
                </div>
                @if (_isEnhancing)
                {
                    <div class="enhance-progress-bar">
                        <div class="enhance-progress-fill" style="width: @(_enhanceProgress)%"></div>
                        <span class="enhance-progress-text">@(_enhanceProgress)%</span>
                    </div>
                }
                <div class="ai-disclaimer">
                    AI-generated image — minor variations in facial features, colours, and details may occur.
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public ImageGeneration? Generation { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }

    private bool _zoomed;
    private bool _showPrompt;
    private bool _isEnhancing;
    private int _enhanceProgress;
    private bool _isColorEnhancing;
    private long _imgVersion;

    private void ToggleZoom() => _zoomed = !_zoomed;

    private static string StripModelPrefix(string text)
    {
        // Remove [model-name] prefix from old saved data
        if (text.StartsWith('[') && text.IndexOf(']') is int idx and > 0)
            return text[(idx + 1)..].TrimStart();
        return text;
    }

    private Task DownloadPng() => DownloadAs("png");
    private Task DownloadJpg() => DownloadAs("jpg");

    private async Task Close()
    {
        _zoomed = false;
        _showPrompt = false;
        _isEnhancing = false;
        _isColorEnhancing = false;
        await OnClose.InvokeAsync();
    }

    private async Task DownloadAs(string format)
    {
        if (Generation?.LocalImagePath is null) return;

        try
        {
            var webPath = await ImageStorage.PrepareHighResDownloadAsync(Generation.LocalImagePath, format);
            var fileName = $"artforge_{Generation.Id}.{format}";
            await JS.InvokeVoidAsync("downloadFile", $"/{webPath}", fileName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Image download failed");
        }
    }

    private async Task EnhanceImage()
    {
        if (Generation?.LocalImagePath is null || _isEnhancing) return;

        _isEnhancing = true;
        _enhanceProgress = 0;
        StateHasChanged();

        try
        {
            var progress = new Progress<int>(pct =>
            {
                _enhanceProgress = pct;
                InvokeAsync(StateHasChanged);
            });

            // Enhancer accepts web-relative paths and returns web-relative paths
            var enhancedPath = await ImageEnhancer.EnhanceImageAsync(Generation.LocalImagePath, progress);
            Generation.LocalImagePath = enhancedPath;
            _imgVersion++;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Gallery image enhancement failed");
        }
        finally
        {
            _isEnhancing = false;
            StateHasChanged();
        }
    }

    private async Task ColorEnhanceImage()
    {
        if (Generation?.LocalImagePath is null || _isColorEnhancing) return;

        _isColorEnhancing = true;
        StateHasChanged();

        try
        {
            // ColorEnhancer accepts web-relative paths and returns web-relative paths
            var enhancedPath = await ColorEnhancer.EnhanceColorsAsync(Generation.LocalImagePath);
            Generation.LocalImagePath = enhancedPath;
            _imgVersion++;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Gallery image color enhancement failed");
        }
        finally
        {
            _isColorEnhancing = false;
            StateHasChanged();
        }
    }

    private async Task RequestDelete()
    {
        if (Generation is not null)
        {
            await OnDelete.InvokeAsync(Generation.Id);
            await Close();
        }
    }
}
