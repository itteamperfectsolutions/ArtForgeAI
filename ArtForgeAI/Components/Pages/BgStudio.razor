    private void SetResult(BackgroundRemovalResult result)
    {
        _resultTransparentPath = result.TransparentImagePath;
        _resultTransparentBytes = result.TransparentPngBytes;
        _resultColoredPath = result.ColoredImagePath;
        _displayPath = _bgType == "transparent" ? _resultTransparentPath : _resultColoredPath;
        _imgVersion++;

        using var resultImg = Image.Load(result.TransparentPngBytes);
        _resultWidth = resultImg.Width;
        _resultHeight = resultImg.Height;
    }

    // ── Re-apply background without re-processing ──
    private async Task ReapplyBackground()
    {
        if (_resultTransparentBytes is null) return;

        _errorMessage = null;

        try
        {
            if (_bgType == "transparent")
            {
                _displayPath = _resultTransparentPath;
            }
            else if (_bgType == "gradient")
            {
                await ApplyGradientBackground();
            }
            else
            {
                // Solid color
                var newPath = await BgService.RecolorBackgroundFromBytesAsync(_resultTransparentBytes, _selectedColor);
                _resultColoredPath = newPath;
                _displayPath = newPath;
            }
            _imgVersion++;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Re-apply background failed");
            _errorMessage = "Failed to re-apply background: " + ex.Message;
            StateHasChanged();
        }
    }

    private async Task ApplyGradientBackground()
    {
        if (_resultTransparentBytes is null) return;

        // Parse gradient colors from the selected gradient CSS
        var (c1, c2) = ParseGradientColors(_selectedGradient);
        var isRadial = _selectedGradient.Contains("radial");

        using var fg = Image.Load<Rgba32>(_resultTransparentBytes);
        int w = fg.Width, h = fg.Height;

        using var canvas = new Image<Rgba32>(w, h);

        // Draw gradient background pixel by pixel
        var color1 = Rgba32.ParseHex(c1);
        var color2 = Rgba32.ParseHex(c2);

        canvas.ProcessPixelRows(accessor =>
        {
            for (int y = 0; y < h; y++)
            {
                var row = accessor.GetRowSpan(y);
                for (int x = 0; x < w; x++)
                {
                    float t;
                    if (isRadial)
                    {
                        float cx = w / 2f, cy = h / 2f;
                        float maxDist = MathF.Sqrt(cx * cx + cy * cy);
                        float dist = MathF.Sqrt((x - cx) * (x - cx) + (y - cy) * (y - cy));
                        t = Math.Clamp(dist / maxDist, 0, 1);
                    }
                    else if (_selectedGradient.Contains("to right"))
                    {
                        t = (float)x / w;
                    }
                    else if (_selectedGradient.Contains("to bottom right"))
                    {
                        t = ((float)x / w + (float)y / h) / 2f;
                    }
                    else // to bottom (default)
                    {
                        t = (float)y / h;
                    }

                    row[x] = new Rgba32(
                        (byte)(color1.R + (color2.R - color1.R) * t),
                        (byte)(color1.G + (color2.G - color1.G) * t),
                        (byte)(color1.B + (color2.B - color1.B) * t),
                        255);
                }
            }
        });

        // Composite foreground over gradient
        canvas.ProcessPixelRows(fg, (bgAcc, fgAcc) =>
        {
            for (int y = 0; y < h; y++)
            {
                var bgRow = bgAcc.GetRowSpan(y);
                var fgRow = fgAcc.GetRowSpan(y);
                for (int x = 0; x < w; x++)
                {
                    var fgPx = fgRow[x];
                    if (fgPx.A == 0) continue;
                    float a = fgPx.A / 255f;
                    float ia = 1f - a;
                    bgRow[x] = new Rgba32(
                        (byte)(fgPx.R * a + bgRow[x].R * ia),
                        (byte)(fgPx.G * a + bgRow[x].G * ia),
                        (byte)(fgPx.B * a + bgRow[x].B * ia),
                        255);
                }
            }
        });

        using var ms = new MemoryStream();
        canvas.SaveAsPng(ms);
        var gradPath = await ImageStorage.SaveImageFromBytesAsync(
            BinaryData.FromBytes(ms.ToArray()), $"bg_grad_{Guid.NewGuid():N}.png");

        _resultColoredPath = gradPath;
        _displayPath = gradPath;
    }

    private static (string c1, string c2) ParseGradientColors(string css)
    {
        // Extract hex colors from gradient CSS
        var matches = System.Text.RegularExpressions.Regex.Matches(css, @"#[0-9a-fA-F]{6}");
        var c1 = matches.Count > 0 ? matches[0].Value : "#667eea";
        var c2 = matches.Count > 1 ? matches[1].Value : "#764ba2";
        return (c1, c2);
    }

    private async Task RotateStatus(string[] messages)
    {
        try
        {
            for (int i = 1; i < messages.Length && _isProcessing; i++)
            {
                await Task.Delay(3000);
                if (!_isProcessing) break;
                _processingStatus = messages[i];
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    // ── Downloads ──

    private async Task DownloadTransparent()
    {
        if (_resultTransparentBytes is null) return;
        _isDownloading = true; _downloadPct = 30; _downloadStatus = "Preparing..."; StateHasChanged();
        try
        {
            var dpiBytes = await ImageStorage.EmbedDpiAsync(_resultTransparentBytes, _selectedDpi);
            _downloadPct = 80; _downloadStatus = "Starting download..."; StateHasChanged();
            var base64 = Convert.ToBase64String(dpiBytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes",
                $"bg_removed_transparent_{_selectedDpi}dpi.png", "image/png", base64);
            _downloadPct = 100; _downloadStatus = "Done!"; StateHasChanged();
            await Task.Delay(400);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Download failed");
            _errorMessage = "Download failed.";
        }
        finally { _isDownloading = false; _downloadPct = 0; StateHasChanged(); }
    }

    private async Task DownloadWithBackground()
    {
        if (_resultColoredPath is null) return;
        _isDownloading = true; _downloadPct = 30; _downloadStatus = "Preparing..."; StateHasChanged();
        try
        {
            var fullPath = ResolvePath(_resultColoredPath);
            var rawBytes = await File.ReadAllBytesAsync(fullPath);
            var dpiBytes = await ImageStorage.EmbedDpiAsync(rawBytes, _selectedDpi);
            _downloadPct = 80; _downloadStatus = "Starting download..."; StateHasChanged();
            var base64 = Convert.ToBase64String(dpiBytes);
            var label = _bgType == "gradient" ? "gradient" : "colored";
            await JS.InvokeVoidAsync("downloadFileFromBytes",
                $"bg_{label}_{_selectedDpi}dpi.png", "image/png", base64);
            _downloadPct = 100; _downloadStatus = "Done!"; StateHasChanged();
            await Task.Delay(400);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Download failed");
            _errorMessage = "Download failed.";
        }
        finally { _isDownloading = false; _downloadPct = 0; StateHasChanged(); }
    }

