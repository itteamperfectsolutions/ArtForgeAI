    private class RefImageState
    {
        public string? ProcessedPath { get; set; }
        public string? TransparentPath { get; set; }
        public byte[]? TransparentBytes { get; set; }
        public bool IsProcessing { get; set; }
        public bool ShowBgOptions { get; set; }
        public string SelectedBgColor { get; set; } = "#FFFFFF";
        public string CustomHexColor { get; set; } = string.Empty;
        public long Version { get; set; }
    }
}
