                        {
                            <div class="admin-completed-category-header">@group.Key</div>
                            <div class="admin-completed-grid">
                                @foreach (var preset in group)
                                {
                                    <div class="admin-completed-card @(_editingStyleId == preset.Id ? "editing" : "")">
                                        @if (_editingStyleId == preset.Id)
                                        {
                                            <div class="admin-style-card-edit">
                                                <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
                                                    <input class="form-input" style="width: 90px; font-size:0.72rem;" @bind="_editStyleName" placeholder="Name" />
                                                    <input class="form-input" style="width: 100px; font-size:0.72rem;" @bind="_editStyleDesc" placeholder="Description" />
                                                    <select class="form-input" style="width: 90px; padding: 0.25rem; font-size: 0.72rem;" @bind="_editStyleCategory">
                                                        <option value="Artistic">Artistic</option>
                                                        <option value="Fun">Fun</option>
                                                        <option value="Professional">Professional</option>
                                                        <option value="Abstract">Abstract</option>
                                                        <option value="Mythological">Mythological</option>
                                                        <option value="Regional">Regional</option>
                                                    </select>
                                                    <input class="form-input" style="width: 40px; font-size:0.72rem;" @bind="_editStyleEmoji" placeholder="Em" />
                                                </div>
                                                <textarea class="form-input" style="width:100%;min-height:36px;font-size:0.72rem;" @bind="_editStylePrompt" placeholder="Prompt"></textarea>
                                                <div style="display:flex;gap:0.25rem;justify-content:flex-end;">
                                                    <button class="btn-primary-gradient btn-sm" style="font-size:0.68rem;padding:0.2rem 0.4rem;" @onclick="() => SaveStyleEdit(preset.Id)">Save</button>
                                                    <button class="btn-secondary btn-sm" style="font-size:0.68rem;padding:0.2rem 0.4rem;" @onclick="CancelStyleEdit">Cancel</button>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="admin-completed-thumb">
                                                <img src="/@preset.ThumbnailPath" alt="@preset.Name" />
                                                @if (_generatingThumbnailId == preset.Id || _batchActiveIds.Contains(preset.Id))
                                                {
                                                    <div class="admin-style-thumb-overlay">
                                                        <div class="loading-spinner" style="width:16px;height:16px;margin:0;border-width:2px;"></div>
                                                    </div>
                                                }
                                            </div>
                                            <div class="admin-completed-info">
                                                <div class="admin-completed-top">
                                                    <span class="admin-completed-name">@preset.IconEmoji @preset.Name</span>
                                                    <label class="toggle-switch" style="transform: scale(0.65);">
                                                        <input type="checkbox" checked="@preset.IsActive"
                                                               @onchange="() => ToggleStyleActive(preset)" />
                                                        <span class="toggle-slider"></span>
                                                    </label>
                                                </div>
                                                <div class="admin-completed-actions">
                                                    <label class="btn-primary-gradient btn-sm admin-upload-label admin-compact-btn" title="Test style">
                                                        &#10024;
                                                        <InputFile OnChange="(e) => TestStyle(e, preset)" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none" />
                                                    </label>
                                                    <button class="btn-secondary btn-sm admin-compact-btn" @onclick="() => GenerateThumbnail(preset)"
                                                            disabled="@(_generatingThumbnailId is not null)" title="Regenerate">&#127912;</button>
                                                    <label class="btn-secondary btn-sm admin-upload-label admin-compact-btn" title="Upload thumbnail">
                                                        &#128247;
                                                        <InputFile OnChange="(e) => UploadThumbnail(e, preset.Id)" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none" />
                                                    </label>
                                                    <button class="btn-secondary btn-sm admin-compact-btn" @onclick="() => StartStyleEdit(preset)" title="Edit">&#9998;</button>
                                                    <button class="btn-danger btn-sm admin-compact-btn" @onclick="() => DeleteStyle(preset.Id)" title="Delete">&#128465;</button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                }
            } @* end inactive sub-tab *@
        </div>
    </div>
}

@* ── Style Test Preview Modal ── *@
@* ── Placeholder text-input modal for test style ── *@
@if (_testPendingPlaceholders && _testPlaceholderPreset is not null)
{
    <div class="style-test-overlay">
        <div class="qs-modal qs-placeholder-modal">
            <div class="qs-modal-header">
                <span>@_testPlaceholderPreset.IconEmoji Personalise Your @_testPlaceholderPreset.Name</span>
                <button class="qs-modal-close" @onclick="CancelTestPlaceholders">&times;</button>
            </div>
            <div class="qs-placeholder-body">
                @if (_testPlaceholderPreset.PromptTemplate.Contains("{{OCCASION}}"))
                {
                    <div class="qs-field">
                        <label>Occasion / Heading <span class="qs-required">*</span></label>
                        <input type="text" @bind="_testOccasionText" placeholder="e.g. Happy Birthday, Happy Anniversary, Congratulations..." maxlength="60" />
                    </div>
                }
                @if (_testPlaceholderPreset.PromptTemplate.Contains("{{MESSAGE}}"))
                {
                    <div class="qs-field">
                        <label>Personal Message <span class="qs-optional">(optional — auto-generated if blank)</span></label>
                        <textarea @bind="_testMessageText" rows="3" placeholder="e.g. Happy Birthday, Olivia! Celebrate and enjoy!" maxlength="200"></textarea>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_testPlaceholderError))
                {
                    <div class="qs-field-error">@_testPlaceholderError</div>
                }
            </div>
            <div class="qs-modal-footer">
                <button class="btn-primary-gradient" @onclick="SubmitTestPlaceholders">Generate</button>
                <button class="btn-secondary" @onclick="CancelTestPlaceholders">&times; Cancel</button>
            </div>
        </div>
    </div>
}

@if (_testingStyleId is not null)
{
    <div class="style-test-overlay">
        <div class="style-test-modal">
            <div class="style-test-header">
                <span>Test Style: @_testStyleName</span>
                <button class="style-test-close" @onclick="DiscardTestResult" disabled="@_testProcessing">&times;</button>
            </div>

            <div class="style-test-body">
                @* Left: source image *@
                <div class="style-test-panel">
                    <div class="style-test-panel-label">SOURCE</div>
                    <div class="style-test-image-wrap">
                        @if (!string.IsNullOrEmpty(_testSourcePath))
                        {
                            <img src="@($"{ImageStorage.GetWebPath(_testSourcePath)}?v={_testVersion}")" alt="Source" />
                        }
                    </div>
                </div>

                @* Right: result *@
                <div class="style-test-panel">
                    <div class="style-test-panel-label">RESULT</div>
                    <div class="style-test-image-wrap">
                        @if (_testProcessing)
                        {
                            <div style="display:flex;flex-direction:column;align-items:center;gap:0.75rem;padding:2rem;">
                                <div class="loading-spinner" style="width:36px;height:36px;margin:0;"></div>
                                <span style="font-size:0.85rem;color:var(--text-muted);">Applying @_testStyleName style...</span>
                                <span style="font-size:0.72rem;color:var(--text-muted);opacity:0.6;">This may take 1-2 minutes</span>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(_testError))
                        {
                            <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;padding:1.5rem;text-align:center;">
                                <span style="font-size:1.5rem;">&#9888;</span>
                                <span style="color:var(--danger);font-size:0.82rem;">@_testError</span>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(_testResultPath))
                        {
                            <img src="@($"{ImageStorage.GetWebPath(_testResultPath)}?v={_testVersion}")" alt="Result" />
                            @if (!string.IsNullOrEmpty(_testModelInfo))
                            {
                                // Extract model name from the [model-name] prefix
                                var modelTag = _testModelInfo.Contains(']')
                                    ? _testModelInfo[..(_testModelInfo.IndexOf(']') + 1)]
                                    : "";
                                <div style="position:absolute;bottom:4px;left:4px;background:rgba(0,0,0,0.7);color:#aaa;font-size:0.65rem;padding:2px 6px;border-radius:3px;">
                                    @modelTag
                                </div>
                            }
                        }
                        else
                        {
                            <span style="color:var(--text-muted);font-size:0.85rem;">Waiting...</span>
                        }
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_testError))
            {
                <div style="padding:0.5rem 1rem;color:var(--danger);font-size:0.82rem;">@_testError</div>
            }

            @if (!_testProcessing && !string.IsNullOrEmpty(_testResultPath))
            {
                <div class="style-test-footer">
                    <button class="btn-primary-gradient" @onclick="UseTestResultAsThumbnail">
                        &#10003; Use as Thumbnail
                    </button>
                    <button class="btn-secondary" @onclick="DiscardTestResult">
                        &#10005; Discard
                    </button>
                </div>
            }
        </div>
    </div>
}

@code {
    private string _activeTab = "general";
    private string _styleSubTab = "active";
    private UserPreference _prefs = new();
    private bool _saving;
    private string? _message;

    // Image sizes
    private List<ImageSizeMaster> _allSizes = [];
    private List<ImageSizeMaster> _activeSizes = [];
    private string? _sizeMessage;

    // Style presets
    private List<StylePreset> _allStyles = [];
    private string? _styleMessage;
    private static readonly string[] _categoryOrder = ["Artistic", "Fun", "Professional", "Abstract", "Mythological", "Regional", "PhotoCollage"];
    private int? _generatingThumbnailId;
    private string? _thumbnailMessage;

    // Batch thumbnail generation
    private bool _batchGenerating;
    private int _batchTotal;
    private int _batchCompleted;
    private HashSet<int> _batchActiveIds = [];

    // Style test preview state
    private int? _testingStyleId;
    private string _testStyleName = string.Empty;
    private string? _testSourcePath;
    private string? _testResultPath;
    private bool _testProcessing;
    private string? _testError;
    private string? _testModelInfo;
    private long _testVersion; // cache-bust counter for img src

    // Placeholder text-input state (for greeting card styles etc.)
    private bool _testPendingPlaceholders;
    private StylePreset? _testPlaceholderPreset;
    private string _testOccasionText = string.Empty;
    private string _testMessageText = string.Empty;
    private string? _testPlaceholderError;

    // Add form
    private string _newName = string.Empty;
    private double _newWidth;
    private double _newHeight;
    private string _newUnit = "px";

    // New style form
    private string _newStyleName = string.Empty;
    private string _newStyleDesc = string.Empty;
    private string _newStyleCategory = "Artistic";
    private string _newStyleEmoji = string.Empty;
    private string _newStyleAccent = string.Empty;
    private string _newStylePrompt = string.Empty;

    // New style inline test preview
    private string? _newStyleTestSourcePath;
    private string? _newStyleTestResultPath;
    private bool _newStyleTestProcessing;
    private string? _newStyleTestError;

    // Style edit state
    private int? _editingStyleId;
    private string _editStyleName = string.Empty;
    private string _editStyleDesc = string.Empty;
    private string _editStyleCategory = "Artistic";
    private string _editStyleEmoji = string.Empty;
    private string _editStyleAccent = string.Empty;
    private string _editStylePrompt = string.Empty;
    private bool _editStyleIsActive = true;

    // Edit state
    private int? _editingSizeId;
    private string _editName = string.Empty;
    private double _editWidth;
    private double _editHeight;
    private string _editUnit = "px";
    private bool _editIsActive = true;

    private const double Dpi = 96.0;

    protected override async Task OnInitializedAsync()
    {
        _prefs = await HistoryService.GetUserPreferencesAsync();
        await LoadSizes();
        await LoadStyles();
    }

    private async Task LoadSizes()
    {
        _allSizes = await SizeService.GetAllAsync();
        _activeSizes = _allSizes.Where(s => s.IsActive).ToList();
    }

    private async Task LoadStyles()
    {
        _allStyles = (await StyleService.GetAllAsync())
            .OrderBy(s => string.IsNullOrEmpty(s.ThumbnailPath) ? 0 : 1)
            .ThenByDescending(s => s.Id)
            .ToList();
    }

    private async Task ApplyTheme()
    {
        var theme = _prefs.DarkMode ? "dark" : "light";
        await JS.InvokeVoidAsync("themeManager.setTheme", theme);
    }

    private async Task SaveSettings()
    {
        _saving = true;
        _message = null;
        StateHasChanged();

        try
        {
            await HistoryService.SaveUserPreferencesAsync(_prefs);
            await ApplyTheme();
            _message = "Settings saved successfully!";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save settings");
            _message = "Failed to save settings. Please try again.";
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    // -- Display helpers --

    private static string FormatDisplay(ImageSizeMaster size)
    {
        var unit = size.Unit ?? "px";
        if (unit == "px" || size.DisplayWidth <= 0)
            return $"{size.Width}x{size.Height} px";

        // Format: remove trailing zeros for clean display
        var w = size.DisplayWidth == Math.Floor(size.DisplayWidth)
            ? size.DisplayWidth.ToString("0") : size.DisplayWidth.ToString("0.##");
        var h = size.DisplayHeight == Math.Floor(size.DisplayHeight)
            ? size.DisplayHeight.ToString("0") : size.DisplayHeight.ToString("0.##");
        return $"{w}x{h} {unit}";
    }

    // -- Unit conversion --

    private static int ToPixels(double value, string unit) => unit switch
    {
        "in" => (int)Math.Round(value * Dpi),
        "cm" => (int)Math.Round(value * Dpi / 2.54),
        _ => (int)Math.Round(value)
    };

    private static double ConvertUnit(double value, string fromUnit, string toUnit)
    {
        if (fromUnit == toUnit) return value;
        // Convert to px first, then to target unit
        double px = fromUnit switch
        {
            "in" => value * Dpi,
            "cm" => value * Dpi / 2.54,
            _ => value
        };
        return toUnit switch
        {
            "in" => Math.Round(px / Dpi, 2),
            "cm" => Math.Round(px / Dpi * 2.54, 2),
            _ => Math.Round(px)
        };
    }

    private void OnNewUnitChanged(ChangeEventArgs e)
    {
        var newUnit = e.Value?.ToString() ?? "px";
        if (_newWidth > 0) _newWidth = ConvertUnit(_newWidth, _newUnit, newUnit);
        if (_newHeight > 0) _newHeight = ConvertUnit(_newHeight, _newUnit, newUnit);
        _newUnit = newUnit;
    }

    private void OnEditUnitChanged(ChangeEventArgs e)
    {
        var newUnit = e.Value?.ToString() ?? "px";
        if (_editWidth > 0) _editWidth = ConvertUnit(_editWidth, _editUnit, newUnit);
        if (_editHeight > 0) _editHeight = ConvertUnit(_editHeight, _editUnit, newUnit);
        _editUnit = newUnit;
    }

    // -- Size CRUD --

    private async Task AddSize()
    {
        if (string.IsNullOrWhiteSpace(_newName) || _newWidth <= 0 || _newHeight <= 0) return;

        var size = new ImageSizeMaster
        {
            Name = _newName.Trim(),
            Width = ToPixels(_newWidth, _newUnit),
            Height = ToPixels(_newHeight, _newUnit),
            Unit = _newUnit,
            DisplayWidth = _newWidth,
            DisplayHeight = _newHeight,
            IsActive = true
        };

        await SizeService.CreateAsync(size);
        _newName = string.Empty;
        _newWidth = 0;
        _newHeight = 0;
        _newUnit = "px";
        _sizeMessage = "Size added!";
        await LoadSizes();
    }

    private void StartEdit(ImageSizeMaster size)
    {
        _editingSizeId = size.Id;
        _editName = size.Name;
        _editUnit = size.Unit ?? "px";
        _editWidth = size.DisplayWidth > 0 ? size.DisplayWidth : size.Width;
        _editHeight = size.DisplayHeight > 0 ? size.DisplayHeight : size.Height;
        _editIsActive = size.IsActive;
    }

    private void CancelEdit()
    {
        _editingSizeId = null;
    }

    private async Task SaveEdit(int id)
    {
        var size = await SizeService.GetByIdAsync(id);
        if (size is null) return;

        size.Name = _editName.Trim();
        size.Width = ToPixels(_editWidth, _editUnit);
        size.Height = ToPixels(_editHeight, _editUnit);
        size.Unit = _editUnit;
        size.DisplayWidth = _editWidth;
        size.DisplayHeight = _editHeight;
        size.IsActive = _editIsActive;

        await SizeService.UpdateAsync(size);
        _editingSizeId = null;
        _sizeMessage = "Size updated!";
        await LoadSizes();
    }

    private async Task DeleteSize(int id)
    {
        await SizeService.DeleteAsync(id);
        _sizeMessage = "Size deleted.";
        await LoadSizes();
    }

    // -- Style CRUD --

    private async Task AddStyleOnly()
    {
        if (string.IsNullOrWhiteSpace(_newStyleName) || string.IsNullOrWhiteSpace(_newStylePrompt)) return;

        var preset = new StylePreset
        {
            Name = _newStyleName.Trim(),
            Description = _newStyleDesc.Trim(),
            PromptTemplate = _newStylePrompt.Trim(),
            Category = _newStyleCategory,
            IconEmoji = _newStyleEmoji.Trim(),
            AccentColor = string.IsNullOrWhiteSpace(_newStyleAccent) ? null : _newStyleAccent.Trim(),
            IsActive = false
        };

        await StyleService.CreateAsync(preset);
        ClearNewStyleForm();
        _styleMessage = "Style added!";
        await LoadStyles();
    }

    private async Task AddStyleWithThumbnail()
    {
        if (string.IsNullOrWhiteSpace(_newStyleName) || string.IsNullOrWhiteSpace(_newStylePrompt)
            || string.IsNullOrEmpty(_newStyleTestResultPath)) return;

        var preset = new StylePreset
        {
            Name = _newStyleName.Trim(),
            Description = _newStyleDesc.Trim(),
            PromptTemplate = _newStylePrompt.Trim(),
            Category = _newStyleCategory,
            IconEmoji = _newStyleEmoji.Trim(),
            AccentColor = string.IsNullOrWhiteSpace(_newStyleAccent) ? null : _newStyleAccent.Trim(),
            IsActive = false,
            ThumbnailPath = _newStyleTestResultPath
        };

        await StyleService.CreateAsync(preset);
        ClearNewStyleForm();
        _styleMessage = "Style added with thumbnail!";
        await LoadStyles();
    }

    private void ClearNewStyleForm()
    {
        _newStyleName = string.Empty;
        _newStyleDesc = string.Empty;
        _newStyleCategory = "Artistic";
        _newStyleEmoji = string.Empty;
        _newStyleAccent = string.Empty;
        _newStylePrompt = string.Empty;
        ClearNewStylePreview();
    }

    private async Task TestNewStyle(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null || file.Size > 10 * 1024 * 1024
            || string.IsNullOrWhiteSpace(_newStylePrompt) || _newStyleTestProcessing) return;

        _newStyleTestResultPath = null;
        _newStyleTestError = null;
        _newStyleTestProcessing = true;
        StateHasChanged();

        try
        {
            // Save uploaded test image
            using var stream = file.OpenReadStream(10 * 1024 * 1024);
            _newStyleTestSourcePath = await ImageStorage.SaveUploadedFileAsync(stream, file.Name);
            _testVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            StateHasChanged();

            // Run style transfer with the prompt template
            var request = new GenerationRequest
            {
                Prompt = _newStylePrompt + StylePreset.FacialIdentitySuffix,
                Width = 512,
                Height = 512,
                SizeName = "Square",
                EnhancePrompt = false,
                ReferenceImagePaths = [_newStyleTestSourcePath],
                Provider = ImageProvider.Gemini
            };

            var result = await ImageGenService.GenerateImageAsync(request);

            if (result.Success && !string.IsNullOrEmpty(result.LocalImagePath))
            {
                _newStyleTestResultPath = result.LocalImagePath;
                _testVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            }
            else
            {
                _newStyleTestError = result.ErrorMessage ?? "Generation failed.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "New style test failed");
            _newStyleTestError = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _newStyleTestProcessing = false;
            StateHasChanged();
        }
    }

    private void ClearNewStylePreview()
    {
        _newStyleTestSourcePath = null;
        _newStyleTestResultPath = null;
        _newStyleTestProcessing = false;
        _newStyleTestError = null;
    }

    private void StartStyleEdit(StylePreset preset)
    {
        _editingStyleId = preset.Id;
        _editStyleName = preset.Name;
        _editStyleDesc = preset.Description;
        _editStyleCategory = preset.Category;
        _editStyleEmoji = preset.IconEmoji;
        _editStyleAccent = preset.AccentColor ?? string.Empty;
        _editStylePrompt = preset.PromptTemplate;
        _editStyleIsActive = preset.IsActive;
    }

    private void CancelStyleEdit()
    {
        _editingStyleId = null;
    }

    private async Task SaveStyleEdit(int id)
    {
        var preset = await StyleService.GetByIdAsync(id);
        if (preset is null) return;

        preset.Name = _editStyleName.Trim();
        preset.Description = _editStyleDesc.Trim();
        preset.PromptTemplate = _editStylePrompt.Trim();
        preset.Category = _editStyleCategory;
        preset.IconEmoji = _editStyleEmoji.Trim();
        preset.AccentColor = string.IsNullOrWhiteSpace(_editStyleAccent) ? null : _editStyleAccent.Trim();
        preset.IsActive = _editStyleIsActive;

        await StyleService.UpdateAsync(preset);
        _editingStyleId = null;
        _styleMessage = "Style updated!";
        await LoadStyles();
    }

    private async Task DeleteStyle(int id)
    {
        await StyleService.DeleteAsync(id);
        _styleMessage = "Style deleted.";
        await LoadStyles();
    }

    private async Task ToggleStyleActive(StylePreset preset)
    {
        var entity = await StyleService.GetByIdAsync(preset.Id);
        if (entity is null) return;

        entity.IsActive = !entity.IsActive;
        await StyleService.UpdateAsync(entity);
        await LoadStyles();
    }

    private async Task UploadThumbnail(InputFileChangeEventArgs e, int presetId)
    {
        var file = e.File;
        if (file is null || file.Size > 10 * 1024 * 1024) return;

        _thumbnailMessage = "Uploading thumbnail...";
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(10 * 1024 * 1024);
            var path = await ImageStorage.SaveUploadedFileAsync(stream, file.Name);

            var entity = await StyleService.GetByIdAsync(presetId);
            if (entity is not null)
            {
                entity.ThumbnailPath = path;
                await StyleService.UpdateAsync(entity);
            }

            _thumbnailMessage = "Thumbnail uploaded!";
            await LoadStyles();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Thumbnail upload failed for preset {PresetId}", presetId);
            _thumbnailMessage = "Upload failed. Please try again.";
        }

        StateHasChanged();
    }

    private bool HasPlaceholders(StylePreset style)
        => style.PromptTemplate.Contains("{{OCCASION}}") || style.PromptTemplate.Contains("{{MESSAGE}}");

    private string ReplacePlaceholders(string prompt, string occasion, string message)
    {
        var result = prompt.Replace("{{OCCASION}}", occasion.Trim());
        if (!string.IsNullOrWhiteSpace(message))
            result = result.Replace("{{MESSAGE}}", message.Trim());
        else
            result = result.Replace("{{MESSAGE}}",
                $"Generate a short warm heartfelt message (2-3 lines) appropriate for the occasion: {occasion.Trim()}");
        return result;
    }

    private async Task TestStyle(InputFileChangeEventArgs e, StylePreset preset)
    {
        var file = e.File;
        if (file is null || file.Size > 10 * 1024 * 1024 || _testingStyleId is not null) return;

        // Save uploaded image first (needed for both placeholder and non-placeholder paths)
        using var stream = file.OpenReadStream(10 * 1024 * 1024);
        _testSourcePath = await ImageStorage.SaveUploadedFileAsync(stream, file.Name);

        // If the style has placeholders, show text input modal first
        if (HasPlaceholders(preset))
        {
            _testPlaceholderPreset = preset;
            _testOccasionText = string.Empty;
            _testMessageText = string.Empty;
            _testPlaceholderError = null;
            _testPendingPlaceholders = true;
            StateHasChanged();
            return;
        }

        await RunTestGeneration(preset, preset.EffectivePrompt);
    }

    private async Task SubmitTestPlaceholders()
    {
        if (_testPlaceholderPreset is null || _testSourcePath is null) return;

        if (_testPlaceholderPreset.PromptTemplate.Contains("{{OCCASION}}") && string.IsNullOrWhiteSpace(_testOccasionText))
        {
            _testPlaceholderError = "Please enter the occasion (e.g. Happy Birthday, Happy Anniversary).";
            return;
        }

        _testPlaceholderError = null;
        _testPendingPlaceholders = false;
        var prompt = ReplacePlaceholders(_testPlaceholderPreset.EffectivePrompt, _testOccasionText, _testMessageText);
        await RunTestGeneration(_testPlaceholderPreset, prompt);
    }

    private void CancelTestPlaceholders()
    {
        _testPendingPlaceholders = false;
        _testPlaceholderPreset = null;
        _testPlaceholderError = null;
        _testSourcePath = null;
    }

    private async Task RunTestGeneration(StylePreset preset, string prompt)
    {
        _testingStyleId = preset.Id;
        _testStyleName = preset.Name;
        _testResultPath = null;
        _testError = null;
        _testModelInfo = null;
        _testProcessing = true;
        _testVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        StateHasChanged();

        try
        {
            if (_testSourcePath is null)
            {
                _testError = "No source image available.";
                return;
            }

            // Use portrait dimensions for collage styles (they describe 20×30 sheets)
            var isCollage = preset.Name.Contains("Collage", StringComparison.OrdinalIgnoreCase);
            var width = isCollage ? 768 : 512;
            var height = isCollage ? 1152 : 512;

            // Run style transfer with the prompt
            var request = new GenerationRequest
            {
                Prompt = prompt,
                Width = width,
                Height = height,
                SizeName = isCollage ? "20x30" : "Square",
                EnhancePrompt = false,
                ReferenceImagePaths = [_testSourcePath],
                Provider = ImageProvider.Gemini
            };

            // Use a 120s timeout to prevent the spinner from hanging forever
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(120));
            var generationTask = ImageGenService.GenerateImageAsync(request);
            var completedTask = await Task.WhenAny(generationTask, Task.Delay(Timeout.Infinite, cts.Token));

            if (generationTask.IsCompleted)
            {
                var result = await generationTask;
                if (result.Success && !string.IsNullOrEmpty(result.LocalImagePath))
                {
                    _testResultPath = result.LocalImagePath;
                    _testModelInfo = result.EnhancedPrompt;
                    _testVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                }
                else
                {
                    _testError = result.ErrorMessage ?? "Generation failed.";
                }
            }
            else
            {
                _testError = "Generation timed out after 2 minutes. The style may be too complex for a quick test.";
                Logger.LogWarning("Style test timed out for {StyleName}", preset.Name);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Style test failed for {StyleName}", preset.Name);
            _testError = $"Error: {ex.Message}";
        }
        finally
        {
            _testProcessing = false;
            StateHasChanged();
        }
    }

    private async Task UseTestResultAsThumbnail()
    {
        if (_testingStyleId is null || string.IsNullOrEmpty(_testResultPath)) return;

        var entity = await StyleService.GetByIdAsync(_testingStyleId.Value);
        if (entity is not null)
        {
            entity.ThumbnailPath = _testResultPath;
            await StyleService.UpdateAsync(entity);
        }

        _thumbnailMessage = $"Thumbnail set for {_testStyleName}!";
        _testingStyleId = null;
        _testSourcePath = null;
        _testResultPath = null;
        _testError = null;
        await LoadStyles();
        StateHasChanged();
    }

    private void DiscardTestResult()
    {
        _testingStyleId = null;
        _testSourcePath = null;
        _testResultPath = null;
        _testError = null;
        StateHasChanged();
    }

    private async Task GenerateThumbnail(StylePreset preset)
    {
        if (_generatingThumbnailId is not null) return;

        _generatingThumbnailId = preset.Id;
        _thumbnailMessage = $"Generating thumbnail for {preset.Name}...";
        StateHasChanged();

        try
        {
            var isCollage = preset.Name.Contains("Collage", StringComparison.OrdinalIgnoreCase);
            var request = new GenerationRequest
            {
                Prompt = $"A beautiful landscape, golden hour lighting. {preset.PromptTemplate}",
                Width = isCollage ? 768 : 512,
                Height = isCollage ? 1152 : 512,
                SizeName = isCollage ? "20x30" : "Square",
                EnhancePrompt = false,
                Provider = ImageProvider.Gemini
            };

            var result = await ImageGenService.GenerateImageAsync(request);

            if (result.Success && !string.IsNullOrEmpty(result.LocalImagePath))
            {
                var entity = await StyleService.GetByIdAsync(preset.Id);
                if (entity is not null)
                {
                    entity.ThumbnailPath = result.LocalImagePath;
                    await StyleService.UpdateAsync(entity);
                }
                _thumbnailMessage = $"Thumbnail generated for {preset.Name}!";
            }
            else
            {
                _thumbnailMessage = "Thumbnail generation failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Thumbnail generation failed for {StyleName}", preset.Name);
            _thumbnailMessage = "An error occurred. Please try again.";
        }
        finally
        {
            _generatingThumbnailId = null;
            await LoadStyles();
            StateHasChanged();
        }
    }

    private async Task GenerateAllThumbnails()
    {
        if (_batchGenerating) return;

        // Get styles missing thumbnails
        var pending = _allStyles
            .Where(s => string.IsNullOrEmpty(s.ThumbnailPath))
            .ToList();

        if (pending.Count == 0)
        {
            _thumbnailMessage = "All styles already have thumbnails!";
            StateHasChanged();
            return;
        }

        _batchGenerating = true;
        _batchTotal = pending.Count;
        _batchCompleted = 0;
        _batchActiveIds = [];
        _thumbnailMessage = null;
        StateHasChanged();

        var semaphore = new SemaphoreSlim(8);
        var tasks = pending.Select(async preset =>
        {
            await semaphore.WaitAsync();
            try
            {
                // Mark as active on UI
                lock (_batchActiveIds) { _batchActiveIds.Add(preset.Id); }
                await InvokeAsync(StateHasChanged);

                var batchIsCollage = preset.Name.Contains("Collage", StringComparison.OrdinalIgnoreCase);
                var request = new GenerationRequest
                {
                    Prompt = $"A beautiful landscape, golden hour lighting. {preset.PromptTemplate}",
                    Width = batchIsCollage ? 768 : 512,
                    Height = batchIsCollage ? 1152 : 512,
                    SizeName = batchIsCollage ? "20x30" : "Square",
                    EnhancePrompt = false,
                    Provider = ImageProvider.Gemini
                };

                var result = await ImageGenService.GenerateImageAsync(request);

                if (result.Success && !string.IsNullOrEmpty(result.LocalImagePath))
                {
                    var entity = await StyleService.GetByIdAsync(preset.Id);
                    if (entity is not null)
                    {
                        entity.ThumbnailPath = result.LocalImagePath;
                        await StyleService.UpdateAsync(entity);
                    }
                }
            }
            catch
            {
                // Skip failures silently during batch
            }
            finally
            {
                lock (_batchActiveIds) { _batchActiveIds.Remove(preset.Id); }
                Interlocked.Increment(ref _batchCompleted);
                await InvokeAsync(async () =>
                {
                    await LoadStyles();
                    StateHasChanged();
                });
                semaphore.Release();
            }
        });

        await Task.WhenAll(tasks);

        _batchGenerating = false;
        _batchActiveIds = [];
        _thumbnailMessage = $"Done! Generated {_batchCompleted} thumbnails.";
        await LoadStyles();
        StateHasChanged();
    }
}
