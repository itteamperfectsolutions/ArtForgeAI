@page "/quick-style"
@rendermode InteractiveServer
@attribute [Authorize]
@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.PixelFormats
@using SixLabors.ImageSharp.Processing
@using SixLabors.ImageSharp.Drawing
@using SixLabors.ImageSharp.Drawing.Processing
@using SixLabors.Fonts
@inject IStylePresetService StyleService
@inject IBackgroundRemovalService BgRemoval
@inject IImageGenerationService ImageGenService
@inject IImageStorageService ImageStorage
@inject ICinematicProfileService CinematicProfile
@inject IGeminiImageService GeminiService
@inject IImageEnhancerService ImageEnhancer
@inject IColorEnhancementService ColorEnhancer
@inject IWebHostEnvironment Env
@inject IJSRuntime JS
@using System.Text
@inject ILogger<QuickStyle> Logger
@inject ISubscriptionService SubscriptionService
@inject ICoinService CoinService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>ArtForge AI - Quick Style</PageTitle>

<div class="page-header">
    <h2>Quick Style <span class="qs-total-count">@_styles.Count styles</span></h2>
    <p>Click any style to upload a photo and get a print-ready result</p>
</div>

<div class="qs-search-bar">
    <span class="qs-search-icon">&#128269;</span>
    <input type="text" class="qs-search-input" placeholder="Search styles..."
           @bind="_searchQuery" @bind:event="oninput" />
    @if (!string.IsNullOrEmpty(_searchQuery))
    {
        <button class="qs-search-clear" @onclick="() => _searchQuery = string.Empty">&times;</button>
    }
</div>

@* ── Style grid is always visible ── *@
@{ var filtered = GetFilteredGroups(); }
@if (filtered.Length == 0 && !string.IsNullOrEmpty(_searchQuery))
{
    <div class="qs-no-results">
        <span>&#128269;</span>
        <p>No styles found for "<strong>@_searchQuery</strong>"</p>
    </div>
}
@foreach (var group in filtered)
{
    <div class="qs-category-section">
        <div class="qs-category-header">@group.Key <span class="qs-category-count">@group.Count()</span></div>
        <div class="qs-grid">
            @foreach (var style in group)
            {
                <label class="qs-tile" style="@(!string.IsNullOrEmpty(style.AccentColor) ? $"--card-accent: {style.AccentColor};" : "")">
                    @if (!string.IsNullOrEmpty(style.ThumbnailPath))
                    {
                        <img src="/@style.ThumbnailPath" alt="@style.Name" />
                    }
                    else
                    {
                        <div class="qs-tile-fallback">
                            <span>@style.IconEmoji</span>
                        </div>
                    }
                    <div class="qs-tile-label">@style.Name</div>
                    <InputFile OnChange="(e) => HandleTileClick(e, style)" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none" />
                </label>
            }
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_error))
{
    <div style="margin-top:0.75rem;color:var(--danger);font-size:0.85rem;">@_error</div>
}

@* ── Placeholder text-input modal (greeting cards etc.) ── *@
@if (_pendingPlaceholders)
{
    <div class="qs-modal-overlay">
        <div class="qs-modal qs-placeholder-modal">
            <div class="qs-modal-header">
                <span>@_selectedStyle?.IconEmoji Personalise Your @_selectedStyle?.Name</span>
                <button class="qs-modal-close" @onclick="CancelPlaceholders">&times;</button>
            </div>
            <div class="qs-placeholder-body">
                @if (_selectedStyle?.PromptTemplate.Contains("{{OCCASION}}") == true)
                {
                    <div class="qs-field">
                        <label>Occasion / Heading <span class="qs-optional">(optional)</span></label>
                        <input type="text" @bind="_occasionText" placeholder="e.g. Happy Birthday, Happy New Year, Congratulations..." maxlength="60" />
                    </div>
                }
                @if (_selectedStyle?.PromptTemplate.Contains("{{MESSAGE}}") == true)
                {
                    <div class="qs-field">
                        <label>Personal Message <span class="qs-optional">(optional — auto-generated if blank)</span></label>
                        <textarea @bind="_messageText" rows="3" placeholder="e.g. Happy New Year! Wishing you all the best!" maxlength="200"></textarea>
                    </div>
                }
                @if (_selectedStyle?.PromptTemplate.Contains("{{CALENDAR}}") == true)
                {
                    <div class="qs-field">
                        <label>Special Date <span class="qs-optional">(optional)</span></label>
                        <input type="date" @bind="_calendarDate" />
                    </div>
                }
                @if (_selectedStyle?.PromptTemplate.Contains("{{NUMBER}}") == true)
                {
                    <div class="qs-field">
                        <label>Number / Age <span class="qs-optional">(optional)</span></label>
                        <input type="number" @bind="_numberValue" min="0" max="999" placeholder="e.g. 2, 5, 25..." />
                    </div>
                }
                @if (_selectedStyle?.Category == "Memorial")
                {
                    <div class="qs-field">
                        <label>Name <span class="qs-required">*</span></label>
                        <input type="text" @bind="_memorialName" placeholder="Enter full name..." maxlength="80" />
                    </div>
                    <div class="qs-field">
                        <label>Date of Birth <span class="qs-optional">(optional)</span></label>
                        <input type="date" @bind="_memorialDob" />
                    </div>
                    <div class="qs-field">
                        <label>Date of Death <span class="qs-optional">(optional)</span></label>
                        <input type="date" @bind="_memorialDod" />
                    </div>
                }
                @if (_selectedStyle?.PromptTemplate.Contains("{{DATE}}") == true)
                {
                    <div class="qs-field">
                        <label>Date <span class="qs-optional">(optional)</span></label>
                        <input type="date" @bind="_datePickerValue" />
                    </div>
                }
                @if (!string.IsNullOrEmpty(_placeholderError))
                {
                    <div class="qs-field-error">@_placeholderError</div>
                }
            </div>
            <div class="qs-modal-footer">
                <button class="btn-primary-gradient" @onclick="ProcessWithPlaceholders">Generate</button>
                <button class="btn-secondary" @onclick="CancelPlaceholders">&times; Cancel</button>
            </div>
        </div>
    </div>
}

@* ── Silhouette Contour options modal ── *@
@if (_pendingSilhouetteOptions)
{
    <div class="qs-modal-overlay">
        <div class="qs-modal qs-placeholder-modal">
            <div class="qs-modal-header">
                <span>@_selectedStyle?.IconEmoji Silhouette Contour Options</span>
                <button class="qs-modal-close" @onclick="CancelSilhouetteOptions">&times;</button>
            </div>
            <div class="qs-placeholder-body">
                <div class="qs-field">
                    <label>Face Orientation</label>
                    <div class="qs-option-group">
                        <label class="qs-option-card @(_silhouetteOrientation == "front" ? "qs-option-selected" : "")" @onclick='() => _silhouetteOrientation = "front"'>
                            <span class="qs-option-icon">&#128100;</span>
                            <span class="qs-option-label">Front</span>
                            <span class="qs-option-desc">All facial elements outlined and visible</span>
                        </label>
                        <label class="qs-option-card @(_silhouetteOrientation == "side" ? "qs-option-selected" : "")" @onclick='() => _silhouetteOrientation = "side"'>
                            <span class="qs-option-icon">&#128100;</span>
                            <span class="qs-option-label">Side</span>
                            <span class="qs-option-desc">Elegant profile silhouette view</span>
                        </label>
                    </div>
                </div>
                <div class="qs-field">
                    <label>Body Type</label>
                    <div class="qs-option-group">
                        <label class="qs-option-card @(_silhouetteBodyType == "bust" ? "qs-option-selected" : "")" @onclick='() => _silhouetteBodyType = "bust"'>
                            <span class="qs-option-icon">&#128372;</span>
                            <span class="qs-option-label">Bust</span>
                            <span class="qs-option-desc">Head, neck, and shoulders</span>
                        </label>
                        <label class="qs-option-card @(_silhouetteBodyType == "full" ? "qs-option-selected" : "")" @onclick='() => _silhouetteBodyType = "full"'>
                            <span class="qs-option-icon">&#128694;</span>
                            <span class="qs-option-label">Full Body</span>
                            <span class="qs-option-desc">Complete figure outline</span>
                        </label>
                    </div>
                </div>
            </div>
            <div class="qs-modal-footer">
                <button class="btn-primary-gradient" @onclick="ProcessSilhouetteOptions">Generate</button>
                <button class="btn-secondary" @onclick="CancelSilhouetteOptions">&times; Cancel</button>
            </div>
        </div>
    </div>
}

@* ── Processing overlay ── *@
@if (_isProcessing)
{
    <div class="qs-processing-overlay">
        <div class="qs-processing-card">
            <div style="font-size:0.85rem;margin-bottom:0.75rem;text-align:center;color:var(--text-secondary);min-height:1.2em;">@_processingStatus</div>
            <div class="loading-spinner" style="width:48px;height:48px;margin:0;"></div>
        </div>
    </div>
}

@* ── Image too large — compression confirmation ── *@
@if (_pendingCompression)
{
    <div class="qs-modal-overlay">
        <div class="qs-modal qs-placeholder-modal">
            <div class="qs-modal-header">
                <span>Image Too Large</span>
                <button class="qs-modal-close" @onclick="CancelCompression">&times;</button>
            </div>
            <div class="qs-placeholder-body">
                <p>Your image (@FormatFileSize(_pendingFileSize)) exceeds the @FormatFileSize(ImageUploadHelper.DefaultMaxUploadSize) limit.</p>
                <p>It will be resized to fit within the limit while preserving quality. No compression artifacts will be added.</p>
            </div>
            <div class="qs-modal-footer">
                <button class="btn-primary-gradient" @onclick="AcceptCompression">Resize &amp; Continue</button>
                <button class="btn-secondary" @onclick="CancelCompression">&times; Cancel</button>
            </div>
        </div>
    </div>
}

@* ── Result popup modal ── *@
@if (_result is not null && _result.Success)
{
    <div class="qs-modal-overlay" @onclick="CloseResult">
        <div class="qs-modal" @onclick:stopPropagation="true">
            <div class="qs-modal-header">
                <span>@_selectedStyle?.IconEmoji @_selectedStyle?.Name</span>
                <button class="qs-modal-close" @onclick="CloseResult">&times;</button>
            </div>
            <div class="qs-modal-body">
                <div class="qs-modal-img-card">
                    <img src="/@_sourcePath" alt="Source" />
                </div>
                <div class="qs-modal-img-card">
                    <img src="@($"{ImageStorage.GetWebPath(_result.LocalImagePath ?? "")}?v={_imgVersion}")" alt="Result" />
                </div>
            </div>
            <div class="qs-modal-footer">
                <button class="btn-primary-gradient" @onclick="DownloadPng">&#11015; Download PNG</button>
                <button class="btn-secondary" @onclick="DownloadJpg">&#11015; Download JPG</button>
                @if (ImageEnhancer.IsAvailable)
                {
                    <button class="btn-enhance" @onclick="EnhanceImage" disabled="@_isEnhancing">
                        @if (_isEnhancing)
                        {
                            <span>Enhancing...</span>
                        }
                        else
                        {
                            <span>&#9889; Enhance 4x</span>
                        }
                    </button>
                }
                @*@if (ColorEnhancer.IsAvailable)
                {
                    <button class="btn-color-enhance" @onclick="ColorEnhanceImage" disabled="@_isColorEnhancing">
                        @if (_isColorEnhancing)
                        {
                            <span>Enhancing...</span>
                        }
                        else
                        {
                            <span>&#127912; Enhance Colors</span>
                        }
                    </button>
                }*@
                <button class="btn-secondary" @onclick="CloseResult">&times; Close</button>
            </div>
            @if (_isEnhancing)
            {
                <div class="enhance-progress-bar">
                    <div class="enhance-progress-fill" style="width: @(_enhanceProgress)%"></div>
                    <span class="enhance-progress-text">@(_enhanceProgress)%</span>
                </div>
            }
            <div class="ai-disclaimer">
                AI-generated image — minor variations in facial features, colours, and details may occur. For best results, try regenerating if needed.
            </div>
        </div>
    </div>
}

@code {
    private List<StylePreset> _styles = [];
    private IGrouping<string, StylePreset>[] _grouped = [];
    private StylePreset? _selectedStyle;
    private string? _sourcePath;
    private string _searchQuery = string.Empty;
    private GenerationResult? _result;
    private bool _isProcessing;
    private bool _isEnhancing;
    private int _enhanceProgress;
    private bool _isColorEnhancing;
    private long _imgVersion;
    private string? _error;

    // Placeholder text-input state
    private bool _pendingPlaceholders;
    private string _occasionText = string.Empty;
    private string _messageText = string.Empty;
    private DateTime? _calendarDate;
    private int? _numberValue;
    private string _dateText = string.Empty; // kept for backward compat
    private DateTime? _datePickerValue;
    private string? _placeholderError;
    private string _processingStatus = "";
    private CancellationTokenSource? _statusCts;

    // Memorial fields
    private string _memorialName = string.Empty;
    private DateTime? _memorialDob;
    private DateTime? _memorialDod;

    // Silhouette Contour options
    private bool _pendingSilhouetteOptions;
    private string _silhouetteOrientation = "side"; // "front" or "side"
    private string _silhouetteBodyType = "bust"; // "full" or "bust"

    // Image compression confirmation state
    private bool _pendingCompression;
    private long _pendingFileSize;
    private InputFileChangeEventArgs? _pendingFileEvent;
    private StylePreset? _pendingFileStyle;

    // Guard against result-close re-triggering generation
    private DateTime _resultClosedAt = DateTime.MinValue;

    private static readonly string[] _categoryOrder = ["Artistic", "Fun", "Professional", "Abstract", "Mythological", "Regional", "Memorial", "PhotoCollage", "PhotoArts", "Trendy Photo Collage"];

    private IGrouping<string, StylePreset>[] GetFilteredGroups()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
            return _grouped;

        var query = _searchQuery.Trim();
        return _styles
            .Where(s => s.Name.Contains(query, StringComparison.OrdinalIgnoreCase)
                     || s.Category.Contains(query, StringComparison.OrdinalIgnoreCase))
            .GroupBy(s => s.Category)
            .OrderBy(g => Array.IndexOf(_categoryOrder, g.Key) is var i && i < 0 ? 999 : i)
            .ToArray();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("SuperAdmin"))
        {
            var userIdStr = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (int.TryParse(userIdStr, out var uid))
            {
                if (!await SubscriptionService.HasFeatureAccessAsync(uid, FeatureAccess.QuickStyle))
                {
                    Nav.NavigateTo("/pricing", forceLoad: true);
                    return;
                }
            }
        }

        _styles = await StyleService.GetActivePresetsAsync();
        _grouped = _styles
            .GroupBy(s => s.Category)
            .OrderBy(g => Array.IndexOf(_categoryOrder, g.Key) is var i && i < 0 ? 999 : i)
            .ToArray();
    }

    private bool HasPlaceholders(StylePreset style)
        => style.PromptTemplate.Contains("{{OCCASION}}") || style.PromptTemplate.Contains("{{MESSAGE}}") || style.PromptTemplate.Contains("{{CALENDAR}}") || style.PromptTemplate.Contains("{{NUMBER}}") || style.PromptTemplate.Contains("{{DATE}}") || style.PromptTemplate.Contains("{{NAME}}") || style.PromptTemplate.Contains("{{DOB}}") || style.PromptTemplate.Contains("{{DOD}}");

    private string ReplacePlaceholders(string prompt)
    {
        var result = prompt;
        var occasion = _occasionText?.Trim() ?? "";

        // OCCASION — if blank, tell AI to pick something fitting
        if (!string.IsNullOrWhiteSpace(occasion))
            result = result.Replace("{{OCCASION}}", occasion);
        else
            result = result.Replace("'{{OCCASION}}' in decorative script, then ", "")
                           .Replace("{{OCCASION}}", "a fitting celebratory greeting");

        // MESSAGE — if blank, auto-generate based on the style context
        if (!string.IsNullOrWhiteSpace(_messageText))
        {
            result = result.Replace("{{MESSAGE}}", _messageText.Trim());
        }
        else
        {
            // Determine the occasion context from the style name / occasion field
            var ctx = !string.IsNullOrWhiteSpace(occasion) ? occasion
                    : (_selectedStyle?.Name?.Contains("Birthday", StringComparison.OrdinalIgnoreCase) == true) ? "a birthday"
                    : (_selectedStyle?.Name?.Contains("Wedding", StringComparison.OrdinalIgnoreCase) == true) ? "a wedding"
                    : (_selectedStyle?.Name?.Contains("Mother", StringComparison.OrdinalIgnoreCase) == true) ? "Mother's Day"
                    : "a celebration";
            result = result.Replace("{{MESSAGE}}",
                $"Generate a short warm heartfelt message (2-3 lines) specifically for {ctx}. Do NOT mention any other festival, holiday, or event name.");
        }

        // Prevent Gemini from adding unrelated festival/event text
        result += " TEXT RESTRICTION: Display ONLY the text explicitly specified in this prompt. Do NOT add, invent, or display any other festival names, holiday greetings, event names, or seasonal references (e.g., no Holi, Diwali, Christmas, New Year, etc.) unless the prompt explicitly asks for it.";

        // CALENDAR
        if (_calendarDate.HasValue)
        {
            result = result.Replace("{{CALENDAR}}", BuildCalendarDescription(_calendarDate.Value));
        }

        // NUMBER — if blank, remove number references from prompt
        if (_numberValue.HasValue)
        {
            result = result.Replace("{{NUMBER}}", _numberValue.Value.ToString());
        }
        else
        {
            result = result.Replace("Giant 3D number '{{NUMBER}}' fills 70-80% of canvas height, with the ENTIRE number surface filled by a mosaic of", "The canvas is filled with a mosaic of");
            result = result.Replace("'{{NUMBER}}'", "");
            result = result.Replace("{{NUMBER}}", "");
        }

        // NAME (memorial)
        if (!string.IsNullOrWhiteSpace(_memorialName))
            result = result.Replace("{{NAME}}", _memorialName.Trim());
        else
            result = result.Replace("{{NAME}}", "");

        // DOB (memorial)
        if (_memorialDob.HasValue)
            result = result.Replace("{{DOB}}", _memorialDob.Value.ToString("dd-MM-yyyy"));
        else
            result = result.Replace("{{DOB}}", "");

        // DOD (memorial)
        if (_memorialDod.HasValue)
            result = result.Replace("{{DOD}}", _memorialDod.Value.ToString("dd-MM-yyyy"));
        else
            result = result.Replace("{{DOD}}", "");

        // DATE — use date picker if set, fall back to text, or omit
        var dateStr = _datePickerValue?.ToString("dd-MM-yyyy") ?? _dateText?.Trim() ?? "";
        if (!string.IsNullOrWhiteSpace(dateStr))
        {
            result = result.Replace("{{DATE}}", dateStr);
        }
        else
        {
            result = result.Replace(", then '{{DATE}}' smaller below", "");
            result = result.Replace("{{DATE}}", "");
        }

        return result;
    }

    private async Task HandleTileClick(InputFileChangeEventArgs e, StylePreset style)
    {
        var file = e.File;
        if (file is null || _isProcessing) return;

        // Guard: ignore file input events that fire right after closing the result modal
        if ((DateTime.UtcNow - _resultClosedAt).TotalMilliseconds < 600) return;

        // If file exceeds max upload size, ask user to confirm compression
        if (file.Size > ImageUploadHelper.DefaultMaxUploadSize)
        {
            if (file.Size > ImageUploadHelper.MaxReadSize)
            {
                _error = $"File is too large ({FormatFileSize(file.Size)}). Maximum allowed is {FormatFileSize(ImageUploadHelper.MaxReadSize)}.";
                StateHasChanged();
                return;
            }
            _pendingFileSize = file.Size;
            _pendingFileEvent = e;
            _pendingFileStyle = style;
            _pendingCompression = true;
            StateHasChanged();
            return;
        }

        _selectedStyle = style;
        _error = null;
        _result = null;
        _placeholderError = null;

        try
        {
            using var stream = file.OpenReadStream(ImageUploadHelper.MaxReadSize);
            _sourcePath = await ImageStorage.SaveUploadedFileAsync(stream, file.Name);

            // If Silhouette Contour, show face/body options modal first
            if (style.Name == "Silhouette Contour")
            {
                _silhouetteOrientation = "side";
                _silhouetteBodyType = "bust";
                _pendingSilhouetteOptions = true;
                StateHasChanged();
                return;
            }

            // Memorial styles always need Name/DOB/DOD inputs
            if (style.Category == "Memorial")
            {
                _memorialName = string.Empty;
                _memorialDob = null;
                _memorialDod = null;
                _pendingPlaceholders = true;
                StateHasChanged();
                return;
            }

            // If the style has text placeholders, show input modal first
            if (HasPlaceholders(style))
            {
                _occasionText = string.Empty;
                _messageText = string.Empty;
                _calendarDate = null;
                _numberValue = null;
                _dateText = string.Empty;
                _datePickerValue = null;
                _memorialName = string.Empty;
                _memorialDob = null;
                _memorialDod = null;
                _pendingPlaceholders = true;
                StateHasChanged();
                return;
            }

            // Otherwise proceed immediately (raw template, RunGeneration collates everything)
            await RunGeneration(style.PromptTemplate);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Quick style processing failed for style {StyleName}", style.Name);
            _error = "An unexpected error occurred. Please try again.";
            StateHasChanged();
        }
    }

    private async Task ProcessWithPlaceholders()
    {
        if (_selectedStyle is null || _sourcePath is null) return;

        // Calendar is the only truly required field (needs a date to draw the grid)
        if (_selectedStyle.PromptTemplate.Contains("{{CALENDAR}}") && !_calendarDate.HasValue)
        {
            _placeholderError = "Please select the special date for the calendar.";
            return;
        }

        // Memorial Name is required
        if (_selectedStyle.Category == "Memorial" && string.IsNullOrWhiteSpace(_memorialName))
        {
            _placeholderError = "Please enter the name.";
            return;
        }

        _placeholderError = null;
        _pendingPlaceholders = false;

        // Memorial styles use a special pipeline: bg-removal → Gemini frame → text overlay
        if (_selectedStyle.Category == "Memorial")
        {
            await RunMemorialGeneration();
            return;
        }

        var prompt = ReplacePlaceholders(_selectedStyle.PromptTemplate);
        await RunGeneration(prompt);
    }

    private void CancelPlaceholders()
    {
        _pendingPlaceholders = false;
        _placeholderError = null;
        _selectedStyle = null;
        _sourcePath = null;
    }

    private async Task ProcessSilhouetteOptions()
    {
        if (_selectedStyle is null || _sourcePath is null) return;
        _pendingSilhouetteOptions = false;
        var prompt = BuildSilhouettePrompt();
        await RunGeneration(prompt);
    }

    private void CancelSilhouetteOptions()
    {
        _pendingSilhouetteOptions = false;
        _selectedStyle = null;
        _sourcePath = null;
    }

    private string BuildSilhouettePrompt()
    {
        var isFront = _silhouetteOrientation == "front";
        var isFull = _silhouetteBodyType == "full";

        if (isFront)
        {
            var bodyDesc = isFull
                ? "Show the complete full-body figure from head to feet as open unfilled outlines. Include all body elements: head, torso, arms, hands, legs, feet, clothing details — all as outline strokes only."
                : "Show the subject from head to upper chest/shoulders area (bust portrait) as open unfilled outlines.";

            return $"Transform into a pure line art portrait in front-facing view. STRICT RULES: The ENTIRE image must consist of thin outline strokes ONLY. ABSOLUTELY NO filled areas, NO solid colors, NO shading, NO color blocks, NO gradients anywhere in the image — not on clothing, not on hair, not on skin, not on any element. Every single part of the subject must be rendered as open unfilled outlines only, like a coloring book page. Do NOT fill or color any clothing — jackets, shirts, dresses must be just outline edges. The subject faces DIRECTLY FORWARD toward the viewer. FRONT FACE DETAIL (CRITICAL): Since this is a front-facing view, render ALL facial elements with clear outline strokes — BOTH eyes with detailed iris outlines, pupils, and eyelashes; BOTH eyebrows with individual hair strokes; the full nose with bridge, tip, and nostrils from the front; BOTH lips with defined upper and lower lip contours; the full jawline and chin contour; BOTH ears visible. Hair rendered with flowing outline strokes showing volume and texture — no filled hair, just strand outlines. {bodyDesc} All lines in fine warm golden-brown or dark gold color on a soft pale cream or warm ivory flat matte background. At the bottom: ornate golden decorative filigree scrollwork — curling vine patterns, swirls, floral ornamental vector art as a decorative border. No trophy, no award, no glass, no pedestal, no 3D objects. Style: pure outline drawing, premium invitation line art.";
        }
        else
        {
            var bodyDesc = isFull
                ? "Show the complete full-body figure from head to feet in side profile as open unfilled outlines. Include the full standing pose: head profile, torso, arms, hands, legs, feet — all as outline strokes only."
                : "Neck, shoulders, and upper body as simple contour outlines.";

            return $"Transform into a pure line art portrait in elegant side profile view. STRICT RULES: The ENTIRE image must consist of thin outline strokes ONLY. ABSOLUTELY NO filled areas, NO solid colors, NO shading, NO color blocks, NO gradients anywhere in the image — not on clothing, not on hair, not on skin, not on any element. Every single part of the subject — face, hair, neck, shoulders, body, clothing — must be rendered as open unfilled outlines only, like a coloring book page. Do NOT fill or color any clothing — jackets, shirts, dresses must be just outline edges. The subject shown in graceful side-facing profile. Face profile with clearly defined line features: eye with lashes, nose bridge and tip, lips, chin and jawline contour. Hair flowing with elegant sweeping line strokes — no filled hair, just strand outlines. {bodyDesc} All lines in fine warm golden-brown or dark gold color on a soft pale cream or warm ivory flat matte background. At the bottom: ornate golden decorative filigree scrollwork — curling vine patterns, swirls, floral ornamental vector art as a decorative border. No trophy, no award, no glass, no pedestal, no 3D objects. Style: pure outline drawing, premium invitation line art.";
        }
    }

    /// <summary>
    /// Special pipeline for Memorial styles:
    /// 1. Remove background from uploaded photo
    /// 2. Send bg-removed photo to Gemini to generate ornate frame + composited person
    /// 3. Overlay Name, DOB, DOD text programmatically with ImageSharp
    /// </summary>
    private async Task RunMemorialGeneration()
    {
        if (_selectedStyle is null || _sourcePath is null) return;

        // Debit coins
        var authState2 = await AuthState.GetAuthenticationStateAsync();
        var uidStr = authState2.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (int.TryParse(uidStr, out var userId) && !authState2.User.IsInRole("SuperAdmin"))
        {
            var cost = FeatureAccess.GetCost(FeatureAccess.QuickStyle);
            if (!await CoinService.DebitCoinsAsync(userId, cost, CoinTransactionType.GenerationSpend, "Quick Style generation"))
            {
                _error = "Insufficient coins. Please purchase more coins.";
                return;
            }
        }

        _isProcessing = true;
        _processingStatus = "Removing background from your photo...";
        _statusCts = new CancellationTokenSource();
        StateHasChanged();
        _ = RotateStatusMessages(_statusCts.Token);

        const int targetW = 1440;
        const int targetH = 2160;

        try
        {
            // Step 1: Remove background
            string refImagePath = _sourcePath!;
            if (BgRemoval.IsAvailable)
            {
                try
                {
                    var bgResult = await BgRemoval.RemoveBackgroundAsync(_sourcePath!);
                    refImagePath = bgResult.TransparentImagePath;
                    await UpdateStatus("Background removed. Generating memorial frame...");
                }
                catch (Exception bgEx)
                {
                    Logger.LogWarning(bgEx, "Background removal failed for memorial, using original photo");
                    await UpdateStatus("Generating memorial frame...");
                }
            }
            else
            {
                await UpdateStatus("Generating memorial frame...");
            }

            // Step 2: Build prompt — strip the placeholder tokens (they're only kept for HasPlaceholders detection)
            var prompt = _selectedStyle.PromptTemplate
                .Replace("{{NAME}}", "").Replace("{{DOB}}", "").Replace("{{DOD}}", "").Trim();

            // Prepend face lock
            var sb = new StringBuilder();
            sb.Append("FACE LOCK (HIGHEST PRIORITY): The face of the person in the output MUST be a PHOTOREALISTIC, EXACT copy of their face from the reference photo. Same face shape, nose, eyes, eyebrows, lips, jawline, skin tone. Do NOT alter any facial feature. The reference image has the background already removed — place this person EXACTLY as-is into the circular frame area. Do NOT regenerate or reimagine the person — use the EXACT reference image person. ");
            sb.Append(prompt);
            sb.Append(" OUTPUT: Highest quality, photorealistic person, exact 2:3 portrait aspect ratio.");

            var request = new GenerationRequest
            {
                Prompt = sb.ToString(),
                Width = targetW,
                Height = targetH,
                SizeName = "20x30",
                EnhancePrompt = false,
                ReferenceImagePaths = [refImagePath],
                Provider = ImageProvider.Gemini,
                SkipMultiImageComposition = true
            };

            _result = await ImageGenService.GenerateImageAsync(request);

            if (_result is null)
            {
                _error = "Image generation returned no result. Please try again.";
                return;
            }

            if (_result.Success)
            {
                await UpdateStatus("Perfecting the final composition...");
                await EnforceAspectRatio(targetW, targetH);

                // Step 3: Overlay text (Name, DOB, DOD) programmatically
                await UpdateStatus("Adding memorial text...");
                await OverlayMemorialText();
                _imgVersion++; // bust browser cache so the text-overlaid image is shown
            }
            else
            {
                _error = _result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Memorial generation failed for style {StyleName}", _selectedStyle?.Name);
            _error = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _statusCts?.Cancel();
            _statusCts?.Dispose();
            _statusCts = null;
            _isProcessing = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Overlays Name, DOB, DOD text on the bottom area of the memorial image
    /// with bold outlined text (fill + stroke) for a professional print look.
    /// </summary>
    private async Task OverlayMemorialText()
    {
        if (_result?.LocalImagePath is null) return;

        try
        {
            var fullPath = System.IO.Path.Combine(Env.WebRootPath,
                _result.LocalImagePath.Replace("/", System.IO.Path.DirectorySeparatorChar.ToString()));
            if (!File.Exists(fullPath)) return;

            var imageBytes = await File.ReadAllBytesAsync(fullPath);
            using var img = Image.Load<Rgba32>(imageBytes);

            // Find a bold serif-style font for professional memorial look
            FontFamily family;
            if (!SystemFonts.TryGet("Georgia", out family) &&
                !SystemFonts.TryGet("Times New Roman", out family) &&
                !SystemFonts.TryGet("Segoe UI", out family) &&
                !SystemFonts.TryGet("Arial", out family))
            {
                family = SystemFonts.Families.First();
            }

            var imgW = img.Width;
            var imgH = img.Height;

            // Text area: bottom 16% of image
            var textAreaTop = (int)(imgH * 0.84);
            var textAreaHeight = imgH - textAreaTop;
            var centerX = imgW / 2f;

            // Scale font sizes based on image width for consistent look at any resolution
            var nameFontSize = imgW * 0.055f;  // ~80px on 1440w, ~198px on 3600w
            var nameFont = family.CreateFont(nameFontSize, FontStyle.Bold);
            var dateFontSize = imgW * 0.032f;  // ~46px on 1440w, ~115px on 3600w
            var dateFont = family.CreateFont(dateFontSize, FontStyle.Bold);

            // Outline thickness scales with image size
            var nameOutlineWidth = Math.Max(2f, imgW * 0.003f);  // ~4px on 1440w, ~11px on 3600w
            var dateOutlineWidth = Math.Max(1.5f, imgW * 0.002f); // ~3px on 1440w, ~7px on 3600w

            // Colors
            var nameColor = Color.White;
            var nameOutlineColor = Color.ParseHex("#1A1A1A");
            var dateColor = Color.ParseHex("#FFD700"); // gold
            var dateOutlineColor = Color.ParseHex("#3D2B00"); // dark gold/brown

            // Build date line
            var dateParts = new List<string>();
            if (_memorialDob.HasValue)
                dateParts.Add($"DOB: {_memorialDob.Value:dd-MM-yyyy}");
            if (_memorialDod.HasValue)
                dateParts.Add($"DOD: {_memorialDod.Value:dd-MM-yyyy}");
            var dateLine = string.Join("     ", dateParts);

            // Name vertical position: 30% into text area
            var nameY = textAreaTop + textAreaHeight * 0.30f;
            // Date vertical position: 75% into text area
            var dateY = textAreaTop + textAreaHeight * 0.75f;

            img.Mutate(ctx =>
            {
                // ── Draw Name with outline ──
                if (!string.IsNullOrWhiteSpace(_memorialName))
                {
                    var nameText = _memorialName.Trim().ToUpper();
                    var nameOpts = new RichTextOptions(nameFont)
                    {
                        Origin = new System.Numerics.Vector2(centerX, nameY),
                        HorizontalAlignment = HorizontalAlignment.Center,
                        VerticalAlignment = VerticalAlignment.Center
                    };

                    // Build glyph paths for fill + stroke
                    var nameGlyphs = TextBuilder.GenerateGlyphs(nameText, nameOpts);

                    // 1) Draw dark outline (stroke) around the name
                    ctx.Draw(new SixLabors.ImageSharp.Drawing.Processing.DrawingOptions(),
                        new SolidPen(nameOutlineColor, nameOutlineWidth), nameGlyphs);
                    // 2) Fill the name text on top
                    ctx.Fill(nameColor, nameGlyphs);
                }

                // ── Draw Dates with outline ──
                if (!string.IsNullOrWhiteSpace(dateLine))
                {
                    var dateOpts = new RichTextOptions(dateFont)
                    {
                        Origin = new System.Numerics.Vector2(centerX, dateY),
                        HorizontalAlignment = HorizontalAlignment.Center,
                        VerticalAlignment = VerticalAlignment.Center
                    };

                    var dateGlyphs = TextBuilder.GenerateGlyphs(dateLine, dateOpts);

                    // 1) Dark outline
                    ctx.Draw(new SixLabors.ImageSharp.Drawing.Processing.DrawingOptions(),
                        new SolidPen(dateOutlineColor, dateOutlineWidth), dateGlyphs);
                    // 2) Gold fill
                    ctx.Fill(dateColor, dateGlyphs);
                }
            });

            await using var ms = new MemoryStream();
            await img.SaveAsPngAsync(ms);
            await File.WriteAllBytesAsync(fullPath, ms.ToArray());

            Logger.LogInformation("Memorial text overlay applied: {Name}", _memorialName);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Memorial text overlay failed (non-fatal, image still usable)");
        }
    }

    private async Task RunGeneration(string prompt)
    {
        // Debit coins
        var authState2 = await AuthState.GetAuthenticationStateAsync();
        var uidStr = authState2.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (int.TryParse(uidStr, out var userId) && !authState2.User.IsInRole("SuperAdmin"))
        {
            var cost = FeatureAccess.GetCost(FeatureAccess.QuickStyle);
            if (!await CoinService.DebitCoinsAsync(userId, cost, CoinTransactionType.GenerationSpend, "Quick Style generation"))
            {
                _error = "Insufficient coins. Please purchase more coins.";
                return;
            }
        }

        _isProcessing = true;
        _processingStatus = $"Analysing your photo for {_selectedStyle?.Name}...";
        _statusCts = new CancellationTokenSource();
        StateHasChanged();

        // Start background status rotation
        _ = RotateStatusMessages(_statusCts.Token);

        const int targetW = 1440;
        const int targetH = 2160;

        // ── Build ONE clean collated prompt: FACE → STYLE → RULES → FORMAT ──
        var sb = new System.Text.StringBuilder();
        var category = _selectedStyle?.Category ?? "";
        var isPhotoStyle = category is "PhotoArts" or "PhotoCollage";

        // 1. Face preservation at the START (highest priority for Gemini)
        sb.Append("FACE LOCK (HIGHEST PRIORITY — NON-NEGOTIABLE): The face of every person in the output MUST be a PHOTOREALISTIC, EXACT copy of their face from the source photo. This means: same face shape, same nose bridge and tip, same eye shape and color, same eyebrow thickness and arch, same lip shape and fullness, same jawline and chin, same skin tone and complexion, same facial hair, same moles, marks, and wrinkles. Do NOT alter, beautify, smooth, age, de-age, lighten, darken, slim, widen, or modify ANY facial feature in ANY way. Even if the style is artistic, cartoonish, or collage-based — the FACE itself must remain photorealistic and perfectly intact with all features clearly visible and sharp. Never generate blurred, smudged, sketch-like, or painterly faces. A viewer must instantly recognize the same person. ");

        // 1b. Extra face rules for PhotoArts/PhotoCollage (multi-panel styles where faces get small)
        if (isPhotoStyle)
        {
            sb.Append("MULTI-PANEL FACE TECHNIQUE (CRITICAL): This is a collage/multi-panel layout. Follow this process: " +
                "(1) FIRST, study the source face carefully — memorize every facial feature at the highest detail level: exact eye shape, pupil color, nose bridge width, nostril shape, lip thickness, chin shape, cheekbone height, skin texture, every mole and mark. " +
                "(2) SINGLE IDENTITY RULE: There is ONLY ONE person identity in this image — the person from the source photo. Every face in every panel is THIS SAME PERSON. Do NOT generate different-looking people across panels. If you drew the face in panel 1, panel 2's face must look like it was copy-pasted from panel 1 with only pose/angle changed. " +
                "(3) For EVERY panel/frame, render the face at HIGH RESOLUTION first (as if generating a 512x512 portrait), then place it into the panel. Never generate faces smaller than 100x100 pixels in the final output. " +
                "(4) FRAMING: Each panel must use CLOSE-UP or MEDIUM framing (head and shoulders, or waist-up). NEVER use full-body shots where the face becomes tiny. The face should occupy at least 25% of each panel's area. " +
                "(5) ALL facial features must be individually distinguishable in every panel: both eyes with visible pupils and iris color, a defined nose with nostrils, distinct lips with shape, visible eyebrows with correct thickness. " +
                "(6) The HERO/main panel should show the face at the LARGEST size — at least 40% of the panel height. " +
                "(7) Use MAXIMUM 4-5 panels with faces. Additional space should be decorative elements, text, flowers, or scenery — NOT more tiny face panels. " +
                "(8) CONSISTENCY CHECK: Before finalizing, verify that if you cover the body/clothing in each panel, the face alone would identify it as the same person in every single panel. " +
                "(9) QUALITY TEST: If you zoom into any panel and cannot clearly see eyes, nose, and mouth as separate distinct features, that face is TOO SMALL — crop tighter or remove that panel. ");
        }

        // 2. Style instructions (the actual creative prompt)
        sb.Append(prompt);

        // 3. Gender adaptation + person count + multi-panel rules
        sb.Append(" RULES: Detect the subject's gender from the source photo and adapt all attire, jewelry, and styling accordingly — use saree/lehenga for women, dhoti/sherwani/kurta for men, or age-appropriate alternatives for children. ABSOLUTE PERSON COUNT (ZERO TOLERANCE): Count the EXACT number of people in the source photo. The output MUST contain EXACTLY that number — if 1 person in source, show ONLY 1 person (do NOT add a partner, spouse, or companion). If 2 people, show EXACTLY 2. NEVER fabricate or add people not present in the source image. This overrides any style that implies couples or groups — adapt the style to match the actual person count. If multiple panels/scenes, each panel must be a completely different scene, pose, outfit, angle, and setting. CRITICAL: In every panel or frame, the face must have clear, sharp, photorealistic facial features — eyes, nose, mouth, and jawline must all be clearly defined and recognizable. Never leave faces blank, blurry, or stylized beyond recognition.");

        // 4. Quality and format
        sb.Append(" OUTPUT: Highest quality, photorealistic detail, exact 2:3 portrait aspect ratio.");

        prompt = sb.ToString();

        try
        {
            // Multi-face cinematic pipeline: detect multiple faces, transform individually, composite
            if (_selectedStyle is not null && CinematicProfile.IsMultiFaceStyle(_selectedStyle.Name))
            {
                await UpdateStatus("Detecting faces in your photo...");
                var cinResult = await CinematicProfile.ProcessAsync(_sourcePath!, prompt, targetW, targetH);
                if (cinResult is not null)
                {
                    _result = cinResult;
                    if (!_result.Success)
                        _error = _result.ErrorMessage;
                    else
                    {
                        await UpdateStatus("Perfecting the final composition...");
                        await EnforceAspectRatio(targetW, targetH);
                    }
                    return;
                }
            }

            // Build reference image list — add pre-rendered calendar as 2nd image if needed
            var refPaths = new List<string> { _sourcePath! };
            bool hasCalendarRef = false;
            if (_calendarDate.HasValue && _selectedStyle?.PromptTemplate.Contains("{{CALENDAR}}") == true)
            {
                var calPath = await CalendarImageGenerator.GenerateAndSaveAsync(_calendarDate.Value, Env.WebRootPath);
                refPaths.Add(calPath);
                hasCalendarRef = true;
            }

            var request = new GenerationRequest
            {
                Prompt = prompt,
                Width = targetW,
                Height = targetH,
                SizeName = "20x30",
                EnhancePrompt = false,
                ReferenceImagePaths = refPaths,
                Provider = ImageProvider.Gemini,
                SkipMultiImageComposition = hasCalendarRef
            };

            _result = await ImageGenService.GenerateImageAsync(request);

            if (_result is null)
            {
                _error = "Image generation returned no result. Please try again.";
                return;
            }

            if (_result.Success)
            {
                await UpdateStatus("Perfecting the final composition...");
                await EnforceAspectRatio(targetW, targetH);

                // Auto-enhance PhotoArts/PhotoCollage for sharper face details
                if (isPhotoStyle && _result.LocalImagePath is not null && ImageEnhancer.IsAvailable)
                {
                    try
                    {
                        await UpdateStatus("Enhancing face details...");
                        var enhancedPath = await ImageEnhancer.EnhanceImageAsync(
                            _result.LocalImagePath,
                            new Progress<int>(pct => { }));
                        _result.LocalImagePath = enhancedPath;
                        Logger.LogInformation("Auto-enhanced PhotoArts/PhotoCollage result for sharper faces");
                    }
                    catch (Exception enhEx)
                    {
                        Logger.LogWarning(enhEx, "Auto-enhancement failed for PhotoArts style, using original");
                    }
                }
            }
            else
            {
                _error = _result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Quick style processing failed for style {StyleName}", _selectedStyle?.Name);
            _error = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _statusCts?.Cancel();
            _statusCts?.Dispose();
            _statusCts = null;
            _isProcessing = false;
            StateHasChanged();
        }
    }

