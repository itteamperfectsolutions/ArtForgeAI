    private async Task UploadThumbnail(InputFileChangeEventArgs e, int presetId)
    {
        var file = e.File;
        if (file is null || file.Size > 10 * 1024 * 1024) return;

        _thumbnailMessage = "Uploading thumbnail...";
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(10 * 1024 * 1024);
            var path = await ImageStorage.SavePresetThumbnailFromStreamAsync(stream, file.Name);

            var entity = await StyleService.GetByIdAsync(presetId);
            if (entity is not null)
            {
                entity.ThumbnailPath = path;
                await StyleService.UpdateAsync(entity);
            }

            _thumbnailMessage = "Thumbnail uploaded!";
            await LoadStyles();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Thumbnail upload failed for preset {PresetId}", presetId);
            _thumbnailMessage = "Upload failed. Please try again.";
        }

        StateHasChanged();
    }

    private bool HasPlaceholders(StylePreset style)
        => style.PromptTemplate.Contains("{{OCCASION}}") || style.PromptTemplate.Contains("{{MESSAGE}}") || style.PromptTemplate.Contains("{{CALENDAR}}") || style.PromptTemplate.Contains("{{NUMBER}}") || style.PromptTemplate.Contains("{{DATE}}") || style.PromptTemplate.Contains("{{NAME}}") || style.PromptTemplate.Contains("{{DOB}}") || style.PromptTemplate.Contains("{{DOD}}");

    private string ReplacePlaceholders(string prompt, string occasion, string message)
    {
        var result = prompt.Replace("{{OCCASION}}", occasion.Trim());
        if (!string.IsNullOrWhiteSpace(message))
            result = result.Replace("{{MESSAGE}}", message.Trim());
        else
            result = result.Replace("{{MESSAGE}}",
                $"Generate a short warm heartfelt message (2-3 lines) appropriate for the occasion: {occasion.Trim()}");
        if (_testCalendarDate.HasValue)
            result = result.Replace("{{CALENDAR}}", BuildCalendarDescription(_testCalendarDate.Value));
        if (_testNumberValue.HasValue)
            result = result.Replace("{{NUMBER}}", _testNumberValue.Value.ToString());
        if (!string.IsNullOrWhiteSpace(_testDateText))
            result = result.Replace("{{DATE}}", _testDateText.Trim());

        // Memorial placeholders
        if (!string.IsNullOrWhiteSpace(_testMemorialName))
            result = result.Replace("{{NAME}}", _testMemorialName.Trim());
        else
            result = result.Replace("{{NAME}}", "");
        if (_testMemorialDob.HasValue)
            result = result.Replace("{{DOB}}", _testMemorialDob.Value.ToString("dd-MM-yyyy"));
        else
            result = result.Replace("{{DOB}}", "");
        if (_testMemorialDod.HasValue)
            result = result.Replace("{{DOD}}", _testMemorialDod.Value.ToString("dd-MM-yyyy"));
        else
            result = result.Replace("{{DOD}}", "");
        return result;
    }

    private async Task TestStyle(InputFileChangeEventArgs e, StylePreset preset)
    {
        var file = e.File;
        if (file is null || file.Size > 10 * 1024 * 1024 || _testingStyleId is not null) return;

        // Save uploaded image first (needed for both placeholder and non-placeholder paths)
        using var stream = file.OpenReadStream(10 * 1024 * 1024);
        _testSourcePath = await ImageStorage.SaveUploadedFileAsync(stream, file.Name);

        // Memorial styles always need Name/DOB/DOD inputs
        // Other styles with placeholders also show modal
        if (preset.Category == "Memorial" || HasPlaceholders(preset))
        {
            _testPlaceholderPreset = preset;
            _testOccasionText = string.Empty;
            _testMessageText = string.Empty;
            _testCalendarDate = null;
            _testNumberValue = null;
            _testDateText = string.Empty;
            _testMemorialName = string.Empty;
            _testMemorialDob = null;
            _testMemorialDod = null;
            _testPlaceholderError = null;
            _testPendingPlaceholders = true;
            StateHasChanged();
            return;
        }

        await RunTestGeneration(preset, preset.EffectivePrompt);
    }

    private async Task SubmitTestPlaceholders()
    {
        if (_testPlaceholderPreset is null || _testSourcePath is null) return;

        if (_testPlaceholderPreset.PromptTemplate.Contains("{{OCCASION}}") && string.IsNullOrWhiteSpace(_testOccasionText))
        {
            _testPlaceholderError = "Please enter the occasion (e.g. Happy Birthday, Happy Anniversary).";
            return;
        }

        if (_testPlaceholderPreset.PromptTemplate.Contains("{{CALENDAR}}") && !_testCalendarDate.HasValue)
        {
            _testPlaceholderError = "Please select the special date for the calendar.";
            return;
        }

        if (_testPlaceholderPreset.PromptTemplate.Contains("{{NUMBER}}") && !_testNumberValue.HasValue)
        {
            _testPlaceholderError = "Please enter the number / age.";
            return;
        }

        if (_testPlaceholderPreset.PromptTemplate.Contains("{{DATE}}") && string.IsNullOrWhiteSpace(_testDateText))
        {
            _testPlaceholderError = "Please enter the date (e.g. 26-07-2023).";
            return;
        }

        if (_testPlaceholderPreset.Category == "Memorial" && string.IsNullOrWhiteSpace(_testMemorialName))
        {
            _testPlaceholderError = "Please enter the name.";
            return;
        }

        _testPlaceholderError = null;
        _testPendingPlaceholders = false;
        var prompt = ReplacePlaceholders(_testPlaceholderPreset.EffectivePrompt, _testOccasionText, _testMessageText);
        await RunTestGeneration(_testPlaceholderPreset, prompt);
    }

    private void CancelTestPlaceholders()
    {
        _testPendingPlaceholders = false;
        _testPlaceholderPreset = null;
        _testPlaceholderError = null;
        _testSourcePath = null;
    }

    private string BuildCalendarDescription(DateTime date)
    {
        var monthName = date.ToString("MMMM").ToUpper();
        var year = date.Year;
        var firstDay = new DateTime(year, date.Month, 1);
        var daysInMonth = DateTime.DaysInMonth(year, date.Month);
        var startDow = (int)firstDay.DayOfWeek; // 0=Sun

        var sb = new StringBuilder();
        sb.Append($"A clean CALENDAR GRID for {monthName} {year}. ");
        sb.Append("White text on the dark background. ");
        sb.Append($"Month name '{monthName} {year}' in bold uppercase above the grid. ");
        sb.Append("Days of the week header row: SUN  MON  TUE  WED  THU  FRI  SAT. ");
        sb.Append("Date number rows: ");

        int dayNum = 1;
        for (int week = 0; dayNum <= daysInMonth; week++)
        {
            var cells = new List<string>();
            for (int dow = 0; dow < 7; dow++)
            {
                if ((week == 0 && dow < startDow) || dayNum > daysInMonth)
                    cells.Add("blank");
                else
                {
                    if (dayNum == date.Day)
                        cells.Add($"[{dayNum} with a small RED HEART background]");
                    else
                        cells.Add(dayNum.ToString());
                    dayNum++;
                }
            }
            sb.Append($"Row {week + 1}: {string.Join(", ", cells)}. ");
        }

        sb.Append($"IMPORTANT: The date number {date.Day} MUST have a small red heart icon or red heart-shaped background behind it to mark the special day. All other dates are plain.");
        return sb.ToString();
    }

    private async Task RunTestGeneration(StylePreset preset, string prompt)
    {
        _testingStyleId = preset.Id;
        _testStyleName = preset.Name;
        _testResultPath = null;
        _testError = null;
        _testModelInfo = null;
        _testProcessing = true;
        _testVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        StateHasChanged();

        try
        {
            if (_testSourcePath is null)
            {
                _testError = "No source image available.";
                return;
            }

            // Always use 2:3 portrait dimensions (20x30 print ratio)
            const int targetW = 1440;
            const int targetH = 2160;

            // Append explicit 2:3 format instruction
            prompt += " OUTPUT FORMAT: The final image MUST be in exact 2:3 portrait aspect ratio (like a 20x30 inch print). Do NOT output square or landscape images.";

            // Append universal face/identity preservation instruction
            prompt += " FACE & IDENTITY PRESERVATION (CRITICAL): Carefully analyse the source photo to determine the subject's GENDER, approximate AGE, SKIN TONE, and every facial detail. The generated image MUST match the source exactly — same gender, same age range, same complexion and skin undertone, same face shape, jawline, eye shape, eye colour, eyebrow thickness and arch, nose shape and size, lip shape and fullness, ear shape, hairline, hair colour, hair texture, and hairstyle. Preserve moles, dimples, facial hair, wrinkles, and any distinguishing facial marks. Do NOT alter, beautify, age, de-age, lighten, darken, or change any facial feature. The face in every panel/photo MUST be immediately recognisable as the SAME person from the source image — identical in every detail.";

            // Memorial styles: remove background first
            var refPath = _testSourcePath;
            bool isMemorial = preset.Category == "Memorial";
            if (isMemorial && BgRemoval.IsAvailable)
            {
                try
                {
                    var bgResult = await BgRemoval.RemoveBackgroundAsync(_testSourcePath);
                    refPath = bgResult.TransparentImagePath;
                }
                catch (Exception bgEx)
                {
                    Logger.LogWarning(bgEx, "Background removal failed for memorial test, using original");
                }
            }

            // Run style transfer with the prompt
            var request = new GenerationRequest
            {
                Prompt = prompt,
                Width = targetW,
                Height = targetH,
                SizeName = "20x30",
                EnhancePrompt = false,
                ReferenceImagePaths = [refPath],
                Provider = ImageProvider.Gemini,
                SkipMultiImageComposition = isMemorial
            };

            // Use a 120s timeout to prevent the spinner from hanging forever
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(120));
            var generationTask = ImageGenService.GenerateImageAsync(request);
            var completedTask = await Task.WhenAny(generationTask, Task.Delay(Timeout.Infinite, cts.Token));

            if (generationTask.IsCompleted)
            {
                var result = await generationTask;
                if (result.Success && !string.IsNullOrEmpty(result.LocalImagePath))
                {
                    _testResultPath = result.LocalImagePath;
                    _testModelInfo = result.EnhancedPrompt;
                    _testVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

                    // Enforce 2:3 aspect ratio via center-crop + resize
                    await EnforceAspectRatio(result.LocalImagePath, targetW, targetH);

                    // Memorial: overlay name/DOB/DOD text programmatically
                    if (isMemorial)
                        await OverlayMemorialText(result.LocalImagePath);
                }
                else
                {
                    _testError = result.ErrorMessage ?? "Generation failed.";
                }
            }
            else
            {
                _testError = "Generation timed out after 2 minutes. The style may be too complex for a quick test.";
                Logger.LogWarning("Style test timed out for {StyleName}", preset.Name);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Style test failed for {StyleName}", preset.Name);
            _testError = $"Error: {ex.Message}";
        }
        finally
        {
            _testProcessing = false;
            StateHasChanged();
        }
    }

    private async Task EnforceAspectRatio(string localImagePath, int targetW, int targetH)
    {
        try
        {
            var fullPath = System.IO.Path.Combine(Env.WebRootPath,
                localImagePath.Replace("/", System.IO.Path.DirectorySeparatorChar.ToString()));

            if (!File.Exists(fullPath)) return;

            var imageBytes = await File.ReadAllBytesAsync(fullPath);
            using var img = Image.Load<Rgba32>(imageBytes);

            double targetRatio = (double)targetW / targetH;
            double currentRatio = (double)img.Width / img.Height;

            if (Math.Abs(currentRatio - targetRatio) < 0.02) return;

            int cropW, cropH;
            if (currentRatio > targetRatio)
            {
                cropH = img.Height;
                cropW = (int)Math.Round(cropH * targetRatio);
            }
            else
            {
                cropW = img.Width;
                cropH = (int)Math.Round(cropW / targetRatio);
            }

            int cropX = (img.Width - cropW) / 2;
            int cropY = (img.Height - cropH) / 2;

            img.Mutate(ctx => ctx
                .Crop(new SixLabors.ImageSharp.Rectangle(cropX, cropY, cropW, cropH))
                .Resize(targetW, targetH));

            await using var ms = new MemoryStream();
            await img.SaveAsPngAsync(ms);
            await File.WriteAllBytesAsync(fullPath, ms.ToArray());

            Logger.LogInformation("Enforced 2:3 aspect ratio on test style output");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Aspect ratio enforcement failed (non-fatal)");
        }
    }

    private async Task UseTestResultAsThumbnail()
    {
        if (_testingStyleId is null || string.IsNullOrEmpty(_testResultPath)) return;

        var presetPath = await MoveToPresetsFolder(_testResultPath);
        var entity = await StyleService.GetByIdAsync(_testingStyleId.Value);
        if (entity is not null)
        {
            entity.ThumbnailPath = presetPath;
            await StyleService.UpdateAsync(entity);
        }

        _thumbnailMessage = $"Thumbnail set for {_testStyleName}!";
        _testingStyleId = null;
        _testSourcePath = null;
        _testResultPath = null;
        _testError = null;
        await LoadStyles();
        StateHasChanged();
    }

