    // ── Reset ──
    private void RemovePhoto() { ResetResult(); _uploadedPath = null; _uploadedDataUrl = null; _sourceWidth = 0; _sourceHeight = 0; _errorMessage = null; }
    private void CreateAnother() => RemovePhoto();
    private void ResetResult() { _hasResult = false; _resultTransparentPath = null; _resultColoredPath = null; _resultTransparentBytes = null; _displayPath = null; _resultWidth = 0; _resultHeight = 0; }

    private string ResolvePath(string webPath) =>
        Path.Combine(Env.WebRootPath, webPath.Replace("/", Path.DirectorySeparatorChar.ToString()));
