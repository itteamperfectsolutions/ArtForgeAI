                                        {
                                            <div class="admin-style-thumb-overlay">
                                                <div class="loading-spinner" style="width:16px;height:16px;margin:0;border-width:2px;"></div>
                                            </div>
                                        }
                                    </div>
                                    <div class="admin-completed-info">
