                                    else
                                    {
                                        <div class="admin-style-thumb">
                                            <div class="admin-style-thumb-placeholder">
                                                <span>@preset.IconEmoji</span>
                                            </div>
                                            @if (_generatingThumbnailId == preset.Id || _batchActiveIds.Contains(preset.Id))
                                            {
                                                <div class="admin-style-thumb-overlay">
                                                    <div class="loading-spinner" style="width:24px;height:24px;margin:0;border-width:2px;"></div>
                                                </div>
                                            }
                                        </div>
                                        <div class="admin-style-info">
                                            <div class="admin-style-header">
                                                <div>
                                                    <div class="admin-style-name">@preset.IconEmoji @preset.Name</div>
                                                    <div class="admin-style-category">@preset.Category</div>
                                                </div>
                                                <label class="toggle-switch" style="transform: scale(0.8);">
                                                    <input type="checkbox" checked="@preset.IsActive"
