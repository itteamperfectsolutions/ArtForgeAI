@page "/settings"
@rendermode InteractiveServer
@inject IGenerationHistoryService HistoryService
@inject IImageSizeMasterService SizeService
@inject IStylePresetService StyleService
@inject IImageGenerationService ImageGenService
@inject IImageStorageService ImageStorage
@inject IJSRuntime JS
@inject ILogger<Settings> Logger

<PageTitle>ArtForge AI - Settings</PageTitle>

<div class="page-header">
    <h2>Settings</h2>
    <p>Customize your experience</p>
</div>

@* ── Tab bar ── *@
<div class="settings-tabs">
    <button class="settings-tab @(_activeTab == "general" ? "active" : "")"
            @onclick='() => _activeTab = "general"'>
        &#9881; General
    </button>
    <button class="settings-tab @(_activeTab == "sizes" ? "active" : "")"
            @onclick='() => _activeTab = "sizes"'>
        &#128208; Image Sizes
    </button>
    <button class="settings-tab @(_activeTab == "styles" ? "active" : "")"
            @onclick='() => _activeTab = "styles"'>
        &#127912; Style Presets
        <span class="settings-tab-badge">@_allStyles.Count(s => s.IsActive)</span>
    </button>
</div>

@* ═══════════ General Tab ═══════════ *@
@if (_activeTab == "general")
{
    <div class="settings-tab-content" style="max-width: 600px;">
        <div class="card">
            <div class="card-body">
                <div class="settings-section">
                    <h3>Generation Defaults</h3>

                    <div class="setting-row">
                        <div>
                            <div class="setting-label">Default Image Size</div>
                            <div class="setting-desc">Pre-selected size for new generations</div>
                        </div>
                        <select class="form-input" style="width: auto; min-width: 160px;"
                                @bind="_prefs.DefaultImageSize">
                            @foreach (var size in _activeSizes)
                            {
                                <option value="@size.Name">@size.Name (@(size.Width)x@(size.Height))</option>
                            }
                        </select>
                    </div>

                    <div class="setting-row">
                        <div>
                            <div class="setting-label">Auto-Enhance Prompts</div>
                            <div class="setting-desc">Use AI to improve prompts before generation</div>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" @bind="_prefs.AutoEnhancePrompt" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="setting-row">
                        <div>
                            <div class="setting-label">Default Download Format</div>
                            <div class="setting-desc">Preferred file format for downloads</div>
                        </div>
                        <select class="form-input" style="width: auto; min-width: 100px;"
                                @bind="_prefs.DefaultDownloadFormat">
                            <option value="png">PNG</option>
                            <option value="jpg">JPG</option>
                        </select>
                    </div>
                </div>

                <div class="settings-section">
                    <h3>Appearance</h3>

                    <div class="setting-row">
                        <div>
                            <div class="setting-label">Dark Mode</div>
                            <div class="setting-desc">Toggle between dark and light themes</div>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" @bind="_prefs.DarkMode" @bind:after="ApplyTheme" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>

                <div style="display: flex; gap: 0.75rem; justify-content: flex-end;">
                    <button class="btn-primary-gradient" @onclick="SaveSettings" disabled="@_saving">
                        @(_saving ? "Saving..." : "Save Settings")
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(_message))
                {
                    <div style="margin-top: 1rem; color: var(--success); font-size: 0.85rem;">
                        @_message
                    </div>
                }
            </div>
        </div>
    </div>
}

@* ═══════════ Image Sizes Tab ═══════════ *@
@if (_activeTab == "sizes")
{
    <div class="settings-tab-content" style="max-width: 600px;">
        <div class="card">
            <div class="card-body">
                <div class="settings-section" style="margin-bottom: 0;">
                    <h3>Image Sizes</h3>

                    @foreach (var size in _allSizes)
                    {
                        <div class="setting-row" style="gap: 0.5rem;">
                            @if (_editingSizeId == size.Id)
                            {
                                <div style="display: flex; gap: 0.5rem; align-items: center; flex: 1; flex-wrap: wrap;">
                                    <input class="form-input" style="width: 100px;" @bind="_editName" placeholder="Name" />
                                    <input type="number" class="form-input" style="width: 72px;" @bind="_editWidth" placeholder="W" step="any" />
                                    <span style="color: var(--text-muted);">x</span>
                                    <input type="number" class="form-input" style="width: 72px;" @bind="_editHeight" placeholder="H" step="any" />
                                    <select class="form-input" style="width: 58px; padding: 0.35rem 0.4rem; font-size: 0.78rem;"
                                            value="@_editUnit" @onchange="OnEditUnitChanged">
                                        <option value="px">px</option>
                                        <option value="in">in</option>
                                        <option value="cm">cm</option>
                                    </select>
                                    @if (_editUnit != "px")
                                    {
                                        <span style="font-size: 0.72rem; color: var(--text-muted);">= @(ToPixels(_editWidth, _editUnit))x@(ToPixels(_editHeight, _editUnit)) px</span>
                                    }
                                    <label style="display: flex; align-items: center; gap: 0.3rem; font-size: 0.8rem;">
                                        <input type="checkbox" @bind="_editIsActive" /> Active
                                    </label>
                                </div>
                                <div style="display: flex; gap: 0.35rem;">
                                    <button class="btn-primary-gradient btn-sm" @onclick="() => SaveEdit(size.Id)">Save</button>
                                    <button class="btn-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                                </div>
                            }
                            else
                            {
                                <div style="flex: 1;">
                                    <div class="setting-label">
                                        @size.Name
                                        @if (!size.IsActive)
                                        {
                                            <span style="color: var(--text-muted); font-size: 0.75rem; margin-left: 0.3rem;">(inactive)</span>
                                        }
                                    </div>
                                    <div class="setting-desc">
                                        @FormatDisplay(size)
                                        @if (size.Unit != "px")
                                        {
                                            <span> (@(size.Width)x@(size.Height) px)</span>
                                        }
                                    </div>
                                </div>
                                <div style="display: flex; gap: 0.35rem;">
                                    <button class="btn-secondary btn-sm" @onclick="() => StartEdit(size)">Edit</button>
                                    <button class="btn-danger btn-sm" style="padding: 0.25rem 0.5rem; font-size: 0.72rem;" @onclick="() => DeleteSize(size.Id)">Delete</button>
                                </div>
                            }
                        </div>
                    }

                    @* Add new size form *@
                    <div style="margin-top: 0.75rem; padding-top: 0.75rem; border-top: 1px solid var(--border-color);">
                        <div style="font-weight: 600; font-size: 0.85rem; margin-bottom: 0.5rem;">Add New Size</div>
                        <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
                            <input class="form-input" style="width: 100px;" @bind="_newName" placeholder="Name" />
                            <input type="number" class="form-input" style="width: 72px;" @bind="_newWidth" placeholder="Width" step="any" />
                            <span style="color: var(--text-muted);">x</span>
                            <input type="number" class="form-input" style="width: 72px;" @bind="_newHeight" placeholder="Height" step="any" />
                            <select class="form-input" style="width: 58px; padding: 0.35rem 0.4rem; font-size: 0.78rem;"
                                    value="@_newUnit" @onchange="OnNewUnitChanged">
                                <option value="px">px</option>
                                <option value="in">in</option>
                                <option value="cm">cm</option>
                            </select>
                            <button class="btn-primary-gradient btn-sm" @onclick="AddSize" disabled="@(string.IsNullOrWhiteSpace(_newName) || _newWidth <= 0 || _newHeight <= 0)">
                                Add
                            </button>
                        </div>
                        @if (_newUnit != "px" && _newWidth > 0 && _newHeight > 0)
                        {
                            <div style="margin-top: 0.35rem; font-size: 0.78rem; color: var(--text-muted);">
                                = @(ToPixels(_newWidth, _newUnit))x@(ToPixels(_newHeight, _newUnit)) px (at 96 DPI)
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_sizeMessage))
                        {
                            <div style="margin-top: 0.5rem; color: var(--success); font-size: 0.82rem;">
                                @_sizeMessage
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ═══════════ Style Presets Tab ═══════════ *@
@if (_activeTab == "styles")
{
    <div class="settings-tab-content">
        <div class="settings-section" style="margin-bottom: 0;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;flex-wrap:wrap;gap:0.5rem;">
                <h3 style="margin-bottom:0;border-bottom:none;padding-bottom:0;">Style Presets</h3>
                <button class="btn-primary-gradient btn-sm" @onclick="GenerateAllThumbnails"
                        disabled="@(_batchGenerating || _generatingThumbnailId is not null)"
                        title="Generate thumbnails for all styles without one (8 concurrent)">
                    @if (_batchGenerating)
                    {
                        <span>&#9203; @_batchCompleted / @_batchTotal generating...</span>
                    }
                    else
                    {
                        <span>&#10024; Generate All Thumbnails</span>
                    }
                </button>
            </div>

            @* ── Active / Inactive sub-tabs ── *@
            @{
                var activeCount = _allStyles.Count(s => s.IsActive);
                var inactiveCount = _allStyles.Count(s => !s.IsActive);
            }
            <div class="style-pill-tabs">
                <button class="style-pill @(_styleSubTab == "active" ? "active" : "")"
                        @onclick='() => _styleSubTab = "active"'>
                    <span class="style-pill-dot active-dot"></span>
                    Active
                    <span class="style-pill-count">@activeCount</span>
                </button>
                <button class="style-pill @(_styleSubTab == "inactive" ? "active" : "")"
                        @onclick='() => _styleSubTab = "inactive"'>
                    <span class="style-pill-dot inactive-dot"></span>
                    Inactive
                    <span class="style-pill-count">@inactiveCount</span>
                </button>
            </div>

            @if (_batchGenerating)
            {
                <div style="margin-bottom:0.75rem;">
                    <div class="enhance-progress-bar" style="border:1px solid var(--border-color);border-radius:var(--radius-sm);height:20px;">
                        <div class="enhance-progress-fill" style="width:@(_batchTotal > 0 ? (int)((double)_batchCompleted / _batchTotal * 100) : 0)%;background:var(--accent-gradient);"></div>
                        <span class="enhance-progress-text">@_batchCompleted / @_batchTotal</span>
                    </div>
                </div>
            }

            @if (_styleSubTab == "active")
            {
                @* ── Active styles view ── *@
                var activeStyles = _allStyles.Where(s => s.IsActive).ToList();
                var pendingStyles = activeStyles.Where(s => string.IsNullOrEmpty(s.ThumbnailPath)).ToList();
                var completedStyles = activeStyles.Where(s => !string.IsNullOrEmpty(s.ThumbnailPath)).ToList();
                var groupedCompleted = completedStyles
                    .GroupBy(s => s.Category)
                    .OrderBy(g => { var idx = Array.IndexOf(_categoryOrder, g.Key); return idx < 0 ? 99 : idx; })
                    .ToArray();

                @if (pendingStyles.Count > 0)
                {
                    <div class="admin-style-section-header pending">
                        <span>&#9888; Pending Thumbnail</span>
                        <span class="admin-style-section-count">@pendingStyles.Count</span>
                    </div>
                }
                <div class="admin-style-grid">
                @foreach (var preset in pendingStyles)
                {
                    <div class="admin-style-card @(!preset.IsActive ? "inactive" : "")">
                        @if (_editingStyleId == preset.Id)
                        {
                            @* ── Inline edit form ── *@
                            <div class="admin-style-card-edit">
                                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                    <input class="form-input" style="width: 100px;" @bind="_editStyleName" placeholder="Name" />
                                    <input class="form-input" style="width: 120px;" @bind="_editStyleDesc" placeholder="Description" />
                                    <select class="form-input" style="width: 110px; padding: 0.35rem 0.4rem; font-size: 0.78rem;" @bind="_editStyleCategory">
                                        <option value="Artistic">Artistic</option>
                                        <option value="Fun">Fun</option>
                                        <option value="Professional">Professional</option>
                                        <option value="Abstract">Abstract</option>
                                        <option value="Mythological">Mythological</option>
                                        <option value="Regional">Regional</option>
                                    </select>
                                    <input class="form-input" style="width: 50px;" @bind="_editStyleEmoji" placeholder="Emoji" />
                                    <input class="form-input" style="width: 80px;" @bind="_editStyleAccent" placeholder="#hex" />
                                </div>
                                <textarea class="form-input" style="width: 100%; min-height: 50px; font-size: 0.78rem;" @bind="_editStylePrompt" placeholder="Prompt Template"></textarea>
                                <div style="display: flex; gap: 0.35rem; justify-content: flex-end;">
                                    <button class="btn-primary-gradient btn-sm" @onclick="() => SaveStyleEdit(preset.Id)">Save</button>
                                    <button class="btn-secondary btn-sm" @onclick="CancelStyleEdit">Cancel</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            @* ── Thumbnail area ── *@
                            <div class="admin-style-thumb">
                                @if (!string.IsNullOrEmpty(preset.ThumbnailPath))
                                {
                                    <img src="/@preset.ThumbnailPath" alt="@preset.Name thumbnail" />
                                }
                                else
                                {
                                    <div class="admin-style-thumb-placeholder">
                                        <span>@preset.IconEmoji</span>
                                    </div>
                                }
                                @if (_generatingThumbnailId == preset.Id || _batchActiveIds.Contains(preset.Id))
                                {
                                    <div class="admin-style-thumb-overlay">
                                        <div class="loading-spinner" style="width:24px;height:24px;margin:0;border-width:2px;"></div>
                                    </div>
                                }
                            </div>

                            @* ── Card info ── *@
                            <div class="admin-style-info">
                                <div class="admin-style-header">
                                    <div>
                                        <div class="admin-style-name">@preset.IconEmoji @preset.Name</div>
                                        <div class="admin-style-category">@preset.Category</div>
                                    </div>
                                    <label class="toggle-switch" style="transform: scale(0.8);">
                                        <input type="checkbox" checked="@preset.IsActive"
                                               @onchange="() => ToggleStyleActive(preset)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </div>
                                <div class="admin-style-desc">@preset.Description</div>
                                <div class="admin-style-actions">
                                    <label class="btn-primary-gradient btn-sm admin-upload-label" title="Upload a test image to preview this style"
                                           style="@(_testingStyleId is not null ? "opacity:0.5;pointer-events:none;" : "")">
                                        &#10024; Test Style
                                        <InputFile OnChange="(e) => TestStyle(e, preset)" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none" />
                                    </label>
                                    <button class="btn-secondary btn-sm" @onclick="() => GenerateThumbnail(preset)"
                                            disabled="@(_generatingThumbnailId is not null)"
                                            title="Auto-generate thumbnail">
                                        &#127912; Generate
                                    </button>
                                    <label class="btn-secondary btn-sm admin-upload-label" title="Upload custom thumbnail">
                                        &#128247; Upload
                                        <InputFile OnChange="(e) => UploadThumbnail(e, preset.Id)" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none" />
                                    </label>
                                    <button class="btn-secondary btn-sm" @onclick="() => StartStyleEdit(preset)">Edit</button>
                                    <button class="btn-danger btn-sm" style="padding: 0.25rem 0.5rem; font-size: 0.72rem;" @onclick="() => DeleteStyle(preset.Id)">Delete</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (completedStyles.Count > 0)
            {
                <div class="admin-style-section-header completed">
                    <span>&#10003; Completed</span>
                    <span class="admin-style-section-count">@completedStyles.Count</span>
                </div>

                @foreach (var group in groupedCompleted)
                {
                    <div class="admin-completed-category-header">@group.Key</div>
                    <div class="admin-completed-grid">
                        @foreach (var preset in group)
                        {
                            <div class="admin-completed-card @(!preset.IsActive ? "inactive" : "") @(_editingStyleId == preset.Id ? "editing" : "")">
                                @if (_editingStyleId == preset.Id)
                                {
                                    <div class="admin-style-card-edit">
                                        <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
                                            <input class="form-input" style="width: 90px; font-size:0.72rem;" @bind="_editStyleName" placeholder="Name" />
                                            <input class="form-input" style="width: 100px; font-size:0.72rem;" @bind="_editStyleDesc" placeholder="Description" />
                                            <select class="form-input" style="width: 90px; padding: 0.25rem; font-size: 0.72rem;" @bind="_editStyleCategory">
                                                <option value="Artistic">Artistic</option>
                                                <option value="Fun">Fun</option>
                                                <option value="Professional">Professional</option>
                                                <option value="Abstract">Abstract</option>
                                                <option value="Mythological">Mythological</option>
                                                <option value="Regional">Regional</option>
                                            </select>
                                            <input class="form-input" style="width: 40px; font-size:0.72rem;" @bind="_editStyleEmoji" placeholder="Em" />
                                        </div>
                                        <textarea class="form-input" style="width:100%;min-height:36px;font-size:0.72rem;" @bind="_editStylePrompt" placeholder="Prompt"></textarea>
                                        <div style="display:flex;gap:0.25rem;justify-content:flex-end;">
                                            <button class="btn-primary-gradient btn-sm" style="font-size:0.68rem;padding:0.2rem 0.4rem;" @onclick="() => SaveStyleEdit(preset.Id)">Save</button>
                                            <button class="btn-secondary btn-sm" style="font-size:0.68rem;padding:0.2rem 0.4rem;" @onclick="CancelStyleEdit">Cancel</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="admin-completed-thumb">
                                        <img src="/@preset.ThumbnailPath" alt="@preset.Name" />
                                        @if (_generatingThumbnailId == preset.Id || _batchActiveIds.Contains(preset.Id))
                                        {
                                            <div class="admin-style-thumb-overlay">
                                                <div class="loading-spinner" style="width:16px;height:16px;margin:0;border-width:2px;"></div>
                                            </div>
                                        }
                                    </div>
                                    <div class="admin-completed-info">
                                        <div class="admin-completed-top">
                                            <span class="admin-completed-name">@preset.IconEmoji @preset.Name</span>
                                            <label class="toggle-switch" style="transform: scale(0.65);">
                                                <input type="checkbox" checked="@preset.IsActive"
                                                       @onchange="() => ToggleStyleActive(preset)" />
                                                <span class="toggle-slider"></span>
                                            </label>
                                        </div>
                                        <div class="admin-completed-actions">
                                            <label class="btn-primary-gradient btn-sm admin-upload-label admin-compact-btn" title="Test style">
                                                &#10024;
                                                <InputFile OnChange="(e) => TestStyle(e, preset)" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none" />
                                            </label>
                                            <button class="btn-secondary btn-sm admin-compact-btn" @onclick="() => GenerateThumbnail(preset)"
                                                    disabled="@(_generatingThumbnailId is not null)" title="Regenerate">&#127912;</button>
                                            <label class="btn-secondary btn-sm admin-upload-label admin-compact-btn" title="Upload thumbnail">
                                                &#128247;
                                                <InputFile OnChange="(e) => UploadThumbnail(e, preset.Id)" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none" />
                                            </label>
                                            <button class="btn-secondary btn-sm admin-compact-btn" @onclick="() => StartStyleEdit(preset)" title="Edit">&#9998;</button>
                                            <button class="btn-danger btn-sm admin-compact-btn" @onclick="() => DeleteStyle(preset.Id)" title="Delete">&#128465;</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }

            @if (!string.IsNullOrEmpty(_thumbnailMessage))
            {
                <div style="margin-top: 0.5rem; color: var(--accent-primary); font-size: 0.82rem;">
                    @_thumbnailMessage
                </div>
            }

            @* Add new style form *@
            <div style="margin-top: 0.75rem; padding-top: 0.75rem; border-top: 1px solid var(--border-color);">
                <div style="font-weight: 600; font-size: 0.85rem; margin-bottom: 0.5rem;">Add New Style</div>
                <div style="display: flex; gap: 0.5rem; align-items: flex-start; flex-wrap: wrap;">
                    <input class="form-input" style="width: 100px;" @bind="_newStyleName" placeholder="Name" />
                    <input class="form-input" style="width: 120px;" @bind="_newStyleDesc" placeholder="Description" />
                    <select class="form-input" style="width: 110px; padding: 0.35rem 0.4rem; font-size: 0.78rem;" @bind="_newStyleCategory">
                        <option value="Artistic">Artistic</option>
                        <option value="Fun">Fun</option>
                        <option value="Professional">Professional</option>
                        <option value="Abstract">Abstract</option>
                        <option value="Mythological">Mythological</option>
                        <option value="Regional">Regional</option>
                    </select>
                    <input class="form-input" style="width: 50px;" @bind="_newStyleEmoji" placeholder="Emoji" />
                    <input class="form-input" style="width: 80px;" @bind="_newStyleAccent" placeholder="#hex" />
                    <textarea class="form-input" style="width: 100%; min-height: 50px; font-size: 0.78rem;" @bind="_newStylePrompt" placeholder="Prompt Template"></textarea>
                </div>

                @* Inline test preview area *@
                @if (!string.IsNullOrEmpty(_newStyleTestSourcePath))
                {
                    <div class="style-test-body" style="margin-top: 0.75rem;">
                        @* Left: source image *@
                        <div class="style-test-panel">
                            <div class="style-test-panel-label">SOURCE</div>
                            <div class="style-test-image-wrap">
                                <img src="@($"{ImageStorage.GetWebPath(_newStyleTestSourcePath!)}?v={_testVersion}")" alt="Source" />
                            </div>
                        </div>

                        @* Right: result *@
                        <div class="style-test-panel">
                            <div class="style-test-panel-label">Result</div>
                            <div class="style-test-image-wrap">
                                @if (_newStyleTestProcessing)
                                {
                                    <div style="display:flex;flex-direction:column;align-items:center;gap:0.75rem;padding:2rem;">
                                        <div class="loading-spinner" style="width:36px;height:36px;margin:0;"></div>
                                        <span style="font-size:0.85rem;color:var(--text-muted);">Applying style...</span>
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(_newStyleTestResultPath))
                                {
                                    <img src="@($"{ImageStorage.GetWebPath(_newStyleTestResultPath)}?v={_testVersion}")" alt="Result" />
                                }
                                else
                                {
                                    <span style="color:var(--text-muted);font-size:0.85rem;">Waiting...</span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_newStyleTestError))
                    {
                        <div style="margin-top:0.5rem;color:var(--danger);font-size:0.82rem;">@_newStyleTestError</div>
                    }
                }

                @* Action buttons *@
                <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; margin-top: 0.5rem;">
                    <label class="btn-primary-gradient btn-sm admin-upload-label"
                           title="Upload a test image to preview this style"
                           style="@(string.IsNullOrWhiteSpace(_newStylePrompt) || _newStyleTestProcessing ? "opacity:0.5;pointer-events:none;" : "")">
                        &#10024; Test Prompt
                        <InputFile OnChange="TestNewStyle" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none" />
                    </label>

                    @if (!_newStyleTestProcessing && !string.IsNullOrEmpty(_newStyleTestResultPath))
                    {
                        <button class="btn-primary-gradient btn-sm" @onclick="AddStyleWithThumbnail"
                                disabled="@(string.IsNullOrWhiteSpace(_newStyleName))">
                            &#10003; Save with Thumbnail
                        </button>
                    }

                    <button class="btn-secondary btn-sm" @onclick="AddStyleOnly"
                            disabled="@(string.IsNullOrWhiteSpace(_newStyleName) || string.IsNullOrWhiteSpace(_newStylePrompt))">
                        Save without Thumbnail
                    </button>

                    @if (!string.IsNullOrEmpty(_newStyleTestSourcePath))
                    {
                        <button class="btn-secondary btn-sm" @onclick="ClearNewStylePreview" disabled="@_newStyleTestProcessing">
                            &#10005; Clear Preview
                        </button>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_styleMessage))
                {
                    <div style="margin-top: 0.5rem; color: var(--success); font-size: 0.82rem;">
                        @_styleMessage
                    </div>
                }
            </div>
            } @* end active sub-tab *@

            @if (_styleSubTab == "inactive")
            {
                @* ── Inactive styles view — same compact card format as active tab ── *@
                var inactiveStyles = _allStyles.Where(s => !s.IsActive).ToList();
                var inactivePending = inactiveStyles.Where(s => string.IsNullOrEmpty(s.ThumbnailPath)).ToList();
                var inactiveCompleted = inactiveStyles.Where(s => !string.IsNullOrEmpty(s.ThumbnailPath)).ToList();
                var groupedInactive = inactiveCompleted
                    .GroupBy(s => s.Category)
                    .OrderBy(g => { var idx = Array.IndexOf(_categoryOrder, g.Key); return idx < 0 ? 99 : idx; })
                    .ToArray();

                @if (inactiveStyles.Count == 0)
                {
                    <div class="right-panel-empty" style="margin-top:0.5rem;">
                        <div class="empty-icon">&#10003;</div>
                        <p>All styles are currently active</p>
                    </div>
                }
                else
                {
                    @* Pending thumbnail section *@
                    @if (inactivePending.Count > 0)
                    {
                        <div class="admin-style-section-header pending">
                            <span>&#9888; Pending Thumbnail</span>
                            <span class="admin-style-section-count">@inactivePending.Count</span>
                        </div>
                        <div class="admin-style-grid">
                            @foreach (var preset in inactivePending)
                            {
                                <div class="admin-style-card">
                                    @if (_editingStyleId == preset.Id)
                                    {
                                        <div class="admin-style-card-edit">
                                            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                                <input class="form-input" style="width: 100px;" @bind="_editStyleName" placeholder="Name" />
                                                <input class="form-input" style="width: 120px;" @bind="_editStyleDesc" placeholder="Description" />
                                                <select class="form-input" style="width: 110px; padding: 0.35rem 0.4rem; font-size: 0.78rem;" @bind="_editStyleCategory">
                                                    <option value="Artistic">Artistic</option>
                                                    <option value="Fun">Fun</option>
                                                    <option value="Professional">Professional</option>
                                                    <option value="Abstract">Abstract</option>
                                                    <option value="Mythological">Mythological</option>
                                                    <option value="Regional">Regional</option>
                                                </select>
                                                <input class="form-input" style="width: 50px;" @bind="_editStyleEmoji" placeholder="Emoji" />
                                                <input class="form-input" style="width: 80px;" @bind="_editStyleAccent" placeholder="#hex" />
                                            </div>
                                            <textarea class="form-input" style="width: 100%; min-height: 50px; font-size: 0.78rem;" @bind="_editStylePrompt" placeholder="Prompt Template"></textarea>
                                            <div style="display: flex; gap: 0.35rem; justify-content: flex-end;">
                                                <button class="btn-primary-gradient btn-sm" @onclick="() => SaveStyleEdit(preset.Id)">Save</button>
                                                <button class="btn-secondary btn-sm" @onclick="CancelStyleEdit">Cancel</button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="admin-style-thumb">
                                            <div class="admin-style-thumb-placeholder">
                                                <span>@preset.IconEmoji</span>
                                            </div>
                                            @if (_generatingThumbnailId == preset.Id || _batchActiveIds.Contains(preset.Id))
                                            {
                                                <div class="admin-style-thumb-overlay">
                                                    <div class="loading-spinner" style="width:24px;height:24px;margin:0;border-width:2px;"></div>
                                                </div>
                                            }
                                        </div>
                                        <div class="admin-style-info">
                                            <div class="admin-style-header">
                                                <div>
                                                    <div class="admin-style-name">@preset.IconEmoji @preset.Name</div>
                                                    <div class="admin-style-category">@preset.Category</div>
                                                </div>
                                                <label class="toggle-switch" style="transform: scale(0.8);">
                                                    <input type="checkbox" checked="@preset.IsActive"
                                                           @onchange="() => ToggleStyleActive(preset)" />
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="admin-style-desc">@preset.Description</div>
                                            <div class="admin-style-actions">
                                                <label class="btn-primary-gradient btn-sm admin-upload-label" title="Upload a test image to preview this style"
                                                       style="@(_testingStyleId is not null ? "opacity:0.5;pointer-events:none;" : "")">
                                                    &#10024; Test Style
                                                    <InputFile OnChange="(e) => TestStyle(e, preset)" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none" />
                                                </label>
                                                <button class="btn-secondary btn-sm" @onclick="() => GenerateThumbnail(preset)"
                                                        disabled="@(_generatingThumbnailId is not null)"
                                                        title="Auto-generate thumbnail">
                                                    &#127912; Generate
                                                </button>
                                                <label class="btn-secondary btn-sm admin-upload-label" title="Upload custom thumbnail">
                                                    &#128247; Upload
                                                    <InputFile OnChange="(e) => UploadThumbnail(e, preset.Id)" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none" />
                                                </label>
                                                <button class="btn-secondary btn-sm" @onclick="() => StartStyleEdit(preset)">Edit</button>
                                                <button class="btn-danger btn-sm" style="padding: 0.25rem 0.5rem; font-size: 0.72rem;" @onclick="() => DeleteStyle(preset.Id)">Delete</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @* Completed (with thumbnails) section — same format as active tab *@
                    @if (inactiveCompleted.Count > 0)
                    {
                        <div class="admin-style-section-header completed">
                            <span>&#10003; With Thumbnails</span>
                            <span class="admin-style-section-count">@inactiveCompleted.Count</span>
                        </div>

